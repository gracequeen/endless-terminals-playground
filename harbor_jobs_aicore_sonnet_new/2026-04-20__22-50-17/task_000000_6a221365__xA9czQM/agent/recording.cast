[31.454729, "o", "    }\r\n\u001b[?2004l\r\u001b[?2004h"]
[31.45476, "o", ">     \r\n\u001b[?2004l\r"]
[31.454791, "o", "\u001b[?2004h> "]
[31.454987, "o", "    processing_time = datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ')\r\n\u001b[?2004l\r"]
[31.455018, "o", "\u001b[?2004h> "]
[31.455047, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.455078, "o", "> "]
[31.455131, "o", "    # Process input file\r\n\u001b[?2004l\r"]
[31.455162, "o", "\u001b[?2004h> "]
[31.455263, "o", "    with open(input_file, 'r') as f:\r\n\u001b[?2004l\r"]
[31.455294, "o", "\u001b[?2004h> "]
[31.455455, "o", "        for line_num, line in enumerate(f, start=1):\r\n\u001b[?2004l\r"]
[31.455493, "o", "\u001b[?2004h> "]
[31.455601, "o", "            raw_line = line.rstrip('\\n')\r\n\u001b[?2004l\r"]
[31.455631, "o", "\u001b[?2004h> "]
[31.455668, "o", "            \r\n\u001b[?2004l\r"]
[31.455697, "o", "\u001b[?2004h> "]
[31.455786, "o", "            # Try to parse JSON\r\n\u001b[?2004l\r"]
[31.455813, "o", "\u001b[?2004h"]
[31.455839, "o", "> "]
[31.45587, "o", "            try:\r\n\u001b[?2004l\r"]
[31.4559, "o", "\u001b[?2004h> "]
[31.456025, "o", "                data = json.loads(raw_line)\r\n\u001b[?2004l\r"]
[31.456055, "o", "\u001b[?2004h> "]
[31.456168, "o", "            except json.JSONDecodeError:\r\n\u001b[?2004l\r"]
[31.456198, "o", "\u001b[?2004h> "]
[31.456341, "o", "                error_counts[\"malformed_json\"] += 1\r\n\u001b[?2004l\r"]
[31.456372, "o", "\u001b[?2004h> "]
[31.456483, "o", "                errors.append({\r\n\u001b[?2004l\r"]
[31.456509, "o", "\u001b[?2004h"]
[31.456537, "o", "> "]
[31.456639, "o", "                    \"line_number\": line_num,\r\n\u001b[?2004l\r"]
[31.456664, "o", "\u001b[?2004h"]
[31.456695, "o", "> "]
[31.456815, "o", "                    \"error_type\": \"malformed_json\",\r\n\u001b[?2004l\r"]
[31.456843, "o", "\u001b[?2004h> "]
[31.457013, "o", "                    \"error_detail\": \"invalid JSON syntax\",\r\n\u001b[?2004l\r"]
[31.457041, "o", "\u001b[?2004h> "]
[31.457183, "o", "                    \"raw_content\": raw_line[:200]\r\n\u001b[?2004l\r"]
[31.457211, "o", "\u001b[?2004h"]
[31.45724, "o", "> "]
[31.457267, "o", "                })\r\n\u001b[?2004l\r"]
[31.457292, "o", "\u001b[?2004h"]
[31.457319, "o", "> "]
[31.457366, "o", "                continue\r\n\u001b[?2004l\r"]
[31.457398, "o", "\u001b[?2004h> "]
[31.457445, "o", "            \r\n\u001b[?2004l\r"]
[31.457474, "o", "\u001b[?2004h> "]
[31.457575, "o", "            # Validate transaction\r\n\u001b[?2004l\r"]
[31.457605, "o", "\u001b[?2004h> "]
[31.45784, "o", "            is_valid, error_type, error_detail = validate_transaction(data, line_num)\r\n\u001b[?2004l\r"]
[31.457881, "o", "\u001b[?2004h> "]
[31.457909, "o", "            \r\n\u001b[?2004l\r"]
[31.457939, "o", "\u001b[?2004h> "]
[31.458013, "o", "            if is_valid:\r\n\u001b[?2004l\r"]
[31.458044, "o", "\u001b[?2004h> "]
[31.458213, "o", "                # Compute hash and add to valid transactions\r\n\u001b[?2004l\r"]
[31.458244, "o", "\u001b[?2004h> "]
[31.458415, "o", "                integrity_hash = compute_integrity_hash(data)\r\n\u001b[?2004l\r"]
[31.458461, "o", "\u001b[?2004h> "]
[31.458544, "o", "                valid_txn = {\r\n\u001b[?2004l\r"]
[31.458573, "o", "\u001b[?2004h> "]
[31.458754, "o", "                    \"transaction_id\": data[\"transaction_id\"],\r\n\u001b[?2004l\r"]
[31.458787, "o", "\u001b[?2004h> "]
[31.458927, "o", "                    \"timestamp\": data[\"timestamp\"],\r\n\u001b[?2004l\r"]
[31.458959, "o", "\u001b[?2004h> "]
[31.459105, "o", "                    \"account_id\": data[\"account_id\"],\r\n\u001b[?2004l\r"]
[31.459136, "o", "\u001b[?2004h> "]
[31.45926, "o", "                    \"amount\": data[\"amount\"],\r\n\u001b[?2004l\r"]
[31.45929, "o", "\u001b[?2004h> "]
[31.459447, "o", "                    \"currency\": data[\"currency\"],\r\n\u001b[?2004l\r"]
[31.459475, "o", "\u001b[?2004h"]
[31.459506, "o", "> "]
[31.459611, "o", "                    \"status\": data[\"status\"],\r\n\u001b[?2004l\r"]
[31.459637, "o", "\u001b[?2004h"]
[31.459667, "o", "> "]
[31.459789, "o", "                    \"integrity_hash\": integrity_hash,\r\n\u001b[?2004l\r"]
[31.45982, "o", "\u001b[?2004h> "]
[31.459963, "o", "                    \"processed_at\": processing_time\r\n\u001b[?2004l\r"]
[31.459995, "o", "\u001b[?2004h> "]
[31.460048, "o", "                }\r\n\u001b[?2004l\r"]
[31.460076, "o", "\u001b[?2004h"]
[31.460107, "o", "> "]
[31.460227, "o", "                valid_transactions.append(valid_txn)\r\n\u001b[?2004l\r"]
[31.46026, "o", "\u001b[?2004h> "]
[31.460311, "o", "            else:\r\n\u001b[?2004l\r"]
[31.460342, "o", "\u001b[?2004h> "]
[31.460479, "o", "                error_counts[error_type] += 1\r\n\u001b[?2004l\r"]
[31.460511, "o", "\u001b[?2004h> "]
[31.460601, "o", "                errors.append({\r\n\u001b[?2004l\r"]
[31.460632, "o", "\u001b[?2004h> "]
[31.460755, "o", "                    \"line_number\": line_num,\r\n\u001b[?2004l\r"]
[31.460782, "o", "\u001b[?2004h> "]
[31.460911, "o", "                    \"error_type\": error_type,\r\n\u001b[?2004l\r"]
[31.460942, "o", "\u001b[?2004h> "]
[31.461076, "o", "                    \"error_detail\": error_detail,\r\n\u001b[?2004l\r"]
[31.461109, "o", "\u001b[?2004h> "]
[31.461246, "o", "                    \"raw_content\": raw_line[:200]\r\n\u001b[?2004l\r"]
[31.461278, "o", "\u001b[?2004h> "]
[31.461332, "o", "                })\r\n\u001b[?2004l\r"]
[31.461364, "o", "\u001b[?2004h> "]
[31.461395, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.461426, "o", "> "]
[31.461539, "o", "    # Sort valid transactions by timestamp\r\n\u001b[?2004l\r"]
[31.461569, "o", "\u001b[?2004h> "]
[31.461728, "o", "    valid_transactions.sort(key=lambda x: x['timestamp'])\r\n\u001b[?2004l\r"]
[31.461758, "o", "\u001b[?2004h> "]
[31.461791, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.461819, "o", "> "]
[31.461883, "o", "    # Write clean audit file\r\n\u001b[?2004l\r"]
[31.461913, "o", "\u001b[?2004h> "]
[31.462018, "o", "    with open(output_file, 'w') as f:\r\n\u001b[?2004l\r"]
[31.46205, "o", "\u001b[?2004h> "]
[31.462157, "o", "        for txn in valid_transactions:\r\n\u001b[?2004l\r"]
[31.462224, "o", "\u001b[?2004h> "]
[31.462308, "o", "            f.write(json.dumps(txn) + '\\n')\r\n\u001b[?2004l\r"]
[31.462344, "o", "\u001b[?2004h> "]
[31.462379, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[31.462454, "o", "    # Write error log\r\n\u001b[?2004l\r"]
[31.462488, "o", "\u001b[?2004h> "]
[31.462582, "o", "    with open(error_file, 'w') as f:\r\n\u001b[?2004l\r"]
[31.462615, "o", "\u001b[?2004h> "]
[31.462703, "o", "        for error in errors:\r\n\u001b[?2004l\r"]
[31.462734, "o", "\u001b[?2004h> "]
[31.462862, "o", "            f.write(json.dumps(error) + '\\n')\r\n\u001b[?2004l\r"]
[31.462898, "o", "\u001b[?2004h> "]
[31.462929, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.462962, "o", "> "]
[31.463024, "o", "    # Generate summary report\r\n\u001b[?2004l\r"]
[31.463056, "o", "\u001b[?2004h> "]
[31.46321, "o", "    total_lines = len(valid_transactions) + len(errors)\r\n\u001b[?2004l\r"]
[31.463244, "o", "\u001b[?2004h> "]
[31.463525, "o", "    success_rate = (len(valid_transactions) / total_lines * 100) if total_lines > 0 else 0.0\r\n\u001b[?2004l\r"]
[31.463567, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[31.463598, "o", "\u001b[?2004h> "]
[31.463691, "o", "    with open(summary_file, 'w') as f:\r\n\u001b[?2004l\r"]
[31.463725, "o", "\u001b[?2004h> "]
[31.463848, "o", "        f.write(\"AUDIT PROCESSING SUMMARY\\n\")\r\n\u001b[?2004l\r"]
[31.463886, "o", "\u001b[?2004h"]
[31.46392, "o", "> "]
[31.464004, "o", "        f.write(\"========================\\n\")\r\n\u001b[?2004l\r"]
[31.464038, "o", "\u001b[?2004h> "]
[31.464163, "o", "        f.write(f\"Input file: {input_file}\\n\")\r\n\u001b[?2004l\r"]
[31.464199, "o", "\u001b[?2004h> "]
[31.464355, "o", "        f.write(f\"Total lines processed: {total_lines}\\n\")\r\n\u001b[?2004l\r"]
[31.46439, "o", "\u001b[?2004h> "]
[31.464584, "o", "        f.write(f\"Valid transactions: {len(valid_transactions)}\\n\")\r\n\u001b[?2004l\r"]
[31.464615, "o", "\u001b[?2004h> "]
[31.46476, "o", "        f.write(f\"Failed records: {len(errors)}\\n\")\r\n\u001b[?2004l\r"]
[31.464795, "o", "\u001b[?2004h> "]
[31.464941, "o", "        f.write(f\"Success rate: {success_rate:.2f}%\\n\")\r\n\u001b[?2004l\r"]
[31.464977, "o", "\u001b[?2004h> "]
[31.465032, "o", "        f.write(\"\\n\")\r\n\u001b[?2004l\r"]
[31.465068, "o", "\u001b[?2004h> "]
[31.465164, "o", "        f.write(\"Errors by type:\\n\")\r\n\u001b[?2004l\r"]
[31.465198, "o", "\u001b[?2004h> "]
[31.465393, "o", "        f.write(f\"  malformed_json: {error_counts['malformed_json']}\\n\")\r\n\u001b[?2004l\r"]
[31.465446, "o", "\u001b[?2004h> "]
[31.465627, "o", "        f.write(f\"  missing_field: {error_counts['missing_field']}\\n\")\r\n\u001b[?2004l\r"]
[31.465661, "o", "\u001b[?2004h> "]
[31.465853, "o", "        f.write(f\"  invalid_format: {error_counts['invalid_format']}\\n\")\r\n\u001b[?2004l\r"]
[31.465887, "o", "\u001b[?2004h> "]
[31.466078, "o", "        f.write(f\"  invalid_value: {error_counts['invalid_value']}\\n\")\r\n\u001b[?2004l\r"]
[31.466112, "o", "\u001b[?2004h> "]
[31.46617, "o", "        f.write(\"\\n\")\r\n\u001b[?2004l\r"]
[31.466202, "o", "\u001b[?2004h> "]
[31.466375, "o", "        f.write(f\"Processing completed at: {processing_time}\\n\")\r\n\u001b[?2004l\r"]
[31.46641, "o", "\u001b[?2004h> "]
[31.466461, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[31.466559, "o", "    print(f\"Processing complete!\")\r\n\u001b[?2004l\r"]
[31.466594, "o", "\u001b[?2004h> "]
[31.466762, "o", "    print(f\"Valid transactions: {len(valid_transactions)}\")\r\n\u001b[?2004l\r"]
[31.466806, "o", "\u001b[?2004h> "]
[31.466914, "o", "    print(f\"Failed records: {len(errors)}\")\r\n\u001b[?2004l\r"]
[31.466951, "o", "\u001b[?2004h> "]
[31.467075, "o", "    print(f\"Success rate: {success_rate:.2f}%\")\r\n\u001b[?2004l\r"]
[31.467111, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[31.467145, "o", "\u001b[?2004h> "]
[31.467215, "o", "if __name__ == \"__main__\":\r\n\u001b[?2004l\r"]
[31.46725, "o", "\u001b[?2004h> "]
[31.467309, "o", "    process_audit_log()\r\n\u001b[?2004l\r"]
[31.467338, "o", "\u001b[?2004h> "]
[31.467369, "o", "EOF\r\n\u001b[?2004l\r"]
[31.470977, "o", "\u001b[?2004h"]
[31.471029, "o", "root@b4b11a43f98d:/home/user# "]
