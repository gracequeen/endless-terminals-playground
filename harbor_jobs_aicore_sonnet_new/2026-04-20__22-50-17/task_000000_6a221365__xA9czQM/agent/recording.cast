[41.026814, "o", "{\"line_number\": 4, \"error_type\": \"malformed_json\", \"error_detail\": \"invalid JSON syntax\", \"raw_content\": \"this is not valid json at all\"}\r\n{\"line_number\": 5, \"error_type\": \"invalid_value\", \"error_detail\": \"account_id must be non-empty string\", \"raw_content\": \"{\\\"transaction_id\\\": \\\"TXN-00000005\\\", \\\"timestamp\\\": \\\"2024-03-15T10:00:00Z\\\", \\\"account_id\\\": \\\"\\\", \\\"amount\\\": 50.00, \\\"currency\\\": \\\"USD\\\", \\\"status\\\": \\\"completed\\\"}\"}\r\n{\"line_number\": 6, \"error_type\": \"invalid_format\", \"error_detail\": \"invalid currency format: usd\", \"raw_content\": \"{\\\"transaction_id\\\": \\\"TXN-00000006\\\", \\\"timestamp\\\": \\\"2024-03-15T10:15:00Z\\\", \\\"account_id\\\": \\\"ACC-003\\\", \\\"amount\\\": 300.00, \\\"currency\\\": \\\"usd\\\", \\\"status\\\": \\\"completed\\\"}\"}\r\n{\"line_number\": 7, \"error_type\": \"invalid_format\", \"error_detail\": \"invalid transaction_id format: INVALID-ID\", \"raw_content\": \"{\\\"transaction_id\\\": \\\"INVALID-ID\\\", \\\"timestamp\\\": \\\"2024-03-15T10:30:00Z\\\", \\\"account_id\\\": \\\"ACC-004\\\", \\\"amount\\\": 125.75, \\\"currency\\\": \\\"CAD\\\", \\\"status\\\": \\\"c"]
[41.026867, "o", "ompleted\\\"}\"}\r\n{\"line_number\": 8, \"error_type\": \"invalid_format\", \"error_detail\": \"amount must be a number: not_a_number\", \"raw_content\": \"{\\\"transaction_id\\\": \\\"TXN-00000008\\\", \\\"timestamp\\\": \\\"2024-03-15T10:45:00Z\\\", \\\"account_id\\\": \\\"ACC-005\\\", \\\"amount\\\": \\\"not_a_number\\\", \\\"currency\\\": \\\"USD\\\", \\\"status\\\": \\\"completed\\\"}\"}\r\n"]
