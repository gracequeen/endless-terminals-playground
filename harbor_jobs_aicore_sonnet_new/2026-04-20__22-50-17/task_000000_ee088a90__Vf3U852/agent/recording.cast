[32.91471, "i", "cat > generate_report.py << 'EOF'\n#!/usr/bin/env python3\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\n# Parse log files\ndef parse_log(filename):\n    entries = []\n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if not line:\n                continue\n            match = re.match(r'\\[(.*?)\\]\\s+(.*?)\\s+\\|\\s+(.*?)\\s+\\|\\s+(.*?)\\s+\\|\\s+(.*?)\\s+\\|\\s+(.*?)$', line)\n            if match:\n                timestamp, service, old_key, new_key, status, rotated_by = match.groups()\n                entries.append({\n                    'timestamp': timestamp,\n                    'service': service,\n                    'old_key': old_key,\n                    'new_key': new_key,\n                    'status': status,\n                    'rotated_by': rotated_by\n                })\n    return entries\n\n# Parse all logs\naws_entries = parse_log('aws-rotation.log')\ndb_entries = parse_log('db-rotation.log')\napi_entries = parse_log('api-keys.log')\n\n# Cal"]
[32.914831, "i", "culate statistics\ndef calc_stats(entries):\n    total = len(entries)\n    success = sum(1 for e in entries if e['status'] == 'SUCCESS')\n    failed = sum(1 for e in entries if e['status'] == 'FAILED')\n    return total, success, failed\n\naws_stats = calc_stats(aws_entries)\ndb_stats = calc_stats(db_entries)\napi_stats = calc_stats(api_entries)\n\ntotal_rotated = aws_stats[0] + db_stats[0] + api_stats[0]\n\n# Sort entries alphabetically by service name\naws_entries.sort(key=lambda x: x['service'])\ndb_entries.sort(key=lambda x: x['service'])\napi_entries.sort(key=lambda x: x['service'])\n\n# Collect failed rotations\nfailed_rotations = []\nfor entry in aws_entries:\n    if entry['status'] == 'FAILED':\n        failed_rotations.append((entry['service'], 'AWS IAM'))\nfor entry in db_entries:\n    if entry['status'] == 'FAILED':\n        failed_rotations.append((entry['service'], 'Database'))\nfor entry in api_entries:\n    if entry['status'] == 'FAILED':\n        failed_rotations.append((entry['service'], 'API Keys'))\n\n# Generate markdow"]
[32.914881, "i", "n\nwith open('ROTATION_REPORT.md', 'w') as f:\n    # Header\n    now = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n    f.write('# Credential Rotation Report\\n\\n')\n    f.write(f'**Generated:** {now}\\n')\n    f.write(f'**Total Credentials Rotated:** {total_rotated}\\n\\n')\n    \n    # Summary table\n    f.write('## Summary by Category\\n\\n')\n    f.write('| Category | Count | Success | Failed |\\n')\n    f.write('|----------|-------|---------|--------|\\n')\n    f.write(f'| AWS IAM | {aws_stats[0]} | {aws_stats[1]} | {aws_stats[2]} |\\n')\n    f.write(f'| Database | {db_stats[0]} | {db_stats[1]} | {db_stats[2]} |\\n')\n    f.write(f'| API Keys | {api_stats[0]} | {api_stats[1]} | {api_stats[2]} |\\n\\n')\n    \n    # Detailed logs\n    f.write('## Detailed Rotation Log\\n\\n')\n    \n    # AWS IAM section\n    f.write('### AWS IAM Credentials\\n\\n')\n    f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\\n')\n    f.write('|---------|------------|------------|--------|------------|\\n')\n    for entry in aws_entries:\n        f"]
[32.914893, "o", "cat > generate_report.py << 'EOF'\r\n\u001b[?2004l\r"]
[32.914952, "i", ".write(f\"| {entry['service']} | {entry['old_key']} | {entry['new_key']} | {entry['status']} | {entry['rotated_by']} |\\n\")\n    f.write('\\n')\n    \n    # Database section\n    f.write('### Database Credentials\\n\\n')\n    f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\\n')\n    f.write('|---------|------------|------------|--------|------------|\\n')\n    for entry in db_entries:\n        f.write(f\"| {entry['service']} | {entry['old_key']} | {entry['new_key']} | {entry['status']} | {entry['rotated_by']} |\\n\")\n    f.write('\\n')\n    \n    # API Keys section\n    f.write('### API Keys\\n\\n')\n    f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\\n')\n    f.write('|---------|------------|------------|--------|------------|\\n')\n    for entry in api_entries:\n        f.write(f\"| {entry['service']} | {entry['old_key']} | {entry['new_key']} | {entry['status']} | {entry['rotated_by']} |\\n\")\n    f.write('\\n')\n    \n    # Failed rotations section\n    f.write('## Failed Rotations\\n\\n')\n    if faile"]
[32.914963, "o", "\u001b[?2004h> "]
[32.915013, "i", "d_rotations:\n        f.write('> **Action Required:** The following credentials failed rotation and need manual intervention.\\n\\n')\n        for service, category in failed_rotations:\n            f.write(f'- {service} ({category}): REASON\\n')\n    else:\n        f.write('> No failed rotations. All credentials rotated successfully.\\n')\n    f.write('\\n')\n    \n    # Sign-off section\n    f.write('## Sign-off\\n\\n')\n    f.write('- [ ] All successful rotations verified\\n')\n    f.write('- [ ] Failed rotations escalated\\n')\n    f.write('- [ ] Old credentials scheduled for deletion\\n')\n\nprint('Report generated successfully!')\nEOF\n"]
