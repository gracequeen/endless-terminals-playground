[31.805419, "i", "lformed_json']}\n  missing_field: {error_counts['missing_field']}\n  invalid_format: {error_counts['invalid_format']}\n  invalid_value: {error_counts['invalid_value']}\n\nProcessing completed at: {processing_time}\n\"\"\"\n    \n    with open(summary_output, 'w') as f:\n        f.write(summary)\n    \n    print(f\"Processing complete!\")\n    print(f\"Valid transactions: {valid_count}\")\n    print(f\"Failed records: {failed_count}\")\n    print(f\"Success rate: {success_rate:.2f}%\")\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
