[41.073629, "o", "{\"transaction_id\": \"TXN-00000025\", \"timestamp\": \"2024-03-15T07:00:00Z\", \"account_id\": \"ACC-020\", \"amount\": 1500.0, \"currency\": \"USD\", \"status\": \"completed\", \"integrity_hash\": \"17ce88f1d5377fcc9acb43e7baa628086d36d611a26c61657ea0c83f0f680796\", \"processed_at\": \"2026-04-20T23:38:12Z\"}\r\n{\"transaction_id\": \"TXN-00000003\", \"timestamp\": \"2024-03-15T08:30:00Z\", \"account_id\": \"ACC-001\", \"amount\": 200.0, \"currency\": \"GBP\", \"status\": \"pending\", \"integrity_hash\": \"26eb8261714887e46fca9af6598d41a648b93c984d030e1f534d0c971650e1cc\", \"processed_at\": \"2026-04-20T23:38:12Z\"}\r\n{\"transaction_id\": \"TXN-00000001\", \"timestamp\": \"2024-03-15T09:00:00Z\", \"account_id\": \"ACC-001\", \"amount\": 150.0, \"currency\": \"USD\", \"status\": \"completed\", \"integrity_hash\": \"9a87d2cb2efbc19b398c0722d8fbbe10476fe7763eb8ebee1195931c5d73f4a6\", \"processed_at\": \"2026-04-20T23:38:12Z\"}\r\n{\"transaction_id\": \"TXN-00000002\", \"timestamp\": \"2024-03-15T09:05:30Z\", \"account_id\": \"ACC-002\", \"amount\": -75.5, \"currency\": \"EUR\", \"status\": \"completed\", \"integrity_hash\": \"0"]
[41.073678, "o", "7bef3064e2cbdaf6623712040f6242d90257be8f6a128cb8f3dfe6c0b52a6e1\", \"processed_at\": \"2026-04-20T23:38:12Z\"}\r\n{\"transaction_id\": \"TXN-00000009\", \"timestamp\": \"2024-03-15T11:00:00Z\", \"account_id\": \"ACC-006\", \"amount\": 500.0, \"currency\": \"JPY\", \"status\": \"completed\", \"integrity_hash\": \"b52fee5f609218474255d61402566b213e761477d07521d8e54122b44de1f5e7\", \"processed_at\": \"2026-04-20T23:38:12Z\"}\r\n"]
