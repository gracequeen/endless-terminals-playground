[40.874224, "o", "-rw-r--r-- 1 root root 3658 Apr 20 23:38 clean_audit.jsonl\r\n-rw-r--r-- 1 root root 3177 Apr 20 23:38 error_log.jsonl\r\n-rw-r--r-- 1 root root  333 Apr 20 23:38 processing_summary.txt\r\n-rw-r--r-- 1 root root 3450 Apr 20 23:09 raw_transactions.jsonl\r\n"]
