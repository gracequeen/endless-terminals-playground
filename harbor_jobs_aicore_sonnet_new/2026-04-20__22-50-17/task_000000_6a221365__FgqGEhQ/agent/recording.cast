[31.817978, "o", "\u001b[?2004h> "]
[31.818125, "o", "    amount_formatted = f\"{record['amount']:.2f}\"\r\n\u001b[?2004l\r"]
[31.818159, "o", "\u001b[?2004h> "]
[31.818572, "o", "    canonical = f\"{record['transaction_id']}|{record['timestamp']}|{record['account_id']}|{amount_formatted}|{record['currency']}|{record['status']}\"\r\n\u001b[?2004l\r"]
[31.818609, "o", "\u001b[?2004h> "]
[31.818783, "o", "    return hashlib.sha256(canonical.encode('utf-8')).hexdigest()\r\n\u001b[?2004l\r"]
[31.818813, "o", "\u001b[?2004h> "]
[31.818844, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[31.818876, "o", "> "]
[31.818907, "o", "def main():\r\n\u001b[?2004l\r\u001b[?2004h"]
[31.818937, "o", "> "]
[31.819077, "o", "    input_file = '/home/user/audit/raw_transactions.jsonl'\r\n\u001b[?2004l\r"]
[31.81912, "o", "\u001b[?2004h> "]
[31.819274, "o", "    clean_output = '/home/user/audit/clean_audit.jsonl'\r\n\u001b[?2004l\r"]
[31.819307, "o", "\u001b[?2004h> "]
[31.819455, "o", "    error_output = '/home/user/audit/error_log.jsonl'\r\n\u001b[?2004l\r"]
[31.819489, "o", "\u001b[?2004h> "]
[31.819659, "o", "    summary_output = '/home/user/audit/processing_summary.txt'\r\n\u001b[?2004l\r"]
[31.819689, "o", "\u001b[?2004h> "]
[31.819721, "o", "    \r\n\u001b[?2004l\r"]
[31.81975, "o", "\u001b[?2004h> "]
[31.81982, "o", "    valid_transactions = []\r\n\u001b[?2004l\r"]
[31.819852, "o", "\u001b[?2004h> "]
[31.819898, "o", "    errors = []\r\n\u001b[?2004l\r"]
[31.819929, "o", "\u001b[?2004h> "]
[31.820031, "o", "    error_counts = defaultdict(int)\r\n\u001b[?2004l\r"]
[31.820063, "o", "\u001b[?2004h> "]
[31.82013, "o", "    total_lines = 0\r\n\u001b[?2004l\r"]
[31.820166, "o", "\u001b[?2004h> "]
[31.820194, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.820224, "o", "> "]
[31.820405, "o", "    processing_time = datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ')\r\n\u001b[?2004l\r"]
[31.820436, "o", "\u001b[?2004h> "]
[31.820468, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.820499, "o", "> "]
[31.820553, "o", "    # Process input file\r\n\u001b[?2004l\r"]
[31.820584, "o", "\u001b[?2004h> "]
[31.820685, "o", "    with open(input_file, 'r') as f:\r\n\u001b[?2004l\r"]
[31.820717, "o", "\u001b[?2004h> "]
[31.820852, "o", "        for line_num, line in enumerate(f, 1):\r\n\u001b[?2004l\r"]
[31.820873, "o", "\u001b[?2004h"]
[31.820916, "o", "> "]
[31.820959, "o", "            total_lines += 1\r\n\u001b[?2004l\r"]
[31.820992, "o", "\u001b[?2004h> "]
[31.8211, "o", "            raw_content = line.strip()\r\n\u001b[?2004l\r"]
[31.821144, "o", "\u001b[?2004h> "]
[31.821177, "o", "            \r\n\u001b[?2004l\r"]
[31.821212, "o", "\u001b[?2004h> "]
[31.821299, "o", "            # Try to parse JSON\r\n\u001b[?2004l\r"]
[31.821332, "o", "\u001b[?2004h> "]
[31.821379, "o", "            try:\r\n\u001b[?2004l\r"]
[31.821411, "o", "\u001b[?2004h> "]
[31.821542, "o", "                record = json.loads(raw_content)\r\n\u001b[?2004l\r"]
[31.821573, "o", "\u001b[?2004h> "]
[31.8217, "o", "            except json.JSONDecodeError as e:\r\n\u001b[?2004l\r"]
[31.82173, "o", "\u001b[?2004h> "]
[31.821819, "o", "                errors.append({\r\n\u001b[?2004l\r"]
[31.82185, "o", "\u001b[?2004h> "]
[31.821975, "o", "                    'line_number': line_num,\r\n\u001b[?2004l\r"]
[31.822004, "o", "\u001b[?2004h> "]
[31.82216, "o", "                    'error_type': 'malformed_json',\r\n\u001b[?2004l\r"]
[31.822194, "o", "\u001b[?2004h> "]
[31.822377, "o", "                    'error_detail': f'JSON parse error: {str(e)}',\r\n\u001b[?2004l\r"]
[31.822411, "o", "\u001b[?2004h> "]
[31.822557, "o", "                    'raw_content': raw_content[:200]\r\n\u001b[?2004l\r"]
[31.822589, "o", "\u001b[?2004h> "]
[31.822641, "o", "                })\r\n\u001b[?2004l\r"]
[31.822673, "o", "\u001b[?2004h> "]
[31.822819, "o", "                error_counts['malformed_json'] += 1\r\n\u001b[?2004l\r"]
[31.822849, "o", "\u001b[?2004h> "]
[31.82292, "o", "                continue\r\n\u001b[?2004l\r"]
[31.822956, "o", "\u001b[?2004h> "]
[31.822989, "o", "            \r\n\u001b[?2004l\r"]
[31.823021, "o", "\u001b[?2004h> "]
[31.823127, "o", "            # Validate transaction\r\n\u001b[?2004l\r"]
[31.823159, "o", "\u001b[?2004h> "]
[31.823401, "o", "            is_valid, error_type, error_detail = validate_transaction(record, line_num)\r\n\u001b[?2004l\r"]
[31.823432, "o", "\u001b[?2004h> "]
[31.823471, "o", "            \r\n\u001b[?2004l\r"]
[31.823503, "o", "\u001b[?2004h> "]
[31.823586, "o", "            if not is_valid:\r\n\u001b[?2004l\r"]
[31.823617, "o", "\u001b[?2004h> "]
[31.823707, "o", "                errors.append({\r\n\u001b[?2004l\r"]
[31.823739, "o", "\u001b[?2004h> "]
[31.823862, "o", "                    'line_number': line_num,\r\n\u001b[?2004l\r"]
[31.823892, "o", "\u001b[?2004h> "]
[31.82402, "o", "                    'error_type': error_type,\r\n\u001b[?2004l\r"]
[31.824052, "o", "\u001b[?2004h> "]
[31.824201, "o", "                    'error_detail': error_detail,\r\n\u001b[?2004l\r"]
[31.824232, "o", "\u001b[?2004h> "]
[31.82438, "o", "                    'raw_content': raw_content[:200]\r\n\u001b[?2004l\r"]
[31.824411, "o", "\u001b[?2004h> "]
[31.824465, "o", "                })\r\n\u001b[?2004l\r"]
[31.824497, "o", "\u001b[?2004h> "]
[31.824627, "o", "                error_counts[error_type] += 1\r\n\u001b[?2004l\r"]
[31.824658, "o", "\u001b[?2004h> "]
[31.824705, "o", "            else:\r\n\u001b[?2004l\r"]
[31.824734, "o", "\u001b[?2004h> "]
[31.824929, "o", "                # Valid transaction - compute hash and prepare output\r\n\u001b[?2004l\r"]
[31.824959, "o", "\u001b[?2004h> "]
[31.825117, "o", "                integrity_hash = compute_hash(record)\r\n\u001b[?2004l\r"]
[31.82515, "o", "\u001b[?2004h> "]
[31.825239, "o", "                clean_record = {\r\n\u001b[?2004l\r"]
[31.82527, "o", "\u001b[?2004h> "]
[31.825446, "o", "                    'transaction_id': record['transaction_id'],\r\n\u001b[?2004l\r"]
[31.825475, "o", "\u001b[?2004h> "]
[31.825627, "o", "                    'timestamp': record['timestamp'],\r\n\u001b[?2004l\r"]
[31.825659, "o", "\u001b[?2004h> "]
[31.825812, "o", "                    'account_id': record['account_id'],\r\n\u001b[?2004l\r"]
[31.825844, "o", "\u001b[?2004h> "]
[31.825977, "o", "                    'amount': record['amount'],\r\n\u001b[?2004l\r"]
[31.826007, "o", "\u001b[?2004h> "]
[31.826161, "o", "                    'currency': record['currency'],\r\n\u001b[?2004l\r"]
[31.826194, "o", "\u001b[?2004h> "]
[31.826325, "o", "                    'status': record['status'],\r\n\u001b[?2004l\r"]
[31.826357, "o", "\u001b[?2004h> "]
[31.826522, "o", "                    'integrity_hash': integrity_hash,\r\n\u001b[?2004l\r"]
[31.826557, "o", "\u001b[?2004h> "]
[31.82669, "o", "                    'processed_at': processing_time\r\n\u001b[?2004l\r"]
[31.82672, "o", "\u001b[?2004h> "]
[31.826769, "o", "                }\r\n\u001b[?2004l\r"]
[31.826801, "o", "\u001b[?2004h> "]
[31.826957, "o", "                valid_transactions.append(clean_record)\r\n\u001b[?2004l\r"]
[31.826988, "o", "\u001b[?2004h> "]
[31.827019, "o", "    \r\n\u001b[?2004l\r"]
[31.827048, "o", "\u001b[?2004h> "]
[31.827169, "o", "    # Sort valid transactions by timestamp\r\n\u001b[?2004l\r"]
[31.827203, "o", "\u001b[?2004h> "]
[31.827359, "o", "    valid_transactions.sort(key=lambda x: x['timestamp'])\r\n\u001b[?2004l\r"]
[31.827391, "o", "\u001b[?2004h> "]
[31.827419, "o", "    \r\n\u001b[?2004l\r"]
[31.82745, "o", "\u001b[?2004h> "]
[31.827519, "o", "    # Write clean audit file\r\n\u001b[?2004l\r"]
[31.82755, "o", "\u001b[?2004h> "]
[31.827657, "o", "    with open(clean_output, 'w') as f:\r\n\u001b[?2004l\r"]
[31.827689, "o", "\u001b[?2004h> "]
[31.827807, "o", "        for record in valid_transactions:\r\n\u001b[?2004l\r"]
[31.827838, "o", "\u001b[?2004h> "]
[31.827969, "o", "            f.write(json.dumps(record) + '\\n')\r\n\u001b[?2004l\r"]
[31.828, "o", "\u001b[?2004h> "]
[31.828031, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.828062, "o", "> "]
[31.828119, "o", "    # Write error log\r\n\u001b[?2004l\r"]
[31.828153, "o", "\u001b[?2004h> "]
[31.828261, "o", "    with open(error_output, 'w') as f:\r\n"]
[31.828292, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[31.828376, "o", "        for error in errors:\r\n\u001b[?2004l\r"]
[31.828407, "o", "\u001b[?2004h> "]
[31.828537, "o", "            f.write(json.dumps(error) + '\\n')\r\n\u001b[?2004l\r"]
[31.828568, "o", "\u001b[?2004h> "]
[31.828599, "o", "    \r\n\u001b[?2004l\r"]
[31.828629, "o", "\u001b[?2004h> "]
[31.828698, "o", "    # Generate summary report\r\n\u001b[?2004l\r"]
[31.828728, "o", "\u001b[?2004h> "]
[31.828845, "o", "    valid_count = len(valid_transactions)\r\n\u001b[?2004l\r"]
[31.828876, "o", "\u001b[?2004h> "]
[31.828963, "o", "    failed_count = len(errors)\r\n\u001b[?2004l\r"]
[31.828995, "o", "\u001b[?2004h> "]
[31.829226, "o", "    success_rate = (valid_count / total_lines * 100) if total_lines > 0 else 0.0\r\n\u001b[?2004l\r"]
[31.829259, "o", "\u001b[?2004h> "]
[31.829294, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.829325, "o", "> "]
[31.829422, "o", "    summary = f\"\"\"AUDIT PROCESSING SUMMARY\r\n\u001b[?2004l\r"]
[31.829453, "o", "\u001b[?2004h> "]
[31.829525, "o", "========================\r\n\u001b[?2004l\r"]
[31.829559, "o", "\u001b[?2004h> "]
[31.829627, "o", "Input file: {input_file}\r\n\u001b[?2004l\r"]
[31.829658, "o", "\u001b[?2004h> "]
[31.829762, "o", "Total lines processed: {total_lines}\r\n\u001b[?2004l\r"]
[31.829794, "o", "\u001b[?2004h> "]
[31.829888, "o", "Valid transactions: {valid_count}\r\n\u001b[?2004l\r"]
[31.829919, "o", "\u001b[?2004h> "]
[31.830008, "o", "Failed records: {failed_count}\r\n\u001b[?2004l\r"]
[31.83004, "o", "\u001b[?2004h> "]
[31.830144, "o", "Success rate: {success_rate:.2f}%\r\n\u001b[?2004l\r"]
[31.830176, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[31.830202, "o", "\u001b[?2004h> "]
[31.830252, "o", "Errors by type:\r\n\u001b[?2004l\r"]
[31.830282, "o", "\u001b[?2004h> "]
[31.830441, "o", "  malformed_json: {error_counts['malformed_json']}\r\n\u001b[?2004l\r"]
[31.830473, "o", "\u001b[?2004h> "]
[31.830608, "o", "  missing_field: {error_counts['missing_field']}\r\n\u001b[?2004l\r"]
[31.83064, "o", "\u001b[?2004h> "]
[31.830781, "o", "  invalid_format: {error_counts['invalid_format']}\r\n\u001b[?2004l\r"]
[31.830813, "o", "\u001b[?2004h> "]
[31.830948, "o", "  invalid_value: {error_counts['invalid_value']}\r\n\u001b[?2004l\r"]
[31.830982, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[31.831012, "o", "\u001b[?2004h> "]
[31.831144, "o", "Processing completed at: {processing_time}\r\n\u001b[?2004l\r"]
[31.831177, "o", "\u001b[?2004h> "]
[31.831208, "o", "\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[31.831227, "o", "> "]
[31.831268, "o", "    \r\n\u001b[?2004l\r"]
[31.831299, "o", "\u001b[?2004h> "]
[31.83138, "o", "    with open(summary_output, 'w') as f:\r\n\u001b[?2004l\r"]
[31.831411, "o", "\u001b[?2004h> "]
[31.831483, "o", "        f.write(summary)\r\n\u001b[?2004l\r"]
[31.831514, "o", "\u001b[?2004h> "]
[31.831545, "o", "    \r\n\u001b[?2004l\r"]
[31.831573, "o", "\u001b[?2004h> "]
[31.831664, "o", "    print(f\"Processing complete!\")\r\n\u001b[?2004l\r"]
[31.831695, "o", "\u001b[?2004h> "]
[31.831829, "o", "    print(f\"Valid transactions: {valid_count}\")\r\n\u001b[?2004l\r"]
[31.831861, "o", "\u001b[?2004h> "]
[31.831987, "o", "    print(f\"Failed records: {failed_count}\")\r\n\u001b[?2004l\r"]
[31.832019, "o", "\u001b[?2004h> "]
[31.832164, "o", "    print(f\"Success rate: {success_rate:.2f}%\")\r\n\u001b[?2004l\r"]
[31.832198, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[31.832229, "o", "\u001b[?2004h> "]
[31.832304, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[31.832334, "o", "\u001b[?2004h> "]
[31.832369, "o", "    main()\r\n\u001b[?2004l\r"]
[31.832398, "o", "\u001b[?2004h> "]
[31.832429, "o", "EOF\r\n\u001b[?2004l\r"]
[31.836257, "o", "\u001b[?2004h"]
[31.836313, "o", "root@e98c4ba8f97b:/home/user# "]
[31.910876, "i", "python3 process_audit.py\n"]
[31.91098, "o", "python3 process_audit.py\r\n\u001b[?2004l\r"]
