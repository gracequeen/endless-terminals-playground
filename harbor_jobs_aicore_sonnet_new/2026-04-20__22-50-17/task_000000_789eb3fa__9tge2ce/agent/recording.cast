[19.890382, "i", "cat > verify_permissions.sh << 'EOF'\n#!/bin/bash\n\n# Function to get octal permissions\nget_perms() {\n    stat -c '%a' \"$1\" 2>/dev/null\n}\n\n# Check directories\nif [ \"$(get_perms /home/user/docs_workspace/public)\" != \"755\" ]; then\n    echo \"FAIL: /home/user/docs_workspace/public\"\n    exit 1\nfi\n\nif [ \"$(get_perms /home/user/docs_workspace/drafts)\" != \"700\" ]; then\n    echo \"FAIL: /home/user/docs_workspace/drafts\"\n    exit 1\nfi\n\nif [ \"$(get_perms /home/user/docs_workspace/templates)\" != \"755\" ]; then\n    echo \"FAIL: /home/user/docs_workspace/templates\"\n    exit 1\nfi\n\nif [ \"$(get_perms /home/user/docs_workspace/archive)\" != \"750\" ]; then\n    echo \"FAIL: /home/user/docs_workspace/archive\"\n    exit 1\nfi\n\n# Check files\nif [ \"$(get_perms /home/user/docs_workspace/public/index.md)\" != \"644\" ]; then\n    echo \"FAIL: /home/user/docs_workspace/public/index.md\"\n    exit 1\nfi\n\nif [ \"$(get_perms /home/user/docs_workspace/drafts/wip-feature.md)\" != \"600\" ]; then\n    echo \"FAIL: /home/user/docs_workspace/drafts/wip-feature.md\"\n  "]
[19.890512, "i", "  exit 1\nfi\n\nif [ \"$(get_perms /home/user/docs_workspace/templates/article-template.md)\" != \"444\" ]; then\n    echo \"FAIL: /home/user/docs_workspace/templates/article-template.md\"\n    exit 1\nfi\n\nif [ \"$(get_perms /home/user/docs_workspace/archive/v1-notes.md)\" != \"440\" ]; then\n    echo \"FAIL: /home/user/docs_workspace/archive/v1-notes.md\"\n    exit 1\nfi\n\necho \"PASS\"\nEOF\n"]
