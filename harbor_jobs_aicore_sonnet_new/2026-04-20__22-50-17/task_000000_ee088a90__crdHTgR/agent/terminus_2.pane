[?2004l[?2004h> api_success = sum(1 for e in api_entries if e['status'] == 'SUCCESS')
[?2004l[?2004h> api_failed = sum(1 for e in api_entries if e['status'] == 'FAILED')
[?2004l[?2004h> 
