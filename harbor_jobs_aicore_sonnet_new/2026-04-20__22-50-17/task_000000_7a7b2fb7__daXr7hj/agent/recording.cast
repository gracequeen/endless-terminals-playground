[58.712668, "i", "tput.strip()\n    return \"unknown\"\n\ndef has_security_update(package):\n    \"\"\"Check if package has security update available\"\"\"\n    output = run_command(f\"apt-cache policy {package} 2>/dev/null\")\n    lines = output.split('\\n')\n    \n    installed_version = None\n    candidate_version = None\n    has_security = False\n    \n    for i, line in enumerate(lines):\n        if 'Installed:' in line:\n            installed_version = line.split(':', 1)[1].strip()\n        elif 'Candidate:' in line:\n            candidate_version = line.split(':', 1)[1].strip()\n        elif 'security' in line.lower() and '/updates' in line.lower():\n            has_security = True\n    \n    # If candidate is different from installed and there's a security repo, likely has update\n    if installed_version and candidate_version and installed_version != candidate_version and installed_version != '(none)':\n        if has_security:\n            return True\n    \n    return False\n\ndef main():\n    # Read package lists\n    with open('installed_packages.txt', "]
[58.712701, "o", "\u001b[?2004h> "]
[58.712738, "i", "'r') as f:\n        installed = set(line.strip() for line in f if line.strip())\n    \n    with open('required_packages.txt', 'r') as f:\n        required = set(line.strip() for line in f if line.strip())\n    \n    print(f\"Analyzing {len(installed)} installed packages and {len(required)} required packages...\")\n    \n    # Find all dependencies of required packages (up to 3 levels)\n    print(\"Checking dependencies (this may take a while)...\")\n    all_required_deps = set()\n    dep_map = defaultdict(list)  # Maps dependency to packages that need it\n    \n    for pkg in required:\n        print(f\"  Checking dependencies for {pkg}...\")\n        deps = get_dependencies(pkg, depth=0, max_depth=3)\n        for dep in deps:\n            all_required_deps.add(dep)\n            dep_map[dep].append(pkg)\n    \n    # Identify packages not in required list\n    extra_packages = installed - required\n    \n    # Separate into removable and dependency-protected\n    removable = []\n    dependency_protected = []\n    \n    print(\"\\nAnalyzing remo"]
[58.712784, "o", "#!/usr/bin/env python3\r\n\u001b[?2004l\r\u001b[?2004h> "]
[58.712821, "i", "vable packages...\")\n    for pkg in sorted(extra_packages):\n        if pkg in all_required_deps:\n            # This package is a dependency of a required package\n            dependency_protected.append({\n                \"name\": pkg,\n                \"required_by\": sorted(dep_map[pkg])\n            })\n        else:\n            # This package can be removed\n            print(f\"  Checking {pkg}...\")\n            size = get_package_size(pkg)\n            version = get_package_version(pkg)\n            sec_update = has_security_update(pkg)\n            \n            removable.append({\n                \"name\": pkg,\n                \"installed_version\": version,\n                \"size_kb\": size,\n                \"has_security_update\": sec_update\n            })\n    \n    # Sort arrays alphabetically\n    removable.sort(key=lambda x: x['name'])\n    dependency_protected.sort(key=lambda x: x['name'])\n    \n    # Calculate total space savings\n    total_space = sum(pkg['size_kb'] for pkg in removable)\n    \n    # Create report\n    report"]
