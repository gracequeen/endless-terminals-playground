[58.712413, "i", "cat > analyze_packages.py << 'SCRIPT_EOF'\n#!/usr/bin/env python3\nimport subprocess\nimport json\nimport re\nfrom collections import defaultdict\n\ndef run_command(cmd):\n    try:\n        result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=30)\n        return result.stdout\n    except Exception as e:\n        return \"\"\n\ndef get_dependencies(package, depth=0, max_depth=3, visited=None):\n    \"\"\"Get dependencies recursively up to max_depth levels\"\"\"\n    if visited is None:\n        visited = set()\n    \n    if depth > max_depth or package in visited:\n        return set()\n    \n    visited.add(package)\n    deps = set()\n    \n    output = run_command(f\"apt-cache depends {package} 2>/dev/null\")\n    for line in output.split('\\n'):\n        line = line.strip()\n        if line.startswith('Depends:') or line.startswith('PreDepends:'):\n            dep = line.split(':', 1)[1].strip()\n            # Remove version constraints and alternatives\n            dep = re.sub(r'[<>=].*', '', dep).strip()\n            d"]
[58.712574, "i", "ep = dep.split('|')[0].strip()\n            if dep and dep not in visited:\n                deps.add(dep)\n                if depth < max_depth:\n                    deps.update(get_dependencies(dep, depth + 1, max_depth, visited))\n    \n    return deps\n\ndef get_package_size(package):\n    \"\"\"Get package installed size in KB\"\"\"\n    output = run_command(f\"dpkg-query -W -f='${{Installed-Size}}' {package} 2>/dev/null\")\n    if output and output.strip().isdigit():\n        return int(output.strip())\n    \n    # Try apt-cache show as fallback\n    output = run_command(f\"apt-cache show {package} 2>/dev/null\")\n    for line in output.split('\\n'):\n        if line.startswith('Installed-Size:'):\n            size = line.split(':', 1)[1].strip()\n            if size.isdigit():\n                return int(size)\n    \n    return 0\n\ndef get_package_version(package):\n    \"\"\"Get installed package version\"\"\"\n    output = run_command(f\"dpkg-query -W -f='${{Version}}' {package} 2>/dev/null\")\n    if output and output.strip():\n        return ou"]
