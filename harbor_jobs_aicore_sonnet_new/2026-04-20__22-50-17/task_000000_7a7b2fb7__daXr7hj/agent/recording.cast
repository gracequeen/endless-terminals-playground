[58.72581, "o", "    candidate_version = None\r\n\u001b[?2004l\r"]
[58.725846, "o", "\u001b[?2004h"]
[58.725881, "o", "> "]
[58.725973, "o", "    has_security = False\r\n\u001b[?2004l\r"]
[58.726009, "o", "\u001b[?2004h"]
[58.726045, "o", ">     \r\n"]
[58.726082, "o", "\u001b[?2004l\r\u001b[?2004h"]
[58.726125, "o", "> "]
[58.726261, "o", "    for i, line in enumerate(lines):\r\n\u001b[?2004l\r"]
[58.726296, "o", "\u001b[?2004h> "]
[58.72645, "o", "        if 'Installed:' in line:\r\n\u001b[?2004l\r"]
[58.726486, "o", "\u001b[?2004h"]
[58.72652, "o", "> "]
[58.726775, "o", "            installed_version = line.split(':', 1)[1].strip()\r\n\u001b[?2004l\r"]
[58.726813, "o", "\u001b[?2004h"]
[58.726846, "o", "> "]
[58.726977, "o", "        elif 'Candidate:' in line:\r\n\u001b[?2004l\r"]
[58.727022, "o", "\u001b[?2004h"]
[58.727058, "o", "> "]
[58.727302, "o", "            candidate_version = line.split(':', 1)[1].strip()\r\n\u001b[?2004l\r"]
[58.727337, "o", "\u001b[?2004h"]
[58.727372, "o", "> "]
[58.727653, "o", "        elif 'security' in line.lower() and '/updates' in line.lower():\r\n\u001b[?2004l\r"]
[58.727688, "o", "\u001b[?2004h"]
[58.727721, "o", "> "]
[58.727857, "o", "            has_security = True\r\n\u001b[?2004l\r"]
[58.727893, "o", "\u001b[?2004h> "]
[58.727929, "o", "    \r\n\u001b[?2004l\r"]
[58.727964, "o", "\u001b[?2004h"]
[58.727999, "o", "> "]
[58.728367, "o", "    # If candidate is different from installed and there's a security repo, likely has update\r\n\u001b[?2004l\r"]
[58.728403, "o", "\u001b[?2004h"]
[58.728437, "o", "> "]
[58.728869, "o", "    if installed_version and candidate_version and installed_version != candidate_version and installed_version != '(none)':\r\n\u001b[?2004l\r"]
[58.72891, "o", "\u001b[?2004h> "]
[58.728997, "o", "        if has_security:\r\n\u001b[?2004l\r"]
[58.729034, "o", "\u001b[?2004h> "]
[58.729122, "o", "            return True\r\n\u001b[?2004l\r"]
[58.729158, "o", "\u001b[?2004h> "]
[58.729193, "o", "    \r\n\u001b[?2004l\r"]
[58.729229, "o", "\u001b[?2004h> "]
[58.72929, "o", "    return False\r\n\u001b[?2004l\r"]
[58.729325, "o", "\u001b[?2004h> "]
[58.72936, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[58.729395, "o", "> "]
[58.729431, "o", "def main():\r\n\u001b[?2004l\r"]
[58.729466, "o", "\u001b[?2004h> "]
[58.729555, "o", "    # Read package lists\r\n\u001b[?2004l\r"]
[58.729591, "o", "\u001b[?2004h"]
[58.729626, "o", "> "]
[58.729774, "o", "    with open('installed_packages.txt', 'r') as f:\r\n\u001b[?2004l\r"]
[58.729812, "o", "\u001b[?2004h> "]
[58.730016, "o", "        installed = set(line.strip() for line in f if line.strip())\r\n\u001b[?2004l\r"]
[58.730052, "o", "\u001b[?2004h"]
[58.730086, "o", ">     \r\n\u001b[?2004l\r"]
[58.730121, "o", "\u001b[?2004h> "]
[58.730277, "o", "    with open('required_packages.txt', 'r') as f:\r\n\u001b[?2004l\r"]
[58.730312, "o", "\u001b[?2004h"]
[58.730346, "o", "> "]
[58.730525, "o", "        required = set(line.strip() for line in f if line.strip())\r\n\u001b[?2004l\r"]
[58.730561, "o", "\u001b[?2004h> "]
[58.730597, "o", "    \r\n\u001b[?2004l\r"]
[58.730632, "o", "\u001b[?2004h> "]
[58.730941, "o", "    print(f\"Analyzing {len(installed)} installed packages and {len(required)} required packages...\")\r\n\u001b[?2004l\r"]
[58.730983, "o", "\u001b[?2004h> "]
[58.73103, "o", "    \r\n\u001b[?2004l\r"]
[58.731065, "o", "\u001b[?2004h> "]
[58.731276, "o", "    # Find all dependencies of required packages (up to 3 levels)\r\n\u001b[?2004l\r"]
[58.731312, "o", "\u001b[?2004h> "]
[58.731511, "o", "    print(\"Checking dependencies (this may take a while)...\")\r\n\u001b[?2004l\r"]
[58.731547, "o", "\u001b[?2004h> "]
[58.731652, "o", "    all_required_deps = set()\r\n\u001b[?2004l\r"]
[58.731687, "o", "\u001b[?2004h> "]
[58.731932, "o", "    dep_map = defaultdict(list)  # Maps dependency to packages that need it\r\n\u001b[?2004l\r"]
[58.731976, "o", "\u001b[?2004h> "]
[58.732011, "o", "    \r\n\u001b[?2004l\r"]
[58.732046, "o", "\u001b[?2004h> "]
[58.732127, "o", "    for pkg in required:\r\n\u001b[?2004l\r"]
[58.732163, "o", "\u001b[?2004h> "]
[58.732332, "o", "        print(f\"  Checking dependencies for {pkg}...\")\r\n\u001b[?2004l\r"]
[58.732368, "o", "\u001b[?2004h> "]
[58.73255, "o", "        deps = get_dependencies(pkg, depth=0, max_depth=3)\r\n\u001b[?2004l\r"]
[58.732586, "o", "\u001b[?2004h> "]
[58.73268, "o", "        for dep in deps:\r\n\u001b[?2004l\r"]
[58.732715, "o", "\u001b[?2004h> "]
[58.732858, "o", "            all_required_deps.add(dep)\r\n\u001b[?2004l\r"]
[58.732894, "o", "\u001b[?2004h> "]
[58.733016, "o", "            dep_map[dep].append(pkg)\r\n\u001b[?2004l\r"]
[58.733051, "o", "\u001b[?2004h> "]
[58.733086, "o", "    \r\n\u001b[?2004l\r"]
[58.733121, "o", "\u001b[?2004h> "]
[58.733268, "o", "    # Identify packages not in required list\r\n\u001b[?2004l\r"]
[58.733304, "o", "\u001b[?2004h> "]
[58.73344, "o", "    extra_packages = installed - required\r\n\u001b[?2004l\r"]
[58.733476, "o", "\u001b[?2004h"]
[58.733511, "o", ">     \r\n\u001b[?2004l\r"]
[58.733545, "o", "\u001b[?2004h> "]
[58.733713, "o", "    # Separate into removable and dependency-protected\r\n\u001b[?2004l\r"]
[58.733748, "o", "\u001b[?2004h> "]
[58.733835, "o", "    removable = []\r\n\u001b[?2004l\r"]
[58.733871, "o", "\u001b[?2004h> "]
[58.733974, "o", "    dependency_protected = []\r\n\u001b[?2004l\r"]
[58.73401, "o", "\u001b[?2004h> "]
[58.734045, "o", "    \r\n\u001b[?2004l\r"]
[58.734081, "o", "\u001b[?2004h> "]
[58.734226, "o", "    print(\"\\nAnalyzing removable packages...\")\r\n\u001b[?2004l\r"]
[58.73426, "o", "\u001b[?2004h> "]
[58.734388, "o", "    for pkg in sorted(extra_packages):\r\n\u001b[?2004l\r"]
[58.734424, "o", "\u001b[?2004h> "]
[58.734546, "o", "        if pkg in all_required_deps:\r\n\u001b[?2004l\r"]
[58.734582, "o", "\u001b[?2004h> "]
[58.734802, "o", "            # This package is a dependency of a required package\r\n\u001b[?2004l\r"]
[58.734838, "o", "\u001b[?2004h> "]
[58.734977, "o", "            dependency_protected.append({\r\n\u001b[?2004l\r"]
[58.73502, "o", "\u001b[?2004h> "]
[58.735126, "o", "                \"name\": pkg,\r\n\u001b[?2004l\r"]
[58.735161, "o", "\u001b[?2004h> "]
[58.735322, "o", "                \"required_by\": sorted(dep_map[pkg])\r\n\u001b[?2004l\r"]
[58.735357, "o", "\u001b[?2004h"]
[58.735391, "o", "> "]
[58.735426, "o", "            })\r\n"]
[58.735462, "o", "\u001b[?2004l\r\u001b[?2004h"]
[58.735496, "o", "> "]
[58.735531, "o", "        else:\r\n\u001b[?2004l\r"]
[58.735566, "o", "\u001b[?2004h"]
[58.7356, "o", "> "]
[58.735712, "o", "            # This package can be removed\r\n\u001b[?2004l\r"]
[58.735748, "o", "\u001b[?2004h> "]
[58.735896, "o", "            print(f\"  Checking {pkg}...\")\r\n\u001b[?2004l\r"]
[58.735933, "o", "\u001b[?2004h"]
[58.735968, "o", "> "]
[58.736076, "o", "            size = get_package_size(pkg)\r\n\u001b[?2004l\r"]
[58.736111, "o", "\u001b[?2004h"]
[58.736146, "o", "> "]
[58.736272, "o", "            version = get_package_version(pkg)\r\n\u001b[?2004l\r"]
[58.736307, "o", "\u001b[?2004h> "]
[58.736464, "o", "            sec_update = has_security_update(pkg)\r\n\u001b[?2004l\r"]
[58.736499, "o", "\u001b[?2004h> "]
[58.736557, "o", "            \r\n\u001b[?2004l\r"]
[58.736592, "o", "\u001b[?2004h> "]
[58.736697, "o", "            removable.append({\r\n\u001b[?2004l\r"]
[58.736732, "o", "\u001b[?2004h> "]
[58.736846, "o", "                \"name\": pkg,\r\n\u001b[?2004l\r"]
[58.736882, "o", "\u001b[?2004h> "]
[58.737028, "o", "                \"installed_version\": version,\r\n\u001b[?2004l\r"]
[58.737063, "o", "\u001b[?2004h"]
[58.737098, "o", "> "]
[58.737186, "o", "                \"size_kb\": size,\r\n\u001b[?2004l\r"]
[58.737222, "o", "\u001b[?2004h"]
[58.737256, "o", "> "]
[58.73739, "o", "                \"has_security_update\": sec_update\r\n\u001b[?2004l\r"]
[58.737426, "o", "\u001b[?2004h> "]
[58.737488, "o", "            })\r\n\u001b[?2004l\r"]
[58.737523, "o", "\u001b[?2004h> "]
[58.73756, "o", "    \r\n\u001b[?2004l\r"]
[58.737594, "o", "\u001b[?2004h> "]
[58.737704, "o", "    # Sort arrays alphabetically\r\n\u001b[?2004l\r"]
[58.737738, "o", "\u001b[?2004h> "]
[58.737892, "o", "    removable.sort(key=lambda x: x['name'])\r\n\u001b[?2004l\r"]
[58.737929, "o", "\u001b[?2004h"]
[58.737963, "o", "> "]
[58.738111, "o", "    dependency_protected.sort(key=lambda x: x['name'])\r\n\u001b[?2004l\r"]
[58.738147, "o", "\u001b[?2004h> "]
[58.738182, "o", "    \r\n\u001b[?2004l\r"]
[58.738217, "o", "\u001b[?2004h> "]
[58.738342, "o", "    # Calculate total space savings\r\n\u001b[?2004l\r"]
[58.738377, "o", "\u001b[?2004h"]
[58.738411, "o", "> "]
[58.73857, "o", "    total_space = sum(pkg['size_kb'] for pkg in removable)\r\n\u001b[?2004l\r"]
[58.738605, "o", "\u001b[?2004h"]
[58.738642, "o", ">     \r\n\u001b[?2004l\r"]
[58.738677, "o", "\u001b[?2004h> "]
[58.738752, "o", "    # Create report\r\n\u001b[?2004l\r"]
[58.738803, "o", "\u001b[?2004h"]
[58.738838, "o", "> "]
[58.738879, "o", "    report = {\r\n\u001b[?2004l\r"]
[58.738914, "o", "\u001b[?2004h> "]
[58.738992, "o", "        \"summary\": {\r\n\u001b[?2004l\r"]
[58.73904, "o", "\u001b[?2004h"]
[58.739075, "o", "> "]
[58.739199, "o", "            \"total_installed\": len(installed),\r\n\u001b[?2004l\r"]
[58.739235, "o", "\u001b[?2004h"]
[58.739269, "o", "> "]
[58.739389, "o", "            \"total_required\": len(required),\r\n\u001b[?2004l\r"]
[58.739425, "o", "\u001b[?2004h> "]
[58.739575, "o", "            \"removable_count\": len(removable),\r\n\u001b[?2004l\r"]
[58.739611, "o", "\u001b[?2004h"]
[58.739645, "o", "> "]
[58.739835, "o", "            \"kept_as_dependencies\": len(dependency_protected),\r\n\u001b[?2004l\r"]
[58.739872, "o", "\u001b[?2004h> "]
[58.740023, "o", "            \"total_space_savings_kb\": total_space\r\n\u001b[?2004l\r"]
[58.740059, "o", "\u001b[?2004h"]
[58.740092, "o", "> "]
[58.740128, "o", "        },\r\n\u001b[?2004l\r"]
[58.740164, "o", "\u001b[?2004h> "]
[58.740294, "o", "        \"removable_packages\": removable,\r\n\u001b[?2004l\r"]
[58.740329, "o", "\u001b[?2004h> "]
[58.740494, "o", "        \"dependency_protected\": dependency_protected\r\n\u001b[?2004l\r"]
[58.740529, "o", "\u001b[?2004h> "]
[58.740566, "o", "    }\r\n\u001b[?2004l\r"]
[58.740602, "o", "\u001b[?2004h> "]
[58.740637, "o", "    \r\n\u001b[?2004l\r"]
[58.740674, "o", "\u001b[?2004h> "]
[58.740752, "o", "    # Write JSON report\r\n\u001b[?2004l\r"]
[58.740801, "o", "\u001b[?2004h> "]
[58.740955, "o", "    with open('removal_report.json', 'w') as f:\r\n\u001b[?2004l\r"]
[58.74099, "o", "\u001b[?2004h> "]
[58.741118, "o", "        json.dump(report, f, indent=2)\r\n\u001b[?2004l\r"]
[58.741154, "o", "\u001b[?2004h> "]
[58.741189, "o", "    \r\n\u001b[?2004l\r"]
[58.74123, "o", "\u001b[?2004h> "]
[58.741408, "o", "    print(f\"\\nReport written to removal_report.json\")\r\n\u001b[?2004l\r"]
[58.741445, "o", "\u001b[?2004h> "]
[58.741619, "o", "    print(f\"  Removable packages: {len(removable)}\")\r\n\u001b[?2004l\r"]
[58.741662, "o", "\u001b[?2004h> "]
[58.741866, "o", "    print(f\"  Dependency-protected: {len(dependency_protected)}\")\r\n\u001b[?2004l\r"]
[58.741903, "o", "\u001b[?2004h"]
[58.741937, "o", "> "]
[58.742156, "o", "    print(f\"  Total space savings: {total_space} KB ({total_space/1024:.2f} MB)\")\r\n\u001b[?2004l\r"]
[58.742191, "o", "\u001b[?2004h> "]
[58.742226, "o", "    \r\n\u001b[?2004l\r"]
[58.74226, "o", "\u001b[?2004h> "]
[58.742357, "o", "    # Create removal script\r\n\u001b[?2004l\r"]
[58.742392, "o", "\u001b[?2004h"]
[58.742427, "o", "> "]
[58.742553, "o", "    with open('remove_packages.sh', 'w') as f:\r\n\u001b[?2004l\r"]
[58.742588, "o", "\u001b[?2004h> "]
[58.742705, "o", "        f.write('#!/bin/bash\\n\\n')\r\n\u001b[?2004l\r"]
[58.742741, "o", "\u001b[?2004h"]
[58.742791, "o", "> "]
[58.742954, "o", "        f.write('# Auto-generated package removal script\\n')\r\n\u001b[?2004l\r"]
[58.742989, "o", "\u001b[?2004h> "]
[58.743366, "o", "        f.write(f'# This script will remove {len(removable)} packages and save approximately {total_space/1024:.2f} MB\\n\\n')\r\n\u001b[?2004l\r"]
[58.743408, "o", "\u001b[?2004h> "]
[58.743445, "o", "        \r\n\u001b[?2004l\r"]
[58.743481, "o", "\u001b[?2004h"]
[58.743515, "o", "> "]
[58.743574, "o", "        if removable:\r\n\u001b[?2004l\r"]
[58.743609, "o", "\u001b[?2004h> "]
[58.743827, "o", "            pkg_list = ' '.join(pkg['name'] for pkg in removable)\r\n\u001b[?2004l\r"]
[58.743864, "o", "\u001b[?2004h> "]
[58.744056, "o", "            f.write('# Dry-run: Show what would be removed\\n')\r\n\u001b[?2004l\r"]
[58.744092, "o", "\u001b[?2004h"]
[58.744126, "o", "> "]
[58.744355, "o", "            f.write(f'echo \"The following packages would be removed: {pkg_list}\"\\n')\r\n\u001b[?2004l\r"]
[58.74439, "o", "\u001b[?2004h"]
[58.744432, "o", "> "]
[58.744511, "o", "            f.write('echo \"\"\\n')\r\n\u001b[?2004l\r"]
[58.744548, "o", "\u001b[?2004h"]
[58.744582, "o", "> "]
[58.744819, "o", "            f.write('echo \"To proceed with removal, uncomment the line below:\"\\n')\r\n\u001b[?2004l\r"]
[58.744857, "o", "\u001b[?2004h> "]
[58.744973, "o", "            f.write('echo \"\"\\n\\n')\r\n\u001b[?2004l\r"]
[58.745008, "o", "\u001b[?2004h> "]
[58.745255, "o", "            f.write('# Uncomment the next line to actually remove the packages\\n')\r\n\u001b[?2004l\r"]
[58.745295, "o", "\u001b[?2004h> "]
[58.745481, "o", "            f.write(f'# apt-get remove -y {pkg_list}\\n')\r\n\u001b[?2004l\r"]
[58.745517, "o", "\u001b[?2004h> "]
[58.745581, "o", "        else:\r\n\u001b[?2004l\r"]
[58.745617, "o", "\u001b[?2004h> "]
[58.745806, "o", "            f.write('echo \"No packages to remove.\"\\n')\r\n\u001b[?2004l\r"]
[58.745844, "o", "\u001b[?2004h> "]
[58.745879, "o", "    \r\n\u001b[?2004l\r"]
[58.745914, "o", "\u001b[?2004h> "]
[58.746055, "o", "    run_command('chmod +x remove_packages.sh')\r\n\u001b[?2004l\r"]
[58.746091, "o", "\u001b[?2004h> "]
[58.746272, "o", "    print(\"Removal script written to remove_packages.sh\")\r\n\u001b[?2004l\r"]
[58.746307, "o", "\u001b[?2004h"]
[58.746343, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[58.746378, "o", "> "]
[58.74646, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[58.746495, "o", "\u001b[?2004h> "]
[58.746548, "o", "    main()\r\n\u001b[?2004l\r"]
[58.746584, "o", "\u001b[?2004h> "]
[58.746635, "o", "SCRIPT_EOF\r\n\u001b[?2004l\r"]
