[30.619215, "i", "cat > generate_report.py << 'EOF'\n#!/usr/bin/env python3\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\n# Parse log files\ndef parse_log_file(filename):\n    entries = []\n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if not line:\n                continue\n            # Parse: [TIMESTAMP] SERVICE_NAME | OLD_KEY_ID | NEW_KEY_ID | STATUS | ROTATED_BY\n            match = re.match(r'\\[(.+?)\\]\\s+(.+?)\\s+\\|\\s+(.+?)\\s+\\|\\s+(.+?)\\s+\\|\\s+(.+?)\\s+\\|\\s+(.+)', line)\n            if match:\n                timestamp, service, old_key, new_key, status, rotated_by = match.groups()\n                entries.append({\n                    'timestamp': timestamp,\n                    'service': service,\n                    'old_key': old_key,\n                    'new_key': new_key,\n                    'status': status,\n                    'rotated_by': rotated_by\n                })\n    return entries\n\n# Parse all log files\naws_entries = parse_log_file('"]
[30.619344, "i", "aws-rotation.log')\ndb_entries = parse_log_file('db-rotation.log')\napi_entries = parse_log_file('api-keys.log')\n\n# Sort entries by service name\naws_entries.sort(key=lambda x: x['service'])\ndb_entries.sort(key=lambda x: x['service'])\napi_entries.sort(key=lambda x: x['service'])\n\n# Calculate statistics\ndef calc_stats(entries):\n    total = len(entries)\n    success = sum(1 for e in entries if e['status'] == 'SUCCESS')\n    failed = sum(1 for e in entries if e['status'] == 'FAILED')\n    return total, success, failed\n\naws_stats = calc_stats(aws_entries)\ndb_stats = calc_stats(db_entries)\napi_stats = calc_stats(api_entries)\n\ntotal_rotations = len(aws_entries) + len(db_entries) + len(api_entries)\n\n# Collect failed rotations\nfailed_rotations = []\nfor entry in aws_entries:\n    if entry['status'] == 'FAILED':\n        failed_rotations.append((entry['service'], 'AWS IAM'))\nfor entry in db_entries:\n    if entry['status'] == 'FAILED':\n        failed_rotations.append((entry['service'], 'Database'))\nfor entry in api_entries:\n   "]
[30.619393, "i", " if entry['status'] == 'FAILED':\n        failed_rotations.append((entry['service'], 'API Keys'))\n\n# Generate markdown report\ncurrent_time = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n\nwith open('ROTATION_REPORT.md', 'w') as f:\n    f.write('# Credential Rotation Report\\n\\n')\n    f.write(f'**Generated:** {current_time}\\n')\n    f.write(f'**Total Credentials Rotated:** {total_rotations}\\n\\n')\n    \n    f.write('## Summary by Category\\n\\n')\n    f.write('| Category | Count | Success | Failed |\\n')\n    f.write('|----------|-------|---------|--------|\\n')\n    f.write(f'| AWS IAM | {aws_stats[0]} | {aws_stats[1]} | {aws_stats[2]} |\\n')\n    f.write(f'| Database | {db_stats[0]} | {db_stats[1]} | {db_stats[2]} |\\n')\n    f.write(f'| API Keys | {api_stats[0]} | {api_stats[1]} | {api_stats[2]} |\\n\\n')\n    \n    f.write('## Detailed Rotation Log\\n\\n')\n    \n    # AWS IAM Credentials\n    f.write('### AWS IAM Credentials\\n\\n')\n    f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\\n')\n    f.write('|---------|-"]
[30.61943, "o", "cat > generate_report.py << 'EOF'\r\n\u001b[?2004l\r if entry['status'] == 'FAILED':\r\n        failed_rotations.append((entry['service'], 'API Keys'))\r\n\r\n# Generate markdown report\r\ncurrent_time "]
[30.619473, "i", "-----------|------------|--------|------------|\\n')\n    for entry in aws_entries:\n        f.write(f\"| {entry['service']} | {entry['old_key']} | {entry['new_key']} | {entry['status']} | {entry['rotated_by']} |\\n\")\n    f.write('\\n')\n    \n    # Database Credentials\n    f.write('### Database Credentials\\n\\n')\n    f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\\n')\n    f.write('|---------|------------|------------|--------|------------|\\n')\n    for entry in db_entries:\n        f.write(f\"| {entry['service']} | {entry['old_key']} | {entry['new_key']} | {entry['status']} | {entry['rotated_by']} |\\n\")\n    f.write('\\n')\n    \n    # API Keys\n    f.write('### API Keys\\n\\n')\n    f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\\n')\n    f.write('|---------|------------|------------|--------|------------|\\n')\n    for entry in api_entries:\n        f.write(f\"| {entry['service']} | {entry['old_key']} | {entry['new_key']} | {entry['status']} | {entry['rotated_by']} |\\n\")\n    f.write('\\n')\n"]
[30.619506, "o", "= datetime.now().strftime('%Y-%m-%d %H:%M:%S')\r\n\r\nwith open('ROTATION_REPORT.md', 'w') as f:\r\n    f.write('# Credential Rotation Report\\n\\n')\r\n    f.write(f'**Generated:** {current_time}\\n')\r\n    f.write(f'**Total Credentials Rotated:** {total_rotations}\\n\\n')\r\n    \r\n    f.write('## Summary by Category\\n\\n')\r\n    f.write('| Category | Count | Success | Faile"]
[30.619544, "i", "    \n    # Failed Rotations\n    f.write('## Failed Rotations\\n\\n')\n    if failed_rotations:\n        f.write('> **Action Required:** The following credentials failed rotation and need manual intervention.\\n\\n')\n        for service, category in failed_rotations:\n            f.write(f'- {service} ({category}): REASON\\n')\n    else:\n        f.write('> No failed rotations. All credentials rotated successfully.\\n')\n    f.write('\\n')\n    \n    # Sign-off\n    f.write('## Sign-off\\n\\n')\n    f.write('- [ ] All successful rotations verified\\n')\n    f.write('- [ ] Failed rotations escalated\\n')\n    f.write('- [ ] Old credentials scheduled for deletion\\n')\n\nprint('Report generated successfully!')\nEOF\n"]
