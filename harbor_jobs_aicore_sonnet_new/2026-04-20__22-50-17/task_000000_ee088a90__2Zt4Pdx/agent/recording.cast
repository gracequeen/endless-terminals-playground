[30.628426, "o", "for entry in api_entries:\r\n\u001b[?2004l\r"]
[30.628457, "o", "\u001b[?2004h> "]
[30.628558, "o", "    if entry['status'] == 'FAILED':\r\n\u001b[?2004l\r"]
[30.628589, "o", "\u001b[?2004h> "]
[30.628767, "o", "        failed_rotations.append((entry['service'], 'API Keys'))\r\n\u001b[?2004l\r"]
[30.628794, "o", "\u001b[?2004h> "]
[30.628825, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[30.628906, "o", "# Generate markdown report\r\n\u001b[?2004l\r"]
[30.628936, "o", "\u001b[?2004h> "]
[30.629115, "o", "current_time = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\r\n\u001b[?2004l\r"]
[30.629152, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[30.629183, "o", "\u001b[?2004h> "]
[30.6293, "o", "with open('ROTATION_REPORT.md', 'w') as f:\r\n\u001b[?2004l\r"]
[30.629331, "o", "\u001b[?2004h> "]
[30.629468, "o", "    f.write('# Credential Rotation Report\\n\\n')\r\n\u001b[?2004l\r"]
[30.6295, "o", "\u001b[?2004h> "]
[30.629633, "o", "    f.write(f'**Generated:** {current_time}\\n')\r\n\u001b[?2004l\r"]
[30.629663, "o", "\u001b[?2004h> "]
[30.629854, "o", "    f.write(f'**Total Credentials Rotated:** {total_rotations}\\n\\n')\r\n\u001b[?2004l\r"]
[30.629885, "o", "\u001b[?2004h> "]
[30.629918, "o", "    \r\n\u001b[?2004l\r"]
[30.629948, "o", "\u001b[?2004h> "]
[30.63005, "o", "    f.write('## Summary by Category\\n\\n')\r\n\u001b[?2004l\r"]
[30.630087, "o", "\u001b[?2004h> "]
[30.630251, "o", "    f.write('| Category | Count | Success | Failed |\\n')\r\n\u001b[?2004l\r"]
[30.630285, "o", "\u001b[?2004h> "]
[30.630438, "o", "    f.write('|----------|-------|---------|--------|\\n')\r\n\u001b[?2004l\r"]
[30.630469, "o", "\u001b[?2004h> "]
[30.630693, "o", "    f.write(f'| AWS IAM | {aws_stats[0]} | {aws_stats[1]} | {aws_stats[2]} |\\n')\r\n\u001b[?2004l\r"]
[30.630724, "o", "\u001b[?2004h> "]
[30.630943, "o", "    f.write(f'| Database | {db_stats[0]} | {db_stats[1]} | {db_stats[2]} |\\n')\r\n\u001b[?2004l\r"]
[30.630975, "o", "\u001b[?2004h> "]
[30.631222, "o", "    f.write(f'| API Keys | {api_stats[0]} | {api_stats[1]} | {api_stats[2]} |\\n\\n')\r\n\u001b[?2004l\r"]
[30.631252, "o", "\u001b[?2004h> "]
[30.631282, "o", "    \r\n\u001b[?2004l\r"]
[30.63131, "o", "\u001b[?2004h> "]
[30.631427, "o", "    f.write('## Detailed Rotation Log\\n\\n')\r\n\u001b[?2004l\r"]
[30.631459, "o", "\u001b[?2004h> "]
[30.631491, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[30.631528, "o", "> "]
[30.631581, "o", "    # AWS IAM Credentials\r\n\u001b[?2004l\r"]
[30.631616, "o", "\u001b[?2004h> "]
[30.631727, "o", "    f.write('### AWS IAM Credentials\\n\\n')\r\n\u001b[?2004l\r"]
[30.631758, "o", "\u001b[?2004h> "]
[30.631968, "o", "    f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\\n')\r\n\u001b[?2004l\r"]
[30.632, "o", "\u001b[?2004h> "]
[30.632226, "o", "    f.write('|---------|------------|------------|--------|------------|\\n')\r\n\u001b[?2004l\r"]
[30.632247, "o", "\u001b[?2004h"]
[30.632268, "o", "> "]
[30.632344, "o", "    for entry in aws_entries:\r\n\u001b[?2004l\r"]
[30.632375, "o", "\u001b[?2004h> "]
[30.632729, "o", "        f.write(f\"| {entry['service']} | {entry['old_key']} | {entry['new_key']} | {entry['status']} | {entry['rotated_by']} |\\n\")\r\n\u001b[?2004l\r"]
[30.632759, "o", "\u001b[?2004h> "]
[30.632812, "o", "    f.write('\\n')\r\n\u001b[?2004l\r"]
[30.632843, "o", "\u001b[?2004h> "]
[30.632873, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[30.632901, "o", "> "]
[30.632963, "o", "    # Database Credentials\r\n\u001b[?2004l\r"]
[30.632994, "o", "\u001b[?2004h> "]
[30.633126, "o", "    f.write('### Database Credentials\\n\\n')\r\n\u001b[?2004l\r"]
[30.633158, "o", "\u001b[?2004h> "]
[30.633369, "o", "    f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\\n')\r\n\u001b[?2004l\r"]
[30.633401, "o", "\u001b[?2004h> "]
[30.633615, "o", "    f.write('|---------|------------|------------|--------|------------|\\n')\r\n\u001b[?2004l\r"]
[30.633646, "o", "\u001b[?2004h> "]
[30.633724, "o", "    for entry in db_entries:\r\n\u001b[?2004l\r"]
[30.633756, "o", "\u001b[?2004h> "]
[30.634127, "o", "        f.write(f\"| {entry['service']} | {entry['old_key']} | {entry['new_key']} | {entry['status']} | {entry['rotated_by']} |\\n\")\r\n\u001b[?2004l\r"]
[30.634161, "o", "\u001b[?2004h> "]
[30.634213, "o", "    f.write('\\n')\r\n\u001b[?2004l\r"]
[30.634244, "o", "\u001b[?2004h> "]
[30.634275, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[30.634307, "o", "> "]
[30.634333, "o", "    # API Keys\r\n\u001b[?2004l\r"]
[30.634363, "o", "\u001b[?2004h> "]
[30.634452, "o", "    f.write('### API Keys\\n\\n')\r\n\u001b[?2004l\r"]
[30.634481, "o", "\u001b[?2004h> "]
[30.634696, "o", "    f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\\n')\r\n\u001b[?2004l\r"]
[30.634727, "o", "\u001b[?2004h> "]
[30.634938, "o", "    f.write('|---------|------------|------------|--------|------------|\\n')\r\n\u001b[?2004l\r"]
[30.63497, "o", "\u001b[?2004h> "]
[30.635054, "o", "    for entry in api_entries:\r\n\u001b[?2004l\r"]
[30.635085, "o", "\u001b[?2004h> "]
[30.635461, "o", "        f.write(f\"| {entry['service']} | {entry['old_key']} | {entry['new_key']} | {entry['status']} | {entry['rotated_by']} |\\n\")\r\n\u001b[?2004l\r"]
[30.635494, "o", "\u001b[?2004h> "]
[30.635546, "o", "    f.write('\\n')\r\n\u001b[?2004l\r"]
[30.635577, "o", "\u001b[?2004h> "]
[30.635607, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[30.635638, "o", "> "]
[30.635686, "o", "    # Failed Rotations\r\n\u001b[?2004l\r"]
[30.635717, "o", "\u001b[?2004h> "]
[30.635828, "o", "    f.write('## Failed Rotations\\n\\n')\r\n\u001b[?2004l\r"]
[30.635859, "o", "\u001b[?2004h> "]
[30.63593, "o", "    if failed_rotations:\r\n\u001b[?2004l\r"]
[30.635961, "o", "\u001b[?2004h> "]
[30.636295, "o", "        f.write('> **Action Required:** The following credentials failed rotation and need manual intervention.\\n\\n')\r\n\u001b[?2004l\r"]
[30.636334, "o", "\u001b[?2004h"]
[30.636371, "o", "> "]
[30.636464, "o", "        for service, category in failed_rotations:\r\n\u001b[?2004l\r"]
[30.636495, "o", "\u001b[?2004h> "]
[30.636658, "o", "            f.write(f'- {service} ({category}): REASON\\n')\r\n\u001b[?2004l\r"]
[30.636689, "o", "\u001b[?2004h> "]
[30.63672, "o", "    else:\r\n\u001b[?2004l\r"]
[30.636749, "o", "\u001b[?2004h> "]
[30.636977, "o", "        f.write('> No failed rotations. All credentials rotated successfully.\\n')\r\n\u001b[?2004l\r"]
[30.637012, "o", "\u001b[?2004h> "]
[30.637062, "o", "    f.write('\\n')\r\n\u001b[?2004l\r"]
[30.637105, "o", "\u001b[?2004h> "]
[30.637135, "o", "    \r\n\u001b[?2004l\r"]
[30.637166, "o", "\u001b[?2004h> "]
