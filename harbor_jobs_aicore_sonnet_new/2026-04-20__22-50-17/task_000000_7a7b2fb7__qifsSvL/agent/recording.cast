[51.386353, "i", "es\n    print(\"\\nAnalyzing dependencies...\", flush=True)\n    all_dependencies = set()\n    dependency_map = defaultdict(list)  # Maps dependency to packages that need it\n    \n    for pkg in sorted(required):\n        print(f\"  Checking dependencies for {pkg}...\", flush=True)\n        deps = get_dependencies(pkg, max_depth=3)\n        for dep in deps:\n            all_dependencies.add(dep)\n            dependency_map[dep].append(pkg)\n    \n    print(f\"\\nFound {len(all_dependencies)} total dependencies\", flush=True)\n    \n    # Identify extra packages\n    extra_packages = installed - required\n    print(f\"Extra packages (not in required): {len(extra_packages)}\", flush=True)\n    \n    # Separate removable from dependency-protected\n    removable = []\n    dependency_protected = []\n    \n    for pkg in sorted(extra_packages):\n        if pkg in all_dependencies:\n            dependency_protected.append({\n                'name': pkg,\n                'required_by': sorted(dependency_map[pkg])\n            })\n        else:\n         "]
