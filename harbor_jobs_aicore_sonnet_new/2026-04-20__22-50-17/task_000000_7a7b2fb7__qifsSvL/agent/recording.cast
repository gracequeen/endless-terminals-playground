[51.38602, "i", "cat > analyze_packages.py << 'SCRIPT_EOF'\n#!/usr/bin/env python3\nimport subprocess\nimport json\nimport re\nfrom collections import defaultdict, deque\n\ndef get_dependencies(package, max_depth=3):\n    \"\"\"Get all dependencies up to max_depth levels deep.\"\"\"\n    all_deps = set()\n    visited = set()\n    queue = deque([(package, 0)])\n    \n    while queue:\n        pkg, depth = queue.popleft()\n        if pkg in visited or depth > max_depth:\n            continue\n        visited.add(pkg)\n        \n        try:\n            result = subprocess.run(\n                ['apt-cache', 'depends', pkg],\n                capture_output=True, text=True, timeout=5\n            )\n            \n            for line in result.stdout.split('\\n'):\n                line = line.strip()\n                if line.startswith('Depends:') or line.startswith('PreDepends:'):\n                    dep = line.split(':', 1)[1].strip()\n                    # Remove version constraints and alternatives\n                    dep = re.sub(r'[(<>].*', '', dep).strip()"]
[51.386147, "i", "\n                    if '|' in dep:\n                        dep = dep.split('|')[0].strip()\n                    if dep and depth < max_depth:\n                        all_deps.add(dep)\n                        queue.append((dep, depth + 1))\n        except Exception as e:\n            print(f\"Warning: Could not get dependencies for {pkg}: {e}\", flush=True)\n    \n    return all_deps\n\ndef get_package_info(package):\n    \"\"\"Get version and size info for a package.\"\"\"\n    info = {'version': 'unknown', 'size_kb': 0}\n    \n    # Try dpkg-query first for installed packages\n    try:\n        result = subprocess.run(\n            ['dpkg-query', '-W', '-f=${Version}\\\\t${Installed-Size}\\\\n', package],\n            capture_output=True, text=True, timeout=5\n        )\n        if result.returncode == 0 and result.stdout.strip():\n            parts = result.stdout.strip().split('\\t')\n            if len(parts) == 2:\n                info['version'] = parts[0]\n                info['size_kb'] = int(parts[1])\n                return info\n   "]
[51.386198, "i", " except Exception:\n        pass\n    \n    # Fallback to apt-cache show\n    try:\n        result = subprocess.run(\n            ['apt-cache', 'show', package],\n            capture_output=True, text=True, timeout=5\n        )\n        for line in result.stdout.split('\\n'):\n            if line.startswith('Version:'):\n                info['version'] = line.split(':', 1)[1].strip()\n            elif line.startswith('Installed-Size:'):\n                info['size_kb'] = int(line.split(':', 1)[1].strip())\n    except Exception:\n        pass\n    \n    return info\n\ndef has_security_update(package):\n    \"\"\"Check if a package has a security update available.\"\"\"\n    try:\n        result = subprocess.run(\n            ['apt-cache', 'policy', package],\n            capture_output=True, text=True, timeout=5\n        )\n        output = result.stdout\n        \n        # Look for security in the output\n        if '-security' in output.lower() or 'security.ubuntu.com' in output.lower():\n            # Check if there's a candidate version diff"]
