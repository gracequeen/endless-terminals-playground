[51.396558, "o", "                info['version'] = parts[0]\r\n\u001b[?2004l\r"]
[51.396591, "o", "\u001b[?2004h> "]
[51.396793, "o", "                info['size_kb'] = int(parts[1])\r\n\u001b[?2004l\r"]
[51.396827, "o", "\u001b[?2004h> "]
[51.396939, "o", "                return info\r\n\u001b[?2004l\r"]
[51.396971, "o", "\u001b[?2004h> "]
[51.397059, "o", "    except Exception:\r\n\u001b[?2004l\r"]
[51.397092, "o", "\u001b[?2004h> "]
[51.397151, "o", "        pass\r\n\u001b[?2004l\r"]
[51.397183, "o", "\u001b[?2004h> "]
[51.39721, "o", "    \r\n\u001b[?2004l\r"]
[51.39724, "o", "\u001b[?2004h> "]
[51.397373, "o", "    # Fallback to apt-cache show\r\n\u001b[?2004l\r"]
[51.397404, "o", "\u001b[?2004h> "]
[51.397448, "o", "    try:\r\n\u001b[?2004l\r"]
[51.397479, "o", "\u001b[?2004h> "]
[51.397608, "o", "        result = subprocess.run(\r\n\u001b[?2004l\r"]
[51.397639, "o", "\u001b[?2004h> "]
[51.397822, "o", "            ['apt-cache', 'show', package],\r\n\u001b[?2004l\r"]
[51.397856, "o", "\u001b[?2004h> "]
[51.398074, "o", "            capture_output=True, text=True, timeout=5\r\n\u001b[?2004l\r"]
[51.398106, "o", "\u001b[?2004h> "]
[51.398153, "o", "        )\r\n\u001b[?2004l\r"]
[51.398186, "o", "\u001b[?2004h> "]
[51.398375, "o", "        for line in result.stdout.split('\\n'):\r\n\u001b[?2004l\r"]
[51.398406, "o", "\u001b[?2004h> "]
[51.398585, "o", "            if line.startswith('Version:'):\r\n\u001b[?2004l\r"]
[51.398619, "o", "\u001b[?2004h> "]
[51.398885, "o", "                info['version'] = line.split(':', 1)[1].strip()\r\n\u001b[?2004l\r"]
[51.398919, "o", "\u001b[?2004h> "]
[51.399139, "o", "            elif line.startswith('Installed-Size:'):\r\n\u001b[?2004l\r"]
[51.399173, "o", "\u001b[?2004h> "]
[51.399448, "o", "                info['size_kb'] = int(line.split(':', 1)[1].strip())\r\n\u001b[?2004l\r"]
[51.399477, "o", "\u001b[?2004h> "]
[51.399574, "o", "    except Exception:\r\n\u001b[?2004l\r"]
[51.399606, "o", "\u001b[?2004h> "]
[51.39966, "o", "        pass\r\n\u001b[?2004l\r"]
[51.399693, "o", "\u001b[?2004h> "]
[51.399725, "o", "    \r\n\u001b[?2004l\r"]
[51.399752, "o", "\u001b[?2004h> "]
[51.399827, "o", "    return info\r\n\u001b[?2004l\r"]
[51.399859, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[51.399891, "o", "\u001b[?2004h> "]
[51.400032, "o", "def has_security_update(package):\r\n\u001b[?2004l\r"]
[51.400063, "o", "\u001b[?2004h> "]
[51.400313, "o", "    \"\"\"Check if a package has a security update available.\"\"\"\r\n\u001b[?2004l\r"]
[51.400342, "o", "\u001b[?2004h> "]
[51.400384, "o", "    try:\r\n\u001b[?2004l\r"]
[51.400416, "o", "\u001b[?2004h> "]
[51.400544, "o", "        result = subprocess.run(\r\n\u001b[?2004l\r"]
[51.400574, "o", "\u001b[?2004h> "]
[51.400777, "o", "            ['apt-cache', 'policy', package],\r\n\u001b[?2004l\r"]
[51.400811, "o", "\u001b[?2004h> "]
[51.401022, "o", "            capture_output=True, text=True, timeout=5\r\n\u001b[?2004l\r"]
[51.401055, "o", "\u001b[?2004h> "]
[51.4011, "o", "        )\r\n\u001b[?2004l\r"]
[51.401132, "o", "\u001b[?2004h> "]
[51.401263, "o", "        output = result.stdout\r\n\u001b[?2004l\r"]
[51.401294, "o", "\u001b[?2004h> "]
[51.401336, "o", "        \r\n\u001b[?2004l\r"]
[51.401368, "o", "\u001b[?2004h> "]
[51.401545, "o", "        # Look for security in the output\r\n\u001b[?2004l\r"]
[51.401578, "o", "\u001b[?2004h> "]
[51.401929, "o", "        if '-security' in output.lower() or 'security.ubuntu.com' in output.lower():\r\n\u001b[?2004l\r"]
[51.401966, "o", "\u001b[?2004h> "]
[51.402271, "o", "            # Check if there's a candidate version different from installed\r\n\u001b[?2004l\r"]
[51.4023, "o", "\u001b[?2004h> "]
[51.40244, "o", "            installed_ver = None\r\n\u001b[?2004l\r"]
[51.402473, "o", "\u001b[?2004h> "]
[51.402605, "o", "            candidate_ver = None\r\n\u001b[?2004l\r"]
[51.402636, "o", "\u001b[?2004h> "]
[51.402829, "o", "            for line in output.split('\\n'):\r\n\u001b[?2004l\r"]
[51.402864, "o", "\u001b[?2004h> "]
[51.403031, "o", "                if 'Installed:' in line:\r\n\u001b[?2004l\r"]
[51.403061, "o", "\u001b[?2004h> "]
[51.40333, "o", "                    installed_ver = line.split(':', 1)[1].strip()\r\n\u001b[?2004l\r"]
[51.403362, "o", "\u001b[?2004h> "]
[51.403534, "o", "                elif 'Candidate:' in line:\r\n\u001b[?2004l\r"]
[51.403567, "o", "\u001b[?2004h> "]
[51.40382, "o", "                    candidate_ver = line.split(':', 1)[1].strip()\r\n\u001b[?2004l\r"]
[51.403855, "o", "\u001b[?2004h> "]
[51.403891, "o", "            \r\n\u001b[?2004l\r"]
[51.403923, "o", "\u001b[?2004h> "]
[51.404233, "o", "            if installed_ver and candidate_ver and installed_ver != candidate_ver and installed_ver != '(none)':\r\n\u001b[?2004l\r"]
[51.404264, "o", "\u001b[?2004h> "]
[51.404347, "o", "                return True\r\n\u001b[?2004l\r"]
[51.404379, "o", "\u001b[?2004h> "]
[51.404435, "o", "        return False\r\n\u001b[?2004l\r"]
[51.404468, "o", "\u001b[?2004h> "]
[51.404528, "o", "    except Exception:\r\n\u001b[?2004l\r"]
[51.404561, "o", "\u001b[?2004h> "]
[51.404618, "o", "        return False\r\n\u001b[?2004l\r"]
[51.40465, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[51.404684, "o", "\u001b[?2004h> "]
[51.404721, "o", "def main():\r\n\u001b[?2004l\r"]
[51.404751, "o", "\u001b[?2004h> "]
[51.404831, "o", "    # Read package lists\r\n\u001b[?2004l\r"]
[51.404864, "o", "\u001b[?2004h> "]
[51.405005, "o", "    with open('installed_packages.txt', 'r') as f:\r\n\u001b[?2004l\r"]
[51.405036, "o", "\u001b[?2004h> "]
[51.405224, "o", "        installed = set(line.strip() for line in f if line.strip())\r\n\u001b[?2004l\r"]
[51.405252, "o", "\u001b[?2004h> "]
[51.405284, "o", "    \r\n\u001b[?2004l\r"]
[51.405313, "o", "\u001b[?2004h> "]
[51.405447, "o", "    with open('required_packages.txt', 'r') as f:\r\n\u001b[?2004l\r"]
[51.405478, "o", "\u001b[?2004h> "]
[51.405663, "o", "        required = set(line.strip() for line in f if line.strip())\r\n\u001b[?2004l\r"]
[51.405693, "o", "\u001b[?2004h> "]
[51.40572, "o", "    \r\n\u001b[?2004l\r"]
[51.405751, "o", "\u001b[?2004h> "]
[51.405929, "o", "    print(f\"Installed packages: {len(installed)}\", flush=True)\r\n\u001b[?2004l\r"]
[51.405957, "o", "\u001b[?2004h> "]
[51.406129, "o", "    print(f\"Required packages: {len(required)}\", flush=True)\r\n\u001b[?2004l\r"]
[51.406161, "o", "\u001b[?2004h> "]
[51.40619, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[51.40622, "o", "> "]
[51.406342, "o", "    # Get all dependencies for required packages\r\n\u001b[?2004l\r"]
[51.406373, "o", "\u001b[?2004h> "]
[51.406521, "o", "    print(\"\\nAnalyzing dependencies...\", flush=True)\r\n\u001b[?2004l\r"]
[51.406552, "o", "\u001b[?2004h> "]
[51.406635, "o", "    all_dependencies = set()\r\n\u001b[?2004l\r"]
[51.406671, "o", "\u001b[?2004h> "]
[51.40691, "o", "    dependency_map = defaultdict(list)  # Maps dependency to packages that need it\r\n\u001b[?2004l\r"]
[51.406943, "o", "\u001b[?2004h> "]
[51.406971, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[51.407002, "o", "> "]
[51.407087, "o", "    for pkg in sorted(required):\r\n\u001b[?2004l\r"]
[51.407119, "o", "\u001b[?2004h> "]
[51.407311, "o", "        print(f\"  Checking dependencies for {pkg}...\", flush=True)\r\n\u001b[?2004l\r"]
[51.407347, "o", "\u001b[?2004h> "]
[51.407477, "o", "        deps = get_dependencies(pkg, max_depth=3)\r\n\u001b[?2004l\r"]
[51.407509, "o", "\u001b[?2004h> "]
[51.407581, "o", "        for dep in deps:\r\n\u001b[?2004l\r"]
[51.407613, "o", "\u001b[?2004h> "]
[51.407719, "o", "            all_dependencies.add(dep)\r\n\u001b[?2004l\r"]
[51.407752, "o", "\u001b[?2004h> "]
[51.407885, "o", "            dependency_map[dep].append(pkg)\r\n\u001b[?2004l\r"]
[51.407917, "o", "\u001b[?2004h> "]
[51.407945, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[51.407974, "o", "> "]
[51.408173, "o", "    print(f\"\\nFound {len(all_dependencies)} total dependencies\", flush=True)\r\n\u001b[?2004l\r"]
[51.408205, "o", "\u001b[?2004h> "]
[51.408231, "o", "    \r\n\u001b[?2004l\r"]
[51.408262, "o", "\u001b[?2004h> "]
[51.40834, "o", "    # Identify extra packages\r\n\u001b[?2004l\r"]
[51.408372, "o", "\u001b[?2004h> "]
[51.40849, "o", "    extra_packages = installed - required\r\n\u001b[?2004l\r"]
[51.408521, "o", "\u001b[?2004h> "]
[51.408748, "o", "    print(f\"Extra packages (not in required): {len(extra_packages)}\", flush=True)\r\n\u001b[?2004l\r"]
[51.408792, "o", "\u001b[?2004h> "]
[51.408822, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[51.408851, "o", "> "]
[51.408979, "o", "    # Separate removable from dependency-protected\r\n\u001b[?2004l\r"]
[51.409011, "o", "\u001b[?2004h> "]
[51.409067, "o", "    removable = []\r\n\u001b[?2004l\r"]
[51.409098, "o", "\u001b[?2004h> "]
[51.409184, "o", "    dependency_protected = []\r\n\u001b[?2004l\r"]
[51.409216, "o", "\u001b[?2004h> "]
[51.40925, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[51.409282, "o", "> "]
[51.40937, "o", "    for pkg in sorted(extra_packages):\r\n\u001b[?2004l\r"]
[51.4094, "o", "\u001b[?2004h> "]
[51.409502, "o", "        if pkg in all_dependencies:\r\n\u001b[?2004l\r"]
[51.409533, "o", "\u001b[?2004h> "]
[51.409649, "o", "            dependency_protected.append({\r\n\u001b[?2004l\r"]
[51.409679, "o", "\u001b[?2004h> "]
[51.409775, "o", "                'name': pkg,\r\n\u001b[?2004l\r"]
[51.409802, "o", "\u001b[?2004h> "]
[51.409965, "o", "                'required_by': sorted(dependency_map[pkg])\r\n\u001b[?2004l\r"]
[51.409997, "o", "\u001b[?2004h> "]
[51.41004, "o", "            })\r\n\u001b[?2004l\r"]
[51.410073, "o", "\u001b[?2004h> "]
[51.410113, "o", "        else:\r\n\u001b[?2004l\r"]
[51.410146, "o", "\u001b[?2004h> "]
[51.41034, "o", "            print(f\"  Analyzing removable package: {pkg}\", flush=True)\r\n\u001b[?2004l\r"]
[51.410372, "o", "\u001b[?2004h> "]
[51.41049, "o", "            info = get_package_info(pkg)\r\n\u001b[?2004l\r"]
[51.410522, "o", "\u001b[?2004h> "]
[51.410662, "o", "            has_update = has_security_update(pkg)\r\n\u001b[?2004l\r"]
[51.410693, "o", "\u001b[?2004h> "]
[51.410797, "o", "            removable.append({\r\n\u001b[?2004l\r"]
[51.410831, "o", "\u001b[?2004h> "]
[51.410906, "o", "                'name': pkg,\r\n\u001b[?2004l\r"]
[51.410938, "o", "\u001b[?2004h> "]
[51.411098, "o", "                'installed_version': info['version'],\r\n\u001b[?2004l\r"]
[51.411123, "o", "\u001b[?2004h"]
[51.411154, "o", "> "]
[51.411254, "o", "                'size_kb': info['size_kb'],\r\n\u001b[?2004l\r"]
[51.411287, "o", "\u001b[?2004h> "]
[51.411422, "o", "                'has_security_update': has_update\r\n\u001b[?2004l\r"]
[51.411453, "o", "\u001b[?2004h> "]
[51.411496, "o", "            })\r\n\u001b[?2004l\r"]
[51.411527, "o", "\u001b[?2004h> "]
[51.411558, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[51.41159, "o", "> "]
[51.411673, "o", "    # Calculate total space savings\r\n\u001b[?2004l\r"]
[51.411705, "o", "\u001b[?2004h> "]
[51.411868, "o", "    total_space = sum(p['size_kb'] for p in removable)\r\n\u001b[?2004l\r"]
[51.411896, "o", "\u001b[?2004h> "]
[51.411928, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[51.411961, "o", "> "]
[51.412004, "o", "    # Generate report\r\n\u001b[?2004l\r"]
[51.412036, "o", "\u001b[?2004h> "]
[51.412082, "o", "    report = {\r\n\u001b[?2004l\r"]
[51.41211, "o", "\u001b[?2004h"]
[51.412137, "o", "> "]
[51.412178, "o", "        'summary': {\r\n\u001b[?2004l\r"]
[51.412207, "o", "\u001b[?2004h> "]
[51.412341, "o", "            'total_installed': len(installed),\r\n\u001b[?2004l\r"]
[51.412372, "o", "\u001b[?2004h> "]
[51.412497, "o", "            'total_required': len(required),\r\n\u001b[?2004l\r"]
[51.41253, "o", "\u001b[?2004h> "]
[51.41266, "o", "            'removable_count': len(removable),\r\n\u001b[?2004l\r"]
[51.412688, "o", "\u001b[?2004h> "]
[51.412876, "o", "            'kept_as_dependencies': len(dependency_protected),\r\n\u001b[?2004l\r"]
[51.412906, "o", "\u001b[?2004h> "]
[51.413049, "o", "            'total_space_savings_kb': total_space\r\n\u001b[?2004l\r"]
[51.413082, "o", "\u001b[?2004h> "]
[51.413114, "o", "        },\r\n\u001b[?2004l\r"]
[51.413147, "o", "\u001b[?2004h> "]
[51.413354, "o", "        'removable_packages': sorted(removable, key=lambda x: x['name']),\r\n\u001b[?2004l\r"]
[51.413386, "o", "\u001b[?2004h> "]
[51.413619, "o", "        'dependency_protected': sorted(dependency_protected, key=lambda x: x['name'])\r\n\u001b[?2004l\r"]
[51.413651, "o", "\u001b[?2004h> "]
[51.413679, "o", "    }\r\n\u001b[?2004l\r"]
[51.413711, "o", "\u001b[?2004h> "]
[51.413742, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[51.413769, "o", "> "]
[51.413872, "o", "    # Write JSON report\r\n\u001b[?2004l\r"]
[51.413885, "o", "\u001b[?2004h> "]
[51.413994, "o", "    with open('removal_report.json', 'w') as f:\r\n\u001b[?2004l\r"]
[51.414037, "o", "\u001b[?2004h> "]
[51.414135, "o", "        json.dump(report, f, indent=2)\r\n\u001b[?2004l\r"]
[51.414176, "o", "\u001b[?2004h> "]
[51.414216, "o", "    \r\n\u001b[?2004l\r"]
[51.414232, "o", "\u001b[?2004h> "]
[51.414337, "o", "    print(f\"\\n=== Summary ===\", flush=True)\r\n\u001b[?2004l\r"]
[51.414373, "o", "\u001b[?2004h> "]
[51.414545, "o", "    print(f\"Removable packages: {len(removable)}\", flush=True)\r\n\u001b[?2004l\r"]
[51.414585, "o", "\u001b[?2004h> "]
[51.414822, "o", "    print(f\"Dependency-protected packages: {len(dependency_protected)}\", flush=True)\r\n\u001b[?2004l\r"]
[51.414866, "o", "\u001b[?2004h> "]
[51.41512, "o", "    print(f\"Total space savings: {total_space} KB ({total_space/1024:.2f} MB)\", flush=True)\r\n\u001b[?2004l\r"]
[51.415172, "o", "\u001b[?2004h> "]
[51.41521, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[51.415248, "o", "> "]
[51.415287, "o", "    # Generate removal script\r\n\u001b[?2004l\r"]
[51.415325, "o", "\u001b[?2004h> "]
[51.415451, "o", "    with open('remove_packages.sh', 'w') as f:\r\n\u001b[?2004l\r"]
[51.41549, "o", "\u001b[?2004h> "]
[51.415574, "o", "        f.write('#!/bin/bash\\n')\r\n\u001b[?2004l\r"]
[51.415617, "o", "\u001b[?2004h> "]
[51.415783, "o", "        f.write('# Auto-generated package removal script\\n')\r\n\u001b[?2004l\r"]
[51.415819, "o", "\u001b[?2004h> "]
[51.416072, "o", "        f.write('# This will remove packages that are not required and not dependencies\\n\\n')\r\n\u001b[?2004l\r"]
[51.41612, "o", "\u001b[?2004h> "]
[51.416155, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[51.416192, "o", "> "]
[51.416225, "o", "        if removable:\r\n\u001b[?2004l\r"]
[51.416264, "o", "\u001b[?2004h> "]
[51.416517, "o", "            pkg_list = ' '.join(p['name'] for p in sorted(removable, key=lambda x: x['name']))\r\n\u001b[?2004l\r"]
[51.416563, "o", "\u001b[?2004h> "]
[51.416794, "o", "            f.write(f'echo \"DRY RUN: Would remove the following packages:\"\\n')\r\n\u001b[?2004l\r"]
[51.416847, "o", "\u001b[?2004h> "]
[51.416932, "o", "            f.write(f'echo \"{pkg_list}\"\\n')\r\n\u001b[?2004l\r"]
[51.416965, "o", "\u001b[?2004h> "]
[51.417058, "o", "            f.write(f'echo \"\"\\n')\r\n\u001b[?2004l\r"]
[51.417089, "o", "\u001b[?2004h> "]
[51.417306, "o", "            f.write(f'echo \"To actually remove, uncomment the line below:\"\\n')\r\n\u001b[?2004l\r"]
[51.417338, "o", "\u001b[?2004h> "]
[51.417494, "o", "            f.write(f'# apt-get remove -y {pkg_list}\\n')\r\n\u001b[?2004l\r"]
[51.417524, "o", "\u001b[?2004h> "]
