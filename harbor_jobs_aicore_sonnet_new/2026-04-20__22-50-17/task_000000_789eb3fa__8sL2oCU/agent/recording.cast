[22.591511, "i", "cat > /home/user/docs_workspace/verify_permissions.sh << 'EOF'\n#!/bin/bash\n\n# Read manifest and verify permissions\nmanifest=\"/home/user/docs_workspace/permissions_manifest.txt\"\n\n# Parse and check directory permissions\nwhile IFS=: read -r path perm; do\n  if [ -z \"$path\" ] || [ \"$path\" = \"DIRECTORY_PERMISSIONS\" ] || [ \"$path\" = \"FILE_PERMISSIONS\" ]; then\n    continue\n  fi\n  \n  # Get actual permissions in octal format\n  actual=$(stat -c '%a' \"$path\" 2>/dev/null)\n  \n  if [ \"$actual\" != \"$perm\" ]; then\n    echo \"FAIL: $path\"\n    exit 1\n  fi\ndone < \"$manifest\"\n\necho \"PASS\"\nEOF\n"]
