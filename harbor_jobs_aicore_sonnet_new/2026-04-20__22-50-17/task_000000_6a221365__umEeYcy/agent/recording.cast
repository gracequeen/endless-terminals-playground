[29.334007, "o", "    total_lines = len(lines)\r\n\u001b[?2004l\r"]
[29.334036, "o", "\u001b[?2004h> "]
[29.334072, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[29.334107, "o", "> "]
[29.334218, "o", "    for line_num, line in enumerate(lines, 1):\r\n\u001b[?2004l\r"]
[29.334247, "o", "\u001b[?2004h> "]
[29.334347, "o", "        raw_content = line.strip()\r\n\u001b[?2004l\r"]
[29.33438, "o", "\u001b[?2004h> "]
[29.334419, "o", "        \r\n\u001b[?2004l\r"]
[29.33445, "o", "\u001b[?2004h> "]
[29.334513, "o", "        # Try to parse JSON\r\n\u001b[?2004l\r"]
[29.334544, "o", "\u001b[?2004h> "]
[29.334597, "o", "        try:\r\n\u001b[?2004l\r"]
[29.334629, "o", "\u001b[?2004h> "]
[29.334754, "o", "            record = json.loads(raw_content)\r\n\u001b[?2004l\r"]
[29.334785, "o", "\u001b[?2004h> "]
[29.334905, "o", "        except json.JSONDecodeError as e:\r\n\u001b[?2004l\r"]
[29.334941, "o", "\u001b[?2004h> "]
[29.335021, "o", "            error_entry = {\r\n\u001b[?2004l\r"]
[29.335055, "o", "\u001b[?2004h> "]
[29.335164, "o", "                'line_number': line_num,\r\n\u001b[?2004l\r"]
[29.335197, "o", "\u001b[?2004h> "]
[29.335326, "o", "                'error_type': 'malformed_json',\r\n\u001b[?2004l\r"]
[29.335361, "o", "\u001b[?2004h> "]
[29.335537, "o", "                'error_detail': f'JSON decode error: {str(e)}',\r\n\u001b[?2004l\r"]
[29.335598, "o", "\u001b[?2004h> "]
[29.335716, "o", "                'raw_content': raw_content[:200]\r\n\u001b[?2004l\r"]
[29.335746, "o", "\u001b[?2004h"]
[29.335778, "o", "> "]
[29.335806, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h"]
[29.335839, "o", "> "]
[29.335926, "o", "            errors.append(error_entry)\r\n\u001b[?2004l\r"]
[29.335961, "o", "\u001b[?2004h> "]
[29.336089, "o", "            error_counts['malformed_json'] += 1\r\n\u001b[?2004l\r"]
[29.336126, "o", "\u001b[?2004h> "]
[29.336178, "o", "            continue\r\n\u001b[?2004l\r"]
[29.336211, "o", "\u001b[?2004h> "]
[29.336245, "o", "        \r\n\u001b[?2004l\r"]
[29.336278, "o", "\u001b[?2004h> "]
[29.336348, "o", "        # Validate the record\r\n\u001b[?2004l\r"]
[29.336379, "o", "\u001b[?2004h> "]
[29.336586, "o", "        is_valid, error_info = validate_transaction(record, line_num)\r\n\u001b[?2004l\r"]
[29.33663, "o", "\u001b[?2004h> "]
[29.336665, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[29.336699, "o", "> "]
[29.336742, "o", "        if not is_valid:\r\n\u001b[?2004l\r"]
[29.336774, "o", "\u001b[?2004h> "]
[29.33692, "o", "            error_type, error_detail = error_info\r\n\u001b[?2004l\r"]
[29.336952, "o", "\u001b[?2004h> "]
[29.337031, "o", "            error_entry = {\r\n\u001b[?2004l\r"]
[29.337064, "o", "\u001b[?2004h> "]
[29.337175, "o", "                'line_number': line_num,\r\n\u001b[?2004l\r"]
[29.337212, "o", "\u001b[?2004h> "]
[29.337322, "o", "                'error_type': error_type,\r\n\u001b[?2004l\r"]
[29.337355, "o", "\u001b[?2004h> "]
[29.337479, "o", "                'error_detail': error_detail,\r\n\u001b[?2004l\r"]
[29.337512, "o", "\u001b[?2004h> "]
[29.337659, "o", "                'raw_content': raw_content[:200]\r\n\u001b[?2004l\r"]
[29.337696, "o", "\u001b[?2004h> "]
[29.337731, "o", "            }\r\n\u001b[?2004l\r"]
[29.337765, "o", "\u001b[?2004h> "]
[29.337868, "o", "            errors.append(error_entry)\r\n\u001b[?2004l\r"]
[29.337903, "o", "\u001b[?2004h> "]
[29.338012, "o", "            error_counts[error_type] += 1\r\n\u001b[?2004l\r"]
[29.338046, "o", "\u001b[?2004h> "]
[29.338082, "o", "        else:\r\n\u001b[?2004l\r"]
[29.338114, "o", "\u001b[?2004h> "]
[29.338214, "o", "            # Compute integrity hash\r\n\u001b[?2004l\r"]
[29.338246, "o", "\u001b[?2004h> "]
[29.338409, "o", "            integrity_hash = compute_integrity_hash(record)\r\n\u001b[?2004l\r"]
[29.338442, "o", "\u001b[?2004h> "]
[29.338478, "o", "            \r\n\u001b[?2004l\r"]
[29.338508, "o", "\u001b[?2004h> "]
[29.338622, "o", "            # Create output record\r\n\u001b[?2004l\r"]
[29.338659, "o", "\u001b[?2004h> "]
[29.338736, "o", "            output_record = {\r\n\u001b[?2004l\r"]
[29.338769, "o", "\u001b[?2004h> "]
[29.338933, "o", "                'transaction_id': record['transaction_id'],\r\n\u001b[?2004l\r"]
[29.338962, "o", "\u001b[?2004h> "]
[29.339103, "o", "                'timestamp': record['timestamp'],\r\n\u001b[?2004l\r"]
[29.339137, "o", "\u001b[?2004h> "]
[29.33928, "o", "                'account_id': record['account_id'],\r\n\u001b[?2004l\r"]
[29.339312, "o", "\u001b[?2004h> "]
[29.339433, "o", "                'amount': record['amount'],\r\n\u001b[?2004l\r"]
[29.339463, "o", "\u001b[?2004h> "]
[29.339614, "o", "                'currency': record['currency'],\r\n\u001b[?2004l\r"]
[29.339649, "o", "\u001b[?2004h> "]
[29.339766, "o", "                'status': record['status'],\r\n\u001b[?2004l\r"]
[29.339803, "o", "\u001b[?2004h> "]
[29.339935, "o", "                'integrity_hash': integrity_hash,\r\n\u001b[?2004l\r"]
[29.339974, "o", "\u001b[?2004h> "]
[29.340097, "o", "                'processed_at': processing_time\r\n\u001b[?2004l\r"]
[29.34013, "o", "\u001b[?2004h> "]
[29.340165, "o", "            }\r\n\u001b[?2004l\r"]
[29.340201, "o", "\u001b[?2004h> "]
[29.340344, "o", "            valid_transactions.append(output_record)\r\n\u001b[?2004l\r"]
[29.340374, "o", "\u001b[?2004h> "]
[29.340408, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[29.34044, "o", "> "]
[29.340539, "o", "    # Sort valid transactions by timestamp\r\n\u001b[?2004l\r"]
[29.340588, "o", "\u001b[?2004h> "]
[29.340744, "o", "    valid_transactions.sort(key=lambda x: x['timestamp'])\r\n\u001b[?2004l\r"]
[29.340775, "o", "\u001b[?2004h> "]
[29.340809, "o", "    \r\n\u001b[?2004l\r"]
[29.340846, "o", "\u001b[?2004h> "]
[29.340915, "o", "    # Write clean audit file\r\n\u001b[?2004l\r"]
[29.340953, "o", "\u001b[?2004h> "]
[29.341048, "o", "    with open(output_file, 'w') as f:\r\n\u001b[?2004l\r"]
[29.341081, "o", "\u001b[?2004h> "]
[29.341197, "o", "        for record in valid_transactions:\r\n\u001b[?2004l\r"]
[29.341229, "o", "\u001b[?2004h> "]
[29.341359, "o", "            f.write(json.dumps(record) + '\\n')\r\n\u001b[?2004l\r"]
[29.341389, "o", "\u001b[?2004h"]
[29.341416, "o", ">     \r\n\u001b[?2004l\r"]
[29.34145, "o", "\u001b[?2004h> "]
[29.341507, "o", "    # Write error log\r\n\u001b[?2004l\r"]
[29.341545, "o", "\u001b[?2004h> "]
[29.341655, "o", "    with open(error_file, 'w') as f:\r\n\u001b[?2004l\r"]
[29.341689, "o", "\u001b[?2004h> "]
[29.341761, "o", "        for error in errors:\r\n\u001b[?2004l\r"]
[29.341797, "o", "\u001b[?2004h> "]
[29.34192, "o", "            f.write(json.dumps(error) + '\\n')\r\n\u001b[?2004l\r"]
[29.341956, "o", "\u001b[?2004h> "]
[29.341986, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[29.342018, "o", "> "]
[29.34208, "o", "    # Generate summary report\r\n\u001b[?2004l\r"]
[29.342113, "o", "\u001b[?2004h> "]
[29.34223, "o", "    valid_count = len(valid_transactions)\r\n\u001b[?2004l\r"]
[29.342263, "o", "\u001b[?2004h> "]
[29.342347, "o", "    failed_count = len(errors)\r\n\u001b[?2004l\r"]
[29.342379, "o", "\u001b[?2004h> "]
[29.34261, "o", "    success_rate = (valid_count / total_lines * 100) if total_lines > 0 else 0\r\n\u001b[?2004l\r"]
[29.342643, "o", "\u001b[?2004h> "]
[29.342676, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[29.342705, "o", "> "]
[29.342808, "o", "    summary = f\"\"\"AUDIT PROCESSING SUMMARY\r\n\u001b[?2004l\r"]
[29.34284, "o", "\u001b[?2004h> "]
[29.342909, "o", "========================\r\n\u001b[?2004l\r"]
[29.342943, "o", "\u001b[?2004h> "]
[29.343085, "o", "Input file: /home/user/audit/raw_transactions.jsonl\r\n\u001b[?2004l\r"]
[29.34312, "o", "\u001b[?2004h> "]
[29.343217, "o", "Total lines processed: {total_lines}\r\n\u001b[?2004l\r"]
[29.34325, "o", "\u001b[?2004h> "]
[29.343344, "o", "Valid transactions: {valid_count}\r\n\u001b[?2004l\r"]
[29.343376, "o", "\u001b[?2004h> "]
[29.343462, "o", "Failed records: {failed_count}\r\n\u001b[?2004l\r"]
[29.343498, "o", "\u001b[?2004h> "]
[29.343609, "o", "Success rate: {success_rate:.2f}%\r\n\u001b[?2004l\r"]
[29.343644, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[29.343675, "o", "\u001b[?2004h> "]
[29.343714, "o", "Errors by type:\r\n\u001b[?2004l\r"]
[29.343748, "o", "\u001b[?2004h> "]
[29.343885, "o", "  malformed_json: {error_counts['malformed_json']}\r\n\u001b[?2004l\r"]
[29.343922, "o", "\u001b[?2004h> "]
[29.344048, "o", "  missing_field: {error_counts['missing_field']}\r\n\u001b[?2004l\r"]
[29.344085, "o", "\u001b[?2004h> "]
[29.344218, "o", "  invalid_format: {error_counts['invalid_format']}\r\n\u001b[?2004l\r"]
[29.344255, "o", "\u001b[?2004h> "]
[29.344383, "o", "  invalid_value: {error_counts['invalid_value']}\r\n\u001b[?2004l\r"]
[29.344419, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[29.344434, "o", "\u001b[?2004h"]
[29.344479, "o", "> "]
[29.34458, "o", "Processing completed at: {processing_time}\r\n\u001b[?2004l\r"]
[29.344615, "o", "\u001b[?2004h> "]
[29.344649, "o", "\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[29.344682, "o", "    \r\n\u001b[?2004l\r"]
[29.344717, "o", "\u001b[?2004h> "]
[29.34481, "o", "    with open(summary_file, 'w') as f:\r\n\u001b[?2004l\r"]
[29.344848, "o", "\u001b[?2004h> "]
[29.344921, "o", "        f.write(summary)\r\n\u001b[?2004l\r"]
[29.344952, "o", "\u001b[?2004h> "]
[29.344985, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[29.345016, "o", "> "]
[29.345098, "o", "    print(f\"Processing complete!\")\r\n\u001b[?2004l\r"]
[29.345131, "o", "\u001b[?2004h> "]
[29.345261, "o", "    print(f\"Valid transactions: {valid_count}\")\r\n\u001b[?2004l\r"]
[29.345291, "o", "\u001b[?2004h> "]
[29.345417, "o", "    print(f\"Failed records: {failed_count}\")\r\n\u001b[?2004l\r"]
[29.345453, "o", "\u001b[?2004h> "]
[29.34555, "o", "    print(f\"Output files created:\")\r\n\u001b[?2004l\r"]
[29.345595, "o", "\u001b[?2004h> "]
[29.345685, "o", "    print(f\"  - {output_file}\")\r\n\u001b[?2004l\r"]
[29.345725, "o", "\u001b[?2004h> "]
[29.345802, "o", "    print(f\"  - {error_file}\")\r\n\u001b[?2004l\r"]
[29.345838, "o", "\u001b[?2004h> "]
[29.345925, "o", "    print(f\"  - {summary_file}\")\r\n\u001b[?2004l\r"]
[29.345961, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[29.345995, "o", "\u001b[?2004h> "]
[29.346063, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[29.346096, "o", "\u001b[?2004h> "]
