[?2004l[?2004h>         return False, ('invalid_format', f'invalid transaction_id format: {record.get("transaction_id", "")}')
[?2004l[?2004h>     
[?2004l[?2004h>     # Validate timestamp format
[?2004l[?2004h>     if not isinstance(record['timestamp'], str) or not ISO8601_PATTERN.match(record['timestamp']):
[?2004l[?2004h>         return False, ('invalid_format', f'invalid timestamp format: {record.get("timestamp", "")}')
[?2004l[?2004h>     
[?2004l[?2004h>     # Validate account_id (non-empty string)
[?2004l[?2004h>     if not isinstance(record['account_id'], str) or record['account_id'] == '':
[?2004l[?2004h>         return False, ('invalid_value', 'account_id is empty or not a string')
[?2004l[?2004h>     
[?2004l[?2004h>     # Validate amount (must be a number)
