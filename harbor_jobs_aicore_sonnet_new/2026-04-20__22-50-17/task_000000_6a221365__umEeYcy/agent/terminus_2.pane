[?2004l[?2004h> CURRENCY_PATTERN = re.compile(r'^[A-Z]{3}$')
[?2004l[?2004h> VALID_STATUSES = {'completed', 'pending', 'failed', 'reversed'}
[?2004l[?2004h> 
[?2004l[?2004h> def validate_transaction(record, line_num):
[?2004l[?2004h>     """Validate a transaction record and return (is_valid, error_info)"""
