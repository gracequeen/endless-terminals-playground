[61.124546, "i", "cat > analyze.py << 'EOF'\nimport subprocess\nimport json\nimport re\n\ndef run_cmd(cmd):\n    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)\n    return result.stdout\n\ndef get_dependencies(package, max_depth=3, current_depth=0, visited=None):\n    if visited is None:\n        visited = set()\n    if current_depth >= max_depth or package in visited:\n        return set()\n    visited.add(package)\n    deps = set()\n    output = run_cmd(f\"apt-cache depends {package} 2>/dev/null\")\n    for line in output.split('\\n'):\n        if line.strip().startswith('Depends:'):\n            dep = line.split(':')[1].strip().split()[0]\n            deps.add(dep)\n            if current_depth < max_depth - 1:\n                deps.update(get_dependencies(dep, max_depth, current_depth + 1, visited))\n    return deps\n\nwith open('installed_packages.txt') as f:\n    installed = [line.strip() for line in f if line.strip()]\n\nwith open('required_packages.txt') as f:\n    required = [line.strip() for line in f if line.strip()]\n\npri"]
[61.124693, "i", "nt(f\"Collecting dependencies for {len(required)} required packages...\")\nall_deps = {}\ndep_sources = {}\n\nfor pkg in required:\n    print(f\"Processing {pkg}...\")\n    deps = get_dependencies(pkg, 3)\n    for dep in deps:\n        all_deps[dep] = True\n        if dep not in dep_sources:\n            dep_sources[dep] = []\n        if pkg not in dep_sources[dep]:\n            dep_sources[dep].append(pkg)\n\nremovable = []\nprotected = []\n\nfor pkg in installed:\n    if pkg in required:\n        continue\n    if pkg in all_deps:\n        protected.append(pkg)\n    else:\n        removable.append(pkg)\n\nprint(f\"Removable: {len(removable)}, Protected: {len(protected)}\")\n\ntotal_space = 0\nremovable_data = []\n\nfor pkg in sorted(removable):\n    output = run_cmd(f\"apt-cache show {pkg} 2>/dev/null\")\n    version = ''\n    size = 0\n    for line in output.split('\\n'):\n        if line.startswith('Version:'):\n            version = line.split(':', 1)[1].strip()\n        elif line.startswith('Installed-Size:'):\n            size = int(line.split(':')["]
