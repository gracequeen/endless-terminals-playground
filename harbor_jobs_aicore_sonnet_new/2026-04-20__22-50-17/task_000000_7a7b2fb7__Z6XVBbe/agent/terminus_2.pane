[?2004l#!/bin/bash
# Auto-generated package removal script
# This will remove packages identified as unnecessary

echo "This will remove the following packages:"
echo "  - apache2"
echo "  - dnsutils"
echo "  - git"
echo "  - htop"
echo "  - iputils-ping"
echo "  - lsof"
echo "  - mysql-client"
echo "  - nano"
echo "  - ncdu"
echo "  - netcat-openbsd"
echo "  - nodejs"
echo "  - npm"
echo "  - postgresql-client"
echo "  - redis-tools"
echo "  - strace"
echo "  - tcpdump"
echo "  - tree"
echo "  - vim"
echo "  - wget"
echo ""
echo "Dry run command:"
echo "apt-get remove --dry-run apache2 dnsutils git htop iputils-ping lsof mysql-client nano ncdu netcat-openbsd nodejs npm postgresql-client redis-tools strace tcpdump tree vim wget"
echo ""
read -p "Proceed with removal? (yes/no): " confirm
if [ "$confirm" = "yes" ]; then
  apt-get remove -y apache2 dnsutils git htop iputils-ping lsof mysql-client nano ncdu netcat-openbsd nodejs npm postgresql-client redis-tools strace tcpdump tree vim wget
else
  echo "Removal cancelled."
fi
