[31.256403, "i", "ction_id']):\n        return ('invalid_format', f'invalid transaction_id format: {data.get(\"transaction_id\", \"\")}')\n    \n    # Validate timestamp\n    if not isinstance(data['timestamp'], str) or not validate_iso8601(data['timestamp']):\n        return ('invalid_format', f'invalid timestamp format: {data.get(\"timestamp\", \"\")}')\n    \n    # Validate account_id (non-empty string)\n    if not isinstance(data['account_id'], str) or data['account_id'] == '':\n        return ('invalid_value', 'account_id must be non-empty string')\n    \n    # Validate amount (number)\n    if not isinstance(data['amount'], (int, float)):\n        return ('invalid_format', f'invalid amount type: {type(data[\"amount\"]).__name__}')\n    \n    # Validate currency (exactly 3 uppercase letters)\n    if not isinstance(data['currency'], str) or not CURRENCY_PATTERN.match(data['currency']):\n        return ('invalid_format', f'invalid currency format: {data.get(\"currency\", \"\")}')\n    \n    # Validate status\n    if not isinstance(data['status'], str) or dat"]
[31.256449, "i", "a['status'] not in VALID_STATUSES:\n        return ('invalid_value', f'invalid status: {data.get(\"status\", \"\")}')\n    \n    return None\n\ndef compute_hash(txn):\n    \"\"\"Compute SHA-256 hash of canonical form\"\"\"\n    amount_formatted = f\"{txn['amount']:.2f}\"\n    canonical = f\"{txn['transaction_id']}|{txn['timestamp']}|{txn['account_id']}|{amount_formatted}|{txn['currency']}|{txn['status']}\"\n    return hashlib.sha256(canonical.encode('utf-8')).hexdigest()\n\ndef main():\n    input_file = '/home/user/audit/raw_transactions.jsonl'\n    clean_output = '/home/user/audit/clean_audit.jsonl'\n    error_output = '/home/user/audit/error_log.jsonl'\n    summary_output = '/home/user/audit/processing_summary.txt'\n    \n    valid_transactions = []\n    errors = []\n    error_counts = defaultdict(int)\n    total_lines = 0\n    \n    processing_time = datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ')\n    \n    # Process input file\n    with open(input_file, 'r') as f:\n        for line_num, line in enumerate(f, 1):\n            total_lines += 1\n  "]
[31.256584, "i", "          raw_content = line.strip()\n            \n            # Try to parse JSON\n            try:\n                data = json.loads(raw_content)\n            except json.JSONDecodeError as e:\n                errors.append({\n                    'line_number': line_num,\n                    'error_type': 'malformed_json',\n                    'error_detail': f'JSON parse error: {str(e)}',\n                    'raw_content': raw_content[:200]\n                })\n                error_counts['malformed_json'] += 1\n                continue\n            \n            # Validate transaction\n            error = validate_transaction(data, line_num)\n            if error:\n                error_type, error_detail = error\n                errors.append({\n                    'line_number': line_num,\n                    'error_type': error_type,\n                    'error_detail': error_detail,\n                    'raw_content': raw_content[:200]\n                })\n                error_counts[error_type] += 1\n                cont"]
