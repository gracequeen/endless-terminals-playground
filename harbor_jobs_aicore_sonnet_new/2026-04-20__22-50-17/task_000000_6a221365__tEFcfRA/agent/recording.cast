[31.269228, "o", "    input_file = '/home/user/audit/raw_transactions.jsonl'\r\n\u001b[?2004l\r"]
[31.269264, "o", "\u001b[?2004h"]
[31.269296, "o", "> "]
[31.269425, "o", "    clean_output = '/home/user/audit/clean_audit.jsonl'\r\n\u001b[?2004l\r"]
[31.269446, "o", "\u001b[?2004h"]
[31.269487, "o", "> "]
[31.269605, "o", "    error_output = '/home/user/audit/error_log.jsonl'\r\n\u001b[?2004l\r"]
[31.269638, "o", "\u001b[?2004h> "]
[31.269807, "o", "    summary_output = '/home/user/audit/processing_summary.txt'\r\n\u001b[?2004l\r"]
[31.269838, "o", "\u001b[?2004h> "]
[31.269869, "o", "    \r\n\u001b[?2004l\r"]
[31.269901, "o", "\u001b[?2004h> "]
[31.269965, "o", "    valid_transactions = []\r\n\u001b[?2004l\r"]
[31.269994, "o", "\u001b[?2004h> "]
[31.270045, "o", "    errors = []\r\n\u001b[?2004l\r"]
[31.270078, "o", "\u001b[?2004h> "]
[31.270172, "o", "    error_counts = defaultdict(int)\r\n\u001b[?2004l\r"]
[31.270204, "o", "\u001b[?2004h> "]
[31.270261, "o", "    total_lines = 0\r\n\u001b[?2004l\r"]
[31.270292, "o", "\u001b[?2004h> "]
[31.270311, "o", "    \r\n\u001b[?2004l\r"]
[31.270346, "o", "\u001b[?2004h> "]
[31.270541, "o", "    processing_time = datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ')\r\n\u001b[?2004l\r"]
[31.270575, "o", "\u001b[?2004h> "]
[31.270605, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.270634, "o", "> "]
[31.270691, "o", "    # Process input file\r\n\u001b[?2004l\r"]
[31.270722, "o", "\u001b[?2004h> "]
[31.270825, "o", "    with open(input_file, 'r') as f:\r\n\u001b[?2004l\r"]
[31.270858, "o", "\u001b[?2004h> "]
[31.270987, "o", "        for line_num, line in enumerate(f, 1):\r\n\u001b[?2004l\r"]
[31.271019, "o", "\u001b[?2004h> "]
[31.2711, "o", "            total_lines += 1\r\n\u001b[?2004l\r"]
[31.271133, "o", "\u001b[?2004h> "]
[31.271241, "o", "            raw_content = line.strip()\r\n\u001b[?2004l\r"]
[31.271266, "o", "\u001b[?2004h"]
[31.271298, "o", "> "]
[31.271329, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.271362, "o", "> "]
[31.27144, "o", "            # Try to parse JSON\r\n\u001b[?2004l\r"]
[31.271472, "o", "\u001b[?2004h> "]
[31.271518, "o", "            try:\r\n\u001b[?2004l\r"]
[31.27155, "o", "\u001b[?2004h> "]
[31.271693, "o", "                data = json.loads(raw_content)\r\n\u001b[?2004l\r"]
[31.271724, "o", "\u001b[?2004h> "]
[31.271854, "o", "            except json.JSONDecodeError as e:\r\n\u001b[?2004l\r"]
[31.271886, "o", "\u001b[?2004h> "]
[31.271974, "o", "                errors.append({\r\n\u001b[?2004l\r"]
[31.272004, "o", "\u001b[?2004h> "]
[31.272131, "o", "                    'line_number': line_num,\r\n\u001b[?2004l\r"]
[31.272163, "o", "\u001b[?2004h> "]
[31.272309, "o", "                    'error_type': 'malformed_json',\r\n\u001b[?2004l\r"]
[31.272343, "o", "\u001b[?2004h> "]
[31.272536, "o", "                    'error_detail': f'JSON parse error: {str(e)}',\r\n\u001b[?2004l\r"]
[31.272561, "o", "\u001b[?2004h"]
[31.272576, "o", "> "]
[31.272715, "o", "                    'raw_content': raw_content[:200]\r\n\u001b[?2004l\r"]
[31.272743, "o", "\u001b[?2004h> "]
[31.272802, "o", "                })\r\n\u001b[?2004l\r"]
[31.272826, "o", "\u001b[?2004h"]
[31.272856, "o", "> "]
[31.272976, "o", "                error_counts['malformed_json'] += 1\r\n\u001b[?2004l\r"]
[31.273007, "o", "\u001b[?2004h> "]
[31.27308, "o", "                continue\r\n\u001b[?2004l\r"]
[31.273111, "o", "\u001b[?2004h> "]
[31.273151, "o", "            \r\n\u001b[?2004l\r"]
[31.273182, "o", "\u001b[?2004h> "]
[31.273277, "o", "            # Validate transaction\r\n\u001b[?2004l\r"]
[31.273308, "o", "\u001b[?2004h> "]
[31.273476, "o", "            error = validate_transaction(data, line_num)\r\n\u001b[?2004l\r"]
[31.273508, "o", "\u001b[?2004h> "]
[31.273572, "o", "            if error:\r\n\u001b[?2004l\r"]
[31.273604, "o", "\u001b[?2004h> "]
[31.27374, "o", "                error_type, error_detail = error\r\n\u001b[?2004l\r"]
[31.273773, "o", "\u001b[?2004h> "]
[31.27386, "o", "                errors.append({\r\n\u001b[?2004l\r"]
[31.273891, "o", "\u001b[?2004h> "]
[31.274016, "o", "                    'line_number': line_num,\r\n\u001b[?2004l\r"]
[31.274046, "o", "\u001b[?2004h> "]
[31.274174, "o", "                    'error_type': error_type,\r\n\u001b[?2004l\r"]
[31.274205, "o", "\u001b[?2004h> "]
[31.274343, "o", "                    'error_detail': error_detail,\r\n\u001b[?2004l\r"]
[31.274377, "o", "\u001b[?2004h> "]
[31.274532, "o", "                    'raw_content': raw_content[:200]\r\n\u001b[?2004l\r"]
[31.274564, "o", "\u001b[?2004h> "]
[31.274617, "o", "                })\r\n\u001b[?2004l\r"]
[31.274649, "o", "\u001b[?2004h> "]
[31.274773, "o", "                error_counts[error_type] += 1\r\n\u001b[?2004l\r"]
[31.274805, "o", "\u001b[?2004h> "]
[31.274873, "o", "                continue\r\n\u001b[?2004l\r"]
[31.274904, "o", "\u001b[?2004h> "]
[31.274942, "o", "            \r\n\u001b[?2004l\r"]
[31.274971, "o", "\u001b[?2004h> "]
[31.27515, "o", "            # Valid transaction - compute hash and add metadata\r\n\u001b[?2004l\r"]
[31.275182, "o", "\u001b[?2004h> "]
[31.275315, "o", "            integrity_hash = compute_hash(data)\r\n\u001b[?2004l\r"]
[31.275346, "o", "\u001b[?2004h> "]
[31.275438, "o", "            clean_record = {\r\n\u001b[?2004l\r"]
[31.27547, "o", "\u001b[?2004h> "]
[31.275625, "o", "                'transaction_id': data['transaction_id'],\r\n\u001b[?2004l\r"]
[31.275655, "o", "\u001b[?2004h> "]
[31.275801, "o", "                'timestamp': data['timestamp'],\r\n\u001b[?2004l\r"]
[31.275827, "o", "\u001b[?2004h"]
[31.275857, "o", "> "]
[31.275973, "o", "                'account_id': data['account_id'],\r\n\u001b[?2004l\r"]
[31.276005, "o", "\u001b[?2004h> "]
[31.276127, "o", "                'amount': data['amount'],\r\n\u001b[?2004l\r"]
[31.276155, "o", "\u001b[?2004h"]
[31.276184, "o", "> "]
[31.276282, "o", "                'currency': data['currency'],\r\n\u001b[?2004l\r"]
[31.27631, "o", "\u001b[?2004h> "]
[31.276444, "o", "                'status': data['status'],\r\n\u001b[?2004l\r"]
[31.276475, "o", "\u001b[?2004h> "]
[31.276609, "o", "                'integrity_hash': integrity_hash,\r\n\u001b[?2004l\r"]
[31.27664, "o", "\u001b[?2004h> "]
[31.276775, "o", "                'processed_at': processing_time\r\n\u001b[?2004l\r"]
[31.276806, "o", "\u001b[?2004h> "]
[31.276846, "o", "            }\r\n\u001b[?2004l\r"]
[31.276878, "o", "\u001b[?2004h> "]
[31.277023, "o", "            valid_transactions.append(clean_record)\r\n\u001b[?2004l\r"]
[31.277054, "o", "\u001b[?2004h> "]
[31.277085, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.277115, "o", "> "]
[31.27722, "o", "    # Sort valid transactions by timestamp\r\n\u001b[?2004l\r"]
[31.277248, "o", "\u001b[?2004h> "]
[31.277425, "o", "    valid_transactions.sort(key=lambda x: x['timestamp'])\r\n\u001b[?2004l\r"]
[31.277462, "o", "\u001b[?2004h> "]
[31.277494, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.277525, "o", "> "]
[31.277584, "o", "    # Write clean audit file\r\n\u001b[?2004l\r"]
[31.277615, "o", "\u001b[?2004h> "]
[31.277723, "o", "    with open(clean_output, 'w') as f:\r\n\u001b[?2004l\r"]
[31.277755, "o", "\u001b[?2004h> "]
[31.277863, "o", "        for txn in valid_transactions:\r\n\u001b[?2004l\r"]
[31.277895, "o", "\u001b[?2004h> "]
[31.278016, "o", "            f.write(json.dumps(txn) + '\\n')\r\n\u001b[?2004l\r"]
[31.278048, "o", "\u001b[?2004h> "]
[31.278079, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.27811, "o", "> "]
[31.278156, "o", "    # Write error log\r\n\u001b[?2004l\r"]
[31.278188, "o", "\u001b[?2004h> "]
[31.278297, "o", "    with open(error_output, 'w') as f:\r\n\u001b[?2004l\r"]
[31.278329, "o", "\u001b[?2004h> "]
[31.278421, "o", "        for error in errors:\r\n\u001b[?2004l\r"]
[31.27845, "o", "\u001b[?2004h> "]
[31.278577, "o", "            f.write(json.dumps(error) + '\\n')\r\n\u001b[?2004l\r"]
[31.278608, "o", "\u001b[?2004h> "]
[31.278636, "o", "    \r\n\u001b[?2004l\r"]
[31.278666, "o", "\u001b[?2004h> "]
[31.278736, "o", "    # Generate summary report\r\n\u001b[?2004l\r"]
[31.278766, "o", "\u001b[?2004h> "]
[31.278885, "o", "    valid_count = len(valid_transactions)\r\n\u001b[?2004l\r"]
[31.278916, "o", "\u001b[?2004h> "]
[31.279002, "o", "    failed_count = len(errors)\r\n\u001b[?2004l\r"]
[31.279033, "o", "\u001b[?2004h> "]
[31.279251, "o", "    success_rate = (valid_count / total_lines * 100) if total_lines > 0 else 0\r\n\u001b[?2004l\r"]
[31.279286, "o", "\u001b[?2004h> "]
[31.279314, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[31.279346, "o", "> "]
[31.279454, "o", "    with open(summary_output, 'w') as f:\r\n\u001b[?2004l\r"]
[31.279486, "o", "\u001b[?2004h"]
[31.279519, "o", "> "]
[31.279615, "o", "        f.write('AUDIT PROCESSING SUMMARY\\n')\r\n\u001b[?2004l\r"]
[31.279647, "o", "\u001b[?2004h> "]
[31.279781, "o", "        f.write('========================\\n')\r\n\u001b[?2004l\r"]
[31.279814, "o", "\u001b[?2004h> "]
[31.279944, "o", "        f.write(f'Input file: {input_file}\\n')\r\n\u001b[?2004l\r"]
[31.279966, "o", "\u001b[?2004h"]
[31.279996, "o", "> "]
[31.280137, "o", "        f.write(f'Total lines processed: {total_lines}\\n')\r\n\u001b[?2004l\r"]
[31.280166, "o", "\u001b[?2004h> "]
[31.280325, "o", "        f.write(f'Valid transactions: {valid_count}\\n')\r\n\u001b[?2004l\r"]
[31.280354, "o", "\u001b[?2004h> "]
[31.280514, "o", "        f.write(f'Failed records: {failed_count}\\n')\r\n\u001b[?2004l\r"]
[31.280547, "o", "\u001b[?2004h> "]
[31.2807, "o", "        f.write(f'Success rate: {success_rate:.2f}%\\n')\r\n\u001b[?2004l\r"]
[31.280729, "o", "\u001b[?2004h> "]
[31.28079, "o", "        f.write('\\n')\r\n\u001b[?2004l\r"]
[31.280821, "o", "\u001b[?2004h> "]
[31.280923, "o", "        f.write('Errors by type:\\n')\r\n\u001b[?2004l\r"]
[31.280955, "o", "\u001b[?2004h> "]
[31.281155, "o", "        f.write(f'  malformed_json: {error_counts[\"malformed_json\"]}\\n')\r\n\u001b[?2004l\r"]
[31.281188, "o", "\u001b[?2004h> "]
[31.281382, "o", "        f.write(f'  missing_field: {error_counts[\"missing_field\"]}\\n')\r\n\u001b[?2004l\r"]
[31.281427, "o", "\u001b[?2004h> "]
[31.281624, "o", "        f.write(f'  invalid_format: {error_counts[\"invalid_format\"]}\\n')\r\n\u001b[?2004l\r"]
[31.281654, "o", "\u001b[?2004h> "]
[31.281851, "o", "        f.write(f'  invalid_value: {error_counts[\"invalid_value\"]}\\n')\r\n\u001b[?2004l\r"]
[31.281884, "o", "\u001b[?2004h> "]
[31.28194, "o", "        f.write('\\n')\r\n\u001b[?2004l\r"]
[31.281972, "o", "\u001b[?2004h> "]
[31.282151, "o", "        f.write(f'Processing completed at: {processing_time}\\n')\r\n\u001b[?2004l\r"]
[31.282182, "o", "\u001b[?2004h> "]
[31.282213, "o", "    \r\n\u001b[?2004l\r"]
[31.282245, "o", "\u001b[?2004h> "]
[31.282333, "o", "    print(f'Processing complete!')\r\n\u001b[?2004l\r"]
[31.282364, "o", "\u001b[?2004h> "]
[31.282487, "o", "    print(f'Total lines: {total_lines}')\r\n\u001b[?2004l\r"]
[31.282521, "o", "\u001b[?2004h> "]
[31.282651, "o", "    print(f'Valid transactions: {valid_count}')\r\n\u001b[?2004l\r"]
[31.282678, "o", "\u001b[?2004h> "]
[31.282809, "o", "    print(f'Failed records: {failed_count}')\r\n\u001b[?2004l\r"]
[31.282841, "o", "\u001b[?2004h> "]
[31.282977, "o", "    print(f'Success rate: {success_rate:.2f}%')\r\n\u001b[?2004l\r"]
[31.28301, "o", "\u001b[?2004h> "]
[31.283038, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[31.283069, "o", "> "]
[31.283124, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[31.283155, "o", "\u001b[?2004h> "]
[31.283186, "o", "    main()\r\n"]
