[33.312378, "o", "\u001b[?2004h> "]
[33.312408, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[33.312429, "o", "> "]
[33.312519, "o", "    # Validate amount is a number\r\n\u001b[?2004l\r"]
[33.312549, "o", "\u001b[?2004h> "]
[33.312715, "o", "    if not isinstance(data['amount'], (int, float)):\r\n\u001b[?2004l\r"]
[33.312748, "o", "\u001b[?2004h> "]
[33.312797, "o", "        return {\r\n\u001b[?2004l\r"]
[33.312826, "o", "\u001b[?2004h> "]
[33.31293, "o", "            'line_number': line_num,\r\n\u001b[?2004l\r"]
[33.31296, "o", "\u001b[?2004h> "]
[33.313082, "o", "            'error_type': 'invalid_format',\r\n\u001b[?2004l\r"]
[33.313113, "o", "\u001b[?2004h> "]
[33.313372, "o", "            'error_detail': f'amount must be a number, got: {type(data[\"amount\"]).__name__}',\r\n\u001b[?2004l\r"]
[33.313404, "o", "\u001b[?2004h> "]
[33.31352, "o", "            'raw_content': raw_line[:200]\r\n\u001b[?2004l\r"]
[33.313551, "o", "\u001b[?2004h> "]
[33.313582, "o", "        }\r\n\u001b[?2004l\r"]
[33.313613, "o", "\u001b[?2004h> "]
[33.313644, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[33.31369, "o", "> "]
[33.313821, "o", "    # Validate currency format (3 uppercase letters)\r\n\u001b[?2004l\r"]
[33.313851, "o", "\u001b[?2004h> "]
[33.31411, "o", "    if not isinstance(data['currency'], str) or not CURRENCY_PATTERN.match(data['currency']):\r\n\u001b[?2004l\r"]
[33.314141, "o", "\u001b[?2004h> "]
[33.314189, "o", "        return {\r\n\u001b[?2004l\r"]
[33.314221, "o", "\u001b[?2004h> "]
[33.314322, "o", "            'line_number': line_num,\r\n\u001b[?2004l\r"]
[33.314353, "o", "\u001b[?2004h> "]
[33.314475, "o", "            'error_type': 'invalid_format',\r\n\u001b[?2004l\r"]
[33.314505, "o", "\u001b[?2004h> "]
[33.31473, "o", "            'error_detail': f'invalid currency format: {data[\"currency\"]}',\r\n\u001b[?2004l\r"]
[33.314763, "o", "\u001b[?2004h> "]
[33.314876, "o", "            'raw_content': raw_line[:200]\r\n\u001b[?2004l\r"]
[33.314907, "o", "\u001b[?2004h> "]
[33.314937, "o", "        }\r\n\u001b[?2004l\r"]
[33.314968, "o", "\u001b[?2004h> "]
[33.314998, "o", "    \r\n\u001b[?2004l\r"]
[33.315029, "o", "\u001b[?2004h> "]
[33.315076, "o", "    # Validate status\r\n\u001b[?2004l\r"]
[33.315108, "o", "\u001b[?2004h> "]
[33.315337, "o", "    if not isinstance(data['status'], str) or data['status'] not in VALID_STATUSES:\r\n\u001b[?2004l\r"]
[33.315372, "o", "\u001b[?2004h> "]
[33.315417, "o", "        return {\r\n\u001b[?2004l\r"]
[33.315446, "o", "\u001b[?2004h> "]
[33.31555, "o", "            'line_number': line_num,\r\n\u001b[?2004l\r"]
[33.315582, "o", "\u001b[?2004h> "]
[33.315717, "o", "            'error_type': 'invalid_value',\r\n\u001b[?2004l\r"]
[33.31575, "o", "\u001b[?2004h> "]
[33.31594, "o", "            'error_detail': f'invalid status: {data[\"status\"]}',\r\n\u001b[?2004l\r"]
[33.315972, "o", "\u001b[?2004h> "]
[33.316091, "o", "            'raw_content': raw_line[:200]\r\n\u001b[?2004l\r"]
[33.316123, "o", "\u001b[?2004h> "]
[33.316152, "o", "        }\r\n\u001b[?2004l\r"]
[33.316183, "o", "\u001b[?2004h> "]
[33.316213, "o", "    \r\n\u001b[?2004l\r"]
[33.316242, "o", "\u001b[?2004h> "]
[33.3163, "o", "    return None  # Valid\r\n\u001b[?2004l\r"]
[33.316331, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[33.316359, "o", "\u001b[?2004h> "]
[33.316429, "o", "def compute_hash(txn):\r\n\u001b[?2004l\r"]
[33.316459, "o", "\u001b[?2004h> "]
[33.316598, "o", "    \"\"\"Compute SHA-256 hash of canonical form.\"\"\"\r\n\u001b[?2004l\r"]
[33.316629, "o", "\u001b[?2004h> "]
[33.316772, "o", "    amount_formatted = f\"{txn['amount']:.2f}\"\r\n\u001b[?2004l\r"]
[33.316807, "o", "\u001b[?2004h> "]
[33.317174, "o", "    canonical = f\"{txn['transaction_id']}|{txn['timestamp']}|{txn['account_id']}|{amount_formatted}|{txn['currency']}|{txn['status']}\"\r\n\u001b[?2004l\r"]
[33.31721, "o", "\u001b[?2004h> "]
[33.317387, "o", "    return hashlib.sha256(canonical.encode('utf-8')).hexdigest()\r\n\u001b[?2004l\r"]
[33.317418, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[33.317448, "o", "\u001b[?2004h> "]
[33.317509, "o", "# Process input file\r\n\u001b[?2004l\r"]
[33.317542, "o", "\u001b[?2004h> "]
[33.317581, "o", "line_num = 0\r\n\u001b[?2004l\r"]
[33.317612, "o", "\u001b[?2004h> "]
[33.317719, "o", "with open(INPUT_FILE, 'r') as f:\r\n\u001b[?2004l\r"]
[33.317752, "o", "\u001b[?2004h> "]
[33.317805, "o", "    for line in f:\r\n\u001b[?2004l\r"]
[33.317836, "o", "\u001b[?2004h> "]
[33.317897, "o", "        line_num += 1\r\n\u001b[?2004l\r"]
[33.317929, "o", "\u001b[?2004h> "]
[33.318031, "o", "        raw_line = line.rstrip('\\n')\r\n\u001b[?2004l\r"]
[33.318062, "o", "\u001b[?2004h> "]
[33.318094, "o", "        \r\n\u001b[?2004l\r"]
[33.318124, "o", "\u001b[?2004h> "]
[33.318199, "o", "        # Try to parse JSON\r\n\u001b[?2004l\r"]
[33.31823, "o", "\u001b[?2004h> "]
[33.318266, "o", "        try:\r\n\u001b[?2004l\r"]
[33.318298, "o", "\u001b[?2004h> "]
[33.318411, "o", "            data = json.loads(raw_line)\r\n\u001b[?2004l\r"]
[33.318443, "o", "\u001b[?2004h> "]
[33.31856, "o", "        except json.JSONDecodeError as e:\r\n\u001b[?2004l\r"]
[33.318592, "o", "\u001b[?2004h> "]
[33.318687, "o", "            errors.append({\r\n\u001b[?2004l\r"]
[33.318722, "o", "\u001b[?2004h> "]
[33.318834, "o", "                'line_number': line_num,\r\n\u001b[?2004l\r"]
[33.318865, "o", "\u001b[?2004h> "]
[33.318996, "o", "                'error_type': 'malformed_json',\r\n\u001b[?2004l\r"]
[33.319027, "o", "\u001b[?2004h> "]
[33.319202, "o", "                'error_detail': f'JSON parse error: {str(e)}',\r\n\u001b[?2004l\r"]
[33.319232, "o", "\u001b[?2004h> "]
[33.319358, "o", "                'raw_content': raw_line[:200]\r\n\u001b[?2004l\r"]
[33.31939, "o", "\u001b[?2004h> "]
[33.319435, "o", "            })\r\n\u001b[?2004l\r"]
[33.319467, "o", "\u001b[?2004h> "]
[33.319601, "o", "            error_counts['malformed_json'] += 1\r\n\u001b[?2004l\r"]
[33.319633, "o", "\u001b[?2004h> "]
[33.319708, "o", "            continue\r\n\u001b[?2004l\r"]
[33.319742, "o", "\u001b[?2004h> "]
[33.319773, "o", "        \r\n\u001b[?2004l\r"]
[33.319804, "o", "\u001b[?2004h> "]
[33.319892, "o", "        # Validate transaction\r\n\u001b[?2004l\r"]
[33.319932, "o", "\u001b[?2004h> "]
[33.320108, "o", "        error = validate_transaction(data, line_num, raw_line)\r\n\u001b[?2004l\r"]
[33.320137, "o", "\u001b[?2004h> "]
[33.320191, "o", "        if error:\r\n\u001b[?2004l\r"]
[33.320221, "o", "\u001b[?2004h> "]
[33.320313, "o", "            errors.append(error)\r\n\u001b[?2004l\r"]
[33.320343, "o", "\u001b[?2004h> "]
[33.320485, "o", "            error_counts[error['error_type']] += 1\r\n\u001b[?2004l\r"]
[33.320517, "o", "\u001b[?2004h> "]
[33.320578, "o", "            continue\r\n\u001b[?2004l\r"]
[33.320607, "o", "\u001b[?2004h> "]
[33.320637, "o", "        \r\n\u001b[?2004l\r"]
[33.320687, "o", "\u001b[?2004h> "]
[33.320849, "o", "        # Valid transaction - compute hash and add metadata\r\n\u001b[?2004l\r"]
[33.32088, "o", "\u001b[?2004h> "]
[33.320928, "o", "        txn = {\r\n\u001b[?2004l\r"]
[33.320959, "o", "\u001b[?2004h> "]
[33.321109, "o", "            'transaction_id': data['transaction_id'],\r\n\u001b[?2004l\r"]
[33.32114, "o", "\u001b[?2004h> "]
[33.321265, "o", "            'timestamp': data['timestamp'],\r\n\u001b[?2004l\r"]
[33.321295, "o", "\u001b[?2004h> "]
[33.321424, "o", "            'account_id': data['account_id'],\r\n\u001b[?2004l\r"]
[33.321456, "o", "\u001b[?2004h> "]
[33.32156, "o", "            'amount': data['amount'],\r\n\u001b[?2004l\r"]
[33.321589, "o", "\u001b[?2004h> "]
[33.321722, "o", "            'currency': data['currency'],\r\n\u001b[?2004l\r"]
[33.321752, "o", "\u001b[?2004h"]
[33.321778, "o", "> "]
[33.32186, "o", "            'status': data['status'],\r\n\u001b[?2004l\r"]
[33.321892, "o", "\u001b[?2004h> "]
[33.322028, "o", "            'integrity_hash': compute_hash(data),\r\n\u001b[?2004l\r"]
[33.32206, "o", "\u001b[?2004h"]
[33.32209, "o", "> "]
[33.322194, "o", "            'processed_at': processing_timestamp\r\n\u001b[?2004l\r"]
[33.322222, "o", "\u001b[?2004h> "]
[33.322254, "o", "        }\r\n\u001b[?2004l\r"]
[33.322285, "o", "\u001b[?2004h> "]
[33.322397, "o", "        valid_transactions.append(txn)\r\n\u001b[?2004l\r"]
[33.322426, "o", "\u001b[?2004h> "]
[33.322457, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[33.322569, "o", "# Sort valid transactions by timestamp\r\n\u001b[?2004l\r"]
[33.3226, "o", "\u001b[?2004h> "]
[33.322765, "o", "valid_transactions.sort(key=lambda x: x['timestamp'])\r\n\u001b[?2004l\r"]
[33.322791, "o", "\u001b[?2004h"]
[33.322821, "o", "> \r\n\u001b[?2004l\r"]
[33.322851, "o", "\u001b[?2004h> "]
[33.322901, "o", "# Write clean audit file\r\n\u001b[?2004l\r"]
[33.322932, "o", "\u001b[?2004h> "]
[33.323027, "o", "with open(OUTPUT_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[33.323056, "o", "\u001b[?2004h> "]
[33.323155, "o", "    for txn in valid_transactions:\r\n\u001b[?2004l\r"]
[33.323187, "o", "\u001b[?2004h> "]
[33.323297, "o", "        f.write(json.dumps(txn) + '\\n')\r\n\u001b[?2004l\r"]
[33.323328, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[33.323358, "o", "\u001b[?2004h> "]
[33.323411, "o", "# Write error log\r\n\u001b[?2004l\r"]
[33.323442, "o", "\u001b[?2004h> "]
[33.323536, "o", "with open(ERROR_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[33.323567, "o", "\u001b[?2004h> "]
[33.32364, "o", "    for error in errors:\r\n\u001b[?2004l\r"]
[33.323685, "o", "\u001b[?2004h> "]
[33.323802, "o", "        f.write(json.dumps(error) + '\\n')\r\n\u001b[?2004l\r"]
[33.323833, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[33.323865, "o", "\u001b[?2004h> "]
[33.32395, "o", "# Generate summary report\r\n\u001b[?2004l\r"]
[33.323984, "o", "\u001b[?2004h> "]
[33.324049, "o", "total_lines = line_num\r\n\u001b[?2004l\r"]
[33.32408, "o", "\u001b[?2004h> "]
[33.324187, "o", "valid_count = len(valid_transactions)\r\n\u001b[?2004l\r"]
[33.324217, "o", "\u001b[?2004h> "]
[33.324293, "o", "failed_count = len(errors)\r\n\u001b[?2004l\r"]
[33.324322, "o", "\u001b[?2004h> "]
[33.324538, "o", "success_rate = (valid_count / total_lines * 100) if total_lines > 0 else 0.0\r\n\u001b[?2004l\r"]
[33.324569, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[33.324599, "o", "\u001b[?2004h> "]
[33.324728, "o", "summary = f\"\"\"AUDIT PROCESSING SUMMARY\r\n\u001b[?2004l\r"]
[33.324756, "o", "\u001b[?2004h"]
[33.324784, "o", "> "]
[33.324831, "o", "========================\r\n\u001b[?2004l\r"]
[33.324859, "o", "\u001b[?2004h"]
[33.324891, "o", "> "]
[33.324932, "o", "Input file: {INPUT_FILE}\r\n\u001b[?2004l\r"]
[33.32496, "o", "\u001b[?2004h> "]
[33.325067, "o", "Total lines processed: {total_lines}\r\n\u001b[?2004l\r"]
[33.325097, "o", "\u001b[?2004h> "]
[33.325194, "o", "Valid transactions: {valid_count}\r\n\u001b[?2004l\r"]
[33.325225, "o", "\u001b[?2004h> "]
[33.325312, "o", "Failed records: {failed_count}\r\n\u001b[?2004l\r"]
[33.325343, "o", "\u001b[?2004h> "]
[33.325441, "o", "Success rate: {success_rate:.2f}%\r\n\u001b[?2004l\r"]
[33.325469, "o", "\u001b[?2004h> "]
[33.3255, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[33.325552, "o", "Errors by type:\r\n\u001b[?2004l\r"]
[33.325583, "o", "\u001b[?2004h> "]
[33.325741, "o", "  malformed_json: {error_counts['malformed_json']}\r\n\u001b[?2004l\r"]
[33.325774, "o", "\u001b[?2004h> "]
[33.32591, "o", "  missing_field: {error_counts['missing_field']}\r\n\u001b[?2004l\r"]
[33.325941, "o", "\u001b[?2004h> "]
[33.326082, "o", "  invalid_format: {error_counts['invalid_format']}\r\n\u001b[?2004l\r"]
[33.326112, "o", "\u001b[?2004h> "]
[33.326247, "o", "  invalid_value: {error_counts['invalid_value']}\r\n\u001b[?2004l\r"]
[33.326278, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[33.326308, "o", "\u001b[?2004h> "]
[33.326444, "o", "Processing completed at: {processing_timestamp}\r\n\u001b[?2004l\r"]
[33.326475, "o", "\u001b[?2004h> "]
[33.326507, "o", "\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[33.32654, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[33.32657, "o", "> "]
[33.32666, "o", "with open(SUMMARY_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[33.326694, "o", "\u001b[?2004h> "]
[33.326756, "o", "    f.write(summary)\r\n\u001b[?2004l\r"]
[33.326787, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[33.326816, "o", "\u001b[?2004h> "]
[33.326907, "o", "print(f\"Processing complete!\")\r\n\u001b[?2004l\r"]
[33.326936, "o", "\u001b[?2004h> "]
[33.32706, "o", "print(f\"Valid transactions: {valid_count}\")\r\n\u001b[?2004l\r"]
[33.327091, "o", "\u001b[?2004h> "]
[33.327204, "o", "print(f\"Failed records: {failed_count}\")\r\n\u001b[?2004l\r"]
[33.327236, "o", "\u001b[?2004h> "]
[33.327353, "o", "print(f\"Output written to {OUTPUT_FILE}\")\r\n\u001b[?2004l\r"]
[33.327384, "o", "\u001b[?2004h> "]
[33.327502, "o", "print(f\"Errors written to {ERROR_FILE}\")\r\n\u001b[?2004l\r"]
[33.327533, "o", "\u001b[?2004h> "]
[33.327671, "o", "print(f\"Summary written to {SUMMARY_FILE}\")\r\n\u001b[?2004l\r"]
[33.327701, "o", "\u001b[?2004h> "]
[33.327723, "o", "EOF\r\n\u001b[?2004l\r"]
[33.33713, "o", "\u001b[?2004h"]
[33.3372, "o", "root@247d8bb0b1e1:/home/user# "]
[33.400049, "i", "python3 process_audit.py\n"]
[33.400162, "o", "python3 process_audit.py\r\n"]
[33.400199, "o", "\u001b[?2004l\r"]
[33.427088, "o", "Processing complete!\r\nValid transactions: 13\r\nFailed records: 12\r\nOutput written to /home/user/audit/clean_audit.jsonl\r\nErrors written to /home/user/audit/error_log.jsonl\r\nSummary written to /home/user/audit/processing_summary.txt\r\n"]
[33.430395, "o", "\u001b[?2004h"]
[33.430439, "o", "root@247d8bb0b1e1:/home/user# "]
[43.129191, "i", "cat audit/processing_summary.txt\n"]
[43.129358, "o", "cat audit/processing_summary.txt\r\n\u001b[?2004l\r"]
[43.130206, "o", "AUDIT PROCESSING SUMMARY\r\n========================\r\nInput file: /home/user/audit/raw_transactions.jsonl\r\nTotal lines processed: 25\r\nValid transactions: 13\r\nFailed records: 12\r\nSuccess rate: 52.00%\r\n\r\nErrors by type:\r\n  malformed_json: 3\r\n  missing_field: 2\r\n  invalid_format: 5\r\n  invalid_value: 2\r\n\r\nProcessing completed at: 2026-04-20T22:59:02Z\r\n"]
[43.130353, "o", "\u001b[?2004h"]
[43.130399, "o", "root@247d8bb0b1e1:/home/user# "]
[43.23315, "i", "echo '--- First 5 valid transactions (sorted by timestamp) ---'\n"]
[43.233459, "o", "echo '--- First 5 valid transactions (sorted by timestamp) ---'\r\n"]
[43.2335, "o", "\u001b[?2004l\r"]
[43.233528, "o", "--- First 5 valid transactions (sorted by timestamp) ---\r\n"]
[43.233559, "o", "\u001b[?2004hroot@247d8bb0b1e1:/home/user# "]
