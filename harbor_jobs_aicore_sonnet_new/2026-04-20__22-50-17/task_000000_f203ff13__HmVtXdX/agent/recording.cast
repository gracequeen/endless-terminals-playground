[22.647499, "i", "sqlite3 -header -csv employees.db \"SELECT e.id, e.name, e.department, e.salary, ROUND(d.avg_salary, 2) as dept_average FROM employees e JOIN (SELECT department, AVG(salary) as avg_salary FROM employees GROUP BY department) d ON e.department = d.department WHERE e.salary > 1.2 * d.avg_salary ORDER BY e.department ASC, e.salary DESC;\" > salary_outliers.csv\n"]
[22.648576, "o", "sqlite3 -header -csv employees.db \"SELECT e.id, e.name, e.department, e.salary, ROUND(d.avg_salary, 2) as dept_average FROM employees e JOIN (SELECT department, AVG(salary) as avg_salary FROM employees GROUP BY department) d ON e.department = d.department WHERE e.salary > 1.2 * d.avg_salary ORDER BY e.department ASC, e.salary DESC;\" > salary_outliers.csv\r\n\u001b[?2004l\r"]
