[42.533957, "i", "python3 << 'EOF'\nimport sqlite3\nimport json\n\nconn = sqlite3.connect('employees.db')\ncursor = conn.cursor()\n\nquery = \"\"\"\nSELECT department, \n       COUNT(*) as count, \n       ROUND(AVG(salary), 2) as avg_salary, \n       MIN(hire_date) as oldest_hire, \n       MAX(hire_date) as newest_hire \nFROM employees \nGROUP BY department \nORDER BY department\n\"\"\"\n\ncursor.execute(query)\nrows = cursor.fetchall()\n\nresult = {}\nfor row in rows:\n    dept_name = row[0]\n    result[dept_name] = {\n        \"count\": row[1],\n        \"avg_salary\": row[2],\n        \"oldest_hire\": row[3],\n        \"newest_hire\": row[4]\n    }\n\nconn.close()\n\nwith open('dept_summary.json', 'w') as f:\n    json.dump(result, f, indent=2, sort_keys=True)\n\nprint(\"Department summary created successfully\")\nEOF\n"]
