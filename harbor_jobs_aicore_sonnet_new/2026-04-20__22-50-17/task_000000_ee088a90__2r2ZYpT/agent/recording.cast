[27.838809, "i", "cat > generate_report.py << 'EOF'\n#!/usr/bin/env python3\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\n# Parse log files\nlog_files = {\n    'AWS IAM': 'aws-rotation.log',\n    'Database': 'db-rotation.log',\n    'API Keys': 'api-keys.log'\n}\n\ndata = defaultdict(list)\nfailed_rotations = []\n\nfor category, filename in log_files.items():\n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if not line:\n                continue\n            # Parse: [TIMESTAMP] SERVICE_NAME | OLD_KEY_ID | NEW_KEY_ID | STATUS | ROTATED_BY\n            match = re.match(r'\\[([^\\]]+)\\]\\s+([^|]+)\\s*\\|\\s*([^|]+)\\s*\\|\\s*([^|]+)\\s*\\|\\s*([^|]+)\\s*\\|\\s*(.+)', line)\n            if match:\n                timestamp, service, old_key, new_key, status, rotated_by = match.groups()\n                service = service.strip()\n                old_key = old_key.strip()\n                new_key = new_key.strip()\n                status = status.strip()\n                rotated_by = r"]
[27.838938, "i", "otated_by.strip()\n                \n                data[category].append({\n                    'service': service,\n                    'old_key': old_key,\n                    'new_key': new_key,\n                    'status': status,\n                    'rotated_by': rotated_by\n                })\n                \n                if status == 'FAILED':\n                    failed_rotations.append((service, category))\n\n# Sort entries by service name within each category\nfor category in data:\n    data[category].sort(key=lambda x: x['service'])\n\n# Calculate statistics\ntotal_count = sum(len(entries) for entries in data.values())\ntotal_success = sum(1 for entries in data.values() for e in entries if e['status'] == 'SUCCESS')\ntotal_failed = sum(1 for entries in data.values() for e in entries if e['status'] == 'FAILED')\n\n# Generate markdown report\ncurrent_time = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n\nwith open('ROTATION_REPORT.md', 'w') as f:\n    f.write('# Credential Rotation Report\\n\\n')\n    f.write(f'**Genera"]
[27.839026, "i", "ted:** {current_time}\\n')\n    f.write(f'**Total Credentials Rotated:** {total_count}\\n\\n')\n    \n    f.write('## Summary by Category\\n\\n')\n    f.write('| Category | Count | Success | Failed |\\n')\n    f.write('|----------|-------|---------|--------|\\n')\n    \n    for category in ['AWS IAM', 'Database', 'API Keys']:\n        entries = data[category]\n        count = len(entries)\n        success = sum(1 for e in entries if e['status'] == 'SUCCESS')\n        failed = sum(1 for e in entries if e['status'] == 'FAILED')\n        f.write(f'| {category} | {count} | {success} | {failed} |\\n')\n    \n    f.write('\\n## Detailed Rotation Log\\n\\n')\n    \n    # AWS IAM Credentials\n    f.write('### AWS IAM Credentials\\n\\n')\n    f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\\n')\n    f.write('|---------|------------|------------|--------|------------|\\n')\n    for entry in data['AWS IAM']:\n        f.write(f\"| {entry['service']} | {entry['old_key']} | {entry['new_key']} | {entry['status']} | {entry['rotated_by']} |\\"]
[27.839062, "o", "cat > generate_report.py << 'EOF'\r\n\u001b[?2004l\r"]
