[75.552399, "o", "        f.write(f\"| {entry['service']} | {entry['old_key']} | {entry['new_key']} | {entry['status']} | {entry['rotated_by']} |\\n\")\r\n\u001b[?2004l\r"]
[75.552433, "o", "\u001b[?2004h> "]
