[75.552569, "o", "\u001b[?2004h> "]
[75.552704, "o", "    f.write('\\n## Failed Rotations\\n\\n')\r\n\u001b[?2004l\r"]
[75.552753, "o", "\u001b[?2004h> "]
[75.552792, "o", "    if failed_rotations:\r\n\u001b[?2004l\r"]
[75.552826, "o", "\u001b[?2004h> "]
[75.553077, "o", "        f.write('> **Action Required:** The following credentials failed rotation\\n')\r\n\u001b[?2004l\r"]
[75.553112, "o", "\u001b[?2004h> "]
[75.553256, "o", "        f.write('> and need manual intervention.\\n\\n')\r\n\u001b[?2004l\r"]
[75.553288, "o", "\u001b[?2004h> "]
