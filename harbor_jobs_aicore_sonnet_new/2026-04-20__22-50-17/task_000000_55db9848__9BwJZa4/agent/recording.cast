[32.465134, "i", "cat > process_reports.py << 'EOF'\nimport os\nimport re\nfrom collections import defaultdict\n\n# Read the inventory file\nwith open('/home/user/disk_inventory.txt', 'r') as f:\n    lines = f.readlines()\n\n# Parse all entries\nentries = []\nfor line in lines:\n    parts = line.strip().split('\\t')\n    if len(parts) == 2:\n        size = int(parts[0])\n        path = parts[1]\n        entries.append((size, path))\n\n# Identify directories (paths that are prefixes of other paths)\ndirectories = set()\nall_paths = [path for _, path in entries]\nfor path in all_paths:\n    # Check if this path is a parent of any other path\n    for other_path in all_paths:\n        if other_path != path and other_path.startswith(path + '/'):\n            directories.add(path)\n            break\n\n# Also add /var/data itself as a directory\ndirectories.add('/var/data')\n\n# Report 1: Large files (>= 10MB)\nlarge_files = []\nfor size, path in entries:\n    if size >= 10485760 and path not in directories:\n        mb_size = size // 1048576  # Floor division to get "]
[32.465263, "i", "MB\n        large_files.append((mb_size, path))\n\n# Sort by size descending, then path ascending\nlarge_files.sort(key=lambda x: (-x[0], x[1]))\n\nwith open('/home/user/reports/large_files.txt', 'w') as f:\n    for mb_size, path in large_files:\n        f.write(f\"{mb_size}MB {path}\\n\")\n\n# Report 2: Extension summary\nextension_bytes = defaultdict(int)\nfor size, path in entries:\n    if path not in directories:\n        filename = os.path.basename(path)\n        if '.' in filename:\n            ext = filename.rsplit('.', 1)[1].lower()\n        else:\n            ext = 'NO_EXTENSION'\n        extension_bytes[ext] += size\n\n# Sort by total bytes descending\next_summary = sorted(extension_bytes.items(), key=lambda x: -x[1])\n\nwith open('/home/user/reports/extension_summary.csv', 'w') as f:\n    f.write(\"extension,total_bytes\\n\")\n    for ext, total in ext_summary:\n        f.write(f\"{ext},{total}\\n\")\n\n# Report 3: Directory rollup\n# Find immediate subdirectories of /var/data\nsubdir_bytes = defaultdict(int)\ntotal_bytes = 0\n\nfor size, p"]
[32.465312, "i", "ath in entries:\n    if path == '/var/data':\n        continue\n    if path.startswith('/var/data/'):\n        # Get immediate subdirectory name\n        rel_path = path[len('/var/data/'):]\n        subdir = rel_path.split('/')[0]\n        subdir_bytes[subdir] += size\n        total_bytes += size\n\n# Sort by total bytes descending\ndir_summary = sorted(subdir_bytes.items(), key=lambda x: -x[1])\n\nwith open('/home/user/reports/directory_rollup.txt', 'w') as f:\n    for dirname, dir_total in dir_summary:\n        percentage = (dir_total / total_bytes * 100) if total_bytes > 0 else 0\n        f.write(f\"{dirname} {dir_total} {percentage:.1f}%\\n\")\n\nprint(\"Reports generated successfully!\")\nEOF\n"]
[32.465329, "o", "cat > process_reports.py << 'EOF'\r\n\u001b[?2004l\r"]
