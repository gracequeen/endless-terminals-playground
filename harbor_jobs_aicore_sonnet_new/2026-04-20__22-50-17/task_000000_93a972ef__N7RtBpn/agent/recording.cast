[25.733885, "i", "cat >> /etc/monitoring/alerts.yaml << 'EOF'\n\n      - alert: DiskSpaceLow\n        expr: node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} < 0.1\n        for: 10m\n        labels:\n          severity: warning\n          team: infrastructure\n        annotations:\n          summary: \"Disk space below 10% on {{ $labels.instance }}\"\nEOF\n"]
