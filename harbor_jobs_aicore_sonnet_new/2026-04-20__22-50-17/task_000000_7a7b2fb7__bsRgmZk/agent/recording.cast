[49.277583, "i", "version != '(none)':\n            return True\n    \n    return False\n\ndef main():\n    # Read input files\n    with open('installed_packages.txt', 'r') as f:\n        installed = set(line.strip() for line in f if line.strip())\n    \n    with open('required_packages.txt', 'r') as f:\n        required = set(line.strip() for line in f if line.strip())\n    \n    print(f\"Analyzing {len(installed)} installed and {len(required)} required packages...\")\n    \n    # Get all dependencies of required packages\n    print(\"Collecting dependencies of required packages (up to 3 levels deep)...\")\n    all_required_deps = set()\n    dependency_map = defaultdict(list)  # Maps dependency -> list of packages that need it\n    \n    for pkg in required:\n        print(f\"  Analyzing dependencies of {pkg}...\")\n        deps = get_dependencies(pkg, max_depth=3)\n        for dep in deps:\n            all_required_deps.add(dep)\n            dependency_map[dep].append(pkg)\n    \n    print(f\"Found {len(all_required_deps)} unique dependencies\")\n    \n    # Id"]
