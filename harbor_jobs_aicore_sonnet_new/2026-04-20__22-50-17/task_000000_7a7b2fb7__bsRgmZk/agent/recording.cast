[49.277281, "i", "cat > analyze_packages.py << 'EOF'\n#!/usr/bin/env python3\nimport subprocess\nimport json\nimport re\nfrom collections import defaultdict, deque\n\ndef run_command(cmd):\n    try:\n        result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=30)\n        return result.stdout\n    except Exception as e:\n        return \"\"\n\ndef get_dependencies(package, max_depth=3):\n    \"\"\"Get all dependencies of a package up to max_depth levels\"\"\"\n    all_deps = set()\n    visited = set()\n    queue = deque([(package, 0)])\n    \n    while queue:\n        pkg, depth = queue.popleft()\n        if depth > max_depth or pkg in visited:\n            continue\n        visited.add(pkg)\n        \n        output = run_command(f\"apt-cache depends {pkg} 2>/dev/null\")\n        for line in output.split('\\n'):\n            line = line.strip()\n            if line.startswith('Depends:') or line.startswith('PreDepends:'):\n                dep = line.split(':', 1)[1].strip()\n                # Remove version constraints\n                dep"]
[49.277432, "i", " = re.sub(r'[<>=].*', '', dep).strip()\n                # Remove alternatives (take first option)\n                if '|' in dep:\n                    dep = dep.split('|')[0].strip()\n                if dep and dep != pkg:\n                    all_deps.add(dep)\n                    if depth < max_depth:\n                        queue.append((dep, depth + 1))\n    \n    return all_deps\n\ndef get_package_size(package):\n    \"\"\"Get installed size of package in KB\"\"\"\n    output = run_command(f\"dpkg-query -W -f='${{Installed-Size}}' {package} 2>/dev/null\")\n    try:\n        return int(output.strip())\n    except:\n        # Try apt-cache show\n        output = run_command(f\"apt-cache show {package} 2>/dev/null\")\n        for line in output.split('\\n'):\n            if line.startswith('Installed-Size:'):\n                try:\n                    return int(line.split(':')[1].strip())\n                except:\n                    pass\n        return 0\n\ndef get_package_version(package):\n    \"\"\"Get installed version of package\"\"\"\n    out"]
