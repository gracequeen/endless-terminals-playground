[49.286237, "o", "    \"\"\"Get installed size of package in KB\"\"\"\r\n\u001b[?2004l\r"]
[49.286276, "o", "\u001b[?2004h> "]
[49.286633, "o", "    output = run_command(f\"dpkg-query -W -f='${{Installed-Size}}' {package} 2>/dev/null\")\r\n\u001b[?2004l\r"]
[49.286671, "o", "\u001b[?2004h> "]
[49.286707, "o", "    try:\r\n\u001b[?2004l\r"]
[49.286736, "o", "\u001b[?2004h> "]
[49.286872, "o", "        return int(output.strip())\r\n\u001b[?2004l\r"]
[49.286907, "o", "\u001b[?2004h> "]
[49.286959, "o", "    except:\r\n\u001b[?2004l\r"]
[49.286991, "o", "\u001b[?2004h> "]
[49.287104, "o", "        # Try apt-cache show\r\n\u001b[?2004l\r"]
[49.287147, "o", "\u001b[?2004h> "]
[49.287427, "o", "        output = run_command(f\"apt-cache show {package} 2>/dev/null\")\r\n\u001b[?2004l\r"]
[49.287456, "o", "\u001b[?2004h> "]
[49.287629, "o", "        for line in output.split('\\n'):\r\n\u001b[?2004l\r"]
[49.287658, "o", "\u001b[?2004h> "]
[49.287862, "o", "            if line.startswith('Installed-Size:'):\r\n\u001b[?2004l\r"]
[49.287896, "o", "\u001b[?2004h> "]
[49.287981, "o", "                try:\r\n\u001b[?2004l\r"]
[49.288013, "o", "\u001b[?2004h> "]
[49.288261, "o", "                    return int(line.split(':')[1].strip())\r\n\u001b[?2004l\r"]
[49.288302, "o", "\u001b[?2004h> "]
[49.288398, "o", "                except:\r\n\u001b[?2004l\r"]
[49.288432, "o", "\u001b[?2004h> "]
[49.288537, "o", "                    pass\r\n\u001b[?2004l\r"]
[49.28858, "o", "\u001b[?2004h> "]
[49.288641, "o", "        return 0\r\n\u001b[?2004l\r"]
[49.288674, "o", "\u001b[?2004h> "]
[49.288705, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.288842, "o", "def get_package_version(package):\r\n\u001b[?2004l\r"]
[49.288872, "o", "\u001b[?2004h> "]
[49.289039, "o", "    \"\"\"Get installed version of package\"\"\"\r\n\u001b[?2004l\r"]
[49.289073, "o", "\u001b[?2004h> "]
[49.289421, "o", "    output = run_command(f\"dpkg-query -W -f='${{Version}}' {package} 2>/dev/null\")\r\n\u001b[?2004l\r"]
[49.289454, "o", "\u001b[?2004h> "]
[49.289573, "o", "    version = output.strip()\r\n\u001b[?2004l\r"]
[49.289606, "o", "\u001b[?2004h> "]
[49.289671, "o", "    if version:\r\n\u001b[?2004l\r"]
[49.289701, "o", "\u001b[?2004h> "]
[49.2898, "o", "        return version\r\n\u001b[?2004l\r"]
[49.289835, "o", "\u001b[?2004h> "]
[49.289917, "o", "    return \"unknown\"\r\n\u001b[?2004l\r"]
[49.289947, "o", "\u001b[?2004h> \r\n"]
[49.289975, "o", "\u001b[?2004l\r\u001b[?2004h"]
[49.290005, "o", "> "]
[49.290135, "o", "def has_security_update(package):\r\n\u001b[?2004l\r"]
[49.29017, "o", "\u001b[?2004h> "]
[49.290398, "o", "    \"\"\"Check if package has security update available\"\"\"\r\n\u001b[?2004l\r"]
[49.290429, "o", "\u001b[?2004h> "]
[49.290707, "o", "    output = run_command(f\"apt-cache policy {package} 2>/dev/null\")\r\n\u001b[?2004l\r"]
[49.290738, "o", "\u001b[?2004h> "]
[49.290875, "o", "    lines = output.split('\\n')\r\n\u001b[?2004l\r"]
[49.290906, "o", "\u001b[?2004h> "]
[49.290935, "o", "    \r\n\u001b[?2004l\r"]
[49.290965, "o", "\u001b[?2004h> "]
[49.29108, "o", "    installed_version = None\r\n\u001b[?2004l\r"]
[49.291122, "o", "\u001b[?2004h> "]
[49.291249, "o", "    candidate_version = None\r\n\u001b[?2004l\r"]
[49.291281, "o", "\u001b[?2004h> "]
[49.291383, "o", "    has_security = False\r\n\u001b[?2004l\r"]
[49.291413, "o", "\u001b[?2004h> "]
[49.291443, "o", "    \r\n\u001b[?2004l\r"]
[49.291472, "o", "\u001b[?2004h> "]
[49.291563, "o", "    for line in lines:\r\n\u001b[?2004l\r"]
[49.291599, "o", "\u001b[?2004h> "]
[49.291732, "o", "        if 'Installed:' in line:\r\n\u001b[?2004l\r"]
[49.291767, "o", "\u001b[?2004h> "]
[49.292012, "o", "            installed_version = line.split(':', 1)[1].strip()\r\n\u001b[?2004l\r"]
[49.292046, "o", "\u001b[?2004h> "]
[49.2922, "o", "        elif 'Candidate:' in line:\r\n\u001b[?2004l\r"]
[49.292239, "o", "\u001b[?2004h> "]
[49.292503, "o", "            candidate_version = line.split(':', 1)[1].strip()\r\n\u001b[?2004l\r"]
[49.292546, "o", "\u001b[?2004h> "]
[49.292695, "o", "        elif 'security' in line.lower():\r\n\u001b[?2004l\r"]
[49.292726, "o", "\u001b[?2004h> "]
[49.292849, "o", "            has_security = True\r\n\u001b[?2004l\r"]
[49.292887, "o", "\u001b[?2004h> "]
[49.292917, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[49.292946, "o", "> "]
[49.293295, "o", "    # If candidate version is different and there's a security repo, likely has update\r\n\u001b[?2004l\r"]
[49.293332, "o", "\u001b[?2004h> "]
[49.293516, "o", "    if installed_version and candidate_version:\r\n\u001b[?2004l\r"]
[49.293546, "o", "\u001b[?2004h> "]
[49.29389, "o", "        if installed_version != candidate_version and installed_version != '(none)':\r\n\u001b[?2004l\r"]
[49.293921, "o", "\u001b[?2004h> "]
[49.294023, "o", "            return True\r\n\u001b[?2004l\r"]
[49.294055, "o", "\u001b[?2004h> "]
[49.294312, "o", "        if has_security and candidate_version != '(none)':\r\n\u001b[?2004l\r"]
[49.294351, "o", "\u001b[?2004h"]
[49.29438, "o", "> "]
[49.294444, "o", "            return True\r\n\u001b[?2004l\r"]
[49.294475, "o", "\u001b[?2004h> "]
[49.294506, "o", "    \r\n\u001b[?2004l\r"]
[49.294525, "o", "\u001b[?2004h> "]
[49.29461, "o", "    return False\r\n\u001b[?2004l\r"]
[49.294642, "o", "\u001b[?2004h> \r\n"]
[49.294674, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[49.29473, "o", "def main():\r\n\u001b[?2004l\r"]
[49.29476, "o", "\u001b[?2004h> "]
[49.29486, "o", "    # Read input files\r\n\u001b[?2004l\r"]
[49.294891, "o", "\u001b[?2004h> "]
[49.295127, "o", "    with open('installed_packages.txt', 'r') as f:\r\n\u001b[?2004l\r"]
[49.295157, "o", "\u001b[?2004h> "]
[49.29544, "o", "        installed = set(line.strip() for line in f if line.strip())\r\n\u001b[?2004l\r"]
[49.295473, "o", "\u001b[?2004h> "]
[49.295507, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[49.295537, "o", "> "]
[49.295722, "o", "    with open('required_packages.txt', 'r') as f:\r\n\u001b[?2004l\r"]
[49.295757, "o", "\u001b[?2004h> "]
[49.296029, "o", "        required = set(line.strip() for line in f if line.strip())\r\n\u001b[?2004l\r"]
[49.296066, "o", "\u001b[?2004h> "]
[49.296098, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[49.296149, "o", "> "]
[49.296508, "o", "    print(f\"Analyzing {len(installed)} installed and {len(required)} required packages...\")\r\n\u001b[?2004l\r"]
[49.296542, "o", "\u001b[?2004h> "]
[49.296575, "o", "    \r\n\u001b[?2004l\r"]
[49.296606, "o", "\u001b[?2004h> "]
[49.296784, "o", "    # Get all dependencies of required packages\r\n\u001b[?2004l\r"]
[49.296818, "o", "\u001b[?2004h> "]
[49.297158, "o", "    print(\"Collecting dependencies of required packages (up to 3 levels deep)...\")\r\n\u001b[?2004l\r"]
[49.297199, "o", "\u001b[?2004h> "]
[49.297312, "o", "    all_required_deps = set()\r\n\u001b[?2004l\r"]
[49.297342, "o", "\u001b[?2004h> "]
[49.297631, "o", "    dependency_map = defaultdict(list)  # Maps dependency -> list of packages that need it\r\n\u001b[?2004l\r"]
[49.29766, "o", "\u001b[?2004h> "]
[49.29769, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[49.297717, "o", "> "]
[49.297775, "o", "    for pkg in required:\r\n\u001b[?2004l\r"]
[49.297804, "o", "\u001b[?2004h> "]
[49.297954, "o", "        print(f\"  Analyzing dependencies of {pkg}...\")\r\n\u001b[?2004l\r"]
[49.297987, "o", "\u001b[?2004h> "]
[49.298138, "o", "        deps = get_dependencies(pkg, max_depth=3)\r\n\u001b[?2004l\r"]
[49.298167, "o", "\u001b[?2004h> "]
[49.298239, "o", "        for dep in deps:\r\n\u001b[?2004l\r"]
[49.298278, "o", "\u001b[?2004h> "]
[49.298373, "o", "            all_required_deps.add(dep)\r\n\u001b[?2004l\r"]
[49.298403, "o", "\u001b[?2004h> "]
[49.298524, "o", "            dependency_map[dep].append(pkg)\r\n\u001b[?2004l\r"]
[49.298556, "o", "\u001b[?2004h> "]
[49.298586, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[49.298617, "o", "> "]
[49.298776, "o", "    print(f\"Found {len(all_required_deps)} unique dependencies\")\r\n\u001b[?2004l\r"]
[49.298809, "o", "\u001b[?2004h> "]
[49.298837, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[49.298865, "o", "> "]
[49.298962, "o", "    # Identify truly removable packages\r\n\u001b[?2004l\r"]
[49.298995, "o", "\u001b[?2004h> "]
[49.299147, "o", "    potentially_removable = installed - required\r\n\u001b[?2004l\r"]
[49.299177, "o", "\u001b[?2004h"]
[49.299206, "o", "> "]
[49.299269, "o", "    dependency_protected = []\r\n\u001b[?2004l\r"]
[49.299299, "o", "\u001b[?2004h> "]
[49.299377, "o", "    removable_packages = []\r\n\u001b[?2004l\r"]
[49.299407, "o", "\u001b[?2004h> "]
[49.299437, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[49.299465, "o", "> "]
[49.299644, "o", "    print(\"\\nAnalyzing removable vs dependency-protected packages...\")\r\n\u001b[?2004l\r"]
[49.299674, "o", "\u001b[?2004h> "]
[49.2998, "o", "    for pkg in sorted(potentially_removable):\r\n\u001b[?2004l\r"]
[49.299829, "o", "\u001b[?2004h> "]
[49.299932, "o", "        if pkg in all_required_deps:\r\n\u001b[?2004l\r"]
[49.299965, "o", "\u001b[?2004h> "]
[49.300157, "o", "            # This package is a dependency of a required package\r\n\u001b[?2004l\r"]
[49.300194, "o", "\u001b[?2004h> "]
[49.300303, "o", "            dependency_protected.append({\r\n\u001b[?2004l\r"]
[49.30034, "o", "\u001b[?2004h> "]
[49.300423, "o", "                \"name\": pkg,\r\n\u001b[?2004l\r"]
[49.300454, "o", "\u001b[?2004h> "]
[49.300612, "o", "                \"required_by\": sorted(dependency_map[pkg])\r\n\u001b[?2004l\r"]
[49.300646, "o", "\u001b[?2004h> "]
[49.300688, "o", "            })\r\n\u001b[?2004l\r"]
[49.300716, "o", "\u001b[?2004h> "]
[49.300932, "o", "            print(f\"  {pkg}: PROTECTED (dependency of {dependency_map[pkg]})\")\r\n\u001b[?2004l\r"]
[49.300963, "o", "\u001b[?2004h> "]
[49.301005, "o", "        else:\r\n\u001b[?2004l\r"]
[49.301033, "o", "\u001b[?2004h> "]
[49.301163, "o", "            # This package can be removed\r\n\u001b[?2004l\r"]
[49.301196, "o", "\u001b[?2004h> "]
[49.301305, "o", "            print(f\"  {pkg}: REMOVABLE\")\r\n\u001b[?2004l\r"]
[49.301335, "o", "\u001b[?2004h> "]
[49.301455, "o", "            size_kb = get_package_size(pkg)\r\n\u001b[?2004l\r"]
[49.301485, "o", "\u001b[?2004h> "]
[49.301614, "o", "            version = get_package_version(pkg)\r\n\u001b[?2004l\r"]
[49.301643, "o", "\u001b[?2004h> "]
[49.301783, "o", "            has_update = has_security_update(pkg)\r\n\u001b[?2004l\r"]
[49.301821, "o", "\u001b[?2004h> "]
[49.30185, "o", "            \r\n\u001b[?2004l\r"]
[49.301878, "o", "\u001b[?2004h> "]
[49.301987, "o", "            removable_packages.append({\r\n\u001b[?2004l\r"]
[49.30202, "o", "\u001b[?2004h> "]
[49.302099, "o", "                \"name\": pkg,\r\n\u001b[?2004l\r"]
[49.302147, "o", "\u001b[?2004h> "]
[49.302274, "o", "                \"installed_version\": version,\r\n\u001b[?2004l\r"]
[49.302311, "o", "\u001b[?2004h> "]
[49.302402, "o", "                \"size_kb\": size_kb,\r\n\u001b[?2004l\r"]
[49.30244, "o", "\u001b[?2004h> "]
[49.302567, "o", "                \"has_security_update\": has_update\r\n\u001b[?2004l\r"]
[49.302601, "o", "\u001b[?2004h> "]
[49.302639, "o", "            })\r\n\u001b[?2004l\r"]
[49.302672, "o", "\u001b[?2004h> "]
[49.3027, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[49.302731, "o", "> "]
[49.302765, "o", "    # Sort arrays\r\n\u001b[?2004l\r"]
[49.302794, "o", "\u001b[?2004h> "]
[49.302939, "o", "    removable_packages.sort(key=lambda x: x['name'])\r\n\u001b[?2004l\r"]
[49.302974, "o", "\u001b[?2004h> "]
[49.303134, "o", "    dependency_protected.sort(key=lambda x: x['name'])\r\n\u001b[?2004l\r"]
[49.303164, "o", "\u001b[?2004h> "]
[49.303197, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[49.303229, "o", "> "]
[49.30331, "o", "    # Calculate total space savings\r\n\u001b[?2004l\r"]
[49.303344, "o", "\u001b[?2004h> "]
[49.303548, "o", "    total_space_savings = sum(pkg['size_kb'] for pkg in removable_packages)\r\n\u001b[?2004l\r"]
[49.303582, "o", "\u001b[?2004h> "]
[49.303616, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[49.303645, "o", "> "]
[49.303685, "o", "    # Create report\r\n\u001b[?2004l\r"]
[49.303716, "o", "\u001b[?2004h> "]
[49.303757, "o", "    report = {\r\n\u001b[?2004l\r"]
[49.303791, "o", "\u001b[?2004h> "]
[49.303847, "o", "        \"summary\": {\r\n\u001b[?2004l\r"]
[49.303877, "o", "\u001b[?2004h> "]
[49.304005, "o", "            \"total_installed\": len(installed),\r\n\u001b[?2004l\r"]
[49.304035, "o", "\u001b[?2004h> "]
[49.304172, "o", "            \"total_required\": len(required),\r\n\u001b[?2004l\r"]
[49.304204, "o", "\u001b[?2004h> "]
[49.304356, "o", "            \"removable_count\": len(removable_packages),\r\n\u001b[?2004l\r"]
[49.304393, "o", "\u001b[?2004h> "]
[49.304568, "o", "            \"kept_as_dependencies\": len(dependency_protected),\r\n\u001b[?2004l\r"]
[49.304597, "o", "\u001b[?2004h> "]
[49.304756, "o", "            \"total_space_savings_kb\": total_space_savings\r\n\u001b[?2004l\r"]
[49.304786, "o", "\u001b[?2004h> "]
[49.30488, "o", "        },\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.304987, "o", "        \"removable_packages\": removable_packages,\r\n\u001b[?2004l\r"]
[49.305027, "o", "\u001b[?2004h"]
[49.305058, "o", "> "]
[49.305176, "o", "        \"dependency_protected\": dependency_protected\r\n\u001b[?2004l\r"]
[49.30521, "o", "\u001b[?2004h"]
[49.305242, "o", ">     }\r\n\u001b[?2004l\r\u001b[?2004h"]
[49.305285, "o", ">     \r\n"]
[49.305316, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[49.30537, "o", "    # Write JSON report\r\n\u001b[?2004l\r"]
[49.3054, "o", "\u001b[?2004h> "]
[49.305532, "o", "    with open('removal_report.json', 'w') as f:\r\n\u001b[?2004l\r"]
[49.305564, "o", "\u001b[?2004h> "]
[49.305669, "o", "        json.dump(report, f, indent=2)\r\n\u001b[?2004l\r"]
[49.305699, "o", "\u001b[?2004h> "]
[49.305731, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[49.305759, "o", "> "]
[49.305834, "o", "    print(f\"\\n=== Summary ===\")\r\n\u001b[?2004l\r"]
[49.305866, "o", "\u001b[?2004h> "]
[49.305995, "o", "    print(f\"Total installed: {len(installed)}\")\r\n\u001b[?2004l\r"]
[49.306029, "o", "\u001b[?2004h> "]
[49.306169, "o", "    print(f\"Total required: {len(required)}\")\r\n\u001b[?2004l\r"]
[49.306199, "o", "\u001b[?2004h> "]
[49.306339, "o", "    print(f\"Removable: {len(removable_packages)}\")\r\n\u001b[?2004l\r"]
[49.306365, "o", "\u001b[?2004h> "]
[49.30656, "o", "    print(f\"Protected as dependencies: {len(dependency_protected)}\")\r\n\u001b[?2004l\r"]
[49.306598, "o", "\u001b[?2004h> "]
[49.306849, "o", "    print(f\"Total space savings: {total_space_savings} KB ({total_space_savings/1024:.2f} MB)\")\r\n\u001b[?2004l\r"]
[49.306877, "o", "\u001b[?2004h> "]
[49.307028, "o", "    print(f\"\\nReport written to removal_report.json\")\r\n\u001b[?2004l\r"]
[49.307054, "o", "\u001b[?2004h> "]
[49.307082, "o", "    \r\n\u001b[?2004l\r"]
[49.307109, "o", "\u001b[?2004h> "]
[49.307194, "o", "    # Create removal script\r\n\u001b[?2004l\r"]
[49.307221, "o", "\u001b[?2004h"]
[49.307251, "o", "> "]
[49.307357, "o", "    with open('remove_packages.sh', 'w') as f:\r\n\u001b[?2004l\r"]
[49.307387, "o", "\u001b[?2004h> "]
[49.307479, "o", "        f.write('#!/bin/bash\\n')\r\n\u001b[?2004l\r"]
[49.307509, "o", "\u001b[?2004h> "]
[49.307677, "o", "        f.write('# Auto-generated package removal script\\n')\r\n\u001b[?2004l\r"]
[49.307706, "o", "\u001b[?2004h> "]
[49.307923, "o", "        f.write('# This script removes packages identified as unnecessary\\n\\n')\r\n\u001b[?2004l\r"]
