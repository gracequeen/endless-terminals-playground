[170.03325, "i", "cy_protected.sort(key=lambda x: x['name'])\n    \n    # Calculate total space savings\n    total_space_savings = sum(pkg['size_kb'] for pkg in removable_packages)\n    \n    # Create report\n    report = {\n        \"summary\": {\n            \"total_installed\": len(installed),\n            \"total_required\": len(required),\n            \"removable_count\": len(removable_packages),\n            \"kept_as_dependencies\": len(dependency_protected),\n            \"total_space_savings_kb\": total_space_savings\n        },\n        \"removable_packages\": removable_packages,\n        \"dependency_protected\": dependency_protected\n    }\n    \n    # Write JSON report\n    with open('removal_report.json', 'w') as f:\n        json.dump(report, f, indent=2)\n    \n    print(f\"\\n{'='*60}\")\n    print(f\"=== SUMMARY ===\")\n    print(f\"{'='*60}\")\n    print(f\"Total installed packages:        {len(installed)}\")\n    print(f\"Total required packages:         {len(required)}\")\n    print(f\"Removable packages:              {len(removable_packages)}\")\n    print(f\"Pro"]
