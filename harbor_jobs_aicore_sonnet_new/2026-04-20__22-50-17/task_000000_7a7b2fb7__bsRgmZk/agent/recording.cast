[170.032763, "i", "cat > analyze_packages_v2.py << 'EOF'\n#!/usr/bin/env python3\nimport subprocess\nimport json\nimport re\nfrom collections import defaultdict, deque\n\n# Cache for apt-cache results to avoid repeated calls\ncache = {}\n\ndef run_command(cmd, timeout=5):\n    try:\n        result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=timeout)\n        return result.stdout\n    except subprocess.TimeoutExpired:\n        print(f\"    [Timeout on command]\")\n        return \"\"\n    except Exception as e:\n        return \"\"\n\ndef get_dependencies(package, max_depth=3):\n    \"\"\"Get all dependencies of a package up to max_depth levels\"\"\"\n    all_deps = set()\n    visited = set()\n    queue = deque([(package, 0)])\n    \n    while queue:\n        pkg, depth = queue.popleft()\n        if depth > max_depth or pkg in visited:\n            continue\n        visited.add(pkg)\n        \n        # Use cache\n        if pkg in cache:\n            output = cache[pkg]\n        else:\n            output = run_command(f\"apt-cache depends {pkg} 2"]
[170.032906, "i", ">/dev/null\", timeout=3)\n            cache[pkg] = output\n        \n        if not output:\n            continue\n            \n        for line in output.split('\\n'):\n            line = line.strip()\n            if line.startswith('Depends:') or line.startswith('PreDepends:'):\n                dep = line.split(':', 1)[1].strip()\n                # Remove version constraints and angle brackets\n                dep = re.sub(r'[<>=].*', '', dep).strip()\n                dep = dep.replace('<', '').replace('>', '')\n                # Remove alternatives (take first option)\n                if '|' in dep:\n                    dep = dep.split('|')[0].strip()\n                if dep and dep != pkg and not dep.startswith('|'):\n                    all_deps.add(dep)\n                    if depth < max_depth:\n                        queue.append((dep, depth + 1))\n    \n    return all_deps\n\ndef get_package_size(package):\n    \"\"\"Get installed size of package in KB\"\"\"\n    output = run_command(f\"dpkg-query -W -f='${{Installed-Size}}' {packa"]
[170.032941, "o", "cat > analyze_packages_v2.py << 'EOF'"]
[170.032976, "i", "ge} 2>/dev/null\", timeout=2)\n    try:\n        return int(output.strip())\n    except:\n        # Try apt-cache show\n        output = run_command(f\"apt-cache show {package} 2>/dev/null | grep '^Installed-Size:' | head -1\", timeout=2)\n        if output:\n            try:\n                return int(output.split(':')[1].strip())\n            except:\n                pass\n        return 0\n\ndef get_package_version(package):\n    \"\"\"Get installed version of package\"\"\"\n    output = run_command(f\"dpkg-query -W -f='${{Version}}' {package} 2>/dev/null\", timeout=2)\n    version = output.strip()\n    if version:\n        return version\n    return \"unknown\"\n\ndef has_security_update(package):\n    \"\"\"Check if package has security update available\"\"\"\n    output = run_command(f\"apt-cache policy {package} 2>/dev/null\", timeout=2)\n    if not output:\n        return False\n        \n    lines = output.split('\\n')\n    \n    installed_version = None\n    candidate_version = None\n    has_security = False\n    \n    for line in lines:\n        if 'In"]
[170.033006, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[170.033041, "i", "stalled:' in line:\n            installed_version = line.split(':', 1)[1].strip()\n        elif 'Candidate:' in line:\n            candidate_version = line.split(':', 1)[1].strip()\n        elif 'security' in line.lower():\n            has_security = True\n    \n    # If candidate version is different and there's a security repo, likely has update\n    if installed_version and candidate_version:\n        if installed_version != candidate_version and installed_version != '(none)':\n            return True\n        if has_security and candidate_version != '(none)':\n            return True\n    \n    return False\n\ndef main():\n    # Read input files\n    with open('installed_packages.txt', 'r') as f:\n        installed = set(line.strip() for line in f if line.strip())\n    \n    with open('required_packages.txt', 'r') as f:\n        required = set(line.strip() for line in f if line.strip())\n    \n    print(f\"Analyzing {len(installed)} installed and {len(required)} required packages...\")\n    \n    # Get all dependencies of required p"]
[170.033067, "o", "> "]
[170.033101, "i", "ackages\n    print(\"Collecting dependencies of required packages (up to 3 levels deep)...\")\n    all_required_deps = set()\n    dependency_map = defaultdict(set)  # Maps dependency -> set of packages that need it\n    \n    for i, pkg in enumerate(sorted(required), 1):\n        print(f\"  [{i}/{len(required)}] Analyzing dependencies of {pkg}...\")\n        deps = get_dependencies(pkg, max_depth=3)\n        print(f\"      Found {len(deps)} dependencies\")\n        for dep in deps:\n            all_required_deps.add(dep)\n            dependency_map[dep].add(pkg)\n    \n    print(f\"\\nFound {len(all_required_deps)} unique dependencies across all required packages\")\n    \n    # Identify truly removable packages\n    potentially_removable = installed - required\n    dependency_protected = []\n    removable_packages = []\n    \n    print(f\"\\nAnalyzing {len(potentially_removable)} potentially removable packages...\")\n    for i, pkg in enumerate(sorted(potentially_removable), 1):\n        print(f\"  [{i}/{len(potentially_removable)}] {pkg}...\""]
[170.033149, "o", "#!/usr/bin/env python3\r\n\u001b[?2004l\r\u001b[?2004h> "]
[170.033186, "i", ", end=' ')\n        if pkg in all_required_deps:\n            # This package is a dependency of a required package\n            required_by_list = sorted(list(dependency_map[pkg]))\n            dependency_protected.append({\n                \"name\": pkg,\n                \"required_by\": required_by_list\n            })\n            print(f\"PROTECTED (required by: {', '.join(required_by_list[:3])}{'...' if len(required_by_list) > 3 else ''})\")\n        else:\n            # This package can be removed\n            size_kb = get_package_size(pkg)\n            version = get_package_version(pkg)\n            has_update = has_security_update(pkg)\n            \n            removable_packages.append({\n                \"name\": pkg,\n                \"installed_version\": version,\n                \"size_kb\": size_kb,\n                \"has_security_update\": has_update\n            })\n            print(f\"REMOVABLE (size: {size_kb} KB, version: {version})\")\n    \n    # Sort arrays\n    removable_packages.sort(key=lambda x: x['name'])\n    dependen"]
