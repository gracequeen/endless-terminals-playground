[170.038417, "o", "\u001b[?2004h> "]
[170.038543, "o", "            cache[pkg] = output\r\n\u001b[?2004l\r"]
[170.03857, "o", "\u001b[?2004h> "]
[170.038615, "o", "        \r\n\u001b[?2004l\r"]
[170.038644, "o", "\u001b[?2004h> "]
[170.038743, "o", "        if not output:\r\n\u001b[?2004l\r"]
[170.038771, "o", "\u001b[?2004h> "]
[170.038863, "o", "            continue\r\n\u001b[?2004l\r"]
[170.038891, "o", "\u001b[?2004h> "]
[170.038953, "o", "            \r\n\u001b[?2004l\r"]
[170.03898, "o", "\u001b[?2004h> "]
[170.039159, "o", "        for line in output.split('\\n'):\r\n\u001b[?2004l\r"]
[170.039189, "o", "\u001b[?2004h> "]
[170.039319, "o", "            line = line.strip()\r\n\u001b[?2004l\r"]
[170.039351, "o", "\u001b[?2004h> "]
[170.039655, "o", "            if line.startswith('Depends:') or line.startswith('PreDepends:'):\r\n\u001b[?2004l\r"]
[170.039689, "o", "\u001b[?2004h> "]
[170.039901, "o", "                dep = line.split(':', 1)[1].strip()\r\n\u001b[?2004l\r"]
[170.039934, "o", "\u001b[?2004h> "]
[170.040208, "o", "                # Remove version constraints and angle brackets\r\n\u001b[?2004l\r"]
[170.040242, "o", "\u001b[?2004h> "]
[170.040485, "o", "                dep = re.sub(r'[<>=].*', '', dep).strip()\r\n\u001b[?2004l\r"]
[170.040519, "o", "\u001b[?2004h"]
[170.040551, "o", "> "]
[170.040758, "o", "                dep = dep.replace('<', '').replace('>', '')\r\n\u001b[?2004l\r"]
[170.040778, "o", "\u001b[?2004h> "]
[170.041025, "o", "                # Remove alternatives (take first option)\r\n\u001b[?2004l\r"]
[170.04105, "o", "\u001b[?2004h> "]
[170.041199, "o", "                if '|' in dep:\r\n\u001b[?2004l\r"]
[170.04123, "o", "\u001b[?2004h> "]
[170.041433, "o", "                    dep = dep.split('|')[0].strip()\r\n\u001b[?2004l\r"]
[170.041457, "o", "\u001b[?2004h"]
[170.041489, "o", "> "]
[170.041739, "o", "                if dep and dep != pkg and not dep.startswith('|'):\r\n\u001b[?2004l\r"]
[170.04177, "o", "\u001b[?2004h> "]
[170.041922, "o", "                    all_deps.add(dep)\r\n\u001b[?2004l\r"]
[170.041945, "o", "\u001b[?2004h> "]
[170.042141, "o", "                    if depth < max_depth:\r\n\u001b[?2004l\r"]
[170.042176, "o", "\u001b[?2004h> "]
[170.042391, "o", "                        queue.append((dep, depth + 1))\r\n\u001b[?2004l\r"]
[170.042423, "o", "\u001b[?2004h> "]
[170.042452, "o", "    \r\n\u001b[?2004l\r"]
[170.042484, "o", "\u001b[?2004h> "]
[170.042563, "o", "    return all_deps\r\n\u001b[?2004l\r"]
[170.042595, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[170.042627, "o", "\u001b[?2004h> "]
[170.042757, "o", "def get_package_size(package):\r\n\u001b[?2004l\r"]
[170.042788, "o", "\u001b[?2004h> "]
[170.042977, "o", "    \"\"\"Get installed size of package in KB\"\"\"\r\n\u001b[?2004l\r"]
[170.043009, "o", "\u001b[?2004h> "]
[170.043428, "o", "    output = run_command(f\"dpkg-query -W -f='${{Installed-Size}}' {package} 2>/dev/null\", timeout=2)\r\n\u001b[?2004l\r"]
[170.04346, "o", "\u001b[?2004h> "]
[170.043499, "o", "    try:\r\n\u001b[?2004l\r"]
[170.043523, "o", "\u001b[?2004h"]
[170.043554, "o", "> "]
[170.04368, "o", "        return int(output.strip())\r\n\u001b[?2004l\r"]
[170.043705, "o", "\u001b[?2004h"]
[170.043732, "o", "> "]
[170.043767, "o", "    except:\r\n\u001b[?2004l\r"]
[170.043798, "o", "\u001b[?2004h> "]
[170.043915, "o", "        # Try apt-cache show\r\n\u001b[?2004l\r"]
[170.043947, "o", "\u001b[?2004h> "]
[170.044434, "o", "        output = run_command(f\"apt-cache show {package} 2>/dev/null | grep '^Installed-Size:' | head -1\", timeout=2)\r\n\u001b[?2004l\r"]
[170.044465, "o", "\u001b[?2004h> "]
[170.04455, "o", "        if output:\r\n\u001b[?2004l\r"]
[170.044574, "o", "\u001b[?2004h"]
[170.044589, "o", "> "]
[170.044651, "o", "            try:\r\n\u001b[?2004l\r"]
[170.044678, "o", "\u001b[?2004h> "]
[170.044917, "o", "                return int(output.split(':')[1].strip())\r\n\u001b[?2004l\r"]
[170.04495, "o", "\u001b[?2004h> "]
[170.045033, "o", "            except:\r\n\u001b[?2004l\r"]
[170.045065, "o", "\u001b[?2004h> "]
[170.045171, "o", "                pass\r\n\u001b[?2004l\r"]
[170.045206, "o", "\u001b[?2004h> "]
[170.045273, "o", "        return 0\r\n\u001b[?2004l\r"]
[170.045306, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[170.045338, "o", "\u001b[?2004h> "]
[170.045478, "o", "def get_package_version(package):\r\n\u001b[?2004l\r"]
[170.04551, "o", "\u001b[?2004h> "]
[170.045681, "o", "    \"\"\"Get installed version of package\"\"\"\r\n\u001b[?2004l\r"]
[170.045713, "o", "\u001b[?2004h> "]
[170.046082, "o", "    output = run_command(f\"dpkg-query -W -f='${{Version}}' {package} 2>/dev/null\", timeout=2)\r\n\u001b[?2004l\r"]
[170.04613, "o", "\u001b[?2004h> "]
[170.046247, "o", "    version = output.strip()\r\n\u001b[?2004l\r"]
[170.046275, "o", "\u001b[?2004h> "]
[170.046355, "o", "    if version:\r\n\u001b[?2004l\r"]
[170.046383, "o", "\u001b[?2004h> "]
[170.046484, "o", "        return version\r\n\u001b[?2004l\r"]
[170.046512, "o", "\u001b[?2004h> "]
[170.046607, "o", "    return \"unknown\"\r\n\u001b[?2004l\r"]
[170.046633, "o", "\u001b[?2004h"]
[170.046661, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[170.046691, "o", "> "]
[170.046815, "o", "def has_security_update(package):\r\n\u001b[?2004l\r"]
[170.046842, "o", "\u001b[?2004h> "]
[170.04708, "o", "    \"\"\"Check if package has security update available\"\"\"\r\n\u001b[?2004l\r"]
[170.047127, "o", "\u001b[?2004h> "]
[170.047446, "o", "    output = run_command(f\"apt-cache policy {package} 2>/dev/null\", timeout=2)\r\n\u001b[?2004l\r"]
[170.047477, "o", "\u001b[?2004h> "]
[170.047557, "o", "    if not output:\r\n\u001b[?2004l\r"]
[170.047582, "o", "\u001b[?2004h"]
[170.047615, "o", "> "]
[170.047678, "o", "        return False\r\n\u001b[?2004l\r"]
[170.047705, "o", "\u001b[?2004h"]
[170.047736, "o", "> "]
[170.047767, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[170.047798, "o", "> "]
[170.047908, "o", "    lines = output.split('\\n')\r\n\u001b[?2004l\r"]
[170.047939, "o", "\u001b[?2004h> "]
[170.04797, "o", "    \r\n\u001b[?2004l\r"]
[170.048001, "o", "\u001b[?2004h> "]
[170.048138, "o", "    installed_version = None\r\n\u001b[?2004l\r"]
[170.048172, "o", "\u001b[?2004h> "]
[170.04829, "o", "    candidate_version = None\r\n\u001b[?2004l\r"]
[170.04832, "o", "\u001b[?2004h> "]
[170.048432, "o", "    has_security = False\r\n\u001b[?2004l\r"]
[170.048465, "o", "\u001b[?2004h> "]
[170.048496, "o", "    \r\n\u001b[?2004l\r"]
[170.048529, "o", "\u001b[?2004h> "]
[170.048618, "o", "    for line in lines:\r\n\u001b[?2004l\r"]
[170.048645, "o", "\u001b[?2004h> "]
[170.048785, "o", "        if 'Installed:' in line:\r\n\u001b[?2004l\r"]
[170.048817, "o", "\u001b[?2004h> "]
[170.049062, "o", "            installed_version = line.split(':', 1)[1].strip()\r\n\u001b[?2004l\r"]
[170.049094, "o", "\u001b[?2004h> "]
[170.04925, "o", "        elif 'Candidate:' in line:\r\n\u001b[?2004l\r"]
[170.049282, "o", "\u001b[?2004h> "]
[170.049545, "o", "            candidate_version = line.split(':', 1)[1].strip()\r\n\u001b[?2004l\r"]
[170.049573, "o", "\u001b[?2004h> "]
[170.049738, "o", "        elif 'security' in line.lower():\r\n\u001b[?2004l\r"]
[170.049763, "o", "\u001b[?2004h"]
[170.049793, "o", "> "]
[170.049898, "o", "            has_security = True\r\n\u001b[?2004l\r"]
[170.049931, "o", "\u001b[?2004h> "]
[170.049964, "o", "    \r\n\u001b[?2004l\r"]
[170.049995, "o", "\u001b[?2004h> "]
[170.050346, "o", "    # If candidate version is different and there's a security repo, likely has update\r\n\u001b[?2004l\r"]
[170.050381, "o", "\u001b[?2004h> "]
[170.050574, "o", "    if installed_version and candidate_version:\r\n\u001b[?2004l\r"]
[170.050605, "o", "\u001b[?2004h> "]
[170.050945, "o", "        if installed_version != candidate_version and installed_version != '(none)':\r\n\u001b[?2004l\r"]
[170.050978, "o", "\u001b[?2004h> "]
[170.05108, "o", "            return True\r\n\u001b[?2004l\r"]
[170.051123, "o", "\u001b[?2004h> "]
[170.051358, "o", "        if has_security and candidate_version != '(none)':\r\n\u001b[?2004l\r"]
[170.051386, "o", "\u001b[?2004h> "]
[170.051497, "o", "            return True\r\n\u001b[?2004l\r"]
[170.051523, "o", "\u001b[?2004h> "]
[170.051558, "o", "    \r\n\u001b[?2004l\r"]
[170.051587, "o", "\u001b[?2004h> "]
[170.051656, "o", "    return False\r\n\u001b[?2004l\r"]
[170.051688, "o", "\u001b[?2004h> \r\n"]
[170.051722, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[170.051776, "o", "def main():\r\n\u001b[?2004l\r"]
[170.051808, "o", "\u001b[?2004h> "]
[170.0519, "o", "    # Read input files\r\n\u001b[?2004l\r"]
[170.051933, "o", "\u001b[?2004h> "]
[170.052153, "o", "    with open('installed_packages.txt', 'r') as f:\r\n\u001b[?2004l\r"]
[170.052186, "o", "\u001b[?2004h> "]
[170.052468, "o", "        installed = set(line.strip() for line in f if line.strip())\r\n\u001b[?2004l\r"]
[170.052503, "o", "\u001b[?2004h> "]
[170.052533, "o", "    \r\n\u001b[?2004l\r"]
[170.052562, "o", "\u001b[?2004h> "]
[170.052764, "o", "    with open('required_packages.txt', 'r') as f:\r\n\u001b[?2004l\r"]
[170.052801, "o", "\u001b[?2004h> "]
[170.053061, "o", "        required = set(line.strip() for line in f if line.strip())\r\n\u001b[?2004l\r"]
[170.053092, "o", "\u001b[?2004h> "]
[170.05314, "o", "    \r\n\u001b[?2004l\r"]
[170.053175, "o", "\u001b[?2004h> "]
[170.053528, "o", "    print(f\"Analyzing {len(installed)} installed and {len(required)} required packages...\")\r\n\u001b[?2004l\r"]
[170.05356, "o", "\u001b[?2004h"]
[170.053588, "o", ">     \r\n\u001b[?2004l\r"]
[170.05362, "o", "\u001b[?2004h> "]
[170.053814, "o", "    # Get all dependencies of required packages\r\n\u001b[?2004l\r"]
[170.053845, "o", "\u001b[?2004h> "]
[170.054201, "o", "    print(\"Collecting dependencies of required packages (up to 3 levels deep)...\")\r\n\u001b[?2004l\r"]
[170.054234, "o", "\u001b[?2004h> "]
[170.054357, "o", "    all_required_deps = set()\r\n\u001b[?2004l\r"]
[170.054389, "o", "\u001b[?2004h> "]
[170.054746, "o", "    dependency_map = defaultdict(set)  # Maps dependency -> set of packages that need it\r\n\u001b[?2004l\r"]
[170.054779, "o", "\u001b[?2004h> "]
[170.054807, "o", "    \r\n\u001b[?2004l\r"]
[170.054836, "o", "\u001b[?2004h> "]
[170.05503, "o", "    for i, pkg in enumerate(sorted(required), 1):\r\n\u001b[?2004l\r"]
[170.055063, "o", "\u001b[?2004h> "]
[170.055377, "o", "        print(f\"  [{i}/{len(required)}] Analyzing dependencies of {pkg}...\")\r\n\u001b[?2004l\r"]
[170.055411, "o", "\u001b[?2004h> "]
[170.05561, "o", "        deps = get_dependencies(pkg, max_depth=3)\r\n\u001b[?2004l\r"]
[170.055638, "o", "\u001b[?2004h> "]
[170.055864, "o", "        print(f\"      Found {len(deps)} dependencies\")\r\n\u001b[?2004l\r"]
[170.055894, "o", "\u001b[?2004h> "]
[170.056, "o", "        for dep in deps:\r\n\u001b[?2004l\r"]
[170.056029, "o", "\u001b[?2004h> "]
[170.0562, "o", "            all_required_deps.add(dep)\r\n\u001b[?2004l\r"]
[170.056231, "o", "\u001b[?2004h> "]
[170.056407, "o", "            dependency_map[dep].add(pkg)\r\n\u001b[?2004l\r"]
[170.056437, "o", "\u001b[?2004h> "]
[170.056465, "o", "    \r\n\u001b[?2004l\r"]
[170.056494, "o", "\u001b[?2004h> "]
[170.056885, "o", "    print(f\"\\nFound {len(all_required_deps)} unique dependencies across all required packages\")\r\n\u001b[?2004l\r"]
[170.056903, "o", "\u001b[?2004h"]
[170.056934, "o", ">     "]
[170.056964, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[170.056995, "o", "> "]
[170.057145, "o", "    # Identify truly removable packages\r\n\u001b[?2004l\r"]
[170.057179, "o", "\u001b[?2004h> "]
[170.057377, "o", "    potentially_removable = installed - required\r\n\u001b[?2004l\r"]
[170.057426, "o", "\u001b[?2004h> "]
[170.057538, "o", "    dependency_protected = []\r\n\u001b[?2004l\r"]
[170.057569, "o", "\u001b[?2004h> "]
[170.057683, "o", "    removable_packages = []\r\n\u001b[?2004l\r"]
[170.057711, "o", "\u001b[?2004h> "]
[170.057739, "o", "    \r\n\u001b[?2004l\r"]
[170.05777, "o", "\u001b[?2004h> "]
[170.058135, "o", "    print(f\"\\nAnalyzing {len(potentially_removable)} potentially removable packages...\")\r\n\u001b[?2004l\r"]
[170.058169, "o", "\u001b[?2004h> "]
[170.058423, "o", "    for i, pkg in enumerate(sorted(potentially_removable), 1):\r\n\u001b[?2004l\r"]
[170.058451, "o", "\u001b[?2004h"]
[170.05848, "o", "> "]
[170.058743, "o", "        print(f\"  [{i}/{len(potentially_removable)}] {pkg}...\", end=' ')\r\n\u001b[?2004l\r"]
[170.058772, "o", "\u001b[?2004h> "]
[170.058923, "o", "        if pkg in all_required_deps:\r\n\u001b[?2004l\r"]
[170.058953, "o", "\u001b[?2004h> "]
[170.059224, "o", "            # This package is a dependency of a required package\r\n\u001b[?2004l\r"]
[170.059267, "o", "\u001b[?2004h> "]
[170.059514, "o", "            required_by_list = sorted(list(dependency_map[pkg]))\r\n\u001b[?2004l\r"]
[170.059546, "o", "\u001b[?2004h> "]
[170.059712, "o", "            dependency_protected.append({\r\n\u001b[?2004l\r"]
[170.059736, "o", "\u001b[?2004h"]
[170.059767, "o", "> "]
[170.059868, "o", "                \"name\": pkg,\r\n\u001b[?2004l\r"]
[170.059896, "o", "\u001b[?2004h> "]
[170.060093, "o", "                \"required_by\": required_by_list\r\n\u001b[?2004l\r"]
[170.060141, "o", "\u001b[?2004h> "]
[170.060195, "o", "            })\r\n\u001b[?2004l\r"]
[170.060226, "o", "\u001b[?2004h> "]
[170.060718, "o", "            print(f\"PROTECTED (required by: {', '.join(required_by_list[:3])}{'...' if len(required_by_list) > 3 else ''})\")\r\n\u001b[?2004l\r"]
[170.060748, "o", "\u001b[?2004h> "]
[170.060792, "o", "        else:\r\n\u001b[?2004l\r"]
[170.060818, "o", "\u001b[?2004h"]
[170.06085, "o", "> "]
[170.060939, "o", "            # This package can be removed\r\n\u001b[?2004l\r"]
[170.060999, "o", "\u001b[?2004h> "]
[170.061092, "o", "            size_kb = get_package_size(pkg)\r\n\u001b[?2004l\r"]
[170.061124, "o", "\u001b[?2004h"]
[170.061156, "o", "> "]
[170.061264, "o", "            version = get_package_version(pkg)\r\n\u001b[?2004l\r"]
[170.06129, "o", "\u001b[?2004h"]
[170.06132, "o", "> "]
[170.061435, "o", "            has_update = has_security_update(pkg)\r\n\u001b[?2004l\r"]
[170.061467, "o", "\u001b[?2004h> "]
[170.061502, "o", "            \r\n\u001b[?2004l\r"]
[170.061534, "o", "\u001b[?2004h> "]
[170.061644, "o", "            removable_packages.append({\r\n\u001b[?2004l\r"]
[170.061676, "o", "\u001b[?2004h> "]
[170.06175, "o", "                \"name\": pkg,\r\n\u001b[?2004l\r"]
[170.061764, "o", "\u001b[?2004h"]
[170.061801, "o", "> "]
[170.061906, "o", "                \"installed_version\": version,\r\n\u001b[?2004l\r"]
[170.061935, "o", "\u001b[?2004h> "]
[170.062033, "o", "                \"size_kb\": size_kb,\r\n\u001b[?2004l\r"]
[170.062061, "o", "\u001b[?2004h> "]
[170.062215, "o", "                \"has_security_update\": has_update\r\n\u001b[?2004l\r"]
[170.062239, "o", "\u001b[?2004h> "]
[170.062287, "o", "            })\r\n\u001b[?2004l\r"]
[170.062312, "o", "\u001b[?2004h> "]
[170.06252, "o", "            print(f\"REMOVABLE (size: {size_kb} KB, version: {version})\")\r\n\u001b[?2004l\r"]
[170.062545, "o", "\u001b[?2004h"]
[170.06258, "o", ">     \r\n\u001b[?2004l\r"]
[170.062611, "o", "\u001b[?2004h> "]
[170.062652, "o", "    # Sort arrays\r\n\u001b[?2004l\r"]
[170.06268, "o", "\u001b[?2004h"]
[170.062712, "o", "> "]
[170.062828, "o", "    removable_packages.sort(key=lambda x: x['name'])\r\n\u001b[?2004l\r"]
[170.062856, "o", "\u001b[?2004h> "]
[170.063011, "o", "    dependency_protected.sort(key=lambda x: x['name'])\r\n\u001b[?2004l\r"]
[170.063042, "o", "\u001b[?2004h> "]
[170.063073, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[170.063103, "o", "> "]
[170.063197, "o", "    # Calculate total space savings\r\n\u001b[?2004l\r"]
[170.063226, "o", "\u001b[?2004h> "]
[170.063437, "o", "    total_space_savings = sum(pkg['size_kb'] for pkg in removable_packages)\r\n\u001b[?2004l\r"]
[170.063468, "o", "\u001b[?2004h> "]
[170.063495, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[170.063524, "o", "> "]
[170.063569, "o", "    # Create report\r\n\u001b[?2004l\r"]
[170.063602, "o", "\u001b[?2004h> "]
[170.06364, "o", "    report = {\r\n\u001b[?2004l\r"]
[170.063672, "o", "\u001b[?2004h> "]
[170.063731, "o", "        \"summary\": {\r\n\u001b[?2004l\r"]
[170.063763, "o", "\u001b[?2004h> "]
[170.063891, "o", "            \"total_installed\": len(installed),\r\n\u001b[?2004l\r"]
[170.063924, "o", "\u001b[?2004h> "]
[170.064047, "o", "            \"total_required\": len(required),\r\n\u001b[?2004l\r"]
[170.064079, "o", "\u001b[?2004h> "]
[170.064242, "o", "            \"removable_count\": len(removable_packages),\r\n\u001b[?2004l\r"]
[170.064275, "o", "\u001b[?2004h> "]
[170.064463, "o", "            \"kept_as_dependencies\": len(dependency_protected),\r\n\u001b[?2004l\r"]
[170.064499, "o", "\u001b[?2004h> "]
[170.06465, "o", "            \"total_space_savings_kb\": total_space_savings\r\n\u001b[?2004l\r"]
[170.06468, "o", "\u001b[?2004h> "]
[170.064716, "o", "        },\r\n\u001b[?2004l\r"]
[170.064762, "o", "\u001b[?2004h> "]
[170.064885, "o", "        \"removable_packages\": removable_packages,\r\n\u001b[?2004l\r"]
[170.064919, "o", "\u001b[?2004h> "]
[170.065063, "o", "        \"dependency_protected\": dependency_protected\r\n\u001b[?2004l\r"]
[170.065092, "o", "\u001b[?2004h> "]
[170.065132, "o", "    }\r\n\u001b[?2004l\r"]
[170.065171, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[170.065203, "o", "\u001b[?2004h> "]
[170.06527, "o", "    # Write JSON report\r\n\u001b[?2004l\r"]
[170.065303, "o", "\u001b[?2004h> "]
[170.065434, "o", "    with open('removal_report.json', 'w') as f:\r\n\u001b[?2004l\r"]
[170.065463, "o", "\u001b[?2004h> "]
[170.065573, "o", "        json.dump(report, f, indent=2)\r\n\u001b[?2004l\r"]
[170.065602, "o", "\u001b[?2004h> "]
[170.065629, "o", "    \r\n\u001b[?2004l\r"]
[170.065655, "o", "\u001b[?2004h> "]
[170.065723, "o", "    print(f\"\\n{'='*60}\")\r\n\u001b[?2004l\r"]
[170.065752, "o", "\u001b[?2004h> "]
[170.065833, "o", "    print(f\"=== SUMMARY ===\")\r\n\u001b[?2004l\r"]
[170.065864, "o", "\u001b[?2004h> "]
[170.065929, "o", "    print(f\"{'='*60}\")\r\n\u001b[?2004l\r"]
[170.06596, "o", "\u001b[?2004h> "]
[170.066146, "o", "    print(f\"Total installed packages:        {len(installed)}\")\r\n\u001b[?2004l\r"]
[170.066179, "o", "\u001b[?2004h> "]
[170.066353, "o", "    print(f\"Total required packages:         {len(required)}\")\r\n"]
[170.066386, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[170.066584, "o", "    print(f\"Removable packages:              {len(removable_packages)}\")\r\n\u001b[?2004l\r"]
[170.066615, "o", "\u001b[?2004h> "]
[170.066818, "o", "    print(f\"Protected as dependencies:       {len(dependency_protected)}\")\r\n\u001b[?2004l\r"]
[170.06685, "o", "\u001b[?2004h> "]
[170.067153, "o", "    print(f\"Total space savings:             {total_space_savings} KB ({total_space_savings/1024:.2f} MB)\")\r\n\u001b[?2004l\r"]
[170.067186, "o", "\u001b[?2004h> "]
[170.067252, "o", "    print(f\"{'='*60}\")\r\n\u001b[?2004l\r"]
[170.067284, "o", "\u001b[?2004h> "]
[170.067436, "o", "    print(f\"\\nReport written to: removal_report.json\")\r\n\u001b[?2004l\r"]
[170.067468, "o", "\u001b[?2004h> "]
[170.0675, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[170.06753, "o", "> "]
[170.067594, "o", "    # Create removal script\r\n\u001b[?2004l\r"]
[170.067626, "o", "\u001b[?2004h> "]
[170.067753, "o", "    with open('remove_packages.sh', 'w') as f:\r\n\u001b[?2004l\r"]
[170.067785, "o", "\u001b[?2004h> "]
[170.067875, "o", "        f.write('#!/bin/bash\\n')\r\n\u001b[?2004l\r"]
[170.067907, "o", "\u001b[?2004h> "]
[170.068074, "o", "        f.write('# Auto-generated package removal script\\n')\r\n\u001b[?2004l\r"]
[170.068106, "o", "\u001b[?2004h> "]
[170.068326, "o", "        f.write('# This script removes packages identified as unnecessary\\n')\r\n\u001b[?2004l\r"]
[170.068358, "o", "\u001b[?2004h> "]
[170.068629, "o", "        f.write(f'# Generated for migration - removes {len(removable_packages)} packages\\n\\n')\r\n\u001b[?2004l\r"]
[170.068662, "o", "\u001b[?2004h> "]
[170.06869, "o", "        \r\n\u001b[?2004l\r"]
[170.068722, "o", "\u001b[?2004h> "]
[170.068802, "o", "        if removable_packages:\r\n\u001b[?2004l\r"]
[170.068834, "o", "\u001b[?2004h> "]
[170.069038, "o", "            pkg_list = ' '.join(pkg['name'] for pkg in removable_packages)\r\n\u001b[?2004l\r"]
[170.06907, "o", "\u001b[?2004h> "]
[170.06921, "o", "            f.write('# Packages to remove:\\n')\r\n\u001b[?2004l\r"]
[170.069243, "o", "\u001b[?2004h> "]
[170.069359, "o", "            for pkg in removable_packages:\r\n\u001b[?2004l\r"]
[170.069389, "o", "\u001b[?2004h> "]
[170.069687, "o", "                f.write(f'#   - {pkg[\"name\"]} ({pkg[\"size_kb\"]} KB, version: {pkg[\"installed_version\"]})\\n')\r\n\u001b[?2004l\r"]
[170.108992, "o", "\u001b[?2004h>             f.write(f'\\n# Total space to reclaim: {total_space_savings} KB ({total_space_savings/1024:.2f} MB)\\n\\n')\r\n\u001b[?2004l\r\u001b[?2004h>             f.write('echo \"========================================\"\\n')\r\n\u001b[?2004l\r\u001b[?2004h>             f.write('echo \"Package Removal Script\"\\n')\r\n\u001b[?2004l\r\u001b[?2004h>             f.write('echo \"========================================\"\\n')\r\n\u001b[?2004l\r\u001b[?2004h>             f.write('echo \"This will remove the following packages:\"\\n')\r\n\u001b[?2004l\r\u001b[?2004h>             f.write(f'echo \"{pkg_list}\"\\n')\r\n\u001b[?2004l\r\u001b[?2004h>             f.write('echo \"\"\\n')\r\n\u001b[?2004l\r\u001b[?2004h>             f.write(f'echo \"Total packages to remove: {len(removable_packages)}\"\\n')\r\n\u001b[?2004l\r\u001b[?2004h>             f.write(f'echo \"Total space to reclaim: {total_space_savings} KB ({total_space_savings/1024:.2f} MB)\"\\n')\r\n\u001b[?2004l\r\u001b[?2004h>             f.write('echo \"\"\\n')\r\n\u001b[?2004l\r\u001b[?2004h> "]
[170.109086, "o", "            f.write('echo \"Dry run command (safe to test):\"\\n')\r\n\u001b[?2004l\r"]
[170.109132, "o", "\u001b[?2004h> "]
[170.109321, "o", "            f.write(f'echo \"  apt-get remove --dry-run {pkg_list}\"\\n')\r\n\u001b[?2004l\r"]
[170.109352, "o", "\u001b[?2004h"]
[170.109383, "o", "> "]
[170.109446, "o", "            f.write('echo \"\"\\n')\r\n\u001b[?2004l\r"]
[170.109474, "o", "\u001b[?2004h> "]
[170.109701, "o", "            f.write('read -p \"Proceed with actual removal? (yes/no): \" confirm\\n')\r\n\u001b[?2004l\r"]
[170.109735, "o", "\u001b[?2004h> "]
[170.109884, "o", "            f.write('if [ \"$confirm\" = \"yes\" ]; then\\n')\r\n\u001b[?2004l\r"]
[170.109916, "o", "\u001b[?2004h> "]
[170.110077, "o", "            f.write(f'    apt-get remove -y {pkg_list}\\n')\r\n\u001b[?2004l\r"]
[170.110108, "o", "\u001b[?2004h> "]
[170.110303, "o", "            f.write('    echo \"Packages removed successfully!\"\\n')\r\n\u001b[?2004l\r"]
[170.110332, "o", "\u001b[?2004h"]
[170.11036, "o", "> "]
[170.110418, "o", "            f.write('else\\n')\r\n\u001b[?2004l\r"]
[170.110451, "o", "\u001b[?2004h> "]
[170.110598, "o", "            f.write('    echo \"Removal cancelled.\"\\n')\r\n\u001b[?2004l\r"]
[170.110629, "o", "\u001b[?2004h> "]
[170.110704, "o", "            f.write('fi\\n')\r\n\u001b[?2004l\r"]
[170.110735, "o", "\u001b[?2004h> "]
[170.110776, "o", "        else:\r\n\u001b[?2004l\r"]
[170.110807, "o", "\u001b[?2004h> "]
[170.111103, "o", "            f.write('echo \"No packages to remove - all installed packages are required or dependencies.\"\\n')\r\n\u001b[?2004l\r"]
[170.111145, "o", "\u001b[?2004h> "]
[170.111177, "o", "    \r\n\u001b[?2004l\r"]
[170.111204, "o", "\u001b[?2004h> "]
[170.111273, "o", "    # Make script executable\r\n\u001b[?2004l\r"]
[170.111305, "o", "\u001b[?2004h> "]
[170.111466, "o", "    subprocess.run(['chmod', '+x', 'remove_packages.sh'])\r\n\u001b[?2004l\r"]
[170.111504, "o", "\u001b[?2004h> "]
[170.111669, "o", "    print(f\"Removal script written to: remove_packages.sh\\n\")\r\n\u001b[?2004l\r"]
[170.111702, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[170.111731, "o", "\u001b[?2004h> "]
[170.111807, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[170.111839, "o", "\u001b[?2004h> "]
[170.111871, "o", "    main()\r\n\u001b[?2004l\r"]
[170.111908, "o", "\u001b[?2004h"]
[170.111946, "o", "> EOF\r\n\u001b[?2004l\r"]
[170.113149, "o", "\u001b[?2004h"]
[170.11318, "o", "user@99146165c8f1:~/migration$ "]
[170.133724, "i", "chmod +x analyze_packages_v2.py\n"]
[170.133851, "o", "chmod +x analyze_packages_v2.py\r\n\u001b[?2004l\r"]
[170.134862, "o", "\u001b[?2004huser@99146165c8f1:~/migration$ "]
[170.242219, "i", "python3 analyze_packages_v2.py\n"]
[170.242351, "o", "python3 analyze_packages_v2.py\r\n"]
