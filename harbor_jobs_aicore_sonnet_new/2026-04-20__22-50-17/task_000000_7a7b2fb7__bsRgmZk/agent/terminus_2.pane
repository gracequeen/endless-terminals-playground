[?2004l[?2004h> def has_security_update(package):
[?2004l[?2004h>     """Check if package has security update available"""
[?2004l[?2004h>     output = run_command(f"apt-cache policy {package} 2>/dev/null", timeout=2)
[?2004l[?2004h>     if not output:
[?2004l[?2004h>         return False
[?2004l[?2004h>         
[?2004l[?2004h>     lines = output.split('\n')
[?2004l[?2004h>     
[?2004l[?2004h>     installed_version = None
[?2004l[?2004h>     candidate_version = None
[?2004l[?2004h>     has_security = False
[?2004l[?2004h>     
[?2004l[?2004h>     for line in lines:
[?2004l[?2004h>         if 'Installed:' in line:
[?2004l[?2004h>             installed_version = line.split(':', 1)[1].strip()
[?2004l[?2004h>         elif 'Candidate:' in line:
[?2004l[?2004h>             candidate_version = line.split(':', 1)[1].strip()
[?2004l[?2004h>         elif 'security' in line.lower():
[?2004l[?2004h>             has_security = True
[?2004l[?2004h>     
[?2004l[?2004h>     # If candidate version is different and there's a security repo, likely has update
[?2004l[?2004h>     if installed_version and candidate_version:
[?2004l[?2004h>         if installed_version != candidate_version and installed_version != '(none)':
[?2004l[?2004h>             return True
[?2004l[?2004h>         if has_security and candidate_version != '(none)':
[?2004l[?2004h>             return True
[?2004l[?2004h>     
[?2004l[?2004h>     return False
[?2004l[?2004h> 
[?2004l[?2004h> def main():
[?2004l[?2004h>     # Read input files
[?2004l[?2004h>     with open('installed_packages.txt', 'r') as f:
[?2004l[?2004h>         installed = set(line.strip() for line in f if line.strip())
[?2004l[?2004h>     
[?2004l[?2004h>     with open('required_packages.txt', 'r') as f:
[?2004l[?2004h>         required = set(line.strip() for line in f if line.strip())
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"Analyzing {len(installed)} installed and {len(required)} required packages...")
[?2004l[?2004h>     
[?2004l[?2004h>     # Get all dependencies of required packages
[?2004l[?2004h>     print("Collecting dependencies of required packages (up to 3 levels deep)...")
[?2004l[?2004h>     all_required_deps = set()
[?2004l[?2004h>     dependency_map = defaultdict(set)  # Maps dependency -> set of packages that need it
[?2004l[?2004h>     
[?2004l[?2004h>     for i, pkg in enumerate(sorted(required), 1):
[?2004l[?2004h>         print(f"  [{i}/{len(required)}] Analyzing dependencies of {pkg}...")
[?2004l[?2004h>         deps = get_dependencies(pkg, max_depth=3)
[?2004l[?2004h>         print(f"      Found {len(deps)} dependencies")
[?2004l[?2004h>         for dep in deps:
[?2004l[?2004h>             all_required_deps.add(dep)
[?2004l[?2004h>             dependency_map[dep].add(pkg)
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"\nFound {len(all_required_deps)} unique dependencies across all required packages")
[?2004l[?2004h>     
[?2004l[?2004h>     # Identify truly removable packages
[?2004l[?2004h>     potentially_removable = installed - required
[?2004l[?2004h>     dependency_protected = []
[?2004l[?2004h>     removable_packages = []
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"\nAnalyzing {len(potentially_removable)} potentially removable packages...")
[?2004l[?2004h>     for i, pkg in enumerate(sorted(potentially_removable), 1):
[?2004l[?2004h>         print(f"  [{i}/{len(potentially_removable)}] {pkg}...", end=' ')
[?2004l[?2004h>         if pkg in all_required_deps:
[?2004l[?2004h>             # This package is a dependency of a required package
[?2004l[?2004h>             required_by_list = sorted(list(dependency_map[pkg]))
[?2004l[?2004h>             dependency_protected.append({
[?2004l[?2004h>                 "name": pkg,
[?2004l[?2004h>                 "required_by": required_by_list
[?2004l[?2004h>             })
[?2004l[?2004h>             print(f"PROTECTED (required by: {', '.join(required_by_list[:3])}{'...' if len(required_by_list) > 3 else ''})")
[?2004l[?2004h>         else:
[?2004l[?2004h>             # This package can be removed
[?2004l[?2004h>             size_kb = get_package_size(pkg)
[?2004l[?2004h>             version = get_package_version(pkg)
[?2004l[?2004h>             has_update = has_security_update(pkg)
[?2004l[?2004h>             
[?2004l[?2004h>             removable_packages.append({
[?2004l[?2004h>                 "name": pkg,
[?2004l[?2004h>                 "installed_version": version,
[?2004l[?2004h>                 "size_kb": size_kb,
[?2004l[?2004h>                 "has_security_update": has_update
[?2004l[?2004h>             })
[?2004l[?2004h>             print(f"REMOVABLE (size: {size_kb} KB, version: {version})")
[?2004l[?2004h>     
[?2004l[?2004h>     # Sort arrays
[?2004l[?2004h>     removable_packages.sort(key=lambda x: x['name'])
[?2004l[?2004h>     dependency_protected.sort(key=lambda x: x['name'])
[?2004l[?2004h>     
[?2004l[?2004h>     # Calculate total space savings
[?2004l[?2004h>     total_space_savings = sum(pkg['size_kb'] for pkg in removable_packages)
[?2004l[?2004h>     
[?2004l[?2004h>     # Create report
[?2004l[?2004h>     report = {
[?2004l[?2004h>         "summary": {
[?2004l[?2004h>             "total_installed": len(installed),
[?2004l[?2004h>             "total_required": len(required),
[?2004l[?2004h>             "removable_count": len(removable_packages),
[?2004l[?2004h>             "kept_as_dependencies": len(dependency_protected),
[?2004l[?2004h>             "total_space_savings_kb": total_space_savings
[?2004l[?2004h>         },
[?2004l[?2004h>         "removable_packages": removable_packages,
[?2004l[?2004h>         "dependency_protected": dependency_protected
[?2004l[?2004h>     }
[?2004l[?2004h>     
[?2004l[?2004h>     # Write JSON report
[?2004l[?2004h>     with open('removal_report.json', 'w') as f:
[?2004l[?2004h>         json.dump(report, f, indent=2)
[?2004l[?2004h>     
[?2004l[?2004h>     print(f"\n{'='*60}")
[?2004l[?2004h>     print(f"=== SUMMARY ===")
[?2004l[?2004h>     print(f"{'='*60}")
[?2004l[?2004h>     print(f"Total installed packages:        {len(installed)}")
[?2004l[?2004h>     print(f"Total required packages:         {len(required)}")
[?2004l[?2004h>     print(f"Removable packages:              {len(removable_packages)}")
[?2004l[?2004h>     print(f"Protected as dependencies:       {len(dependency_protected)}")
[?2004l[?2004h>     print(f"Total space savings:             {total_space_savings} KB ({total_space_savings/1024:.2f} MB)")
[?2004l[?2004h>     print(f"{'='*60}")
[?2004l[?2004h>     print(f"\nReport written to: removal_report.json")
