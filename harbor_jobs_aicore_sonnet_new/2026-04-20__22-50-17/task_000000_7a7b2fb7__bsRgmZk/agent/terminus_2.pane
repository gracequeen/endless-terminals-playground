[?2004l[?2004h> def get_package_version(package):
[?2004l[?2004h>     """Get installed version of package"""
[?2004l[?2004h>     output = run_command(f"dpkg-query -W -f='${{Version}}' {package} 2>/dev/null", timeout=2)
[?2004l[?2004h>     version = output.strip()
[?2004l[?2004h>     if version:
[?2004l[?2004h>         return version
[?2004l[?2004h>     return "unknown"
