[19.43106, "i", "sqlite3 -header -csv employees.db \"SELECT e.id, e.name, e.department, e.salary, ROUND(d.avg_salary, 2) as dept_average FROM employees e JOIN (SELECT department, AVG(salary) as avg_salary FROM employees GROUP BY department) d ON e.department = d.department WHERE e.salary > d.avg_salary * 1.2 ORDER BY e.department ASC, e.salary DESC;\" > salary_outliers.csv\n"]
