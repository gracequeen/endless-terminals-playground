[72.627472, "o", "    dir_bytes[subdir] += $1\r\n\u001b[?2004l\r"]
[72.6275, "o", "\u001b[?2004h> "]
[72.627549, "o", "    total += $1\r\n\u001b[?2004l\r"]
[72.627578, "o", "\u001b[?2004h> "]
[72.627633, "o", "  }\r\n\u001b[?2004l\r\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[72.627688, "o", "\u001b[?2004h> END {\r\n\u001b[?2004l\r"]
[72.627717, "o", "\u001b[?2004h> "]
[72.627792, "o", "  for (dir in dir_bytes) {\r\n\u001b[?2004l\r"]
[72.627823, "o", "\u001b[?2004h> "]
[72.627935, "o", "    pct = (dir_bytes[dir] / total) * 100\r\n\u001b[?2004l\r"]
[72.627965, "o", "\u001b[?2004h> "]
[72.628119, "o", "    printf \"%s %d %.1f%%\\n\", dir, dir_bytes[dir], pct\r\n\u001b[?2004l\r"]
[72.628148, "o", "\u001b[?2004h"]
[72.628193, "o", ">   }\r\n\u001b[?2004l\r"]
[72.628228, "o", "\u001b[?2004h> "]
[72.628482, "o", "}' /home/user/disk_inventory.txt | sort -k2,2rn > /home/user/reports/directory_rollup.txt\r\n\u001b[?2004l\r"]
