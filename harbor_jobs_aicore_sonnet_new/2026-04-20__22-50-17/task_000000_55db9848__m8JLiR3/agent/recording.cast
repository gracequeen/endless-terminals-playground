[64.624918, "i", "awk '\n# Skip directory entries themselves\n$2 !~ /\\/(logs|backups|cache|uploads|archives)$/ && $2 != \"/var/data\" {\n  # Extract immediate subdirectory\n  if (match($2, /^\\/var\\/data\\/([^\\/]+)/, arr)) {\n    subdir = arr[1]\n    dir_bytes[subdir] += $1\n    total += $1\n  }\n}\nEND {\n  for (dir in dir_bytes) {\n    pct = (dir_bytes[dir] / total) * 100\n    printf \"%s %d %.1f%%\\n\", dir, dir_bytes[dir], pct\n  }\n}' /home/user/disk_inventory.txt | sort -k2,2rn\n"]
