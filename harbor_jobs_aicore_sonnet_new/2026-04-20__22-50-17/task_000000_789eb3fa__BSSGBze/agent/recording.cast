[18.73252, "i", "cat > verify_permissions.sh << 'SCRIPT'\n#!/bin/bash\n\n# Read manifest and verify permissions\nmanifest=\"/home/user/docs_workspace/permissions_manifest.txt\"\n\n# Parse directory permissions\nwhile IFS=: read -r path perm; do\n    if [[ \"$path\" == \"/home/user/docs_workspace/\"* ]] && [[ -d \"$path\" ]]; then\n        actual=$(stat -c '%a' \"$path\")\n        if [[ \"$actual\" != \"$perm\" ]]; then\n            echo \"FAIL: $path\"\n            exit 1\n        fi\n    fi\ndone < <(sed -n '/^DIRECTORY_PERMISSIONS:/,/^$/p' \"$manifest\" | grep '^/home')\n\n# Parse file permissions\nwhile IFS=: read -r path perm; do\n    if [[ \"$path\" == \"/home/user/docs_workspace/\"* ]] && [[ -f \"$path\" ]]; then\n        actual=$(stat -c '%a' \"$path\")\n        if [[ \"$actual\" != \"$perm\" ]]; then\n            echo \"FAIL: $path\"\n            exit 1\n        fi\n    fi\ndone < <(sed -n '/^FILE_PERMISSIONS:/,/^$/p' \"$manifest\" | grep '^/home')\n\necho \"PASS\"\nexit 0\nSCRIPT\n"]
