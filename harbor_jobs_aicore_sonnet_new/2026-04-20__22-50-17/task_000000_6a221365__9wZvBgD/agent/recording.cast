[32.080871, "o", "        return False, \"invalid_format\", f\"invalid transaction_id format: {record['transaction_id']}\"\r\n\u001b[?2004l\r"]
[32.080915, "o", "\u001b[?2004h> "]
[32.080949, "o", "    \r\n\u001b[?2004l\r"]
[32.080979, "o", "\u001b[?2004h> "]
[32.081087, "o", "    # Validate timestamp\r\n\u001b[?2004l\r"]
[32.081119, "o", "\u001b[?2004h"]
[32.081164, "o", "> "]
[32.081335, "o", "    if not isinstance(record['timestamp'], str):\r\n\u001b[?2004l\r"]
[32.081365, "o", "\u001b[?2004h"]
[32.081397, "o", "> "]
[32.081655, "o", "        return False, \"invalid_format\", \"timestamp must be string\"\r\n\u001b[?2004l\r"]
[32.081687, "o", "\u001b[?2004h> "]
[32.081914, "o", "    if not validate_iso8601(record['timestamp']):\r\n\u001b[?2004l\r"]
[32.081948, "o", "\u001b[?2004h> "]
[32.082302, "o", "        return False, \"invalid_format\", f\"invalid timestamp format: {record['timestamp']}\"\r\n\u001b[?2004l\r"]
[32.082336, "o", "\u001b[?2004h> "]
[32.082369, "o", "    \r\n\u001b[?2004l\r"]
[32.082402, "o", "\u001b[?2004h> "]
[32.082511, "o", "    # Validate account_id\r\n"]
[32.082544, "o", "\u001b[?2004l\r\u001b[?2004h"]
[32.082578, "o", "> "]
[32.08276, "o", "    if not isinstance(record['account_id'], str):\r\n\u001b[?2004l\r"]
[32.082799, "o", "\u001b[?2004h> "]
[32.083082, "o", "        return False, \"invalid_format\", \"account_id must be string\"\r\n\u001b[?2004l\r"]
[32.083115, "o", "\u001b[?2004h"]
[32.083142, "o", "> "]
[32.083285, "o", "    if record['account_id'] == \"\":\r\n\u001b[?2004l\r"]
[32.083324, "o", "\u001b[?2004h"]
[32.083354, "o", "> "]
[32.083635, "o", "        return False, \"invalid_value\", \"account_id cannot be empty\"\r\n\u001b[?2004l\r"]
[32.083673, "o", "\u001b[?2004h> "]
[32.083705, "o", "    \r\n"]
[32.083738, "o", "\u001b[?2004l\r\u001b[?2004h"]
[32.08377, "o", "> "]
[32.083839, "o", "    # Validate amount\r\n\u001b[?2004l\r"]
[32.083871, "o", "\u001b[?2004h"]
[32.083909, "o", "> "]
[32.084133, "o", "    if not isinstance(record['amount'], (int, float)):\r\n\u001b[?2004l\r"]
[32.084167, "o", "\u001b[?2004h> "]
[32.084649, "o", "        return False, \"invalid_format\", f\"amount must be number, got: {type(record['amount']).__name__}\"\r\n\u001b[?2004l\r"]
[32.084689, "o", "\u001b[?2004h> "]
[32.08472, "o", "    \r\n\u001b[?2004l\r"]
[32.08475, "o", "\u001b[?2004h"]
[32.084778, "o", "> "]
[32.084857, "o", "    # Validate currency\r\n\u001b[?2004l\r"]
[32.084899, "o", "\u001b[?2004h"]
[32.084931, "o", "> "]
[32.085111, "o", "    if not isinstance(record['currency'], str):\r\n\u001b[?2004l\r"]
[32.08515, "o", "\u001b[?2004h"]
[32.08518, "o", "> "]
[32.085429, "o", "        return False, \"invalid_format\", \"currency must be string\"\r\n\u001b[?2004l\r"]
[32.085461, "o", "\u001b[?2004h"]
[32.085491, "o", "> "]
[32.085692, "o", "    if not CURRENCY_PATTERN.match(record['currency']):\r\n\u001b[?2004l\r"]
[32.085724, "o", "\u001b[?2004h> "]
[32.086094, "o", "        return False, \"invalid_format\", f\"invalid currency format: {record['currency']}\"\r\n\u001b[?2004l\r"]
[32.086128, "o", "\u001b[?2004h"]
[32.08616, "o", ">     \r\n\u001b[?2004l\r"]
[32.086194, "o", "\u001b[?2004h> "]
[32.086289, "o", "    # Validate status\r\n\u001b[?2004l\r"]
[32.086322, "o", "\u001b[?2004h> "]
[32.086511, "o", "    if not isinstance(record['status'], str):\r\n\u001b[?2004l\r"]
[32.086545, "o", "\u001b[?2004h> "]
[32.086806, "o", "        return False, \"invalid_format\", \"status must be string\"\r\n\u001b[?2004l\r"]
[32.08684, "o", "\u001b[?2004h> "]
[32.087058, "o", "    if record['status'] not in ALLOWED_STATUSES:\r\n\u001b[?2004l\r"]
[32.087089, "o", "\u001b[?2004h"]
[32.08712, "o", "> "]
[32.087413, "o", "        return False, \"invalid_value\", f\"invalid status: {record['status']}\"\r\n\u001b[?2004l\r"]
[32.087444, "o", "\u001b[?2004h"]
[32.087478, "o", "> "]
[32.087512, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[32.087621, "o", "    return True, \"\", \"\"\r\n\u001b[?2004l\r"]
[32.087654, "o", "\u001b[?2004h> \r\n"]
[32.087687, "o", "\u001b[?2004l\r\u001b[?2004h"]
[32.087721, "o", "> "]
[32.087952, "o", "def compute_integrity_hash(record: Dict[str, Any]) -> str:\r\n\u001b[?2004l\r"]
[32.087984, "o", "\u001b[?2004h> "]
[32.088194, "o", "    \"\"\"Compute SHA-256 hash of canonical form.\"\"\"\r\n\u001b[?2004l\r"]
[32.088227, "o", "\u001b[?2004h> "]
[32.088457, "o", "    amount_formatted = f\"{float(record['amount']):.2f}\"\r\n\u001b[?2004l\r"]
[32.08849, "o", "\u001b[?2004h> "]
[32.088963, "o", "    canonical = f\"{record['transaction_id']}|{record['timestamp']}|{record['account_id']}|{amount_formatted}|{record['currency']}|{record['status']}\"\r\n\u001b[?2004l\r"]
[32.088994, "o", "\u001b[?2004h> "]
[32.089196, "o", "    return hashlib.sha256(canonical.encode('utf-8')).hexdigest()\r\n\u001b[?2004l\r"]
[32.089227, "o", "\u001b[?2004h"]
[32.089258, "o", "> \r\n\u001b[?2004l\r"]
[32.089291, "o", "\u001b[?2004h> "]
[32.089366, "o", "def process_audit_logs():\r\n\u001b[?2004l\r"]
[32.0894, "o", "\u001b[?2004h> "]
[32.089565, "o", "    input_file = '/home/user/audit/raw_transactions.jsonl'\r\n\u001b[?2004l\r"]
[32.089596, "o", "\u001b[?2004h"]
[32.089625, "o", "> "]
[32.089764, "o", "    output_file = '/home/user/audit/clean_audit.jsonl'\r\n\u001b[?2004l\r"]
[32.089794, "o", "\u001b[?2004h"]
[32.089825, "o", "> "]
[32.08997, "o", "    error_file = '/home/user/audit/error_log.jsonl'\r\n\u001b[?2004l\r"]
[32.090001, "o", "\u001b[?2004h> "]
[32.090174, "o", "    summary_file = '/home/user/audit/processing_summary.txt'\r\n\u001b[?2004l\r"]
[32.090207, "o", "\u001b[?2004h> "]
[32.090238, "o", "    \r\n\u001b[?2004l\r"]
[32.09027, "o", "\u001b[?2004h> "]
[32.09034, "o", "    valid_transactions = []\r\n\u001b[?2004l\r"]
[32.090374, "o", "\u001b[?2004h> "]
[32.090432, "o", "    errors = []\r\n\u001b[?2004l\r"]
[32.090465, "o", "\u001b[?2004h"]
[32.090496, "o", "> "]
[32.09054, "o", "    error_counts = {\r\n\u001b[?2004l\r"]
[32.09057, "o", "\u001b[?2004h"]
[32.090602, "o", "> "]
[32.090671, "o", "        \"malformed_json\": 0,\r\n\u001b[?2004l\r"]
[32.090702, "o", "\u001b[?2004h"]
[32.090732, "o", "> "]
[32.090798, "o", "        \"missing_field\": 0,\r\n"]
[32.090829, "o", "\u001b[?2004l\r\u001b[?2004h"]
[32.090861, "o", "> "]
[32.090941, "o", "        \"invalid_format\": 0,\r\n\u001b[?2004l\r"]
[32.090973, "o", "\u001b[?2004h"]
[32.091003, "o", "> "]
[32.091065, "o", "        \"invalid_value\": 0\r\n\u001b[?2004l\r"]
[32.091098, "o", "\u001b[?2004h> "]
[32.091129, "o", "    }\r\n\u001b[?2004l\r"]
[32.091161, "o", "\u001b[?2004h> "]
[32.091192, "o", "    \r\n\u001b[?2004l\r"]
[32.091223, "o", "\u001b[?2004h> "]
[32.091437, "o", "    processing_timestamp = datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ')\r\n\u001b[?2004l\r"]
[32.091469, "o", "\u001b[?2004h"]
[32.091501, "o", ">     \r\n\u001b[?2004l\r"]
[32.091534, "o", "\u001b[?2004h> "]
[32.091634, "o", "    # Read and process each line\r\n\u001b[?2004l\r"]
[32.091667, "o", "\u001b[?2004h"]
[32.0917, "o", "> "]
[32.091785, "o", "    with open(input_file, 'r') as f:\r\n\u001b[?2004l\r"]
[32.091819, "o", "\u001b[?2004h> "]
[32.091974, "o", "        for line_num, line in enumerate(f, 1):\r\n\u001b[?2004l\r"]
[32.092005, "o", "\u001b[?2004h> "]
[32.092132, "o", "            raw_content = line.rstrip('\\n')\r\n\u001b[?2004l\r"]
[32.092154, "o", "\u001b[?2004h"]
[32.092174, "o", "> "]
[32.092222, "o", "            \r\n\u001b[?2004l\r"]
[32.092256, "o", "\u001b[?2004h> "]
[32.092341, "o", "            # Try to parse JSON\r\n\u001b[?2004l\r"]
[32.092374, "o", "\u001b[?2004h"]
[32.092406, "o", "> "]
[32.092438, "o", "            try:\r\n\u001b[?2004l\r"]
[32.092469, "o", "\u001b[?2004h> "]
[32.092616, "o", "                record = json.loads(raw_content)\r\n\u001b[?2004l\r"]
[32.092647, "o", "\u001b[?2004h"]
[32.092679, "o", "> "]
[32.092791, "o", "            except json.JSONDecodeError as e:\r\n\u001b[?2004l\r"]
[32.092824, "o", "\u001b[?2004h"]
[32.092858, "o", "> "]
[32.092944, "o", "                errors.append({\r\n\u001b[?2004l\r"]
[32.092977, "o", "\u001b[?2004h> "]
[32.093104, "o", "                    \"line_number\": line_num,\r\n\u001b[?2004l\r"]
[32.093147, "o", "\u001b[?2004h> "]
[32.093293, "o", "                    \"error_type\": \"malformed_json\",\r\n\u001b[?2004l\r"]
[32.093324, "o", "\u001b[?2004h"]
[32.093357, "o", "> "]
[32.093527, "o", "                    \"error_detail\": f\"JSON parse error: {str(e)}\",\r\n\u001b[?2004l\r"]
[32.093559, "o", "\u001b[?2004h"]
[32.093592, "o", "> "]
[32.093721, "o", "                    \"raw_content\": raw_content[:200]\r\n\u001b[?2004l\r"]
[32.093753, "o", "\u001b[?2004h"]
[32.093784, "o", "> "]
[32.093825, "o", "                })\r\n\u001b[?2004l\r"]
[32.093857, "o", "\u001b[?2004h"]
[32.093902, "o", "> "]
[32.094031, "o", "                error_counts[\"malformed_json\"] += 1\r\n\u001b[?2004l\r"]
[32.094063, "o", "\u001b[?2004h"]
[32.094096, "o", "> "]
[32.09415, "o", "                continue\r\n\u001b[?2004l\r"]
[32.09418, "o", "\u001b[?2004h"]
[32.094212, "o", "> "]
[32.094239, "o", "            \r\n\u001b[?2004l\r"]
[32.09427, "o", "\u001b[?2004h"]
[32.0943, "o", "> "]
[32.09438, "o", "            # Validate the record\r\n"]
[32.094409, "o", "\u001b[?2004l\r\u001b[?2004h"]
[32.09444, "o", "> "]
[32.09467, "o", "            is_valid, error_type, error_detail = validate_transaction(record, line_num)\r\n\u001b[?2004l\r"]
[32.094705, "o", "\u001b[?2004h> "]
[32.094754, "o", "            \r\n\u001b[?2004l\r"]
[32.094787, "o", "\u001b[?2004h"]
[32.094818, "o", "> "]
[32.094896, "o", "            if not is_valid:\r\n\u001b[?2004l\r"]
[32.094925, "o", "\u001b[?2004h"]
[32.094957, "o", "> "]
[32.09503, "o", "                errors.append({\r\n\u001b[?2004l\r"]
[32.095063, "o", "\u001b[?2004h"]
[32.095096, "o", "> "]
[32.095202, "o", "                    \"line_number\": line_num,\r\n\u001b[?2004l\r"]
[32.095233, "o", "\u001b[?2004h"]
[32.095265, "o", "> "]
[32.095376, "o", "                    \"error_type\": error_type,\r\n\u001b[?2004l\r"]
[32.095408, "o", "\u001b[?2004h"]
[32.095438, "o", "> "]
[32.095565, "o", "                    \"error_detail\": error_detail,\r\n\u001b[?2004l\r"]
[32.095596, "o", "\u001b[?2004h> "]
[32.095754, "o", "                    \"raw_content\": raw_content[:200]\r\n\u001b[?2004l\r"]
[32.095781, "o", "\u001b[?2004h"]
[32.09581, "o", "> "]
[32.095856, "o", "                })\r\n\u001b[?2004l\r"]
[32.0959, "o", "\u001b[?2004h"]
[32.095932, "o", "> "]
[32.096044, "o", "                error_counts[error_type] += 1\r\n"]
[32.096075, "o", "\u001b[?2004l\r\u001b[?2004h"]
[32.096107, "o", "> "]
[32.096144, "o", "            else:\r\n\u001b[?2004l\r"]
[32.096175, "o", "\u001b[?2004h"]
[32.096206, "o", "> "]
[32.096383, "o", "                # Valid transaction - compute hash and prepare output\r\n\u001b[?2004l\r"]
[32.096412, "o", "\u001b[?2004h"]
[32.096443, "o", "> "]
[32.096606, "o", "                integrity_hash = compute_integrity_hash(record)\r\n\u001b[?2004l\r"]
[32.09664, "o", "\u001b[?2004h> "]
[32.096745, "o", "                output_record = {\r\n\u001b[?2004l\r"]
[32.096779, "o", "\u001b[?2004h"]
[32.096809, "o", "> "]
[32.096988, "o", "                    \"transaction_id\": record['transaction_id'],\r\n\u001b[?2004l\r"]
[32.097025, "o", "\u001b[?2004h> "]
[32.097185, "o", "                    \"timestamp\": record['timestamp'],\r\n\u001b[?2004l\r"]
[32.097213, "o", "\u001b[?2004h"]
[32.09724, "o", "> "]
[32.097387, "o", "                    \"account_id\": record['account_id'],\r\n\u001b[?2004l\r"]
[32.097421, "o", "\u001b[?2004h"]
[32.097454, "o", "> "]
[32.09757, "o", "                    \"amount\": record['amount'],\r\n\u001b[?2004l\r"]
[32.0976, "o", "\u001b[?2004h"]
[32.097632, "o", "> "]
[32.097761, "o", "                    \"currency\": record['currency'],\r\n\u001b[?2004l\r"]
[32.097794, "o", "\u001b[?2004h"]
[32.097825, "o", "> "]
[32.097959, "o", "                    \"status\": record['status'],\r\n\u001b[?2004l\r"]
[32.09799, "o", "\u001b[?2004h> "]
[32.098144, "o", "                    \"integrity_hash\": integrity_hash,\r\n\u001b[?2004l\r"]
[32.098176, "o", "\u001b[?2004h> "]
[32.098338, "o", "                    \"processed_at\": processing_timestamp\r\n\u001b[?2004l\r"]
[32.09837, "o", "\u001b[?2004h"]
[32.098403, "o", "> "]
[32.098437, "o", "                }\r\n\u001b[?2004l\r"]
[32.09847, "o", "\u001b[?2004h> "]
[32.098639, "o", "                valid_transactions.append(output_record)\r\n\u001b[?2004l\r"]
[32.09867, "o", "\u001b[?2004h"]
[32.098703, "o", ">     \r\n\u001b[?2004l\r"]
[32.098735, "o", "\u001b[?2004h"]
[32.098766, "o", "> "]
[32.098874, "o", "    # Sort valid transactions by timestamp\r\n\u001b[?2004l\r"]
[32.09892, "o", "\u001b[?2004h> "]
[32.099087, "o", "    valid_transactions.sort(key=lambda x: x['timestamp'])\r\n\u001b[?2004l\r"]
[32.099115, "o", "\u001b[?2004h"]
[32.099143, "o", ">     \r\n"]
[32.099174, "o", "\u001b[?2004l\r\u001b[?2004h"]
[32.099207, "o", "> "]
[32.099275, "o", "    # Write clean audit file\r\n\u001b[?2004l\r"]
[32.099304, "o", "\u001b[?2004h"]
[32.099317, "o", "> "]
[32.09943, "o", "    with open(output_file, 'w') as f:\r\n\u001b[?2004l\r"]
[32.099463, "o", "\u001b[?2004h> "]
[32.09959, "o", "        for record in valid_transactions:\r\n\u001b[?2004l\r"]
[32.099622, "o", "\u001b[?2004h"]
[32.099654, "o", "> "]
[32.099772, "o", "            f.write(json.dumps(record) + '\\n')\r\n\u001b[?2004l\r"]
[32.099805, "o", "\u001b[?2004h"]
[32.099838, "o", ">     \r\n\u001b[?2004l\r"]
[32.099871, "o", "\u001b[?2004h> "]
[32.099948, "o", "    # Write error log\r\n\u001b[?2004l\r"]
[32.099978, "o", "\u001b[?2004h> "]
[32.100089, "o", "    with open(error_file, 'w') as f:\r\n\u001b[?2004l\r"]
[32.100121, "o", "\u001b[?2004h"]
[32.100154, "o", "> "]
[32.100219, "o", "        for error in errors:\r\n\u001b[?2004l\r"]
[32.100252, "o", "\u001b[?2004h"]
[32.100286, "o", "> "]
[32.100394, "o", "            f.write(json.dumps(error) + '\\n')\r\n\u001b[?2004l\r"]
[32.100427, "o", "\u001b[?2004h"]
[32.100456, "o", ">     \r\n\u001b[?2004l\r"]
[32.100486, "o", "\u001b[?2004h"]
[32.100514, "o", "> "]
[32.100586, "o", "    # Generate summary report\r\n\u001b[?2004l\r"]
[32.100615, "o", "\u001b[?2004h"]
[32.100646, "o", "> "]
[32.100789, "o", "    total_lines = len(valid_transactions) + len(errors)\r\n\u001b[?2004l\r"]
[32.100821, "o", "\u001b[?2004h"]
[32.100854, "o", "> "]
[32.101099, "o", "    success_rate = (len(valid_transactions) / total_lines * 100) if total_lines > 0 else 0\r\n\u001b[?2004l\r"]
[32.101142, "o", "\u001b[?2004h"]
[32.101171, "o", ">     \r\n\u001b[?2004l\r"]
[32.101202, "o", "\u001b[?2004h"]
[32.101233, "o", "> "]
[32.101327, "o", "    with open(summary_file, 'w') as f:\r\n\u001b[?2004l\r"]
[32.10136, "o", "\u001b[?2004h"]
[32.101392, "o", "> "]
[32.101503, "o", "        f.write(\"AUDIT PROCESSING SUMMARY\\n\")\r\n\u001b[?2004l\r"]
[32.101537, "o", "\u001b[?2004h"]
[32.10157, "o", "> "]
[32.10168, "o", "        f.write(\"========================\\n\")\r\n\u001b[?2004l\r"]
[32.101711, "o", "\u001b[?2004h"]
[32.101744, "o", "> "]
[32.101859, "o", "        f.write(f\"Input file: {input_file}\\n\")\r\n\u001b[?2004l\r"]
[32.101901, "o", "\u001b[?2004h"]
[32.101931, "o", "> "]
[32.102082, "o", "        f.write(f\"Total lines processed: {total_lines}\\n\")\r\n\u001b[?2004l\r"]
[32.102114, "o", "\u001b[?2004h"]
[32.102145, "o", "> "]
[32.102319, "o", "        f.write(f\"Valid transactions: {len(valid_transactions)}\\n\")\r\n\u001b[?2004l\r"]
