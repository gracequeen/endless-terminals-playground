[6.87206, "o", "cat /etc/monitoring/alerts.yaml\r\n\u001b[?2004l\r"]
[6.872964, "o", "# Prometheus alerting rules\r\ngroups:\r\n  - name: service_alerts\r\n    rules:\r\n      - alert: HighLatency\r\n        expr: http_request_duration_seconds > 0.5\r\n        for: 5m\r\n        labels:\r\n          severity: warning\r\n        annotations:\r\n          summary: \"High latency detected on {{ $labels.instance }}\"\r\n\r\n      - alert: ServiceDown\r\n        expr: up == 0\r\n        for: 1m\r\n        labels:\r\n          severity: critical\r\n          team: platform\r\n        annotations:\r\n          summary: \"Service {{ $labels.job }} is down\"\r\n\r\n      - alert: HighMemoryUsage\r\n        expr: node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes < 0.1\r\n        for: 5m\r\n        labels:\r\n          severity: warning\r\n        annotations:\r\n          summary: \"Memory usage critical on {{ $labels.instance }}\"\r\n"]
[6.873129, "o", "\u001b[?2004h"]
[6.873176, "o", "root@fa7e72a3ebb2:/home/user# "]
[6.968785, "i", "cat /etc/monitoring/uptime.toml\n"]
[6.968925, "o", "cat /etc/monitoring/uptime.toml\r\n\u001b[?2004l\r"]
[6.969785, "o", "# Uptime checker daemon configuration\r\n\r\n[global]\r\ncheck_interval = 60\r\nretry_count = 3\r\nlog_level = \"info\"\r\n\r\n[[endpoints]]\r\nname = \"api-gateway\"\r\nurl = \"https://api.example.com/health\"\r\nexpected_status = 204\r\nmethod = \"GET\"\r\n\r\n[[endpoints]]\r\nname = \"auth-service\"\r\nurl = \"https://auth.internal.example.com/ping\"\r\nexpected_status = 200\r\ncritical = false\r\n\r\n[[endpoints]]\r\nname = \"frontend\"\r\nurl = \"https://www.example.com\"\r\nexpected_status = 200\r\n"]
[6.969947, "o", "\u001b[?2004h"]
[6.969976, "o", "root@fa7e72a3ebb2:/home/user# "]
