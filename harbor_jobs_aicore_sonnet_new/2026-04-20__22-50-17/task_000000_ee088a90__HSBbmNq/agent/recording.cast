[29.594958, "i", "cat > generate_report.py << 'EOF'\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\n# Read and parse log files\ndef parse_log_file(filename):\n    entries = []\n    with open(filename, 'r') as f:\n        for line in f:\n            line = line.strip()\n            if line:\n                match = re.match(r'\\[(.*?)\\]\\s+(.*)\\s+\\|\\s+(.*)\\s+\\|\\s+(.*)\\s+\\|\\s+(.*)\\s+\\|\\s+(.*)', line)\n                if match:\n                    timestamp, service, old_key, new_key, status, rotated_by = match.groups()\n                    entries.append({\n                        'timestamp': timestamp,\n                        'service': service,\n                        'old_key': old_key,\n                        'new_key': new_key,\n                        'status': status,\n                        'rotated_by': rotated_by\n                    })\n    return entries\n\n# Parse all log files\naws_entries = parse_log_file('aws-rotation.log')\ndb_entries = parse_log_file('db-rotation.log')\napi_entries = parse_log_file('a"]
[29.595097, "i", "pi-keys.log')\n\n# Sort entries alphabetically by service name\naws_entries.sort(key=lambda x: x['service'])\ndb_entries.sort(key=lambda x: x['service'])\napi_entries.sort(key=lambda x: x['service'])\n\n# Calculate statistics\ndef calc_stats(entries):\n    total = len(entries)\n    success = sum(1 for e in entries if e['status'] == 'SUCCESS')\n    failed = sum(1 for e in entries if e['status'] == 'FAILED')\n    return total, success, failed\n\naws_total, aws_success, aws_failed = calc_stats(aws_entries)\ndb_total, db_success, db_failed = calc_stats(db_entries)\napi_total, api_success, api_failed = calc_stats(api_entries)\n\ntotal_rotations = aws_total + db_total + api_total\n\n# Collect failed rotations\nfailed_rotations = []\nfor entry in aws_entries:\n    if entry['status'] == 'FAILED':\n        failed_rotations.append((entry['service'], 'AWS IAM'))\nfor entry in db_entries:\n    if entry['status'] == 'FAILED':\n        failed_rotations.append((entry['service'], 'Database'))\nfor entry in api_entries:\n    if entry['status'] == 'FAILED"]
[29.59514, "i", "':\n        failed_rotations.append((entry['service'], 'API Keys'))\n\n# Generate markdown report\ngenerated_time = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n\nwith open('ROTATION_REPORT.md', 'w') as f:\n    f.write('# Credential Rotation Report\\n\\n')\n    f.write(f'**Generated:** {generated_time}\\n')\n    f.write(f'**Total Credentials Rotated:** {total_rotations}\\n\\n')\n    \n    f.write('## Summary by Category\\n\\n')\n    f.write('| Category | Count | Success | Failed |\\n')\n    f.write('|----------|-------|---------|--------|\\n')\n    f.write(f'| AWS IAM | {aws_total} | {aws_success} | {aws_failed} |\\n')\n    f.write(f'| Database | {db_total} | {db_success} | {db_failed} |\\n')\n    f.write(f'| API Keys | {api_total} | {api_success} | {api_failed} |\\n\\n')\n    \n    f.write('## Detailed Rotation Log\\n\\n')\n    \n    f.write('### AWS IAM Credentials\\n\\n')\n    f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\\n')\n    f.write('|---------|------------|------------|--------|------------|\\n')\n    for entry in a"]
