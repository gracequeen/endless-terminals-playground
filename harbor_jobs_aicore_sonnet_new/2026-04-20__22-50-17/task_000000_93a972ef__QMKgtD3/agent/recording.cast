[72.942334, "i", "grep -A 3 'alert: HighLatency' /etc/monitoring/alerts.yaml\n"]
[72.942551, "o", "grep -A 3 'alert: HighLatency' /etc/monitoring/alerts.yaml\r\n\u001b[?2004l\r"]
[72.943646, "o", "      - \u001b[01;31m\u001b[Kalert: HighLatency\u001b[m\u001b[K\r\n        expr: http_request_duration_seconds > 0.5\r\n        for: 3m\r\n        labels:\r\n"]
[72.94384, "o", "\u001b[?2004h"]
[72.943878, "o", "root@85ba19c88e12:/home/user# "]
[73.045249, "i", "grep -A 7 'alert: ServiceDown' /etc/monitoring/alerts.yaml\n"]
[73.045456, "o", "grep -A 7 'alert: ServiceDown' /etc/monitoring/alerts.yaml\r\n"]
[73.045502, "o", "\u001b[?2004l\r"]
[73.046561, "o", "      - \u001b[01;31m\u001b[Kalert: ServiceDown\u001b[m\u001b[K\r\n        expr: up == 0\r\n"]
[73.046602, "o", "        for: 1m\r\n        labels:\r\n          severity: critical\r\n          team: platform\r\n          escalation_level: critical\r\n        annotations:\r\n"]
[73.046757, "o", "\u001b[?2004h"]
[73.046787, "o", "root@85ba19c88e12:/home/user# "]
[73.151379, "i", "grep -A 8 'alert: DiskSpaceLow' /etc/monitoring/alerts.yaml\n"]
[73.151594, "o", "grep -A 8 'alert: DiskSpaceLow' /etc/monitoring/alerts.yaml\r\n\u001b[?2004l\r"]
[73.152706, "o", "      - \u001b[01;31m\u001b[Kalert: DiskSpaceLow\u001b[m\u001b[K\r\n        expr: node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} < 0.1\r\n        for: 10m\r\n        labels:\r\n          severity: warning\r\n          team: infrastructure\r\n"]
[73.152764, "o", "        annotations:\r\n          summary: \"Disk space below 10% on {{ $labels.instance }}\"\r\n"]
[73.152935, "o", "\u001b[?2004h"]
[73.152963, "o", "root@85ba19c88e12:/home/user# "]
