[22.595072, "i", "sqlite3 -header -csv employees.db \"SELECT e.id, e.name, e.department, e.salary, ROUND(dept_avg.avg_salary, 2) as dept_average FROM employees e JOIN (SELECT department, AVG(salary) as avg_salary FROM employees GROUP BY department) dept_avg ON e.department = dept_avg.department WHERE e.salary > dept_avg.avg_salary * 1.2 ORDER BY e.department ASC, e.salary DESC;\" > salary_outliers.csv\n"]
[22.596278, "o", "sqlite3 -header -csv employees.db \"SELECT e.id, e.name, e.department, e.salary, ROUND(dept_avg.avg_salary, 2) as dept_average FROM employees e JOIN (SELECT department, AVG(salary) as avg_salary FROM employees GROUP BY department) dept_avg ON e.department = dept_avg.department WHERE e.salary > dept_avg.avg_salary * 1.2 ORDER BY e.department ASC, e.salary DESC;\" > salary_outliers.csv\r\n\u001b[?2004l\r"]
