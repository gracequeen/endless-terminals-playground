[48.106756, "o", "    \"\"\"Get installed version\"\"\"\r\n\u001b[?2004l\r"]
[48.106787, "o", "\u001b[?2004h> "]
[48.106829, "o", "    try:\r\n\u001b[?2004l\r"]
[48.106863, "o", "\u001b[?2004h> "]
[48.10699, "o", "        result = subprocess.run(\r\n\u001b[?2004l\r"]
[48.107022, "o", "\u001b[?2004h> "]
[48.107257, "o", "            ['dpkg-query', '-W', '-f=${Version}', package],\r\n\u001b[?2004l\r"]
[48.107288, "o", "\u001b[?2004h> "]
[48.107507, "o", "            capture_output=True, text=True, timeout=5\r\n\u001b[?2004l\r"]
[48.107542, "o", "\u001b[?2004h> "]
[48.107583, "o", "        )\r\n\u001b[?2004l\r"]
[48.107615, "o", "\u001b[?2004h> "]
[48.107759, "o", "        if result.returncode == 0:\r\n\u001b[?2004l\r"]
[48.107795, "o", "\u001b[?2004h> "]
[48.107959, "o", "            return result.stdout.strip()\r\n\u001b[?2004l\r"]
[48.107993, "o", "\u001b[?2004h> "]
[48.108038, "o", "    except:\r\n"]
[48.108065, "o", "\u001b[?2004l\r\u001b[?2004h"]
[48.108103, "o", "> "]
[48.108135, "o", "        pass\r\n\u001b[?2004l\r"]
[48.108172, "o", "\u001b[?2004h> "]
[48.108247, "o", "    return \"unknown\"\r\n\u001b[?2004l\r"]
[48.108281, "o", "\u001b[?2004h> \r\n"]
[48.108315, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[48.108467, "o", "def has_security_update(package):\r\n\u001b[?2004l\r"]
[48.108502, "o", "\u001b[?2004h> "]
[48.108721, "o", "    \"\"\"Check if package has security update available\"\"\"\r\n\u001b[?2004l\r"]
[48.108753, "o", "\u001b[?2004h> "]
[48.108791, "o", "    try:\r\n\u001b[?2004l\r"]
[48.108824, "o", "\u001b[?2004h> "]
[48.108951, "o", "        result = subprocess.run(\r\n\u001b[?2004l\r"]
[48.108987, "o", "\u001b[?2004h> "]
[48.109167, "o", "            ['apt-cache', 'policy', package],\r\n\u001b[?2004l\r"]
[48.1092, "o", "\u001b[?2004h> "]
[48.109415, "o", "            capture_output=True, text=True, timeout=5\r\n\u001b[?2004l\r"]
[48.109452, "o", "\u001b[?2004h> "]
[48.109486, "o", "        )\r\n\u001b[?2004l\r"]
[48.109519, "o", "\u001b[?2004h> "]
[48.109556, "o", "        \r\n\u001b[?2004l\r"]
[48.109585, "o", "\u001b[?2004h> "]
[48.109806, "o", "        # Check if there's a version from security pocket\r\n\u001b[?2004l\r"]
[48.109841, "o", "\u001b[?2004h> "]
[48.110002, "o", "        if '-security' in result.stdout:\r\n\u001b[?2004l\r"]
[48.110035, "o", "\u001b[?2004h> "]
[48.110212, "o", "            lines = result.stdout.split('\\n')\r\n\u001b[?2004l\r"]
[48.110249, "o", "\u001b[?2004h"]
[48.110283, "o", "> "]
[48.110391, "o", "            installed_version = None\r\n\u001b[?2004l\r"]
[48.110436, "o", "\u001b[?2004h> "]
[48.110584, "o", "            has_newer_security = False\r\n\u001b[?2004l\r"]
[48.110618, "o", "\u001b[?2004h> "]
[48.110668, "o", "            \r\n"]
[48.110705, "o", "\u001b[?2004l\r"]
[48.110739, "o", "\u001b[?2004h> "]
[48.110835, "o", "            for i, line in enumerate(lines):\r\n\u001b[?2004l\r"]
[48.110869, "o", "\u001b[?2004h> "]
[48.110978, "o", "                if 'Installed:' in line:\r\n\u001b[?2004l\r"]
[48.111012, "o", "\u001b[?2004h> "]
[48.111199, "o", "                    installed_version = line.split(':', 1)[1].strip()\r\n\u001b[?2004l\r"]
[48.111231, "o", "\u001b[?2004h> "]
[48.111501, "o", "                if installed_version and installed_version != '(none)' and '-security' in line:\r\n\u001b[?2004l\r"]
[48.111537, "o", "\u001b[?2004h> "]
[48.111723, "o", "                    # Check if there's a version line with security\r\n\u001b[?2004l\r"]
[48.111753, "o", "\u001b[?2004h"]
[48.11178, "o", "> "]
[48.111951, "o", "                    if i > 0 and lines[i-1].strip().startswith('***'):\r\n\u001b[?2004l\r"]
[48.111984, "o", "\u001b[?2004h> "]
[48.11216, "o", "                        continue  # This is the installed version\r\n\u001b[?2004l\r"]
[48.112191, "o", "\u001b[?2004h> "]
[48.112316, "o", "                    has_newer_security = True\r\n\u001b[?2004l\r"]
[48.112349, "o", "\u001b[?2004h> "]
[48.112384, "o", "            \r\n\u001b[?2004l\r"]
[48.11243, "o", "\u001b[?2004h> "]
[48.112526, "o", "            return has_newer_security\r\n\u001b[?2004l\r"]
[48.112557, "o", "\u001b[?2004h> "]
[48.112594, "o", "    except:\r\n\u001b[?2004l\r"]
[48.112627, "o", "\u001b[?2004h> "]
[48.112655, "o", "        pass\r\n\u001b[?2004l\r"]
[48.112686, "o", "\u001b[?2004h> "]
[48.11272, "o", "    \r\n\u001b[?2004l\r"]
[48.112751, "o", "\u001b[?2004h> "]
[48.112782, "o", "    return False\r\n\u001b[?2004l\r"]
[48.112813, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[48.112846, "o", "\u001b[?2004h> "]
[48.112898, "o", "# Read package lists\r\n\u001b[?2004l\r"]
[48.112932, "o", "\u001b[?2004h> "]
[48.113057, "o", "with open('installed_packages.txt', 'r') as f:\r\n\u001b[?2004l\r"]
[48.113085, "o", "\u001b[?2004h> "]
[48.113265, "o", "    installed = set(line.strip() for line in f if line.strip())\r\n\u001b[?2004l\r"]
[48.113301, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[48.113334, "o", "\u001b[?2004h> "]
[48.113465, "o", "with open('required_packages.txt', 'r') as f:\r\n\u001b[?2004l\r"]
[48.1135, "o", "\u001b[?2004h> "]
[48.113667, "o", "    required = set(line.strip() for line in f if line.strip())\r\n\u001b[?2004l\r"]
[48.113701, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[48.113734, "o", "\u001b[?2004h> "]
[48.11386, "o", "print(f\"Installed packages: {len(installed)}\")\r\n\u001b[?2004l\r"]
[48.113897, "o", "\u001b[?2004h"]
[48.113932, "o", "> "]
[48.114014, "o", "print(f\"Required packages: {len(required)}\")\r\n\u001b[?2004l\r"]
[48.114042, "o", "\u001b[?2004h> "]
[48.114069, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[48.114099, "o", "> "]
[48.114216, "o", "# Build dependency tree for all required packages\r\n\u001b[?2004l\r"]
[48.114251, "o", "\u001b[?2004h> "]
[48.114426, "o", "print(\"\\nBuilding dependency trees (up to 3 levels deep)...\")\r\n\u001b[?2004l\r"]
[48.114456, "o", "\u001b[?2004h> "]
[48.114524, "o", "all_dependencies = set()\r\n\u001b[?2004l\r"]
[48.114558, "o", "\u001b[?2004h> "]
[48.114799, "o", "dependency_map = defaultdict(list)  # Maps dependency -> list of packages that require it\r\n\u001b[?2004l\r"]
[48.114832, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[48.114873, "o", "\u001b[?2004h> "]
[48.114925, "o", "for pkg in required:\r\n\u001b[?2004l\r"]
[48.114959, "o", "\u001b[?2004h> "]
[48.115094, "o", "    print(f\"  Analyzing dependencies for: {pkg}\")\r\n\u001b[?2004l\r"]
[48.115129, "o", "\u001b[?2004h> "]
[48.115251, "o", "    deps = get_dependencies(pkg, max_depth=3)\r\n\u001b[?2004l\r"]
[48.115284, "o", "\u001b[?2004h> "]
[48.115374, "o", "    all_dependencies.update(deps)\r\n\u001b[?2004l\r"]
[48.115421, "o", "\u001b[?2004h> "]
[48.115473, "o", "    for dep in deps:\r\n\u001b[?2004l\r"]
[48.115507, "o", "\u001b[?2004h> "]
[48.115614, "o", "        dependency_map[dep].append(pkg)\r\n\u001b[?2004l\r"]
[48.115646, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[48.115691, "o", "\u001b[?2004h> "]
[48.115853, "o", "print(f\"Total dependencies found: {len(all_dependencies)}\")\r\n\u001b[?2004l\r"]
[48.115886, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[48.115918, "o", "\u001b[?2004h> "]
[48.11608, "o", "# Find packages that are in installed but not in required\r\n\u001b[?2004l\r"]
[48.116115, "o", "\u001b[?2004h> "]
[48.116211, "o", "extra_packages = installed - required\r\n\u001b[?2004l\r"]
[48.116247, "o", "\u001b[?2004h"]
[48.116281, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.116424, "o", "# Separate into removable and dependency-protected\r\n\u001b[?2004l\r"]
[48.116457, "o", "\u001b[?2004h> "]
[48.116498, "o", "removable = []\r\n\u001b[?2004l\r"]
[48.116532, "o", "\u001b[?2004h> "]
[48.116598, "o", "dependency_protected = []\r\n\u001b[?2004l\r"]
[48.116636, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[48.116671, "o", "\u001b[?2004h"]
[48.116704, "o", "> "]
[48.116768, "o", "print(\"\\nAnalyzing extra packages...\")\r\n\u001b[?2004l\r"]
[48.116803, "o", "\u001b[?2004h> "]
[48.116895, "o", "for pkg in sorted(extra_packages):\r\n\u001b[?2004l\r"]
[48.11693, "o", "\u001b[?2004h> "]
[48.117013, "o", "    if pkg in all_dependencies:\r\n\u001b[?2004l\r"]
[48.117048, "o", "\u001b[?2004h> "]
[48.117146, "o", "        dependency_protected.append({\r\n\u001b[?2004l\r"]
[48.117183, "o", "\u001b[?2004h"]
[48.117213, "o", "> "]
[48.117248, "o", "            \"name\": pkg,\r\n\u001b[?2004l\r"]
[48.117282, "o", "\u001b[?2004h> "]
[48.11744, "o", "            \"required_by\": sorted(dependency_map[pkg])\r\n\u001b[?2004l\r"]
[48.117476, "o", "\u001b[?2004h> "]
[48.117511, "o", "        })\r\n\u001b[?2004l\r"]
[48.117546, "o", "\u001b[?2004h> "]
[48.117577, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[48.117608, "o", "> "]
[48.117704, "o", "        version = get_package_version(pkg)\r\n\u001b[?2004l\r"]
[48.117738, "o", "\u001b[?2004h> "]
[48.117838, "o", "        size = get_package_size(pkg)\r\n\u001b[?2004l\r"]
[48.117874, "o", "\u001b[?2004h"]
[48.117907, "o", "> "]
[48.118008, "o", "        security_update = has_security_update(pkg)\r\n\u001b[?2004l\r"]
[48.118039, "o", "\u001b[?2004h"]
[48.11807, "o", ">         \r\n\u001b[?2004l\r"]
[48.1181, "o", "\u001b[?2004h> "]
[48.118171, "o", "        removable.append({\r\n\u001b[?2004l\r"]
[48.118205, "o", "\u001b[?2004h> "]
[48.118268, "o", "            \"name\": pkg,\r\n\u001b[?2004l\r"]
[48.118303, "o", "\u001b[?2004h> "]
[48.118423, "o", "            \"installed_version\": version,\r\n\u001b[?2004l\r"]
[48.118459, "o", "\u001b[?2004h> "]
[48.118531, "o", "            \"size_kb\": size,\r\n\u001b[?2004l\r"]
[48.118557, "o", "\u001b[?2004h"]
[48.118591, "o", "> "]
[48.118704, "o", "            \"has_security_update\": security_update\r\n\u001b[?2004l\r"]
[48.118737, "o", "\u001b[?2004h> "]
[48.118771, "o", "        })\r\n\u001b[?2004l\r"]
[48.118807, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[48.118838, "o", "\u001b[?2004h> "]
[48.118926, "o", "# Sort removable packages by name\r\n\u001b[?2004l\r"]
[48.118959, "o", "\u001b[?2004h> "]
[48.119065, "o", "removable.sort(key=lambda x: x['name'])\r\n\u001b[?2004l\r"]
[48.119099, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[48.119132, "o", "\u001b[?2004h> "]
[48.119217, "o", "# Calculate total space savings\r\n\u001b[?2004l\r"]
[48.119252, "o", "\u001b[?2004h> "]
[48.119399, "o", "total_space = sum(pkg['size_kb'] for pkg in removable)\r\n\u001b[?2004l\r"]
[48.119443, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[48.119473, "o", "\u001b[?2004h> "]
[48.119519, "o", "# Create report\r\n\u001b[?2004l\r"]
[48.119552, "o", "\u001b[?2004h> "]
[48.119584, "o", "report = {\r\n\u001b[?2004l\r"]
[48.119617, "o", "\u001b[?2004h> "]
[48.119657, "o", "    \"summary\": {\r\n\u001b[?2004l\r"]
[48.119698, "o", "\u001b[?2004h> "]
[48.119817, "o", "        \"total_installed\": len(installed),\r\n\u001b[?2004l\r"]
[48.11985, "o", "\u001b[?2004h> "]
[48.119961, "o", "        \"total_required\": len(required),\r\n\u001b[?2004l\r"]
[48.119995, "o", "\u001b[?2004h> "]
[48.120111, "o", "        \"removable_count\": len(removable),\r\n\u001b[?2004l\r"]
[48.120145, "o", "\u001b[?2004h> "]
[48.120302, "o", "        \"kept_as_dependencies\": len(dependency_protected),\r\n\u001b[?2004l\r"]
[48.120332, "o", "\u001b[?2004h> "]
[48.120472, "o", "        \"total_space_savings_kb\": total_space\r\n\u001b[?2004l\r"]
[48.120504, "o", "\u001b[?2004h"]
[48.120536, "o", ">     },\r\n\u001b[?2004l\r\u001b[?2004h"]
[48.120566, "o", "> "]
[48.120651, "o", "    \"removable_packages\": removable,\r\n\u001b[?2004l\r"]
[48.120684, "o", "\u001b[?2004h> "]
[48.120814, "o", "    \"dependency_protected\": dependency_protected\r\n\u001b[?2004l\r"]
[48.120849, "o", "\u001b[?2004h> }\r\n\u001b[?2004l\r"]
[48.120881, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[48.120915, "o", "\u001b[?2004h> "]
[48.120969, "o", "# Write JSON report\r\n\u001b[?2004l\r"]
[48.121005, "o", "\u001b[?2004h> "]
[48.12112, "o", "with open('removal_report.json', 'w') as f:\r\n\u001b[?2004l\r"]
[48.121154, "o", "\u001b[?2004h> "]
[48.121246, "o", "    json.dump(report, f, indent=2)\r\n\u001b[?2004l\r"]
[48.121279, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[48.121312, "o", "\u001b[?2004h> "]
[48.121458, "o", "print(f\"\\nReport generated: removal_report.json\")\r\n\u001b[?2004l\r"]
[48.121494, "o", "\u001b[?2004h> "]
[48.121614, "o", "print(f\"Removable packages: {len(removable)}\")\r\n\u001b[?2004l\r"]
[48.121651, "o", "\u001b[?2004h> "]
[48.121838, "o", "print(f\"Dependency-protected packages: {len(dependency_protected)}\")\r\n\u001b[?2004l\r"]
[48.121873, "o", "\u001b[?2004h> "]
[48.122075, "o", "print(f\"Total space savings: {total_space} KB ({total_space/1024:.2f} MB)\")\r\n\u001b[?2004l\r"]
[48.122109, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[48.122143, "o", "\u001b[?2004h> "]
[48.122202, "o", "# Create removal script\r\n\u001b[?2004l\r"]
[48.122236, "o", "\u001b[?2004h> "]
[48.122354, "o", "with open('remove_packages.sh', 'w') as f:\r\n\u001b[?2004l\r"]
[48.122388, "o", "\u001b[?2004h> "]
[48.122482, "o", "    f.write('#!/bin/bash\\n\\n')\r\n\u001b[?2004l\r"]
[48.122517, "o", "\u001b[?2004h> "]
[48.122668, "o", "    f.write('# Auto-generated package removal script\\n')\r\n\u001b[?2004l\r"]
[48.122699, "o", "\u001b[?2004h"]
[48.122727, "o", "> "]
[48.122913, "o", "    f.write('# This script will remove packages identified as unnecessary\\n\\n')\r\n\u001b[?2004l\r"]
[48.122948, "o", "\u001b[?2004h> "]
[48.122983, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[48.123003, "o", "> "]
[48.123044, "o", "    if removable:\r\n\u001b[?2004l\r"]
[48.123078, "o", "\u001b[?2004h> "]
[48.123254, "o", "        package_names = ' '.join(pkg['name'] for pkg in removable)\r\n\u001b[?2004l\r"]
[48.123288, "o", "\u001b[?2004h> "]
[48.123456, "o", "        f.write('# Dry-run: Show what would be removed\\n')\r\n\u001b[?2004l\r"]
[48.12349, "o", "\u001b[?2004h> "]
[48.123727, "o", "        f.write(f'echo \"The following packages will be removed: {package_names}\"\\n')\r\n\u001b[?2004l\r"]
[48.123766, "o", "\u001b[?2004h> "]
[48.124026, "o", "        f.write(f'echo \"Total space to be freed: {total_space} KB ({total_space/1024:.2f} MB)\"\\n')\r\n\u001b[?2004l\r"]
[48.12406, "o", "\u001b[?2004h> "]
[48.124138, "o", "        f.write('echo \"\"\\n')\r\n\u001b[?2004l\r"]
[48.124167, "o", "\u001b[?2004h> "]
[48.124399, "o", "        f.write('echo \"To proceed, run: sudo apt-get remove -y {package_names}\"\\n')\r\n\u001b[?2004l\r"]
[48.124447, "o", "\u001b[?2004h> "]
[48.124666, "o", "        f.write('\\n# Uncomment the line below to actually remove the packages\\n')\r\n\u001b[?2004l\r"]
[48.124706, "o", "\u001b[?2004h> "]
[48.124869, "o", "        f.write(f'# sudo apt-get remove -y {package_names}\\n')\r\n\u001b[?2004l\r"]
[48.124902, "o", "\u001b[?2004h> "]
[48.124933, "o", "    else:\r\n\u001b[?2004l\r"]
[48.124964, "o", "\u001b[?2004h> "]
[48.125097, "o", "        f.write('echo \"No packages to remove.\"\\n')\r\n\u001b[?2004l\r"]
[48.12513, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[48.125165, "o", "\u001b[?2004h> "]
[48.12523, "o", "# Make script executable\r\n\u001b[?2004l\r"]
[48.125261, "o", "\u001b[?2004h> "]
[48.12529, "o", "import os\r\n\u001b[?2004l\r"]
[48.125317, "o", "\u001b[?2004h> "]
[48.125438, "o", "os.chmod('remove_packages.sh', 0o755)\r\n\u001b[?2004l\r"]
[48.125481, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
