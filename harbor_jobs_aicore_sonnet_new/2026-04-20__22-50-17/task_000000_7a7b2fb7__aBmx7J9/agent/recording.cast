[48.095993, "i", "cat > audit_packages.py << 'EOF'\n#!/usr/bin/env python3\nimport subprocess\nimport json\nimport re\nfrom collections import defaultdict\n\ndef get_dependencies(package, max_depth=3, current_depth=0, visited=None):\n    \"\"\"Get dependencies up to max_depth levels deep\"\"\"\n    if visited is None:\n        visited = set()\n    \n    if current_depth >= max_depth or package in visited:\n        return set()\n    \n    visited.add(package)\n    deps = set()\n    \n    try:\n        result = subprocess.run(\n            ['apt-cache', 'depends', package],\n            capture_output=True, text=True, timeout=5\n        )\n        \n        for line in result.stdout.split('\\n'):\n            line = line.strip()\n            if line.startswith('Depends:'):\n                dep = line.split(':', 1)[1].strip()\n                # Remove version constraints and alternatives\n                dep = re.split(r'[<>=|]', dep)[0].strip()\n                if dep and dep not in visited:\n                    deps.add(dep)\n                    # Recursively get de"]
[48.096123, "i", "pendencies\n                    deps.update(get_dependencies(dep, max_depth, current_depth + 1, visited))\n    except Exception as e:\n        pass\n    \n    return deps\n\ndef get_package_size(package):\n    \"\"\"Get installed size in KB\"\"\"\n    try:\n        result = subprocess.run(\n            ['dpkg-query', '-W', '-f=${Installed-Size}', package],\n            capture_output=True, text=True, timeout=5\n        )\n        if result.returncode == 0 and result.stdout.strip():\n            return int(result.stdout.strip())\n    except:\n        pass\n    \n    # Try apt-cache show as fallback\n    try:\n        result = subprocess.run(\n            ['apt-cache', 'show', package],\n            capture_output=True, text=True, timeout=5\n        )\n        for line in result.stdout.split('\\n'):\n            if line.startswith('Installed-Size:'):\n                size_str = line.split(':', 1)[1].strip()\n                return int(size_str)\n    except:\n        pass\n    \n    return 0\n\ndef get_package_version(package):\n    \"\"\"Get installed ver"]
