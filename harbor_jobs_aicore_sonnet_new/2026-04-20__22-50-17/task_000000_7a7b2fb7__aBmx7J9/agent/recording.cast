[48.09642, "i", "otal space savings\ntotal_space = sum(pkg['size_kb'] for pkg in removable)\n\n# Create report\nreport = {\n    \"summary\": {\n        \"total_installed\": len(installed),\n        \"total_required\": len(required),\n        \"removable_count\": len(removable),\n        \"kept_as_dependencies\": len(dependency_protected),\n        \"total_space_savings_kb\": total_space\n    },\n    \"removable_packages\": removable,\n    \"dependency_protected\": dependency_protected\n}\n\n# Write JSON report\nwith open('removal_report.json', 'w') as f:\n    json.dump(report, f, indent=2)\n\nprint(f\"\\nReport generated: removal_report.json\")\nprint(f\"Removable packages: {len(removable)}\")\nprint(f\"Dependency-protected packages: {len(dependency_protected)}\")\nprint(f\"Total space savings: {total_space} KB ({total_space/1024:.2f} MB)\")\n\n# Create removal script\nwith open('remove_packages.sh', 'w') as f:\n    f.write('#!/bin/bash\\n\\n')\n    f.write('# Auto-generated package removal script\\n')\n    f.write('# This script will remove packages identified as unnecessary\\n\\n')"]
