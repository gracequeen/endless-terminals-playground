[8.045941, "o", "# Uptime checker daemon configuration\r\n\r\n[global]\r\ncheck_interval = 60\r\nretry_count = 3\r\nlog_level = \"info\"\r\n\r\n[[endpoints]]\r\nname = \"api-gateway\"\r\nurl = \"https://api.example.com/health\"\r\nexpected_status = 204\r\nmethod = \"GET\"\r\n\r\n[[endpoints]]\r\nname = \"auth-service\"\r\nurl = \"https://auth.internal.example.com/ping\"\r\nexpected_status = 200\r\ncritical = false\r\n\r\n[[endpoints]]\r\nname = \"frontend\"\r\nurl = \"https://www.example.com\"\r\nexpected_status = 200\r\n"]
