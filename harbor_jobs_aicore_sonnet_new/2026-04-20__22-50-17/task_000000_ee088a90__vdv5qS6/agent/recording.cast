[30.014407, "i", "cat > generate_report.py << 'EOF'\n#!/usr/bin/env python3\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\n# Parse log files\nlog_files = {\n    'AWS IAM': 'aws-rotation.log',\n    'Database': 'db-rotation.log',\n    'API Keys': 'api-keys.log'\n}\n\ndata = defaultdict(list)\nfailed_rotations = []\n\nfor category, filename in log_files.items():\n    with open(filename, 'r') as f:\n        for line in f:\n            match = re.match(r'\\[(.*?)\\] (.*?) \\| (.*?) \\| (.*?) \\| (.*?) \\| (.*?)$', line.strip())\n            if match:\n                timestamp, service, old_key, new_key, status, rotated_by = match.groups()\n                data[category].append({\n                    'service': service,\n                    'old_key': old_key,\n                    'new_key': new_key,\n                    'status': status,\n                    'rotated_by': rotated_by\n                })\n                if status == 'FAILED':\n                    failed_rotations.append({\n                        'service': service,\n"]
[30.014536, "i", "                        'category': category,\n                        'status': status\n                    })\n\n# Sort entries alphabetically by service name\nfor category in data:\n    data[category].sort(key=lambda x: x['service'].lower())\n\n# Calculate statistics\nstats = {}\ntotal_count = 0\ntotal_success = 0\ntotal_failed = 0\n\nfor category in ['AWS IAM', 'Database', 'API Keys']:\n    count = len(data[category])\n    success = sum(1 for item in data[category] if item['status'] == 'SUCCESS')\n    failed = sum(1 for item in data[category] if item['status'] == 'FAILED')\n    stats[category] = {'count': count, 'success': success, 'failed': failed}\n    total_count += count\n    total_success += success\n    total_failed += failed\n\n# Generate markdown report\ngenerated_time = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n\nwith open('ROTATION_REPORT.md', 'w') as f:\n    f.write('# Credential Rotation Report\\n\\n')\n    f.write(f'**Generated:** {generated_time}\\n')\n    f.write(f'**Total Credentials Rotated:** {total_count}\\n\\n')\n  "]
[30.014576, "o", "cat > generate_report.py << 'EOF'\r\n\u001b[?2004l\r"]
[30.014612, "i", "  \n    f.write('## Summary by Category\\n\\n')\n    f.write('| Category | Count | Success | Failed |\\n')\n    f.write('|----------|-------|---------|--------|\\n')\n    for category in ['AWS IAM', 'Database', 'API Keys']:\n        s = stats[category]\n        f.write(f'| {category} | {s[\"count\"]} | {s[\"success\"]} | {s[\"failed\"]} |\\n')\n    f.write('\\n')\n    \n    f.write('## Detailed Rotation Log\\n\\n')\n    \n    # AWS IAM Credentials\n    f.write('### AWS IAM Credentials\\n\\n')\n    f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\\n')\n    f.write('|---------|------------|------------|--------|------------|\\n')\n    for item in data['AWS IAM']:\n        f.write(f'| {item[\"service\"]} | {item[\"old_key\"]} | {item[\"new_key\"]} | {item[\"status\"]} | {item[\"rotated_by\"]} |\\n')\n    f.write('\\n')\n    \n    # Database Credentials\n    f.write('### Database Credentials\\n\\n')\n    f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\\n')\n    f.write('|---------|------------|------------|--------|-----------"]
[30.014637, "o", "\u001b[?2004h> "]
[30.014679, "i", "-|\\n')\n    for item in data['Database']:\n        f.write(f'| {item[\"service\"]} | {item[\"old_key\"]} | {item[\"new_key\"]} | {item[\"status\"]} | {item[\"rotated_by\"]} |\\n')\n    f.write('\\n')\n    \n    # API Keys\n    f.write('### API Keys\\n\\n')\n    f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\\n')\n    f.write('|---------|------------|------------|--------|------------|\\n')\n    for item in data['API Keys']:\n        f.write(f'| {item[\"service\"]} | {item[\"old_key\"]} | {item[\"new_key\"]} | {item[\"status\"]} | {item[\"rotated_by\"]} |\\n')\n    f.write('\\n')\n    \n    # Failed Rotations\n    f.write('## Failed Rotations\\n\\n')\n    if failed_rotations:\n        f.write('> **Action Required:** The following credentials failed rotation and need manual intervention.\\n\\n')\n        for failure in failed_rotations:\n            f.write(f'- {failure[\"service\"]} ({failure[\"category\"]}): Rotation failed\\n')\n    else:\n        f.write('> No failed rotations. All credentials rotated successfully.\\n')\n    f.write('\\n')\n    "]
[30.01469, "o", "#!/usr/bin/env python3\r\n"]
[30.014778, "i", "\n    # Sign-off\n    f.write('## Sign-off\\n\\n')\n    f.write('- [ ] All successful rotations verified\\n')\n    f.write('- [ ] Failed rotations escalated\\n')\n    f.write('- [ ] Old credentials scheduled for deletion\\n')\n\nprint('Report generated successfully!')\nEOF\n"]
