[?2004l[?2004h> #!/usr/bin/env python3
[?2004l[?2004h> import re
[?2004l[?2004h> from datetime import datetime
[?2004l[?2004h> from collections import defaultdict
[?2004l[?2004h> 
[?2004l[?2004h> # Parse log files
[?2004l[?2004h> log_files = {
[?2004l[?2004h>     'AWS IAM': 'aws-rotation.log',
[?2004l[?2004h>     'Database': 'db-rotation.log',
[?2004l[?2004h>     'API Keys': 'api-keys.log'
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> data = defaultdict(list)
[?2004l[?2004h> failed_rotations = []
[?2004l[?2004h> 
[?2004l[?2004h> for category, filename in log_files.items():
[?2004l[?2004h>     with open(filename, 'r') as f:
[?2004l[?2004h>         for line in f:
[?2004l[?2004h>             match = re.match(r'\[(.*?)\] (.*?) \| (.*?) \| (.*?) \| (.*?) \| (.*?)$', line.strip())
[?2004l[?2004h>             if match:
[?2004l[?2004h>                 timestamp, service, old_key, new_key, status, rotated_by = match.groups()
[?2004l[?2004h>                 data[category].append({
[?2004l[?2004h>                     'service': service,
[?2004l[?2004h>                     'old_key': old_key,
[?2004l[?2004h>                     'new_key': new_key,
[?2004l[?2004h>                     'status': status,
[?2004l[?2004h>                     'rotated_by': rotated_by
[?2004l[?2004h>                 })
[?2004l[?2004h>                 if status == 'FAILED':
[?2004l[?2004h>                     failed_rotations.append({
[?2004l[?2004h>                         'service': service,
[?2004l[?2004h>                         'category': category,
[?2004l[?2004h>                         'status': status
[?2004l[?2004h>                     })
[?2004l[?2004h> 
[?2004l[?2004h> # Sort entries alphabetically by service name
[?2004l[?2004h> for category in data:
[?2004l[?2004h>     data[category].sort(key=lambda x: x['service'].lower())
[?2004l[?2004h> 
[?2004l[?2004h> # Calculate statistics
[?2004l[?2004h> stats = {}
[?2004l[?2004h> total_count = 0
[?2004l[?2004h> total_success = 0
[?2004l[?2004h> total_failed = 0
[?2004l[?2004h> 
[?2004l[?2004h> for category in ['AWS IAM', 'Database', 'API Keys']:
[?2004l[?2004h>     count = len(data[category])
[?2004l[?2004h>     success = sum(1 for item in data[category] if item['status'] == 'SUCCESS')
[?2004l[?2004h>     failed = sum(1 for item in data[category] if item['status'] == 'FAILED')
[?2004l[?2004h>     stats[category] = {'count': count, 'success': success, 'failed': failed}
[?2004l[?2004h>     total_count += count
[?2004l[?2004h>     total_success += success
[?2004l[?2004h>     total_failed += failed
[?2004l[?2004h> 
[?2004l[?2004h> # Generate markdown report
[?2004l[?2004h> generated_time = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
[?2004l[?2004h> 
[?2004l[?2004h> with open('ROTATION_REPORT.md', 'w') as f:
[?2004l[?2004h>     f.write('# Credential Rotation Report\n\n')
[?2004l[?2004h>     f.write(f'**Generated:** {generated_time}\n')
[?2004l[?2004h>     f.write(f'**Total Credentials Rotated:** {total_count}\n\n')
[?2004l[?2004h>     
[?2004l[?2004h>     f.write('## Summary by Category\n\n')
[?2004l[?2004h>     f.write('| Category | Count | Success | Failed |\n')
[?2004l[?2004h>     f.write('|----------|-------|---------|--------|\n')
[?2004l[?2004h>     for category in ['AWS IAM', 'Database', 'API Keys']:
[?2004l[?2004h>         s = stats[category]
[?2004l[?2004h>         f.write(f'| {category} | {s["count"]} | {s["success"]} | {s["failed"]} |\n')
[?2004l[?2004h>     f.write('\n')
[?2004l[?2004h>     
[?2004l[?2004h>     f.write('## Detailed Rotation Log\n\n')
[?2004l[?2004h>     
[?2004l[?2004h>     # AWS IAM Credentials
[?2004l[?2004h>     f.write('### AWS IAM Credentials\n\n')
[?2004l[?2004h>     f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\n')
[?2004l[?2004h>     f.write('|---------|------------|------------|--------|------------|\n')
[?2004l[?2004h>     for item in data['AWS IAM']:
[?2004l[?2004h>         f.write(f'| {item["service"]} | {item["old_key"]} | {item["new_key"]} | {item["status"]} | {item["rotated_by"]} |\n')
[?2004l[?2004h>     f.write('\n')
[?2004l[?2004h>     
[?2004l[?2004h>     # Database Credentials
[?2004l[?2004h>     f.write('### Database Credentials\n\n')
[?2004l[?2004h>     f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\n')
[?2004l[?2004h>     f.write('|---------|------------|------------|--------|------------|\n')
[?2004l[?2004h>     for item in data['Database']:
[?2004l[?2004h>         f.write(f'| {item["service"]} | {item["old_key"]} | {item["new_key"]} | {item["status"]} | {item["rotated_by"]} |\n')
[?2004l[?2004h>     f.write('\n')
[?2004l[?2004h>     
[?2004l[?2004h>     # API Keys
[?2004l[?2004h>     f.write('### API Keys\n\n')
[?2004l[?2004h>     f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\n')
[?2004l[?2004h>     f.write('|---------|------------|------------|--------|------------|\n')
[?2004l[?2004h>     for item in data['API Keys']:
[?2004l[?2004h>         f.write(f'| {item["service"]} | {item["old_key"]} | {item["new_key"]} | {item["status"]} | {item["rotated_by"]} |\n')
[?2004l[?2004h>     f.write('\n')
[?2004l[?2004h>     
[?2004l[?2004h>     # Failed Rotations
[?2004l[?2004h>     f.write('## Failed Rotations\n\n')
