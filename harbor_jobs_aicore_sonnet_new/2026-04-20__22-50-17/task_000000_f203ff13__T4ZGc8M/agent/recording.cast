[63.019803, "i", "python3 << 'EOF'\nimport sqlite3\nimport json\nfrom collections import OrderedDict\n\nconn = sqlite3.connect('/home/user/company/employees.db')\ncursor = conn.cursor()\n\nquery = \"\"\"\nSELECT \n    department, \n    COUNT(*) as count, \n    ROUND(AVG(salary), 2) as avg_salary, \n    MIN(hire_date) as oldest_hire, \n    MAX(hire_date) as newest_hire \nFROM employees \nGROUP BY department \nORDER BY department\n\"\"\"\n\ncursor.execute(query)\nresults = cursor.fetchall()\n\ndept_summary = OrderedDict()\nfor row in results:\n    dept_name = row[0]\n    dept_summary[dept_name] = {\n        \"count\": row[1],\n        \"avg_salary\": row[2],\n        \"oldest_hire\": row[3],\n        \"newest_hire\": row[4]\n    }\n\nconn.close()\n\nwith open('/home/user/company/dept_summary.json', 'w') as f:\n    json.dump(dept_summary, f, indent=2)\n\nprint(\"Department summary JSON created successfully\")\nEOF\n"]
