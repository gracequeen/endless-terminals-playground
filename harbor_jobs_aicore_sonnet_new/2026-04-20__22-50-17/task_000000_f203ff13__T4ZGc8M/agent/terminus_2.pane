[?2004hroot@e26d8c7cabf3:/home/user# python3 << 'EOF'
[?2004l[?2004h> import sqlite3
[?2004l[?2004h> import json
[?2004l[?2004h> from collections import OrderedDict
[?2004l[?2004h> 
[?2004l[?2004h> conn = sqlite3.connect('/home/user/company/employees.db')
[?2004l[?2004h> cursor = conn.cursor()
[?2004l[?2004h> 
[?2004l[?2004h> query = """
[?2004l[?2004h> SELECT 
[?2004l[?2004h>     department, 
[?2004l[?2004h>     COUNT(*) as count, 
[?2004l[?2004h>     ROUND(AVG(salary), 2) as avg_salary, 
[?2004l[?2004h>     MIN(hire_date) as oldest_hire, 
[?2004l[?2004h>     MAX(hire_date) as newest_hire 
[?2004l[?2004h> FROM employees 
[?2004l[?2004h> GROUP BY department 
[?2004l[?2004h> ORDER BY department
[?2004l[?2004h> """
[?2004l[?2004h> 
[?2004l[?2004h> cursor.execute(query)
[?2004l[?2004h> results = cursor.fetchall()
[?2004l[?2004h> 
[?2004l[?2004h> dept_summary = OrderedDict()
[?2004l[?2004h> for row in results:
[?2004l[?2004h>     dept_name = row[0]
[?2004l[?2004h>     dept_summary[dept_name] = {
[?2004l[?2004h>         "count": row[1],
[?2004l[?2004h>         "avg_salary": row[2],
[?2004l[?2004h>         "oldest_hire": row[3],
[?2004l[?2004h>         "newest_hire": row[4]
[?2004l[?2004h>     }
[?2004l[?2004h> 
[?2004l[?2004h> conn.close()
[?2004l[?2004h> 
[?2004l[?2004h> with open('/home/user/company/dept_summary.json', 'w') as f:
[?2004l[?2004h>     json.dump(dept_summary, f, indent=2)
[?2004l[?2004h> 
