[17.513247, "i", "cat > /home/user/docs_workspace/verify_permissions.sh << 'EOF'\n#!/bin/bash\n\n# Read manifest and verify permissions\nwhile IFS=: read -r path expected_perm; do\n    if [[ \"$path\" == \"DIRECTORY_PERMISSIONS\" ]] || [[ \"$path\" == \"FILE_PERMISSIONS\" ]] || [[ -z \"$path\" ]]; then\n        continue\n    fi\n    \n    if [[ -e \"$path\" ]]; then\n        actual_perm=$(stat -c '%a' \"$path\")\n        if [[ \"$actual_perm\" != \"$expected_perm\" ]]; then\n            echo \"FAIL: $path\"\n            exit 1\n        fi\n    else\n        echo \"FAIL: $path\"\n        exit 1\n    fi\ndone < /home/user/docs_workspace/permissions_manifest.txt\n\necho \"PASS\"\nEOF\n"]
