[79.887682, "i", "cat /etc/monitoring/alerts.yaml\n"]
[79.887815, "o", "cat /etc/monitoring/alerts.yaml\r\n"]
[79.88786, "o", "\u001b[?2004l\r"]
[79.88874, "o", "# Prometheus alerting rules\r\ngroups:\r\n  - name: service_alerts\r\n    rules:\r\n      - alert: HighLatency\r\n        expr: http_request_duration_seconds > 0.5\r\n        for: 3m\r\n        labels:\r\n          severity: warning\r\n        annotations:\r\n          summary: \"High latency detected on {{ $labels.instance }}\"\r\n\r\n      - alert: ServiceDown\r\n        expr: up == 0\r\n        for: 1m\r\n        labels:\r\n          severity: critical\r\n          team: platform\r\n          escalation_level: critical\r\n        annotations:\r\n          summary: \"Service {{ $labels.job }} is down\"\r\n\r\n      - alert: DiskSpaceLow\r\n        expr: node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} < 0.1\r\n        for: 10m\r\n        labels:\r\n          severity: warning\r\n          team: infrastructure\r\n        annotations:\r\n          summary: \"Disk space below 10% on {{ $labels.instance }}\"\r\n\r\n"]
[79.888781, "o", "      - alert: HighMemoryUsage\r\n        expr: node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes < 0.1\r\n        for: 5m\r\n        labels:\r\n          severity: warning\r\n        annotations:\r\n          summary: \"Memory usage critical on {{ $labels.instance }}\"\r\n"]
[79.888941, "o", "\u001b[?2004h"]
[79.888973, "o", "root@a3bdda27b05d:/home/user# "]
[89.444489, "i", "python3 << 'PYEOF'\nimport re\n\nwith open('/etc/monitoring/uptime.toml', 'r') as f:\n    content = f.read()\n\n# Change check_interval from 60 to 30\ncontent = re.sub(r'check_interval = 60', 'check_interval = 30', content)\n\n# Add timeout = 10 after check_interval\ncontent = re.sub(r'(check_interval = 30\\n)', r'\\1timeout = 10\\n', content)\n\n# Change api-gateway expected_status to 200 and add critical = true\ncontent = re.sub(\n    r'(\\[\\[endpoints\\]\\]\\nname = \"api-gateway\"\\nurl = \"https://api\\.example\\.com/health\"\\n)expected_status = 204',\n    r'\\1expected_status = 200\\ncritical = true',\n    content\n)\n\n# Add payment-service endpoint at the end\npayment_endpoint = '''\\n[[endpoints]]\nname = \"payment-service\"\nurl = \"https://payments.internal.example.com/health\"\nexpected_status = 200\ncritical = true\n\n[endpoints.headers]\nAuthorization = \"Bearer ${PAYMENTS_TOKEN}\"\n'''\n\ncontent = content.rstrip() + payment_endpoint\n\nwith open('/etc/monitoring/uptime.toml', 'w') as f:\n    f.write(content)\n\nprint(\"TOML changes completed\")\nPYEOF\n"]
