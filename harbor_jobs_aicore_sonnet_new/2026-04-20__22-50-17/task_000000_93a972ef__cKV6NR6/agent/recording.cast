[73.748685, "i", "python3 << 'PYEOF'\nimport re\n\nwith open('/etc/monitoring/alerts.yaml', 'r') as f:\n    content = f.read()\n\n# Change HighLatency for duration from 5m to 3m\ncontent = re.sub(r'(- alert: HighLatency.*?for: )5m', r'\\g<1>3m', content, flags=re.DOTALL)\n\n# Add escalation_level to ServiceDown\ncontent = re.sub(r'(- alert: ServiceDown.*?team: platform)', r'\\g<1>\\n          escalation_level: critical', content, flags=re.DOTALL)\n\n# Add DiskSpaceLow alert before HighMemoryUsage\nnew_alert = '''      - alert: DiskSpaceLow\n        expr: node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} < 0.1\n        for: 10m\n        labels:\n          severity: warning\n          team: infrastructure\n        annotations:\n          summary: \"Disk space below 10% on {{ $labels.instance }}\"\n\n'''\ncontent = re.sub(r'(      - alert: HighMemoryUsage)', new_alert + r'\\1', content)\n\nwith open('/etc/monitoring/alerts.yaml', 'w') as f:\n    f.write(content)\n\nprint(\"YAML changes completed\")\nPYEOF\n"]
