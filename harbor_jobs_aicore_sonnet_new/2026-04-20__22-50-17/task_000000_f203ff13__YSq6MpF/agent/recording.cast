[19.39608, "i", "sqlite3 -header -csv employees.db \"SELECT e.id, e.name, e.department, e.salary, ROUND(AVG(e2.salary), 2) as dept_average FROM employees e JOIN employees e2 ON e.department = e2.department GROUP BY e.id, e.name, e.department, e.salary HAVING e.salary > dept_average * 1.2 ORDER BY e.department ASC, e.salary DESC;\" > salary_outliers.csv\n"]
