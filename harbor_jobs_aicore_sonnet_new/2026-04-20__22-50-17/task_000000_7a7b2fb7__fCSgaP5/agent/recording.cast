[47.24845, "o", "\u001b[?2004h> "]
[47.248703, "o", "                    # Remove version constraints and alternatives\r\n\u001b[?2004l\r"]
[47.248732, "o", "\u001b[?2004h> "]
[47.248985, "o", "                    dep = re.split(r'[<>=|]', dep)[0].strip()\r\n\u001b[?2004l\r"]
[47.249012, "o", "\u001b[?2004h> "]
[47.24921, "o", "                    if dep and depth < max_depth:\r\n\u001b[?2004l\r"]
[47.249237, "o", "\u001b[?2004h> "]
[47.249393, "o", "                        deps.add(dep)\r\n\u001b[?2004l\r"]
[47.249419, "o", "\u001b[?2004h> "]
[47.249657, "o", "                        dependency_map[dep].add(package)\r\n\u001b[?2004l\r"]
[47.249682, "o", "\u001b[?2004h"]
[47.249708, "o", "> "]
[47.249917, "o", "                        queue.append((dep, depth + 1))\r\n\u001b[?2004l\r"]
[47.249942, "o", "\u001b[?2004h> "]
[47.250077, "o", "        except Exception as e:\r\n\u001b[?2004l\r"]
[47.250103, "o", "\u001b[?2004h> "]
[47.250406, "o", "            print(f\"Warning: Could not get dependencies for {pkg}: {e}\")\r\n\u001b[?2004l\r"]
[47.250432, "o", "\u001b[?2004h> "]
[47.25046, "o", "    \r\n\u001b[?2004l\r"]
[47.250483, "o", "\u001b[?2004h"]
[47.250514, "o", "> "]
[47.250557, "o", "    return deps\r\n\u001b[?2004l\r"]
[47.250587, "o", "\u001b[?2004h> "]
[47.250618, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.250645, "o", "> "]
[47.250797, "o", "print(\"\\nBuilding dependency trees...\")\r\n\u001b[?2004l\r"]
[47.250825, "o", "\u001b[?2004h> "]
[47.250931, "o", "for req_pkg in required:\r\n\u001b[?2004l\r"]
[47.250962, "o", "\u001b[?2004h> "]
[47.251129, "o", "    print(f\"  Analyzing {req_pkg}...\")\r\n\u001b[?2004l\r"]
[47.251157, "o", "\u001b[?2004h> "]
[47.251311, "o", "    deps = get_dependencies(req_pkg)\r\n\u001b[?2004l\r"]
[47.251343, "o", "\u001b[?2004h> "]
[47.251484, "o", "    all_dependencies.update(deps)\r\n\u001b[?2004l\r"]
[47.251517, "o", "\u001b[?2004h> "]
[47.251549, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.251809, "o", "print(f\"\\nTotal dependencies found: {len(all_dependencies)}\")\r\n\u001b[?2004l\r"]
[47.251837, "o", "\u001b[?2004h"]
[47.251866, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[47.251895, "o", "> "]
[47.251962, "o", "# Classify packages\r\n\u001b[?2004l\r"]
[47.25199, "o", "\u001b[?2004h> "]
[47.252123, "o", "removable = extra_packages - all_dependencies\r\n\u001b[?2004l\r"]
[47.25215, "o", "\u001b[?2004h> "]
[47.252309, "o", "dependency_protected = extra_packages & all_dependencies\r\n\u001b[?2004l\r"]
[47.25234, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.252371, "o", "\u001b[?2004h> "]
[47.252475, "o", "print(f\"Removable: {len(removable)}\")\r\n\u001b[?2004l\r"]
[47.252506, "o", "\u001b[?2004h> "]
[47.25267, "o", "print(f\"Dependency-protected: {len(dependency_protected)}\")\r\n\u001b[?2004l\r"]
[47.252692, "o", "\u001b[?2004h"]
[47.252719, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[47.252758, "o", "> "]
[47.252855, "o", "# Get package info for removable packages\r\n\u001b[?2004l\r"]
[47.252881, "o", "\u001b[?2004h> "]
[47.252942, "o", "removable_info = []\r\n\u001b[?2004l\r"]
[47.252973, "o", "\u001b[?2004h> "]
[47.253023, "o", "total_size_kb = 0\r\n\u001b[?2004l\r"]
[47.253054, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.253085, "o", "\u001b[?2004h> "]
[47.25317, "o", "for pkg in sorted(removable):\r\n\u001b[?2004l\r"]
[47.253202, "o", "\u001b[?2004h> "]
[47.253233, "o", "    try:\r\n\u001b[?2004l\r"]
[47.25326, "o", "\u001b[?2004h> "]
[47.253371, "o", "        # Get installed version and size\r\n\u001b[?2004l\r"]
[47.253404, "o", "\u001b[?2004h> "]
[47.253494, "o", "        result = subprocess.run(\r\n\u001b[?2004l\r"]
[47.253521, "o", "\u001b[?2004h> "]
[47.253753, "o", "            ['dpkg-query', '-W', '-f=${Version}\\\\t${Installed-Size}\\\\n', pkg],\r\n\u001b[?2004l\r"]
[47.253781, "o", "\u001b[?2004h> "]
[47.253932, "o", "            capture_output=True, text=True, timeout=5\r\n\u001b[?2004l\r"]
[47.253959, "o", "\u001b[?2004h"]
[47.253984, "o", "> "]
[47.25401, "o", "        )\r\n\u001b[?2004l\r"]
[47.254036, "o", "\u001b[?2004h> "]
[47.254063, "o", "        \r\n\u001b[?2004l\r"]
[47.254089, "o", "\u001b[?2004h> "]
[47.254251, "o", "        if result.returncode == 0 and result.stdout.strip():\r\n\u001b[?2004l\r"]
[47.254282, "o", "\u001b[?2004h> "]
[47.25446, "o", "            version, size_kb = result.stdout.strip().split('\\t')\r\n\u001b[?2004l\r"]
[47.254492, "o", "\u001b[?2004h> "]
[47.254589, "o", "            size_kb = int(size_kb)\r\n\u001b[?2004l\r"]
[47.254619, "o", "\u001b[?2004h> "]
[47.254659, "o", "        else:\r\n\u001b[?2004l\r"]
[47.254685, "o", "\u001b[?2004h> "]
[47.254801, "o", "            # Fallback to apt-cache\r\n\u001b[?2004l\r"]
[47.254829, "o", "\u001b[?2004h> "]
[47.254936, "o", "            result = subprocess.run(\r\n\u001b[?2004l\r"]
[47.254968, "o", "\u001b[?2004h> "]
[47.255098, "o", "                ['apt-cache', 'show', pkg],\r\n\u001b[?2004l\r"]
[47.25513, "o", "\u001b[?2004h> "]
[47.25529, "o", "                capture_output=True, text=True, timeout=5\r\n\u001b[?2004l\r"]
[47.255318, "o", "\u001b[?2004h> "]
[47.255362, "o", "            )\r\n\u001b[?2004l\r"]
[47.255387, "o", "\u001b[?2004h"]
[47.255411, "o", "> "]
[47.255483, "o", "            version = \"unknown\"\r\n\u001b[?2004l\r"]
[47.255509, "o", "\u001b[?2004h> "]
[47.25558, "o", "            size_kb = 0\r\n\u001b[?2004l\r"]
[47.255606, "o", "\u001b[?2004h> "]
[47.255761, "o", "            for line in result.stdout.split('\\n'):\r\n\u001b[?2004l\r"]
[47.255784, "o", "\u001b[?2004h"]
[47.255812, "o", "> "]
[47.255924, "o", "                if line.startswith('Version:'):\r\n\u001b[?2004l\r"]
[47.255951, "o", "\u001b[?2004h> "]
[47.25612, "o", "                    version = line.split(':', 1)[1].strip()\r\n\u001b[?2004l\r"]
[47.256148, "o", "\u001b[?2004h> "]
[47.256308, "o", "                elif line.startswith('Installed-Size:'):\r\n\u001b[?2004l\r"]
[47.256336, "o", "\u001b[?2004h> "]
[47.256515, "o", "                    size_kb = int(line.split(':', 1)[1].strip())\r\n\u001b[?2004l\r"]
[47.256539, "o", "\u001b[?2004h"]
[47.256565, "o", "> "]
[47.25659, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[47.256616, "o", "> "]
[47.256706, "o", "        # Check for security updates\r\n\u001b[?2004l\r"]
[47.25673, "o", "\u001b[?2004h"]
[47.256768, "o", "> "]
[47.256845, "o", "        has_security_update = False\r\n\u001b[?2004l\r"]
[47.256876, "o", "\u001b[?2004h> "]
[47.256916, "o", "        try:\r\n\u001b[?2004l\r"]
[47.256947, "o", "\u001b[?2004h> "]
[47.25707, "o", "            policy_result = subprocess.run(\r\n\u001b[?2004l\r"]
[47.257101, "o", "\u001b[?2004h> "]
[47.257228, "o", "                ['apt-cache', 'policy', pkg],\r\n\u001b[?2004l\r"]
[47.257259, "o", "\u001b[?2004h> "]
[47.257418, "o", "                capture_output=True, text=True, timeout=5\r\n\u001b[?2004l\r"]
[47.257449, "o", "\u001b[?2004h> "]
[47.25749, "o", "            )\r\n\u001b[?2004l\r"]
[47.257518, "o", "\u001b[?2004h> "]
[47.257689, "o", "            # Look for security pocket in policy output\r\n\u001b[?2004l\r"]
[47.257715, "o", "\u001b[?2004h> "]
[47.257874, "o", "            if '-security' in policy_result.stdout:\r\n\u001b[?2004l\r"]
[47.257898, "o", "\u001b[?2004h"]
[47.257928, "o", "> "]
[47.258022, "o", "                has_security_update = True\r\n\u001b[?2004l\r"]
[47.258053, "o", "\u001b[?2004h> "]
[47.258098, "o", "        except:\r\n\u001b[?2004l\r"]
[47.258122, "o", "\u001b[?2004h> "]
[47.258175, "o", "            pass\r\n\u001b[?2004l\r"]
[47.258205, "o", "\u001b[?2004h> "]
[47.258236, "o", "        \r\n\u001b[?2004l\r"]
[47.258268, "o", "\u001b[?2004h> "]
[47.258351, "o", "        removable_info.append({\r\n\u001b[?2004l\r"]
[47.258378, "o", "\u001b[?2004h> "]
[47.258451, "o", "            'name': pkg,\r\n\u001b[?2004l\r"]
[47.258482, "o", "\u001b[?2004h> "]
[47.258596, "o", "            'installed_version': version,\r\n\u001b[?2004l\r"]
[47.258627, "o", "\u001b[?2004h> "]
[47.258714, "o", "            'size_kb': size_kb,\r\n\u001b[?2004l\r"]
[47.25875, "o", "\u001b[?2004h> "]
[47.258907, "o", "            'has_security_update': has_security_update\r\n\u001b[?2004l\r"]
[47.258938, "o", "\u001b[?2004h> "]
[47.258969, "o", "        })\r\n\u001b[?2004l\r"]
[47.259006, "o", "\u001b[?2004h> "]
[47.259104, "o", "        total_size_kb += size_kb\r\n\u001b[?2004l\r"]
[47.259135, "o", "\u001b[?2004h> "]
[47.259166, "o", "        \r\n\u001b[?2004l\r"]
[47.259192, "o", "\u001b[?2004h> "]
[47.25927, "o", "    except Exception as e:\r\n\u001b[?2004l\r"]
[47.259301, "o", "\u001b[?2004h> "]
[47.259468, "o", "        print(f\"Warning: Could not get info for {pkg}: {e}\")\r\n\u001b[?2004l\r"]
[47.259494, "o", "\u001b[?2004h"]
[47.259524, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[47.25955, "o", "> "]
[47.259627, "o", "# Build dependency_protected list\r\n\u001b[?2004l\r"]
[47.259656, "o", "\u001b[?2004h> "]
[47.259727, "o", "dep_protected_info = []\r\n\u001b[?2004l\r"]
[47.259769, "o", "\u001b[?2004h> "]
[47.259883, "o", "for pkg in sorted(dependency_protected):\r\n\u001b[?2004l\r"]
[47.259913, "o", "\u001b[?2004h> "]
[47.260077, "o", "    required_by = sorted(list(dependency_map.get(pkg, [])))\r\n\u001b[?2004l\r"]
[47.260109, "o", "\u001b[?2004h> "]
[47.260196, "o", "    dep_protected_info.append({\r\n\u001b[?2004l\r"]
[47.260226, "o", "\u001b[?2004h> "]
[47.260287, "o", "        'name': pkg,\r\n\u001b[?2004l\r"]
[47.260319, "o", "\u001b[?2004h> "]
[47.260416, "o", "        'required_by': required_by\r\n\u001b[?2004l\r"]
[47.260442, "o", "\u001b[?2004h> "]
[47.26047, "o", "    })\r\n\u001b[?2004l\r"]
[47.260496, "o", "\u001b[?2004h> "]
[47.260522, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.260548, "o", "> "]
[47.260574, "o", "# Create report\r\n"]
[47.260605, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[47.260639, "o", "report = {\r\n\u001b[?2004l\r"]
[47.260671, "o", "\u001b[?2004h> "]
[47.260723, "o", "    'summary': {\r\n\u001b[?2004l\r"]
[47.260763, "o", "\u001b[?2004h> "]
[47.260877, "o", "        'total_installed': len(installed),\r\n\u001b[?2004l\r"]
[47.260903, "o", "\u001b[?2004h> "]
[47.26102, "o", "        'total_required': len(required),\r\n\u001b[?2004l\r"]
[47.261047, "o", "\u001b[?2004h> "]
[47.261172, "o", "        'removable_count': len(removable),\r\n\u001b[?2004l\r"]
[47.261205, "o", "\u001b[?2004h> "]
[47.261363, "o", "        'kept_as_dependencies': len(dependency_protected),\r\n\u001b[?2004l\r"]
[47.261393, "o", "\u001b[?2004h> "]
[47.261523, "o", "        'total_space_savings_kb': total_size_kb\r\n\u001b[?2004l\r"]
[47.261552, "o", "\u001b[?2004h> "]
[47.261583, "o", "    },\r\n\u001b[?2004l\r"]
[47.261609, "o", "\u001b[?2004h> "]
[47.261755, "o", "    'removable_packages': removable_info,\r\n\u001b[?2004l\r"]
[47.261782, "o", "\u001b[?2004h> "]
[47.261916, "o", "    'dependency_protected': dep_protected_info\r\n\u001b[?2004l\r"]
[47.261946, "o", "\u001b[?2004h> "]
[47.261976, "o", "}\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.262002, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[47.262034, "o", "> "]
[47.262074, "o", "# Write JSON report\r\n\u001b[?2004l\r"]
[47.2621, "o", "\u001b[?2004h> "]
[47.262284, "o", "with open('/home/user/migration/removal_report.json', 'w') as f:\r\n\u001b[?2004l\r"]
[47.262312, "o", "\u001b[?2004h> "]
[47.262414, "o", "    json.dump(report, f, indent=2)\r\n\u001b[?2004l\r"]
[47.262446, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.262476, "o", "\u001b[?2004h> "]
[47.262617, "o", "print(f\"\\nReport written to removal_report.json\")\r\n\u001b[?2004l\r"]
[47.262648, "o", "\u001b[?2004h> "]
[47.262883, "o", "print(f\"Total space savings: {total_size_kb} KB ({total_size_kb/1024:.2f} MB)\")\r\n\u001b[?2004l\r"]
[47.262925, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.262954, "o", "\u001b[?2004h> "]
[47.263028, "o", "# Create removal script\r\n\u001b[?2004l\r"]
[47.263053, "o", "\u001b[?2004h"]
[47.263087, "o", "> "]
[47.263234, "o", "with open('/home/user/migration/remove_packages.sh', 'w') as f:\r\n\u001b[?2004l\r"]
[47.26326, "o", "\u001b[?2004h"]
[47.263286, "o", "> "]
[47.263347, "o", "    f.write('#!/bin/bash\\n')\r\n\u001b[?2004l\r"]
[47.263373, "o", "\u001b[?2004h> "]
[47.263539, "o", "    f.write('# Auto-generated package removal script\\n\\n')\r\n\u001b[?2004l\r"]
[47.263566, "o", "\u001b[?2004h> "]
[47.263765, "o", "    f.write('echo \"This will remove the following packages:\"\\n')\r\n\u001b[?2004l\r"]
[47.263795, "o", "\u001b[?2004h> "]
[47.26389, "o", "    for pkg in sorted(removable):\r\n\u001b[?2004l\r"]
[47.263917, "o", "\u001b[?2004h> "]
[47.26403, "o", "        f.write(f'echo \"  - {pkg}\"\\n')\r\n\u001b[?2004l\r"]
[47.264057, "o", "\u001b[?2004h> "]
[47.264129, "o", "    f.write('echo \"\"\\n')\r\n\u001b[?2004l\r"]
[47.264155, "o", "\u001b[?2004h"]
[47.264186, "o", "> "]
[47.264293, "o", "    f.write('echo \"Total space to be freed: '\r\n\u001b[?2004l\r"]
[47.264321, "o", "\u001b[?2004h> "]
[47.264517, "o", "            f'{total_size_kb} KB ({total_size_kb/1024:.2f} MB)\"\\n')\r\n\u001b[?2004l\r"]
[47.264545, "o", "\u001b[?2004h"]
[47.264576, "o", "> "]
[47.264624, "o", "    f.write('echo \"\"\\n')\r\n\u001b[?2004l\r"]
[47.264652, "o", "\u001b[?2004h"]
[47.26468, "o", "> "]
[47.26479, "o", "    f.write('echo \"Dry run command:\"\\n')\r\n\u001b[?2004l\r"]
[47.264822, "o", "\u001b[?2004h"]
[47.26485, "o", ">     \r\n\u001b[?2004l\r"]
[47.264883, "o", "\u001b[?2004h> "]
[47.264918, "o", "    if removable:\r\n\u001b[?2004l\r"]
[47.264947, "o", "\u001b[?2004h> "]
[47.265079, "o", "        pkg_list = ' '.join(sorted(removable))\r\n\u001b[?2004l\r"]
[47.265107, "o", "\u001b[?2004h> "]
[47.265304, "o", "        f.write(f'echo \"sudo apt-get remove --dry-run {pkg_list}\"\\n')\r\n\u001b[?2004l\r"]
[47.265332, "o", "\u001b[?2004h> "]
[47.265415, "o", "        f.write('echo \"\"\\n')\r\n\u001b[?2004l\r"]
[47.265444, "o", "\u001b[?2004h> "]
[47.265662, "o", "        f.write('read -p \"Proceed with actual removal? (yes/no):\" response\\n')\r\n\u001b[?2004l\r"]
[47.265689, "o", "\u001b[?2004h> "]
[47.265858, "o", "        f.write('if [ \"$response\" = \"yes\" ]; then\\n')\r\n\u001b[?2004l\r"]
[47.265892, "o", "\u001b[?2004h> "]
[47.266055, "o", "        f.write(f'    sudo apt-get remove -y {pkg_list}\\n')\r\n\u001b[?2004l\r"]
[47.266083, "o", "\u001b[?2004h> "]
[47.266158, "o", "        f.write('else\\n')\r\n\u001b[?2004l\r"]
[47.266186, "o", "\u001b[?2004h> "]
[47.266324, "o", "        f.write('    echo \"Removal cancelled.\"\\n')\r\n\u001b[?2004l\r"]
[47.266352, "o", "\u001b[?2004h> "]
[47.266424, "o", "        f.write('fi\\n')\r\n\u001b[?2004l\r"]
[47.266455, "o", "\u001b[?2004h"]
[47.266481, "o", ">     else:\r\n"]
[47.266506, "o", "\u001b[?2004l\r\u001b[?2004h"]
[47.266534, "o", "> "]
[47.266656, "o", "        f.write('echo \"No packages to remove.\"\\n')\r\n\u001b[?2004l\r"]
[47.266688, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.266719, "o", "\u001b[?2004h> "]
[47.266944, "o", "subprocess.run(['chmod', '+x', '/home/user/migration/remove_packages.sh'])\r\n\u001b[?2004l\r"]
