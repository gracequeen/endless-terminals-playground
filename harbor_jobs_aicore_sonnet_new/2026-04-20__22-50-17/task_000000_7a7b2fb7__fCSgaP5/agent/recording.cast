[47.239421, "i", "cat > analyze_packages.py << 'SCRIPT_EOF'\n#!/usr/bin/env python3\nimport subprocess\nimport json\nimport re\nfrom collections import defaultdict, deque\n\n# Read package lists\nwith open('installed_packages.txt') as f:\n    installed = set(line.strip() for line in f if line.strip())\n\nwith open('required_packages.txt') as f:\n    required = set(line.strip() for line in f if line.strip())\n\nprint(f\"Installed: {len(installed)}, Required: {len(required)}\")\n\n# Find packages that are installed but not required\nextra_packages = installed - required\nprint(f\"Extra packages (before dependency check): {len(extra_packages)}\")\n\n# Build dependency tree for required packages (up to 3 levels)\ndependency_map = defaultdict(set)  # pkg -> packages that depend on it\nall_dependencies = set()\n\ndef get_dependencies(package, max_depth=3):\n    \"\"\"Get dependencies up to max_depth levels deep\"\"\"\n    deps = set()\n    queue = deque([(package, 0)])\n    visited = set()\n    \n    while queue:\n        pkg, depth = queue.popleft()\n        if pkg in visi"]
[47.239534, "i", "ted or depth > max_depth:\n            continue\n        visited.add(pkg)\n        \n        try:\n            # Use apt-cache depends to get direct dependencies\n            result = subprocess.run(\n                ['apt-cache', 'depends', pkg],\n                capture_output=True, text=True, timeout=5\n            )\n            \n            for line in result.stdout.split('\\n'):\n                line = line.strip()\n                # Parse dependency lines (Depends:, PreDepends:)\n                if line.startswith('Depends:') or line.startswith('PreDepends:'):\n                    dep = line.split(':', 1)[1].strip()\n                    # Remove version constraints and alternatives\n                    dep = re.split(r'[<>=|]', dep)[0].strip()\n                    if dep and depth < max_depth:\n                        deps.add(dep)\n                        dependency_map[dep].add(package)\n                        queue.append((dep, depth + 1))\n        except Exception as e:\n            print(f\"Warning: Could not get depend"]
[47.239589, "i", "encies for {pkg}: {e}\")\n    \n    return deps\n\nprint(\"\\nBuilding dependency trees...\")\nfor req_pkg in required:\n    print(f\"  Analyzing {req_pkg}...\")\n    deps = get_dependencies(req_pkg)\n    all_dependencies.update(deps)\n\nprint(f\"\\nTotal dependencies found: {len(all_dependencies)}\")\n\n# Classify packages\nremovable = extra_packages - all_dependencies\ndependency_protected = extra_packages & all_dependencies\n\nprint(f\"Removable: {len(removable)}\")\nprint(f\"Dependency-protected: {len(dependency_protected)}\")\n\n# Get package info for removable packages\nremovable_info = []\ntotal_size_kb = 0\n\nfor pkg in sorted(removable):\n    try:\n        # Get installed version and size\n        result = subprocess.run(\n            ['dpkg-query', '-W', '-f=${Version}\\\\t${Installed-Size}\\\\n', pkg],\n            capture_output=True, text=True, timeout=5\n        )\n        \n        if result.returncode == 0 and result.stdout.strip():\n            version, size_kb = result.stdout.strip().split('\\t')\n            size_kb = int(size_kb)\n        e"]
