[41.759532, "o", "\u001b[?2004h> "]
[41.759898, "o", "    canonical = f\"{txn['transaction_id']}|{txn['timestamp']}|{txn['account_id']}|{amount_formatted}|{txn['currency']}|{txn['status']}\"\r\n\u001b[?2004l\r"]
[41.759934, "o", "\u001b[?2004h> "]
[41.76011, "o", "    return hashlib.sha256(canonical.encode('utf-8')).hexdigest()\r\n\u001b[?2004l\r"]
[41.760143, "o", "\u001b[?2004h> "]
[41.760174, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[41.760205, "o", "> "]
[41.760253, "o", "def process_audit_logs():\r\n\u001b[?2004l\r"]
[41.760285, "o", "\u001b[?2004h> "]
[41.760465, "o", "    input_file = '/home/user/audit/raw_transactions.jsonl'\r\n\u001b[?2004l\r"]
[41.760501, "o", "\u001b[?2004h> "]
[41.760668, "o", "    output_file = '/home/user/audit/clean_audit.jsonl'\r\n\u001b[?2004l\r"]
[41.760702, "o", "\u001b[?2004h> "]
[41.760844, "o", "    error_file = '/home/user/audit/error_log.jsonl'\r\n\u001b[?2004l\r"]
[41.760875, "o", "\u001b[?2004h> "]
[41.761045, "o", "    summary_file = '/home/user/audit/processing_summary.txt'\r\n\u001b[?2004l\r"]
[41.761076, "o", "\u001b[?2004h> "]
[41.761107, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[41.76114, "o", "> "]
[41.761197, "o", "    valid_transactions = []\r\n\u001b[?2004l\r"]
[41.761228, "o", "\u001b[?2004h> "]
[41.761276, "o", "    errors = []\r\n\u001b[?2004l\r"]
[41.761307, "o", "\u001b[?2004h> "]
[41.76138, "o", "    error_counts = {\r\n\u001b[?2004l\r"]
[41.761414, "o", "\u001b[?2004h> "]
[41.761497, "o", "        'malformed_json': 0,\r\n\u001b[?2004l\r"]
[41.761529, "o", "\u001b[?2004h> "]
[41.761607, "o", "        'missing_field': 0,\r\n\u001b[?2004l\r"]
[41.761641, "o", "\u001b[?2004h> "]
[41.761719, "o", "        'invalid_format': 0,\r\n\u001b[?2004l\r"]
[41.761752, "o", "\u001b[?2004h> "]
[41.761826, "o", "        'invalid_value': 0\r\n\u001b[?2004l\r"]
[41.761858, "o", "\u001b[?2004h> "]
[41.761884, "o", "    }\r\n\u001b[?2004l\r"]
[41.761914, "o", "\u001b[?2004h> "]
[41.761941, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[41.761973, "o", "> "]
[41.762153, "o", "    processing_time = datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ')\r\n\u001b[?2004l\r"]
[41.762182, "o", "\u001b[?2004h> "]
[41.762209, "o", "    \r\n\u001b[?2004l\r"]
[41.762239, "o", "\u001b[?2004h> "]
[41.762306, "o", "    # Process input file\r\n\u001b[?2004l\r"]
[41.762338, "o", "\u001b[?2004h> "]
[41.762457, "o", "    with open(input_file, 'r') as f:\r\n\u001b[?2004l\r"]
[41.762489, "o", "\u001b[?2004h> "]
[41.762619, "o", "        for line_num, line in enumerate(f, 1):\r\n\u001b[?2004l\r"]
[41.762648, "o", "\u001b[?2004h> "]
[41.762773, "o", "            raw_content = line.rstrip('\\n')\r\n\u001b[?2004l\r"]
[41.762802, "o", "\u001b[?2004h> "]
[41.762843, "o", "            \r\n\u001b[?2004l\r"]
[41.762872, "o", "\u001b[?2004h> "]
[41.762965, "o", "            # Try to parse JSON\r\n\u001b[?2004l\r"]
[41.762995, "o", "\u001b[?2004h> "]
[41.763044, "o", "            try:\r\n\u001b[?2004l\r"]
[41.763076, "o", "\u001b[?2004h> "]
[41.763186, "o", "                data = json.loads(line)\r\n\u001b[?2004l\r"]
[41.763216, "o", "\u001b[?2004h> "]
[41.763345, "o", "            except json.JSONDecodeError as e:\r\n\u001b[?2004l\r"]
[41.763389, "o", "\u001b[?2004h> "]
[41.763479, "o", "                errors.append({\r\n\u001b[?2004l\r"]
[41.763508, "o", "\u001b[?2004h> "]
[41.763638, "o", "                    'line_number': line_num,\r\n\u001b[?2004l\r"]
[41.763667, "o", "\u001b[?2004h> "]
[41.763817, "o", "                    'error_type': 'malformed_json',\r\n\u001b[?2004l\r"]
[41.763849, "o", "\u001b[?2004h> "]
[41.764029, "o", "                    'error_detail': f'JSON parse error: {str(e)}',\r\n\u001b[?2004l\r"]
[41.764057, "o", "\u001b[?2004h> "]
[41.764207, "o", "                    'raw_content': raw_content[:200]\r\n\u001b[?2004l\r"]
[41.764236, "o", "\u001b[?2004h> "]
[41.764292, "o", "                })\r\n\u001b[?2004l\r"]
[41.76432, "o", "\u001b[?2004h> "]
[41.764488, "o", "                error_counts['malformed_json'] += 1\r\n\u001b[?2004l\r"]
[41.764519, "o", "\u001b[?2004h> "]
[41.764587, "o", "                continue\r\n\u001b[?2004l\r"]
[41.764617, "o", "\u001b[?2004h> "]
[41.764668, "o", "            \r\n\u001b[?2004l\r"]
[41.764699, "o", "\u001b[?2004h> "]
[41.764796, "o", "            # Validate transaction\r\n\u001b[?2004l\r"]
[41.764825, "o", "\u001b[?2004h> "]
[41.765035, "o", "            is_valid, error_type, error_detail = validate_transaction(data)\r\n\u001b[?2004l\r"]
[41.765067, "o", "\u001b[?2004h> "]
[41.765105, "o", "            \r\n\u001b[?2004l\r"]
[41.765135, "o", "\u001b[?2004h> "]
[41.765207, "o", "            if is_valid:\r\n\u001b[?2004l\r"]
[41.765235, "o", "\u001b[?2004h> "]
[41.765351, "o", "                # Compute integrity hash\r\n\u001b[?2004l\r"]
[41.765438, "o", "\u001b[?2004h> "]
[41.765581, "o", "                integrity_hash = compute_integrity_hash(data)\r\n\u001b[?2004l\r"]
[41.765613, "o", "\u001b[?2004h> "]
[41.76566, "o", "                \r\n\u001b[?2004l\r"]
[41.765692, "o", "\u001b[?2004h> "]
[41.765797, "o", "                # Create output record\r\n\u001b[?2004l\r"]
[41.765826, "o", "\u001b[?2004h> "]
[41.765926, "o", "                output_record = {\r\n\u001b[?2004l\r"]
[41.765956, "o", "\u001b[?2004h> "]
[41.766127, "o", "                    'transaction_id': data['transaction_id'],\r\n\u001b[?2004l\r"]
[41.766157, "o", "\u001b[?2004h> "]
[41.7663, "o", "                    'timestamp': data['timestamp'],\r\n\u001b[?2004l\r"]
[41.766333, "o", "\u001b[?2004h"]
[41.766364, "o", "> "]
[41.76649, "o", "                    'account_id': data['account_id'],\r\n\u001b[?2004l\r"]
[41.766522, "o", "\u001b[?2004h> "]
[41.766649, "o", "                    'amount': data['amount'],\r\n\u001b[?2004l\r"]
[41.76668, "o", "\u001b[?2004h> "]
[41.766818, "o", "                    'currency': data['currency'],\r\n\u001b[?2004l\r"]
[41.766847, "o", "\u001b[?2004h> "]
[41.766972, "o", "                    'status': data['status'],\r\n\u001b[?2004l\r"]
[41.767002, "o", "\u001b[?2004h> "]
[41.767157, "o", "                    'integrity_hash': integrity_hash,\r\n\u001b[?2004l\r"]
[41.767189, "o", "\u001b[?2004h> "]
[41.76733, "o", "                    'processed_at': processing_time\r\n\u001b[?2004l\r"]
[41.767361, "o", "\u001b[?2004h> "]
[41.767422, "o", "                }\r\n\u001b[?2004l\r"]
[41.767454, "o", "\u001b[?2004h> "]
[41.767611, "o", "                valid_transactions.append(output_record)\r\n\u001b[?2004l\r"]
[41.767642, "o", "\u001b[?2004h> "]
[41.767693, "o", "            else:\r\n\u001b[?2004l\r"]
[41.767725, "o", "\u001b[?2004h> "]
[41.767813, "o", "                errors.append({\r\n\u001b[?2004l\r"]
[41.767845, "o", "\u001b[?2004h> "]
[41.76797, "o", "                    'line_number': line_num,\r\n\u001b[?2004l\r"]
[41.768002, "o", "\u001b[?2004h> "]
[41.768129, "o", "                    'error_type': error_type,\r\n\u001b[?2004l\r"]
[41.768158, "o", "\u001b[?2004h> "]
[41.768302, "o", "                    'error_detail': error_detail,\r\n\u001b[?2004l\r"]
[41.768333, "o", "\u001b[?2004h> "]
[41.768487, "o", "                    'raw_content': raw_content[:200]\r\n\u001b[?2004l\r"]
[41.768508, "o", "\u001b[?2004h"]
[41.768527, "o", "> "]
[41.768574, "o", "                })\r\n\u001b[?2004l\r"]
[41.768605, "o", "\u001b[?2004h> "]
[41.768739, "o", "                error_counts[error_type] += 1\r\n\u001b[?2004l\r"]
[41.768773, "o", "\u001b[?2004h> "]
[41.768805, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[41.768836, "o", "> "]
[41.768936, "o", "    # Sort valid transactions by timestamp\r\n\u001b[?2004l\r"]
[41.768966, "o", "\u001b[?2004h> "]
[41.769129, "o", "    valid_transactions.sort(key=lambda x: x['timestamp'])\r\n\u001b[?2004l\r"]
[41.769161, "o", "\u001b[?2004h> "]
[41.769191, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[41.769219, "o", "> "]
[41.769288, "o", "    # Write clean audit file\r\n\u001b[?2004l\r"]
[41.769316, "o", "\u001b[?2004h> "]
[41.769436, "o", "    with open(output_file, 'w') as f:\r\n\u001b[?2004l\r"]
[41.769469, "o", "\u001b[?2004h> "]
[41.769575, "o", "        for txn in valid_transactions:\r\n\u001b[?2004l\r"]
[41.769606, "o", "\u001b[?2004h> "]
[41.769727, "o", "            f.write(json.dumps(txn) + '\\n')\r\n\u001b[?2004l\r"]
[41.769758, "o", "\u001b[?2004h> "]
[41.769787, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[41.769815, "o", "> "]
[41.769866, "o", "    # Write error log\r\n\u001b[?2004l\r"]
[41.769895, "o", "\u001b[?2004h> "]
[41.769999, "o", "    with open(error_file, 'w') as f:\r\n\u001b[?2004l\r"]
[41.770029, "o", "\u001b[?2004h> "]
[41.770113, "o", "        for error in errors:\r\n\u001b[?2004l\r"]
[41.770143, "o", "\u001b[?2004h> "]
[41.770275, "o", "            f.write(json.dumps(error) + '\\n')\r\n\u001b[?2004l\r"]
[41.770303, "o", "\u001b[?2004h> "]
[41.770334, "o", "    \r\n\u001b[?2004l\r"]
[41.770362, "o", "\u001b[?2004h> "]
[41.770449, "o", "    # Generate summary report\r\n\u001b[?2004l\r"]
[41.770479, "o", "\u001b[?2004h> "]
[41.770636, "o", "    total_lines = len(valid_transactions) + len(errors)\r\n\u001b[?2004l\r"]
[41.770666, "o", "\u001b[?2004h> "]
[41.770923, "o", "    success_rate = (len(valid_transactions) / total_lines * 100) if total_lines > 0 else 0.0\r\n\u001b[?2004l\r"]
[41.770952, "o", "\u001b[?2004h> "]
[41.770982, "o", "    \r\n\u001b[?2004l\r"]
[41.771013, "o", "\u001b[?2004h> "]
[41.77111, "o", "    with open(summary_file, 'w') as f:\r\n\u001b[?2004l\r"]
[41.771141, "o", "\u001b[?2004h> "]
[41.77127, "o", "        f.write('AUDIT PROCESSING SUMMARY\\n')\r\n\u001b[?2004l\r"]
[41.7713, "o", "\u001b[?2004h> "]
[41.77144, "o", "        f.write('========================\\n')\r\n\u001b[?2004l\r"]
[41.771472, "o", "\u001b[?2004h> "]
[41.7716, "o", "        f.write(f'Input file: {input_file}\\n')\r\n\u001b[?2004l\r"]
[41.771634, "o", "\u001b[?2004h> "]
[41.771793, "o", "        f.write(f'Total lines processed: {total_lines}\\n')\r\n\u001b[?2004l\r"]
[41.771823, "o", "\u001b[?2004h> "]
[41.772011, "o", "        f.write(f'Valid transactions: {len(valid_transactions)}\\n')\r\n\u001b[?2004l\r"]
[41.772042, "o", "\u001b[?2004h> "]
[41.772189, "o", "        f.write(f'Failed records: {len(errors)}\\n')\r\n\u001b[?2004l\r"]
[41.77222, "o", "\u001b[?2004h> "]
[41.772384, "o", "        f.write(f'Success rate: {success_rate:.2f}%\\n')\r\n\u001b[?2004l\r"]
[41.772418, "o", "\u001b[?2004h> "]
[41.772476, "o", "        f.write('\\n')\r\n\u001b[?2004l\r"]
[41.772507, "o", "\u001b[?2004h> "]
[41.772612, "o", "        f.write('Errors by type:\\n')\r\n\u001b[?2004l\r"]
[41.77265, "o", "\u001b[?2004h"]
[41.772681, "o", "> "]
[41.772851, "o", "        f.write(f'  malformed_json: {error_counts[\"malformed_json\"]}\\n')\r\n\u001b[?2004l\r"]
[41.772884, "o", "\u001b[?2004h> "]
[41.773079, "o", "        f.write(f'  missing_field: {error_counts[\"missing_field\"]}\\n')\r\n\u001b[?2004l\r"]
[41.773111, "o", "\u001b[?2004h> "]
[41.773316, "o", "        f.write(f'  invalid_format: {error_counts[\"invalid_format\"]}\\n')\r\n\u001b[?2004l\r"]
[41.773355, "o", "\u001b[?2004h> "]
[41.773546, "o", "        f.write(f'  invalid_value: {error_counts[\"invalid_value\"]}\\n')\r\n\u001b[?2004l\r"]
[41.773581, "o", "\u001b[?2004h> "]
[41.773641, "o", "        f.write('\\n')\r\n\u001b[?2004l\r"]
[41.773673, "o", "\u001b[?2004h> "]
[41.773853, "o", "        f.write(f'Processing completed at: {processing_time}\\n')\r\n\u001b[?2004l\r"]
[41.773877, "o", "\u001b[?2004h"]
[41.773914, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.773995, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[41.774025, "o", "\u001b[?2004h> "]
[41.7741, "o", "    process_audit_logs()\r\n\u001b[?2004l\r"]
[41.774128, "o", "\u001b[?2004h> "]
[41.774245, "o", "    print('Audit processing complete!')\r\n\u001b[?2004l\r"]
[41.774275, "o", "\u001b[?2004h> "]
[41.774305, "o", "EOF\r\n\u001b[?2004l\r"]
[41.781572, "o", "\u001b[?2004h"]
