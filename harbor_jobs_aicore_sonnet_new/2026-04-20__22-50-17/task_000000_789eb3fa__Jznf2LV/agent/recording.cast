[19.267257, "i", "cat > /home/user/docs_workspace/verify_permissions.sh << 'EOF'\n#!/bin/bash\n\n# Read manifest and verify permissions\nmanifest=\"/home/user/docs_workspace/permissions_manifest.txt\"\n\n# Function to get octal permissions\nget_perms() {\n    stat -c '%a' \"$1\" 2>/dev/null\n}\n\n# Parse and check directories\nwhile IFS=: read -r path expected_perm; do\n    if [[ -n \"$path\" && \"$path\" != \"DIRECTORY_PERMISSIONS\" && \"$path\" != \"FILE_PERMISSIONS\" && \"$path\" != \"\" ]]; then\n        actual_perm=$(get_perms \"$path\")\n        if [[ \"$actual_perm\" != \"$expected_perm\" ]]; then\n            echo \"FAIL: $path\"\n            exit 1\n        fi\n    fi\ndone < <(grep -A 10 'DIRECTORY_PERMISSIONS:' \"$manifest\" | grep -v 'DIRECTORY_PERMISSIONS:' | grep -v '^$' | head -4)\n\n# Parse and check files\nwhile IFS=: read -r path expected_perm; do\n    if [[ -n \"$path\" && \"$path\" != \"FILE_PERMISSIONS\" && \"$path\" != \"\" ]]; then\n        actual_perm=$(get_perms \"$path\")\n        if [[ \"$actual_perm\" != \"$expected_perm\" ]]; then\n            echo \"FAIL: $path\"\n     "]
[19.267379, "i", "       exit 1\n        fi\n    fi\ndone < <(grep -A 10 'FILE_PERMISSIONS:' \"$manifest\" | grep -v 'FILE_PERMISSIONS:' | grep -v '^$' | head -4)\n\necho \"PASS\"\nexit 0\nEOF\n"]
[19.267478, "o", "cat > /home/user/docs_workspace/verify_permissions.sh << 'EOF'\r\n\u001b[?2004l\r"]
