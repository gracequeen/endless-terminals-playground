[149.48387, "o", "\r\nFound 5 dependency packages\r\n"]
[149.483987, "o", "\r\nRemovable: 19, Dependency-protected: 3\r\n\r\nGathering package information...\r\n  Processing apache2...\r\n"]
[151.730491, "o", "  Processing dnsutils...\r\n"]
[153.993858, "o", "  Processing git...\r\n"]
[156.198273, "o", "  Processing htop...\r\n"]
[158.39709, "o", "  Processing iputils-ping...\r\n"]
[160.59541, "o", "  Processing lsof...\r\n"]
