[207.298943, "o", "#!/bin/bash\r\n\r\n# Container package removal script\r\n# Generated by migration audit\r\n\r\n# This will remove 19 packages and free approximately 37114 KB\r\n\r\necho 'The following packages will be removed:'\r\necho ''\r\necho '  - apache2'\r\necho '  - dnsutils'\r\necho '  - git'\r\necho '  - htop'\r\necho '  - iputils-ping'\r\necho '  - lsof'\r\necho '  - mysql-client'\r\necho '  - nano'\r\necho '  - ncdu'\r\n"]
[207.299016, "o", "echo '  - netcat-openbsd'\r\necho '  - nodejs'\r\necho '  - npm'\r\necho '  - postgresql-client'\r\necho '  - redis-tools'\r\necho '  - strace'\r\necho '  - tcpdump'\r\necho '  - tree'\r\necho '  - vim'\r\necho '  - wget'\r\necho ''\r\necho 'Dry run: apt-get remove -y \\'\r\necho '  apache2 \\'\r\necho '  dnsutils \\'\r\necho '  git \\'\r\necho '  htop \\'\r\necho '  iputils-ping \\'\r\necho '  lsof \\'\r\necho '  mysql-client \\'\r\necho '  nano \\'\r\necho '  ncdu \\'\r\necho '  netcat-openbsd \\'\r\necho '  nodejs \\'\r\necho '  npm \\'\r\necho '  postgresql-client \\'\r\necho '  redis-tools \\'\r\necho '  strace \\'\r\necho '  tcpdump \\'\r\necho '  tree \\'\r\necho '  vim \\'\r\necho '  wget'\r\necho ''\r\necho 'Uncomment the line below to actually remove packages:'\r\n# apt-get remove -y apache2 dnsutils git htop iputils-ping lsof mysql-client nano ncdu netcat-openbsd nodejs npm postgresql-client redis-tools strace tcpdump tree vim wget\r\n"]
