[47.314189, "o", "\u001b[?2004h> "]
[47.31426, "o", "                except:\r\n\u001b[?2004l\r"]
[47.314291, "o", "\u001b[?2004h> "]
[47.314361, "o", "                    pass\r\n\u001b[?2004l\r"]
[47.314405, "o", "\u001b[?2004h> "]
[47.314434, "o", "    \r\n\u001b[?2004l\r"]
[47.314465, "o", "\u001b[?2004h> "]
[47.314528, "o", "    return version, size_kb\r\n\u001b[?2004l\r"]
[47.314557, "o", "\u001b[?2004h> "]
[47.314589, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.314688, "o", "def has_security_update(package):\r\n\u001b[?2004l\r"]
[47.314722, "o", "\u001b[?2004h> "]
[47.314925, "o", "    policy_output = run_command(f\"apt-cache policy {package} 2>/dev/null\")\r\n\u001b[?2004l\r"]
[47.314957, "o", "\u001b[?2004h> "]
[47.315061, "o", "    lines = policy_output.split('\\n')\r\n\u001b[?2004l\r"]
[47.315092, "o", "\u001b[?2004h> "]
[47.31512, "o", "    \r\n\u001b[?2004l\r"]
[47.315148, "o", "\u001b[?2004h> "]
[47.315219, "o", "    installed_version = None\r\n\u001b[?2004l\r"]
[47.315251, "o", "\u001b[?2004h> "]
[47.315332, "o", "    candidate_version = None\r\n\u001b[?2004l\r"]
[47.315363, "o", "\u001b[?2004h> "]
[47.315444, "o", "    has_security = False\r\n\u001b[?2004l\r"]
[47.315475, "o", "\u001b[?2004h> "]
[47.315509, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[47.315537, "o", "> "]
[47.315589, "o", "    for line in lines:\r\n\u001b[?2004l\r"]
[47.31562, "o", "\u001b[?2004h> "]
[47.315711, "o", "        if 'Installed:' in line:\r\n\u001b[?2004l\r"]
[47.31574, "o", "\u001b[?2004h> "]
[47.315913, "o", "            installed_version = line.split(':', 1)[1].strip()\r\n\u001b[?2004l\r"]
[47.315947, "o", "\u001b[?2004h> "]
[47.316042, "o", "        elif 'Candidate:' in line:\r\n\u001b[?2004l\r"]
[47.316075, "o", "\u001b[?2004h> "]
[47.316244, "o", "            candidate_version = line.split(':', 1)[1].strip()\r\n\u001b[?2004l\r"]
[47.316276, "o", "\u001b[?2004h> "]
[47.316401, "o", "        elif 'security' in line.lower():\r\n\u001b[?2004l\r"]
[47.316432, "o", "\u001b[?2004h> "]
[47.316519, "o", "            has_security = True\r\n\u001b[?2004l\r"]
[47.316551, "o", "\u001b[?2004h> "]
[47.316579, "o", "    \r\n\u001b[?2004l\r"]
[47.316611, "o", "\u001b[?2004h> "]
[47.316941, "o", "    if installed_version and candidate_version and installed_version != candidate_version and installed_version != '(none)':\r\n\u001b[?2004l\r"]
[47.316973, "o", "\u001b[?2004h> "]
[47.317029, "o", "        return True\r\n\u001b[?2004l\r"]
[47.31706, "o", "\u001b[?2004h> "]
[47.317093, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[47.317121, "o", "> "]
[47.317268, "o", "    return has_security and installed_version != '(none)'\r\n\u001b[?2004l\r"]
[47.317297, "o", "\u001b[?2004h> "]
[47.317324, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.317355, "o", "> "]
[47.317438, "o", "print(\"Loading package lists...\")\r\n\u001b[?2004l\r"]
[47.317472, "o", "\u001b[?2004h> "]
[47.317605, "o", "with open('installed_packages.txt', 'r') as f:\r\n\u001b[?2004l\r"]
[47.317644, "o", "\u001b[?2004h> "]
[47.317815, "o", "    installed = [line.strip() for line in f if line.strip()]\r\n\u001b[?2004l\r"]
[47.317846, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.317879, "o", "\u001b[?2004h> "]
[47.318008, "o", "with open('required_packages.txt', 'r') as f:\r\n\u001b[?2004l\r"]
[47.318039, "o", "\u001b[?2004h> "]
[47.318205, "o", "    required = [line.strip() for line in f if line.strip()]\r\n\u001b[?2004l\r"]
[47.318237, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.318269, "o", "\u001b[?2004h> "]
[47.318462, "o", "print(f\"Installed: {len(installed)}, Required: {len(required)}\")\r\n\u001b[?2004l\r"]
[47.3185, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.318531, "o", "\u001b[?2004h> "]
[47.318696, "o", "print(\"\\nAnalyzing dependencies (this may take a moment)...\")\r\n\u001b[?2004l\r"]
[47.318728, "o", "\u001b[?2004h> "]
[47.318777, "o", "all_deps = set()\r\n\u001b[?2004l\r"]
[47.318807, "o", "\u001b[?2004h> "]
[47.318887, "o", "dep_map = defaultdict(list)\r\n\u001b[?2004l\r"]
[47.318919, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.318952, "o", "\u001b[?2004h> "]
[47.319012, "o", "for pkg in required:\r\n\u001b[?2004l\r"]
[47.319043, "o", "\u001b[?2004h> "]
[47.319185, "o", "    print(f\"  Checking dependencies for {pkg}...\")\r\n\u001b[?2004l\r"]
[47.319215, "o", "\u001b[?2004h> "]
[47.319308, "o", "    deps = get_dependencies(pkg)\r\n\u001b[?2004l\r"]
[47.319339, "o", "\u001b[?2004h> "]
[47.319411, "o", "    for dep in deps:\r\n\u001b[?2004l\r"]
[47.319445, "o", "\u001b[?2004h> "]
[47.319522, "o", "        if dep in installed:\r\n\u001b[?2004l\r"]
[47.319554, "o", "\u001b[?2004h> "]
[47.319638, "o", "            all_deps.add(dep)\r\n\u001b[?2004l\r"]
[47.31967, "o", "\u001b[?2004h> "]
[47.319773, "o", "            dep_map[dep].append(pkg)\r\n\u001b[?2004l\r"]
[47.319807, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.319838, "o", "\u001b[?2004h> "]
[47.319987, "o", "print(f\"\\nFound {len(all_deps)} dependency packages\")\r\n\u001b[?2004l\r"]
[47.320019, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.32005, "o", "\u001b[?2004h> "]
[47.320095, "o", "removable = []\r\n\u001b[?2004l\r"]
[47.320127, "o", "\u001b[?2004h> "]
[47.320201, "o", "dependency_protected = []\r\n\u001b[?2004l\r"]
[47.320232, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.320265, "o", "\u001b[?2004h> "]
[47.320328, "o", "for pkg in installed:\r\n\u001b[?2004l\r"]
[47.320357, "o", "\u001b[?2004h> "]
[47.320448, "o", "    if pkg not in required:\r\n\u001b[?2004l\r"]
[47.320481, "o", "\u001b[?2004h> "]
[47.320559, "o", "        if pkg in all_deps:\r\n\u001b[?2004l\r"]
[47.32059, "o", "\u001b[?2004h> "]
[47.320707, "o", "            dependency_protected.append({\r\n\u001b[?2004l\r"]
[47.320738, "o", "\u001b[?2004h> "]
[47.320819, "o", "                \"name\": pkg,\r\n\u001b[?2004l\r"]
[47.320849, "o", "\u001b[?2004h> "]
[47.321024, "o", "                \"required_by\": sorted(list(set(dep_map[pkg])))\r\n\u001b[?2004l\r"]
[47.321055, "o", "\u001b[?2004h> "]
[47.321098, "o", "            })\r\n\u001b[?2004l\r"]
[47.321129, "o", "\u001b[?2004h> "]
[47.321168, "o", "        else:\r\n\u001b[?2004l\r"]
[47.321198, "o", "\u001b[?2004h> "]
[47.321295, "o", "            removable.append(pkg)\r\n\u001b[?2004l\r"]
[47.321325, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.321356, "o", "\u001b[?2004h> "]
[47.321617, "o", "print(f\"\\nRemovable: {len(removable)}, Dependency-protected: {len(dependency_protected)}\")\r\n\u001b[?2004l\r"]
[47.32165, "o", "\u001b[?2004h"]
[47.321683, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[47.321716, "o", "> "]
[47.321815, "o", "print(\"\\nGathering package information...\")\r\n\u001b[?2004l\r"]
[47.321848, "o", "\u001b[?2004h> "]
[47.321914, "o", "removable_packages = []\r\n\u001b[?2004l\r"]
[47.321947, "o", "\u001b[?2004h> "]
[47.321993, "o", "total_space = 0\r\n\u001b[?2004l\r"]
[47.322026, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.322057, "o", "\u001b[?2004h> "]
[47.322142, "o", "for pkg in sorted(removable):\r\n\u001b[?2004l\r"]
[47.322173, "o", "\u001b[?2004h> "]
[47.322275, "o", "    print(f\"  Processing {pkg}...\")\r\n\u001b[?2004l\r"]
[47.322304, "o", "\u001b[?2004h> "]
[47.322442, "o", "    version, size_kb = get_package_info(pkg)\r\n\u001b[?2004l\r"]
[47.322472, "o", "\u001b[?2004h> "]
[47.322588, "o", "    has_update = has_security_update(pkg)\r\n\u001b[?2004l\r"]
[47.322618, "o", "\u001b[?2004h> "]
[47.322652, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[47.322684, "o", "> "]
[47.322757, "o", "    removable_packages.append({\r\n\u001b[?2004l\r"]
[47.322789, "o", "\u001b[?2004h> "]
[47.322849, "o", "        \"name\": pkg,\r\n\u001b[?2004l\r"]
[47.322879, "o", "\u001b[?2004h> "]
[47.322987, "o", "        \"installed_version\": version,\r\n\u001b[?2004l\r"]
[47.323019, "o", "\u001b[?2004h> "]
[47.323096, "o", "        \"size_kb\": size_kb,\r\n\u001b[?2004l\r"]
[47.323129, "o", "\u001b[?2004h> "]
[47.323241, "o", "        \"has_security_update\": has_update\r\n\u001b[?2004l\r"]
[47.323275, "o", "\u001b[?2004h> "]
[47.323302, "o", "    })\r\n\u001b[?2004l\r"]
[47.323334, "o", "\u001b[?2004h> "]
[47.323414, "o", "    total_space += size_kb\r\n\u001b[?2004l\r"]
[47.323445, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.323476, "o", "\u001b[?2004h> "]
[47.323509, "o", "report = {\r\n\u001b[?2004l\r"]
[47.32354, "o", "\u001b[?2004h> "]
[47.323589, "o", "    \"summary\": {\r\n\u001b[?2004l\r"]
[47.32362, "o", "\u001b[?2004h> "]
[47.323742, "o", "        \"total_installed\": len(installed),\r\n\u001b[?2004l\r"]
[47.323772, "o", "\u001b[?2004h> "]
[47.323888, "o", "        \"total_required\": len(required),\r\n\u001b[?2004l\r"]
[47.323919, "o", "\u001b[?2004h> "]
[47.324039, "o", "        \"removable_count\": len(removable),\r\n\u001b[?2004l\r"]
[47.324068, "o", "\u001b[?2004h> "]
[47.324234, "o", "        \"kept_as_dependencies\": len(dependency_protected),\r\n\u001b[?2004l\r"]
[47.324265, "o", "\u001b[?2004h> "]
[47.324407, "o", "        \"total_space_savings_kb\": total_space\r\n\u001b[?2004l\r"]
[47.32444, "o", "\u001b[?2004h> "]
[47.324474, "o", "    },\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.324505, "o", "> "]
[47.324611, "o", "    \"removable_packages\": removable_packages,\r\n\u001b[?2004l\r"]
[47.324645, "o", "\u001b[?2004h> "]
[47.324867, "o", "    \"dependency_protected\": sorted(dependency_protected, key=lambda x: x[\"name\"])\r\n\u001b[?2004l\r"]
[47.324901, "o", "\u001b[?2004h> }\r\n"]
[47.324932, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[47.324962, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.324993, "o", "> "]
[47.32505, "o", "print(\"\\nWriting report...\")\r\n\u001b[?2004l\r"]
[47.325081, "o", "\u001b[?2004h> "]
[47.325204, "o", "with open('removal_report.json', 'w') as f:\r\n\u001b[?2004l\r"]
[47.325235, "o", "\u001b[?2004h> "]
[47.325332, "o", "    json.dump(report, f, indent=2)\r\n\u001b[?2004l\r"]
[47.325375, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.325407, "o", "\u001b[?2004h> "]
[47.325517, "o", "print(\"\\nGenerating removal script...\")\r\n\u001b[?2004l\r"]
[47.325548, "o", "\u001b[?2004h> "]
[47.325678, "o", "with open('remove_packages.sh', 'w') as f:\r\n\u001b[?2004l\r"]
[47.325711, "o", "\u001b[?2004h> "]
[47.3258, "o", "    f.write(\"#!/bin/bash\\n\\n\")\r\n\u001b[?2004l\r"]
[47.325831, "o", "\u001b[?2004h> "]
[47.325987, "o", "    f.write(\"# Container package removal script\\n\")\r\n\u001b[?2004l\r"]
[47.326023, "o", "\u001b[?2004h> "]
[47.326145, "o", "    f.write(\"# Generated by migration audit\\n\\n\")\r\n\u001b[?2004l\r"]
[47.326177, "o", "\u001b[?2004h> "]
[47.326474, "o", "    f.write(f\"# This will remove {len(removable)} packages and free approximately {total_space} KB\\n\\n\")\r\n\u001b[?2004l\r"]
[47.326507, "o", "\u001b[?2004h> "]
[47.326683, "o", "    f.write(\"echo 'The following packages will be removed:'\\n\")\r\n\u001b[?2004l\r"]
[47.326714, "o", "\u001b[?2004h> "]
[47.326789, "o", "    f.write(\"echo ''\\n\")\r\n\u001b[?2004l\r"]
[47.32682, "o", "\u001b[?2004h> "]
[47.326917, "o", "    for pkg in sorted(removable):\r\n\u001b[?2004l\r"]
[47.326947, "o", "\u001b[?2004h> "]
[47.32706, "o", "        f.write(f\"echo '  - {pkg}'\\n\")\r\n\u001b[?2004l\r"]
[47.327091, "o", "\u001b[?2004h> "]
[47.327163, "o", "    f.write(\"echo ''\\n\")\r\n\u001b[?2004l\r"]
[47.327193, "o", "\u001b[?2004h> "]
[47.327344, "o", "    f.write(\"echo 'Dry run: apt-get remove -y \\\\'\\n\")\r\n\u001b[?2004l\r"]
[47.327382, "o", "\u001b[?2004h> "]
[47.327518, "o", "    for i, pkg in enumerate(sorted(removable)):\r\n\u001b[?2004l\r"]
[47.327549, "o", "\u001b[?2004h> "]
[47.327646, "o", "        if i < len(removable) - 1:\r\n\u001b[?2004l\r"]
[47.327676, "o", "\u001b[?2004h> "]
[47.3278, "o", "            f.write(f\"echo '  {pkg} \\\\'\\n\")\r\n\u001b[?2004l\r"]
[47.327831, "o", "\u001b[?2004h> "]
[47.327871, "o", "        else:\r\n\u001b[?2004l\r"]
[47.327902, "o", "\u001b[?2004h> "]
[47.328016, "o", "            f.write(f\"echo '  {pkg}'\\n\")\r\n\u001b[?2004l\r"]
[47.328046, "o", "\u001b[?2004h> "]
[47.328119, "o", "    f.write(\"echo ''\\n\")\r\n\u001b[?2004l\r"]
[47.328149, "o", "\u001b[?2004h> "]
[47.328375, "o", "    f.write(\"echo 'Uncomment the line below to actually remove packages:'\\n\")\r\n\u001b[?2004l\r"]
[47.328411, "o", "\u001b[?2004h> "]
[47.328509, "o", "    f.write(\"# apt-get remove -y \")\r\n\u001b[?2004l\r"]
[47.328539, "o", "\u001b[?2004h> "]
[47.328654, "o", "    f.write(\" \".join(sorted(removable)))\r\n\u001b[?2004l\r"]
[47.328685, "o", "\u001b[?2004h> "]
[47.328736, "o", "    f.write(\"\\n\")\r\n\u001b[?2004l\r"]
[47.328766, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.328794, "o", "\u001b[?2004h> "]
[47.32892, "o", "run_command(\"chmod +x remove_packages.sh\")\r\n\u001b[?2004l\r"]
[47.328951, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.32898, "o", "\u001b[?2004h> "]
[47.329138, "o", "print(\"\\nDone! Report written to removal_report.json\")\r\n\u001b[?2004l\r"]
[47.329169, "o", "\u001b[?2004h> "]
[47.329325, "o", "print(f\"Removal script written to remove_packages.sh\")\r\n\u001b[?2004l\r"]
[47.329356, "o", "\u001b[?2004h> "]
[47.329401, "o", "SCRIPT_EOF\r\n\u001b[?2004l\r"]
[47.334053, "o", "\u001b[?2004h"]
[47.334105, "o", "user@c32c98d583c3:~/migration$ "]
[47.398715, "i", "python3 audit_packages.py\n"]
[47.398828, "o", "python3 audit_packages.py\r\n\u001b[?2004l\r"]
[47.42284, "o", "Loading package lists...\r\n"]
[47.422925, "o", "Installed: 31, Required: 9\r\n\r\nAnalyzing dependencies (this may take a moment)...\r\n  Checking dependencies for curl...\r\n"]
[68.723897, "o", "  Checking dependencies for python3...\r\n"]
[76.563723, "o", "  Checking dependencies for python3-pip...\r\n"]
[87.572848, "o", "  Checking dependencies for jq...\r\n"]
[92.910552, "o", "  Checking dependencies for nginx...\r\n"]
[129.706125, "o", "  Checking dependencies for ca-certificates...\r\n"]
