[47.304143, "i", "f\"apt-cache policy {package} 2>/dev/null\")\n    lines = policy_output.split('\\n')\n    \n    installed_version = None\n    candidate_version = None\n    has_security = False\n    \n    for line in lines:\n        if 'Installed:' in line:\n            installed_version = line.split(':', 1)[1].strip()\n        elif 'Candidate:' in line:\n            candidate_version = line.split(':', 1)[1].strip()\n        elif 'security' in line.lower():\n            has_security = True\n    \n    if installed_version and candidate_version and installed_version != candidate_version and installed_version != '(none)':\n        return True\n    \n    return has_security and installed_version != '(none)'\n\nprint(\"Loading package lists...\")\nwith open('installed_packages.txt', 'r') as f:\n    installed = [line.strip() for line in f if line.strip()]\n\nwith open('required_packages.txt', 'r') as f:\n    required = [line.strip() for line in f if line.strip()]\n\nprint(f\"Installed: {len(installed)}, Required: {len(required)}\")\n\nprint(\"\\nAnalyzing dependencies "]
