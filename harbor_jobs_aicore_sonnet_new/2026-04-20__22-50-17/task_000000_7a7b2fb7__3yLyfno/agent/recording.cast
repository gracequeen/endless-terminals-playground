[74.196399, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[74.196428, "o", "> "]
[74.196491, "o", "declare -a removable_packages\r\n\u001b[?2004l\r"]
[74.19652, "o", "\u001b[?2004h> "]
[74.196633, "o", "declare -a dependency_protected_packages\r\n\u001b[?2004l\r"]
[74.19668, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[74.196715, "o", "\u001b[?2004h> "]
[74.196795, "o", "for pkg in \"${INSTALLED[@]}\"; do\r\n\u001b[?2004l\r"]
[74.196828, "o", "\u001b[?2004h> "]
[74.196954, "o", "    if [ \"${required_map[$pkg]}\" = \"1\" ]; then\r\n\u001b[?2004l\r"]
[74.196984, "o", "\u001b[?2004h> "]
[74.197032, "o", "        continue\r\n\u001b[?2004l\r"]
[74.197066, "o", "\u001b[?2004h> "]
[74.197095, "o", "    fi\r\n\u001b[?2004l\r"]
[74.19713, "o", "\u001b[?2004h>     \r\n"]
[74.197159, "o", "\u001b[?2004l\r\u001b[?2004h"]
[74.197187, "o", "> "]
[74.197299, "o", "    if [ \"${dependency_map[$pkg]}\" = \"1\" ]; then\r\n\u001b[?2004l\r"]
[74.197329, "o", "\u001b[?2004h> "]
[74.197461, "o", "        dependency_protected_packages+=(\"$pkg\")\r\n\u001b[?2004l\r"]
[74.19749, "o", "\u001b[?2004h> "]
[74.197518, "o", "    else\r\n\u001b[?2004l\r"]
[74.197547, "o", "\u001b[?2004h> "]
[74.197651, "o", "        removable_packages+=(\"$pkg\")\r\n\u001b[?2004l\r"]
[74.197696, "o", "\u001b[?2004h> "]
[74.197725, "o", "    fi\r\n\u001b[?2004l\r\u001b[?2004h"]
[74.197754, "o", "> done\r\n"]
[74.197783, "o", "\u001b[?2004l\r\u001b[?2004h"]
[74.197817, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[74.198021, "o", "IFS=$'\\n' removable_packages=($(sort <<<\"${removable_packages[*]}\"))\r\n\u001b[?2004l\r"]
[74.198052, "o", "\u001b[?2004h> "]
[74.198302, "o", "IFS=$'\\n' dependency_protected_packages=($(sort <<<\"${dependency_protected_packages[*]}\"))\r\n\u001b[?2004l\r"]
[74.198334, "o", "\u001b[?2004h> "]
[74.198363, "o", "unset IFS\r\n\u001b[?2004l\r"]
[74.198392, "o", "\u001b[?2004h> "]
[74.198421, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[74.19845, "o", "> "]
[74.198478, "o", "total_space=0\r\n\u001b[?2004l\r"]
[74.198507, "o", "\u001b[?2004h> "]
[74.198553, "o", "removable_json=\"\"\r\n\u001b[?2004l\r"]
[74.198582, "o", "\u001b[?2004h> "]
[74.198611, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[74.19864, "o", "> "]
[74.198746, "o", "for pkg in \"${removable_packages[@]}\"; do\r\n\u001b[?2004l\r"]
[74.198777, "o", "\u001b[?2004h> "]
[74.199001, "o", "    version=$(dpkg-query -W -f='${Version}' \"$pkg\" 2>/dev/null || echo \"unknown\")\r\n\u001b[?2004l\r"]
[74.199035, "o", "\u001b[?2004h> "]
[74.199264, "o", "    size_kb=$(dpkg-query -W -f='${Installed-Size}' \"$pkg\" 2>/dev/null || echo \"0\")\r\n\u001b[?2004l\r"]
[74.199297, "o", "\u001b[?2004h> "]
[74.199326, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[74.199359, "o", "> "]
[74.199407, "o", "    has_security=false\r\n\u001b[?2004l\r"]
[74.19944, "o", "\u001b[?2004h> "]
[74.199593, "o", "    policy_output=$(apt-cache policy \"$pkg\" 2>/dev/null)\r\n\u001b[?2004l\r"]
[74.199626, "o", "\u001b[?2004h> "]
[74.199786, "o", "    if echo \"$policy_output\" | grep -q \"security\"; then\r\n\u001b[?2004l\r"]
[74.199821, "o", "\u001b[?2004h> "]
[74.20005, "o", "        installed_ver=$(echo \"$policy_output\" | grep \"Installed:\" | awk '{print $2}')\r\n\u001b[?2004l\r"]
[74.200079, "o", "\u001b[?2004h> "]
[74.200313, "o", "        candidate_ver=$(echo \"$policy_output\" | grep \"Candidate:\" | awk '{print $2}')\r\n\u001b[?2004l\r"]
[74.200347, "o", "\u001b[?2004h> "]
[74.2006, "o", "        if [ \"$installed_ver\" != \"$candidate_ver\" ] && [ \"$candidate_ver\" != \"(none)\" ]; then\r\n\u001b[?2004l\r"]
[74.200629, "o", "\u001b[?2004h> "]
[74.200723, "o", "            has_security=true\r\n\u001b[?2004l\r"]
[74.200758, "o", "\u001b[?2004h> "]
[74.200788, "o", "        fi\r\n\u001b[?2004l\r"]
[74.200816, "o", "\u001b[?2004h> "]
[74.200845, "o", "    fi\r\n\u001b[?2004l\r"]
[74.200874, "o", "\u001b[?2004h> "]
[74.200902, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[74.200931, "o", "> "]
[74.201038, "o", "    total_space=$((total_space + size_kb))\r\n\u001b[?2004l\r"]
[74.201067, "o", "\u001b[?2004h> "]
[74.201095, "o", "    \r\n\u001b[?2004l\r"]
[74.201128, "o", "\u001b[?2004h> "]
[74.201224, "o", "    if [ -n \"$removable_json\" ]; then\r\n\u001b[?2004l\r"]
[74.201261, "o", "\u001b[?2004h> "]
[74.201332, "o", "        removable_json+=\",\"\r\n\u001b[?2004l\r"]
[74.201361, "o", "\u001b[?2004h> "]
[74.201389, "o", "    fi\r\n\u001b[?2004l\r"]
[74.201419, "o", "\u001b[?2004h> "]
[74.201479, "o", "    removable_json+=\"\r\n\u001b[?2004l\r"]
[74.201508, "o", "\u001b[?2004h> "]
[74.201964, "o", "    {\\n      \\\"name\\\": \\\"$pkg\\\",\\n      \\\"installed_version\\\": \\\"$version\\\",\\n      \\\"size_kb\\\": $size_kb,\\n      \\\"has_security_update\\\": $has_security\\n    }\"\r\n\u001b[?2004l\r"]
[74.202002, "o", "\u001b[?2004h> "]
[74.20203, "o", "done\r\n\u001b[?2004l\r\u001b[?2004h"]
[74.202059, "o", "> \r\n\u001b[?2004l\r"]
[74.202088, "o", "\u001b[?2004h> "]
[74.202132, "o", "protected_json=\"\"\r\n\u001b[?2004l\r"]
[74.202165, "o", "\u001b[?2004h> "]
[74.20231, "o", "for pkg in \"${dependency_protected_packages[@]}\"; do\r\n\u001b[?2004l\r"]
[74.202339, "o", "\u001b[?2004h> "]
[74.202461, "o", "    required_by_str=\"${protected_by[$pkg]}\"\r\n\u001b[?2004l\r"]
[74.20249, "o", "\u001b[?2004h> "]
[74.202671, "o", "    IFS=',' read -ra required_by_array <<<\"$required_by_str\"\r\n\u001b[?2004l\r"]
[74.202702, "o", "\u001b[?2004h> "]
[74.20273, "o", "    \r\n\u001b[?2004l\r"]
[74.202764, "o", "\u001b[?2004h> "]
[74.202821, "o", "    required_by_json=\"\"\r\n\u001b[?2004l\r"]
[74.202849, "o", "\u001b[?2004h> "]
[74.202977, "o", "    for req in \"${required_by_array[@]}\"; do\r\n\u001b[?2004l\r"]
[74.203009, "o", "\u001b[?2004h> "]
[74.203127, "o", "        if [ -n \"$required_by_json\" ]; then\r\n\u001b[?2004l\r"]
[74.203156, "o", "\u001b[?2004h> "]
[74.203254, "o", "            required_by_json+=\", \"\r\n\u001b[?2004l\r"]
[74.203283, "o", "\u001b[?2004h> "]
[74.203319, "o", "        fi\r\n\u001b[?2004l\r"]
[74.203348, "o", "\u001b[?2004h> "]
[74.203462, "o", "        required_by_json+=\"\\\\\\\"$req\\\\\\\"\"\r\n\u001b[?2004l\r"]
[74.203491, "o", "\u001b[?2004h> "]
[74.203524, "o", "    done\r\n\u001b[?2004l\r"]
[74.203557, "o", "\u001b[?2004h> "]
[74.203591, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[74.203623, "o", "> "]
[74.203716, "o", "    if [ -n \"$protected_json\" ]; then\r\n\u001b[?2004l\r"]
[74.203752, "o", "\u001b[?2004h> "]
[74.203826, "o", "        protected_json+=\",\"\r\n\u001b[?2004l\r"]
[74.203855, "o", "\u001b[?2004h> "]
[74.203884, "o", "    fi\r\n\u001b[?2004l\r"]
[74.203913, "o", "\u001b[?2004h> "]
[74.203971, "o", "    protected_json+=\"\r\n\u001b[?2004l\r"]
[74.204001, "o", "\u001b[?2004h> "]
[74.204233, "o", "    {\\n      \\\"name\\\": \\\"$pkg\\\",\\n      \\\"required_by\\\": [$required_by_json]\\n    }\"\r\n\u001b[?2004l\r"]
[74.204262, "o", "\u001b[?2004h> "]
[74.20429, "o", "done\r\n\u001b[?2004l\r"]
[74.204323, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[74.204352, "o", "\u001b[?2004h> "]
[74.204446, "o", "cat > removal_report.json <<JSONEOF\r\n\u001b[?2004l\r"]
[74.204474, "o", "\u001b[?2004h> "]
[74.204504, "o", "{\r\n\u001b[?2004l\r\u001b[?2004h"]
[74.204536, "o", "> "]
[74.204566, "o", "  \"summary\": {\r\n\u001b[?2004l\r"]
[74.204594, "o", "\u001b[?2004h> "]
[74.204713, "o", "    \"total_installed\": ${#INSTALLED[@]},\r\n\u001b[?2004l\r"]
[74.204748, "o", "\u001b[?2004h> "]
[74.204852, "o", "    \"total_required\": ${#REQUIRED[@]},\r\n\u001b[?2004l\r"]
[74.204881, "o", "\u001b[?2004h"]
[74.204918, "o", "> "]
[74.205049, "o", "    \"removable_count\": ${#removable_packages[@]},\r\n\u001b[?2004l\r"]
[74.205085, "o", "\u001b[?2004h> "]
[74.20526, "o", "    \"kept_as_dependencies\": ${#dependency_protected_packages[@]},\r\n\u001b[?2004l\r"]
[74.205288, "o", "\u001b[?2004h> "]
[74.205408, "o", "    \"total_space_savings_kb\": $total_space\r\n\u001b[?2004l\r"]
[74.205437, "o", "\u001b[?2004h> "]
[74.205472, "o", "  },\r\n\u001b[?2004l\r\u001b[?2004h"]
[74.205504, "o", "> "]
[74.205596, "o", "  \"removable_packages\": [$removable_json\r\n\u001b[?2004l\r"]
[74.205626, "o", "\u001b[?2004h> "]
[74.205672, "o", "  ],\r\n\u001b[?2004l\r"]
[74.205702, "o", "\u001b[?2004h> "]
[74.205808, "o", "  \"dependency_protected\": [$protected_json\r\n\u001b[?2004l\r"]
[74.205838, "o", "\u001b[?2004h> "]
[74.205866, "o", "  ]\r\n\u001b[?2004l\r\u001b[?2004h"]
[74.205895, "o", "> }\r\n\u001b[?2004l\r"]
[74.205938, "o", "\u001b[?2004h> "]
[74.205969, "o", "JSONEOF\r\n\u001b[?2004l\r\u001b[?2004h"]
[74.205998, "o", "> \r\n\u001b[?2004l\r"]
[74.206027, "o", "\u001b[?2004h> "]
[74.20612, "o", "cat > remove_packages.sh <<REMSCRIPT\r\n\u001b[?2004l\r"]
[74.206149, "o", "\u001b[?2004h> "]
[74.206187, "o", "#!/bin/bash\r\n\u001b[?2004l\r"]
[74.206216, "o", "\u001b[?2004h> "]
[74.206356, "o", "echo \"This will remove the following packages:\"\r\n\u001b[?2004l\r"]
[74.206393, "o", "\u001b[?2004h> "]
[74.206475, "o", "echo \"${removable_packages[*]}\"\r\n\u001b[?2004l\r"]
[74.206504, "o", "\u001b[?2004h> "]
[74.206533, "o", "echo \"\"\r\n\u001b[?2004l\r"]
[74.206562, "o", "\u001b[?2004h> "]
[74.206628, "o", "echo \"Dry run command:\"\r\n\u001b[?2004l\r"]
[74.20667, "o", "\u001b[?2004h> "]
[74.206806, "o", "echo \"apt-get remove -y ${removable_packages[*]}\"\r\n\u001b[?2004l\r"]
[74.206841, "o", "\u001b[?2004h> "]
[74.20687, "o", "echo \"\"\r\n\u001b[?2004l\r"]
[74.2069, "o", "\u001b[?2004h> "]
[74.20703, "o", "read -p \"Proceed with removal? (yes/no): \" confirm\r\n\u001b[?2004l\r"]
[74.207059, "o", "\u001b[?2004h> "]
[74.207159, "o", "if [ \"\\$confirm\" = \"yes\" ]; then\r\n\u001b[?2004l\r"]
[74.207188, "o", "\u001b[?2004h> "]
[74.207319, "o", "    apt-get remove -y ${removable_packages[*]}\r\n\u001b[?2004l\r"]
[74.207347, "o", "\u001b[?2004h> "]
[74.207466, "o", "    echo \"Packages removed successfully.\"\r\n\u001b[?2004l\r"]
[74.207507, "o", "\u001b[?2004h> else\r\n"]
[74.20754, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[74.207625, "o", "    echo \"Removal cancelled.\"\r\n\u001b[?2004l\r"]
[74.207667, "o", "\u001b[?2004h> "]
[74.207697, "o", "fi\r\n\u001b[?2004l\r\u001b[?2004h"]
[74.207725, "o", "> "]
[74.207753, "o", "REMSCRIPT\r\n\u001b[?2004l\r\u001b[?2004h"]
[74.207784, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[74.207814, "o", "> "]
[74.207879, "o", "chmod +x remove_packages.sh\r\n\u001b[?2004l\r"]
[74.207907, "o", "\u001b[?2004h> "]
[74.207937, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[74.207965, "o", "> "]
[74.208028, "o", "echo \"Analysis complete!\" >&2\r\n\u001b[?2004l\r"]
[74.208056, "o", "\u001b[?2004h> "]
[74.208222, "o", "echo \"Removable packages: ${#removable_packages[@]}\" >&2\r\n\u001b[?2004l\r"]
[74.208255, "o", "\u001b[?2004h> "]
[74.208448, "o", "echo \"Dependency protected: ${#dependency_protected_packages[@]}\" >&2\r\n\u001b[?2004l\r"]
[74.208478, "o", "\u001b[?2004h> "]
[74.208621, "o", "echo \"Total space savings: ${total_space} KB\" >&2\r\n\u001b[?2004l\r"]
[74.20865, "o", "\u001b[?2004h> "]
[74.208699, "o", "ENDOFSCRIPT\r\n\u001b[?2004l\r"]
