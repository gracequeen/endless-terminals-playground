[169.306779, "o", "        installed_ver=$(echo \"$policy_output\" | grep \"Installed:\" | awk '{print $2}')\r\n\u001b[?2004l\r"]
[169.306814, "o", "\u001b[?2004h> "]
[169.307043, "o", "        candidate_ver=$(echo \"$policy_output\" | grep \"Candidate:\" | awk '{print $2}')\r\n\u001b[?2004l\r"]
[169.30707, "o", "\u001b[?2004h> "]
[169.307401, "o", "        if [ \"$installed_ver\" != \"$candidate_ver\" ] && [ \"$candidate_ver\" != \"(none)\" ] && [ -n \"$candidate_ver\" ]; then\r\n\u001b[?2004l\r"]
[169.307436, "o", "\u001b[?2004h> "]
[169.307521, "o", "            has_security=\"true\"\r\n\u001b[?2004l\r"]
[169.307555, "o", "\u001b[?2004h> "]
[169.307591, "o", "        fi\r\n\u001b[?2004l\r"]
[169.307627, "o", "\u001b[?2004h> "]
