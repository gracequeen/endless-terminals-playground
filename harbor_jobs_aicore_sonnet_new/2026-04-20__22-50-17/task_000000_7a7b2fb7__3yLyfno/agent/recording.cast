[169.310023, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[169.310279, "o", "    protected_json_items+=(\"    {\\\"name\\\": \\\"$pkg\\\", \\\"required_by\\\": [$required_by_json]}\")\r\n\u001b[?2004l\r"]
