[169.307709, "o", "    \r\n\u001b[?2004l\r"]
[169.307744, "o", "\u001b[?2004h> "]
[169.307845, "o", "    total_space=$((total_space + size_kb))\r\n\u001b[?2004l\r"]
[169.307873, "o", "\u001b[?2004h> "]
[169.30791, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[169.307945, "o", "> "]
[169.308341, "o", "    removable_json_items+=(\"    {\\\"name\\\": \\\"$pkg\\\", \\\"installed_version\\\": \\\"$version\\\", \\\"size_kb\\\": $size_kb, \\\"has_security_update\\\": $has_security}\")\r\n\u001b[?2004l\r"]
