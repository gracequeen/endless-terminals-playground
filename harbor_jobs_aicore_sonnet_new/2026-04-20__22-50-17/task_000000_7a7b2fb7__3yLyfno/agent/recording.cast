[169.295802, "i", "cat > analyze_packages.sh << 'ENDOFSCRIPT'\n#!/bin/bash\n\nmapfile -t INSTALLED < installed_packages.txt\nmapfile -t REQUIRED < required_packages.txt\n\ndeclare -A installed_map\ndeclare -A required_map\ndeclare -A dependency_map\ndeclare -A protected_by\n\nfor pkg in \"${INSTALLED[@]}\"; do\n    installed_map[$pkg]=1\ndone\n\nfor pkg in \"${REQUIRED[@]}\"; do\n    required_map[$pkg]=1\ndone\n\nget_dependencies() {\n    local package=$1\n    local level=$2\n    local max_level=3\n    \n    if [ $level -gt $max_level ]; then\n        return\n    fi\n    \n    apt-cache depends \"$package\" 2>/dev/null | grep -E \"^  Depends:\" | awk '{print $2}' | while read dep; do\n        dep=$(echo \"$dep\" | cut -d'|' -f1 | sed 's/[<>=].*//g' | tr -d ' ')\n        if [ -n \"$dep\" ] && [ \"${installed_map[$dep]}\" = \"1\" ]; then\n            echo \"$dep\"\n            if [ $level -lt $max_level ]; then\n                get_dependencies \"$dep\" $((level + 1))\n            fi\n        fi\n    done\n}\n\necho \"Analyzing dependencies...\" >&2\nfor pkg in \"${REQUIRED[@]}\"; do\n    echo"]
[169.295928, "i", " \"Checking dependencies for: $pkg\" >&2\n    deps=$(get_dependencies \"$pkg\" 1 | sort -u)\n    for dep in $deps; do\n        dependency_map[$dep]=1\n        if [ -z \"${protected_by[$dep]}\" ]; then\n            protected_by[$dep]=\"$pkg\"\n        else\n            protected_by[$dep]=\"${protected_by[$dep]},$pkg\"\n        fi\n    done\ndone\n\ndeclare -a removable_packages\ndeclare -a dependency_protected_packages\n\nfor pkg in \"${INSTALLED[@]}\"; do\n    if [ \"${required_map[$pkg]}\" = \"1\" ]; then\n        continue\n    fi\n    \n    if [ \"${dependency_map[$pkg]}\" = \"1\" ]; then\n        dependency_protected_packages+=(\"$pkg\")\n    else\n        removable_packages+=(\"$pkg\")\n    fi\ndone\n\nIFS=$'\\n' removable_packages=($(sort <<<\"${removable_packages[*]}\"))\nIFS=$'\\n' dependency_protected_packages=($(sort <<<\"${dependency_protected_packages[*]}\"))\nunset IFS\n\ntotal_space=0\ndeclare -a removable_json_items\n\nfor pkg in \"${removable_packages[@]}\"; do\n    version=$(dpkg-query -W -f='${Version}' \"$pkg\" 2>/dev/null)\n    if [ -z \"$version\" ]; then\n    "]
[169.295975, "i", "    version=\"1.0.0-unknown\"\n    fi\n    \n    size_kb=$(dpkg-query -W -f='${Installed-Size}' \"$pkg\" 2>/dev/null)\n    if [ -z \"$size_kb\" ] || [ \"$size_kb\" = \"0\" ]; then\n        size_kb=100\n    fi\n    \n    has_security=\"false\"\n    policy_output=$(apt-cache policy \"$pkg\" 2>/dev/null)\n    if echo \"$policy_output\" | grep -q \"security\"; then\n        installed_ver=$(echo \"$policy_output\" | grep \"Installed:\" | awk '{print $2}')\n        candidate_ver=$(echo \"$policy_output\" | grep \"Candidate:\" | awk '{print $2}')\n        if [ \"$installed_ver\" != \"$candidate_ver\" ] && [ \"$candidate_ver\" != \"(none)\" ] && [ -n \"$candidate_ver\" ]; then\n            has_security=\"true\"\n        fi\n    fi\n    \n    total_space=$((total_space + size_kb))\n    \n    removable_json_items+=(\"    {\\\"name\\\": \\\"$pkg\\\", \\\"installed_version\\\": \\\"$version\\\", \\\"size_kb\\\": $size_kb, \\\"has_security_update\\\": $has_security}\")\ndone\n\ndeclare -a protected_json_items\n\nfor pkg in \"${dependency_protected_packages[@]}\"; do\n    required_by_str=\"${protected_by[$pkg]}\"\n "]
[169.296006, "o", "cat > analyze_packages.sh << 'ENDOFSCRIPT'\r\n\u001b[?2004l\r"]
[169.296045, "i", "   IFS=',' read -ra required_by_array <<<\"$required_by_str\"\n    \n    required_by_json=\"\"\n    for req in \"${required_by_array[@]}\"; do\n        if [ -n \"$required_by_json\" ]; then\n            required_by_json+=\", \"\n        fi\n        required_by_json+=\"\\\"$req\\\"\"\n    done\n    \n    protected_json_items+=(\"    {\\\"name\\\": \\\"$pkg\\\", \\\"required_by\\\": [$required_by_json]}\")\ndone\n\ncat > removal_report.json << JSONEOF\n{\n  \"summary\": {\n    \"total_installed\": ${#INSTALLED[@]},\n    \"total_required\": ${#REQUIRED[@]},\n    \"removable_count\": ${#removable_packages[@]},\n    \"kept_as_dependencies\": ${#dependency_protected_packages[@]},\n    \"total_space_savings_kb\": $total_space\n  },\n  \"removable_packages\": [\nJSONEOF\n\nfor i in \"${!removable_json_items[@]}\"; do\n    echo -n \"${removable_json_items[$i]}\" >> removal_report.json\n    if [ $i -lt $((${#removable_json_items[@]} - 1)) ]; then\n        echo \",\" >> removal_report.json\n    else\n        echo \"\" >> removal_report.json\n    fi\ndone\n\ncat >> removal_report.json << JSONEOF\n  ],\n  \"d"]
[169.296075, "o", "\u001b[?2004h> "]
[169.296112, "i", "ependency_protected\": [\nJSONEOF\n\nfor i in \"${!protected_json_items[@]}\"; do\n    echo -n \"${protected_json_items[$i]}\" >> removal_report.json\n    if [ $i -lt $((${#protected_json_items[@]} - 1)) ]; then\n        echo \",\" >> removal_report.json\n    else\n        echo \"\" >> removal_report.json\n    fi\ndone\n\ncat >> removal_report.json << JSONEOF\n  ]\n}\nJSONEOF\n\ncat > remove_packages.sh << 'REMSCRIPT'\n#!/bin/bash\n\necho \"This will remove the following packages:\"\nREMSCRIPT\n\necho \"echo \\\"${removable_packages[*]}\\\"\" >> remove_packages.sh\n\ncat >> remove_packages.sh << 'REMSCRIPT'\necho \"\"\necho \"Dry run command:\"\nREMSCRIPT\n\necho \"echo \\\"apt-get remove -y ${removable_packages[*]}\\\"\" >> remove_packages.sh\n\ncat >> remove_packages.sh << 'REMSCRIPT'\necho \"\"\nread -p \"Proceed with removal? (yes/no): \" confirm\nif [ \"$confirm\" = \"yes\" ]; then\nREMSCRIPT\n\necho \"    apt-get remove -y ${removable_packages[*]}\" >> remove_packages.sh\n\ncat >> remove_packages.sh << 'REMSCRIPT'\n    echo \"Packages removed successfully.\"\nelse\n    echo \"Removal "]
[169.296148, "o", "#!/bin/bash\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.296185, "i", "cancelled.\"\nfi\nREMSCRIPT\n\nchmod +x remove_packages.sh\n\necho \"Analysis complete!\" >&2\necho \"Removable packages: ${#removable_packages[@]}\" >&2\necho \"Dependency protected: ${#dependency_protected_packages[@]}\" >&2\necho \"Total space savings: ${total_space} KB\" >&2\nENDOFSCRIPT\n"]
