[?2004l#!/bin/bash

echo "This will remove the following packages:"
echo "apache2 dnsutils git htop iputils-ping lsof mysql-client nano ncdu netcat-openbsd nodejs npm postgresql-client redis-tools strace tcpdump tree vim wget"
echo ""
echo "Dry run command:"
echo "apt-get remove -y apache2 dnsutils git htop iputils-ping lsof mysql-client nano ncdu netcat-openbsd nodejs npm postgresql-client redis-tools strace tcpdump tree vim wget"
echo ""
read -p "Proceed with removal? (yes/no): " confirm
if [ "$confirm" = "yes" ]; then
    apt-get remove -y apache2 dnsutils git htop iputils-ping lsof mysql-client nano ncdu netcat-openbsd nodejs npm postgresql-client redis-tools strace tcpdump tree vim wget
    echo "Packages removed successfully."
else
    echo "Removal cancelled."
fi
