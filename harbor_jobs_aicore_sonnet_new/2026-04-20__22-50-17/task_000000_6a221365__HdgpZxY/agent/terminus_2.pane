    return True, None, None

def compute_integrity_hash(transaction):
    """Compute SHA-256 hash of canonical transaction form"""
    amount_formatted = f"{transaction['amount']:.2f}"
    canonical = f"{transaction['transaction_id']}|{transaction['timestamp']}|{transaction['account_id']}|{amount_formatted}|{transaction['currency']}|{transaction['status']}"
    return hashlib.sha256(canonical.encode('utf-8')).hexdigest()

