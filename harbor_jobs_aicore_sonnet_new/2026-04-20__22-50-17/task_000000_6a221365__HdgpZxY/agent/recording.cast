[35.726191, "o", "\u001b[?2004h> "]
[35.726609, "o", "        return False, \"invalid_value\", f\"amount must be a number, got: {type(data['amount']).__name__}\"\r\n\u001b[?2004l\r"]
[35.726651, "o", "\u001b[?2004h"]
[35.726687, "o", ">     \r\n\u001b[?2004l\r"]
[35.726721, "o", "\u001b[?2004h> "]
[35.726817, "o", "    # Validate currency\r\n\u001b[?2004l\r"]
[35.726847, "o", "\u001b[?2004h> "]
[35.727036, "o", "    if not isinstance(data[\"currency\"], str):\r\n\u001b[?2004l\r"]
[35.727072, "o", "\u001b[?2004h> "]
[35.727331, "o", "        return False, \"invalid_value\", \"currency must be a string\"\r\n\u001b[?2004l\r"]
[35.727365, "o", "\u001b[?2004h> "]
[35.727586, "o", "    if not CURRENCY_PATTERN.match(data[\"currency\"]):\r\n\u001b[?2004l\r"]
[35.727617, "o", "\u001b[?2004h> "]
[35.727979, "o", "        return False, \"invalid_format\", f\"invalid currency format: {data['currency']}\"\r\n\u001b[?2004l\r"]
[35.728016, "o", "\u001b[?2004h"]
[35.728054, "o", ">     \r\n\u001b[?2004l\r"]
[35.72809, "o", "\u001b[?2004h> "]
[35.728156, "o", "    # Validate status\r\n\u001b[?2004l\r"]
[35.72819, "o", "\u001b[?2004h> "]
[35.728363, "o", "    if not isinstance(data[\"status\"], str):\r\n\u001b[?2004l\r"]
[35.728396, "o", "\u001b[?2004h> "]
[35.72867, "o", "        return False, \"invalid_value\", \"status must be a string\"\r\n\u001b[?2004l\r"]
[35.728708, "o", "\u001b[?2004h> "]
[35.728878, "o", "    if data[\"status\"] not in VALID_STATUSES:\r\n\u001b[?2004l\r"]
[35.72891, "o", "\u001b[?2004h> "]
[35.729206, "o", "        return False, \"invalid_value\", f\"invalid status value: {data['status']}\"\r\n\u001b[?2004l\r"]
[35.729246, "o", "\u001b[?2004h> "]
[35.729276, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[35.729312, "o", "> "]
[35.729366, "o", "    return True, None, None\r\n\u001b[?2004l\r"]
[35.729399, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[35.729431, "o", "\u001b[?2004h> "]
[35.729544, "o", "def compute_integrity_hash(transaction):\r\n\u001b[?2004l\r"]
[35.729578, "o", "\u001b[?2004h> "]
[35.729764, "o", "    \"\"\"Compute SHA-256 hash of canonical transaction form\"\"\"\r\n\u001b[?2004l\r"]
[35.729799, "o", "\u001b[?2004h> "]
[35.72995, "o", "    amount_formatted = f\"{transaction['amount']:.2f}\"\r\n\u001b[?2004l\r"]
[35.729986, "o", "\u001b[?2004h> "]
[35.730456, "o", "    canonical = f\"{transaction['transaction_id']}|{transaction['timestamp']}|{transaction['account_id']}|{amount_formatted}|{transaction['currency']}|{transaction['status']}\"\r\n\u001b[?2004l\r"]
[35.730492, "o", "\u001b[?2004h> "]
[35.730679, "o", "    return hashlib.sha256(canonical.encode('utf-8')).hexdigest()\r\n\u001b[?2004l\r"]
[35.730714, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[35.730748, "o", "\u001b[?2004h> "]
[35.730819, "o", "def process_audit_logs():\r\n\u001b[?2004l\r"]
[35.730853, "o", "\u001b[?2004h> "]
[35.730928, "o", "    valid_transactions = []\r\n\u001b[?2004l\r"]
[35.730968, "o", "\u001b[?2004h> "]
[35.731004, "o", "    errors = []\r\n\u001b[?2004l\r"]
[35.731038, "o", "\u001b[?2004h> "]
[35.731129, "o", "    error_counts = defaultdict(int)\r\n\u001b[?2004l\r"]
[35.731164, "o", "\u001b[?2004h> "]
[35.731219, "o", "    total_lines = 0\r\n\u001b[?2004l\r"]
[35.731252, "o", "\u001b[?2004h> "]
[35.731286, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[35.731316, "o", "> "]
[35.73139, "o", "    # Read and process input file\r\n\u001b[?2004l\r"]
[35.731423, "o", "\u001b[?2004h"]
[35.731457, "o", "> "]
[35.731523, "o", "    with open(INPUT_FILE, 'r') as f:\r\n\u001b[?2004l\r"]
[35.731558, "o", "\u001b[?2004h> "]
[35.7317, "o", "        for line_num, line in enumerate(f, 1):\r\n\u001b[?2004l\r"]
[35.731733, "o", "\u001b[?2004h> "]
[35.731814, "o", "            total_lines += 1\r\n\u001b[?2004l\r"]
[35.731835, "o", "\u001b[?2004h"]
[35.731869, "o", "> "]
[35.731969, "o", "            raw_content = line.rstrip('\\n')\r\n\u001b[?2004l\r"]
[35.732004, "o", "\u001b[?2004h> "]
[35.732041, "o", "            \r\n\u001b[?2004l\r"]
[35.732074, "o", "\u001b[?2004h> "]
[35.732151, "o", "            # Try to parse JSON\r\n\u001b[?2004l\r"]
[35.732184, "o", "\u001b[?2004h> "]
[35.732232, "o", "            try:\r\n\u001b[?2004l\r"]
[35.732267, "o", "\u001b[?2004h> "]
[35.732373, "o", "                data = json.loads(line)\r\n\u001b[?2004l\r"]
[35.732408, "o", "\u001b[?2004h> "]
[35.732532, "o", "            except json.JSONDecodeError as e:\r\n\u001b[?2004l\r"]
[35.732566, "o", "\u001b[?2004h> "]
[35.732665, "o", "                errors.append({\r\n\u001b[?2004l\r"]
[35.732702, "o", "\u001b[?2004h> "]
[35.73282, "o", "                    \"line_number\": line_num,\r\n\u001b[?2004l\r"]
[35.732845, "o", "\u001b[?2004h"]
[35.732873, "o", "> "]
[35.732995, "o", "                    \"error_type\": \"malformed_json\",\r\n\u001b[?2004l\r"]
[35.733032, "o", "\u001b[?2004h> "]
[35.733211, "o", "                    \"error_detail\": f\"JSON parse error: {str(e)}\",\r\n\u001b[?2004l\r"]
[35.733245, "o", "\u001b[?2004h> "]
[35.733388, "o", "                    \"raw_content\": raw_content[:200]\r\n\u001b[?2004l\r"]
[35.733424, "o", "\u001b[?2004h> "]
[35.733473, "o", "                })\r\n\u001b[?2004l\r"]
[35.733507, "o", "\u001b[?2004h> "]
[35.733661, "o", "                error_counts[\"malformed_json\"] += 1\r\n\u001b[?2004l\r"]
[35.733696, "o", "\u001b[?2004h> "]
[35.733762, "o", "                continue\r\n\u001b[?2004l\r"]
[35.733778, "o", "\u001b[?2004h"]
[35.733818, "o", "> "]
[35.733851, "o", "            \r\n\u001b[?2004l\r\u001b[?2004h"]
[35.733893, "o", "> "]
[35.733965, "o", "            # Validate transaction\r\n\u001b[?2004l\r"]
[35.733998, "o", "\u001b[?2004h> "]
[35.734232, "o", "            is_valid, error_type, error_detail = validate_transaction(data, line_num)\r\n\u001b[?2004l\r"]
[35.734266, "o", "\u001b[?2004h> "]
[35.734301, "o", "            \r\n\u001b[?2004l\r"]
[35.734334, "o", "\u001b[?2004h> "]
[35.734411, "o", "            if not is_valid:\r\n\u001b[?2004l\r"]
[35.734445, "o", "\u001b[?2004h> "]
[35.734541, "o", "                errors.append({\r\n\u001b[?2004l\r"]
[35.734581, "o", "\u001b[?2004h"]
[35.73461, "o", "> "]
[35.734728, "o", "                    \"line_number\": line_num,\r\n\u001b[?2004l\r"]
[35.734765, "o", "\u001b[?2004h> "]
[35.7349, "o", "                    \"error_type\": error_type,\r\n\u001b[?2004l\r"]
[35.734931, "o", "\u001b[?2004h> "]
[35.735081, "o", "                    \"error_detail\": error_detail,\r\n\u001b[?2004l\r"]
[35.735111, "o", "\u001b[?2004h> "]
[35.735269, "o", "                    \"raw_content\": raw_content[:200]\r\n\u001b[?2004l\r"]
[35.735299, "o", "\u001b[?2004h> "]
[35.735365, "o", "                })\r\n\u001b[?2004l\r"]
[35.735396, "o", "\u001b[?2004h> "]
[35.735535, "o", "                error_counts[error_type] += 1\r\n\u001b[?2004l\r"]
[35.735565, "o", "\u001b[?2004h> "]
[35.735643, "o", "            else:\r\n\u001b[?2004l\r"]
[35.735678, "o", "\u001b[?2004h> "]
[35.735883, "o", "                # Compute integrity hash and add processed_at timestamp\r\n\u001b[?2004l\r"]
[35.735914, "o", "\u001b[?2004h> "]
[35.736045, "o", "                processed_transaction = {\r\n\u001b[?2004l\r"]
[35.736076, "o", "\u001b[?2004h"]
[35.736107, "o", "> "]
[35.736266, "o", "                    \"transaction_id\": data[\"transaction_id\"],\r\n\u001b[?2004l\r"]
[35.736295, "o", "\u001b[?2004h> "]
[35.73645, "o", "                    \"timestamp\": data[\"timestamp\"],\r\n\u001b[?2004l\r"]
[35.73648, "o", "\u001b[?2004h> "]
[35.736656, "o", "                    \"account_id\": data[\"account_id\"],\r\n\u001b[?2004l\r"]
[35.736695, "o", "\u001b[?2004h> "]
[35.736828, "o", "                    \"amount\": data[\"amount\"],\r\n\u001b[?2004l\r"]
[35.736865, "o", "\u001b[?2004h> "]
[35.737008, "o", "                    \"currency\": data[\"currency\"],\r\n\u001b[?2004l\r"]
[35.73704, "o", "\u001b[?2004h> "]
[35.737176, "o", "                    \"status\": data[\"status\"],\r\n\u001b[?2004l\r"]
[35.737209, "o", "\u001b[?2004h> "]
[35.737409, "o", "                    \"integrity_hash\": compute_integrity_hash(data),\r\n\u001b[?2004l\r"]
[35.737437, "o", "\u001b[?2004h> "]
[35.7377, "o", "                    \"processed_at\": datetime.utcnow().strftime(\"%Y-%m-%dT%H:%M:%SZ\")\r\n\u001b[?2004l\r"]
[35.737742, "o", "\u001b[?2004h> "]
[35.737797, "o", "                }\r\n\u001b[?2004l\r"]
[35.737831, "o", "\u001b[?2004h> "]
[35.738019, "o", "                valid_transactions.append(processed_transaction)\r\n\u001b[?2004l\r"]
[35.738056, "o", "\u001b[?2004h> "]
[35.738087, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[35.73812, "o", "> "]
[35.738231, "o", "    # Sort valid transactions by timestamp\r\n\u001b[?2004l\r"]
[35.738264, "o", "\u001b[?2004h> "]
[35.738431, "o", "    valid_transactions.sort(key=lambda x: x[\"timestamp\"])\r\n\u001b[?2004l\r"]
[35.738462, "o", "\u001b[?2004h> "]
[35.738493, "o", "    \r\n\u001b[?2004l\r"]
[35.738526, "o", "\u001b[?2004h> "]
[35.738611, "o", "    # Write clean audit file\r\n\u001b[?2004l\r"]
[35.738661, "o", "\u001b[?2004h> "]
[35.738772, "o", "    with open(OUTPUT_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[35.738806, "o", "\u001b[?2004h> "]
[35.738944, "o", "        for transaction in valid_transactions:\r\n\u001b[?2004l\r"]
[35.738975, "o", "\u001b[?2004h"]
[35.739003, "o", "> "]
[35.739135, "o", "            f.write(json.dumps(transaction) + '\\n')\r\n\u001b[?2004l\r"]
[35.739163, "o", "\u001b[?2004h> "]
[35.739192, "o", "    \r\n\u001b[?2004l\r"]
[35.739221, "o", "\u001b[?2004h> "]
[35.739295, "o", "    # Write error log\r\n\u001b[?2004l\r"]
[35.739326, "o", "\u001b[?2004h> "]
[35.739441, "o", "    with open(ERROR_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[35.739471, "o", "\u001b[?2004h> "]
[35.739565, "o", "        for error in errors:\r\n\u001b[?2004l\r"]
[35.739594, "o", "\u001b[?2004h> "]
[35.739749, "o", "            f.write(json.dumps(error) + '\\n')\r\n\u001b[?2004l\r"]
[35.73978, "o", "\u001b[?2004h> "]
[35.739812, "o", "    \r\n\u001b[?2004l\r"]
[35.739846, "o", "\u001b[?2004h> "]
[35.739934, "o", "    # Generate summary report\r\n\u001b[?2004l\r"]
[35.739974, "o", "\u001b[?2004h> "]
[35.740092, "o", "    valid_count = len(valid_transactions)\r\n\u001b[?2004l\r"]
[35.740125, "o", "\u001b[?2004h> "]
[35.740216, "o", "    failed_count = len(errors)\r\n\u001b[?2004l\r"]
[35.740245, "o", "\u001b[?2004h"]
[35.740277, "o", "> "]
[35.740483, "o", "    success_rate = (valid_count / total_lines * 100) if total_lines > 0 else 0.0\r\n\u001b[?2004l\r"]
[35.740513, "o", "\u001b[?2004h> "]
[35.740543, "o", "    \r\n\u001b[?2004l\r"]
[35.740576, "o", "\u001b[?2004h> "]
[35.740708, "o", "    with open(SUMMARY_FILE, 'w') as f:\r\n\u001b[?2004l\r"]
[35.740743, "o", "\u001b[?2004h> "]
[35.740874, "o", "        f.write(\"AUDIT PROCESSING SUMMARY\\n\")\r\n\u001b[?2004l\r"]
[35.740908, "o", "\u001b[?2004h> "]
[35.74104, "o", "        f.write(\"========================\\n\")\r\n\u001b[?2004l\r"]
[35.741073, "o", "\u001b[?2004h> "]
[35.74121, "o", "        f.write(f\"Input file: {INPUT_FILE}\\n\")\r\n\u001b[?2004l\r"]
[35.741256, "o", "\u001b[?2004h> "]
[35.741416, "o", "        f.write(f\"Total lines processed: {total_lines}\\n\")\r\n\u001b[?2004l\r"]
[35.741447, "o", "\u001b[?2004h> "]
[35.74161, "o", "        f.write(f\"Valid transactions: {valid_count}\\n\")\r\n\u001b[?2004l\r"]
[35.74165, "o", "\u001b[?2004h"]
[35.741683, "o", "> "]
[35.741818, "o", "        f.write(f\"Failed records: {failed_count}\\n\")\r\n\u001b[?2004l\r"]
[35.741857, "o", "\u001b[?2004h"]
[35.741897, "o", "> "]
[35.742058, "o", "        f.write(f\"Success rate: {success_rate:.2f}%\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[35.742104, "o", "> "]
[35.742138, "o", "        f.write(\"\\n\")\r\n\u001b[?2004l\r"]
[35.742175, "o", "\u001b[?2004h> "]
[35.742283, "o", "        f.write(\"Errors by type:\\n\")\r\n\u001b[?2004l\r"]
[35.742314, "o", "\u001b[?2004h> "]
[35.742526, "o", "        f.write(f\"  malformed_json: {error_counts['malformed_json']}\\n\")\r\n\u001b[?2004l\r"]
[35.742558, "o", "\u001b[?2004h> "]
[35.742778, "o", "        f.write(f\"  missing_field: {error_counts['missing_field']}\\n\")\r\n\u001b[?2004l\r"]
[35.742815, "o", "\u001b[?2004h> "]
[35.743026, "o", "        f.write(f\"  invalid_format: {error_counts['invalid_format']}\\n\")\r\n\u001b[?2004l\r"]
[35.743058, "o", "\u001b[?2004h> "]
[35.743267, "o", "        f.write(f\"  invalid_value: {error_counts['invalid_value']}\\n\")\r\n\u001b[?2004l\r"]
[35.743303, "o", "\u001b[?2004h> "]
[35.743372, "o", "        f.write(\"\\n\")\r\n\u001b[?2004l\r"]
[35.743409, "o", "\u001b[?2004h> "]
[35.743693, "o", "        f.write(f\"Processing completed at: {datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ')}\\n\")\r\n\u001b[?2004l\r"]
[35.743732, "o", "\u001b[?2004h> "]
[35.743763, "o", "    \r\n\u001b[?2004l\r"]
[35.743797, "o", "\u001b[?2004h> "]
[35.743889, "o", "    print(f\"Processing complete!\")\r\n\u001b[?2004l\r"]
[35.743918, "o", "\u001b[?2004h"]
[35.743949, "o", "> "]
[35.744048, "o", "    print(f\"Total lines: {total_lines}\")\r\n\u001b[?2004l\r"]
[35.744071, "o", "\u001b[?2004h"]
[35.744102, "o", "> "]
[35.744193, "o", "    print(f\"Valid: {valid_count}\")\r\n\u001b[?2004l\r"]
[35.744227, "o", "\u001b[?2004h> "]
[35.74434, "o", "    print(f\"Failed: {failed_count}\")\r\n\u001b[?2004l\r"]
[35.744367, "o", "\u001b[?2004h> "]
[35.744401, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[35.744434, "o", "> "]
[35.744503, "o", "if __name__ == \"__main__\":\r\n\u001b[?2004l\r"]
[35.744537, "o", "\u001b[?2004h> "]
[35.744614, "o", "    process_audit_logs()\r\n\u001b[?2004l\r"]
[35.744651, "o", "\u001b[?2004h"]
[35.74468, "o", "> EOF\r\n\u001b[?2004l\r"]
[35.750307, "o", "\u001b[?2004h"]
[35.750372, "o", "root@fd2d23f0acd5:/home/user# "]
[40.559605, "i", "python3 /home/user/process_audit.py\n"]
[40.559782, "o", "python3 /home/user/process_audit.py\r\n\u001b[?2004l\r"]
[40.5866, "o", "Processing complete!\r\nTotal lines: 25\r\nValid: 13\r\nFailed: 12\r\n"]
[40.589911, "o", "\u001b[?2004h"]
[40.589948, "o", "root@fd2d23f0acd5:/home/user# "]
[48.227289, "i", "ls -la /home/user/audit/\n"]
[48.227406, "o", "ls -la /home/user/audit/\r\n"]
[48.227442, "o", "\u001b[?2004l\r"]
[48.228718, "o", "total 28\r\n"]
[48.228751, "o", "drwxrwxrwx 1 root root 4096 Apr 20 23:21 \u001b[0m\u001b[34;42m.\u001b[0m\r\ndrwxrwxrwx 1 root root 4096 Apr 20 23:21 \u001b[34;42m..\u001b[0m\r\n"]
[48.228787, "o", "-rw-r--r-- 1 root root 3658 Apr 20 23:21 clean_audit.jsonl\r\n-rw-r--r-- 1 root root 3184 Apr 20 23:21 error_log.jsonl\r\n-rw-r--r-- 1 root root  333 Apr 20 23:21 processing_summary.txt\r\n-rw-r--r-- 1 root root 3450 Apr 20 23:09 raw_transactions.jsonl\r\n"]
[48.228963, "o", "\u001b[?2004h"]
[48.228993, "o", "root@fd2d23f0acd5:/home/user# "]
[48.331051, "i", "echo \"=== CLEAN AUDIT FILE (first 5 records) ===\"\n"]
[48.331236, "o", "echo \"=== CLEAN AUDIT FILE (first 5 records) ===\"\r\n"]
[48.331274, "o", "\u001b[?2004l\r"]
[48.331308, "o", "=== CLEAN AUDIT FILE (first 5 records) ===\r\n"]
[48.331341, "o", "\u001b[?2004h"]
[48.331374, "o", "root@fd2d23f0acd5:/home/user# "]
