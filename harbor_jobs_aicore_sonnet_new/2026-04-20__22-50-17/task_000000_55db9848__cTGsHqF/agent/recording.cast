[34.558321, "i", "cat > /tmp/process_inventory.py << 'EOF'\nimport os\nimport math\nfrom collections import defaultdict\n\n# Read the inventory file\nwith open('/home/user/disk_inventory.txt', 'r') as f:\n    lines = f.readlines()\n\n# Parse entries\nentries = []\nfor line in lines:\n    parts = line.strip().split('\\t')\n    if len(parts) == 2:\n        size = int(parts[0])\n        path = parts[1]\n        entries.append((size, path))\n\n# Report 1: Large files (>= 10MB)\nlarge_files = []\nfor size, path in entries:\n    # Skip directories (they typically have small sizes like 4096)\n    # A file is not a directory if it has an extension or if it's >= 10MB\n    if size >= 10485760:\n        # Check if it's actually a file (not a directory entry)\n        # Directories in du output are marked, but we need to filter them\n        # In this case, entries with 4096 bytes are directories\n        is_dir = False\n        for _, dir_path in entries:\n            if path != dir_path and path.startswith(dir_path + '/'):\n                # This path has children, b"]
[34.558458, "i", "ut that doesn't mean it's a dir\n                pass\n        \n        # Simple heuristic: if size is exactly 4096, it's likely a directory\n        if size != 4096:\n            mb_size = size // 1048576  # Floor division to get MB\n            large_files.append((mb_size, size, path))\n\n# Sort by MB size descending, then by path ascending\nlarge_files.sort(key=lambda x: (-x[0], x[2]))\n\nwith open('/home/user/reports/large_files.txt', 'w') as f:\n    for mb_size, _, path in large_files:\n        f.write(f\"{mb_size}MB {path}\\n\")\n\n# Report 2: Extension summary\nextension_totals = defaultdict(int)\nfor size, path in entries:\n    # Skip directory entries (size 4096)\n    if size == 4096:\n        continue\n    \n    filename = os.path.basename(path)\n    if '.' in filename:\n        ext = filename.rsplit('.', 1)[1].lower()\n    else:\n        ext = 'NO_EXTENSION'\n    \n    extension_totals[ext] += size\n\n# Sort by total bytes descending\nsorted_extensions = sorted(extension_totals.items(), key=lambda x: -x[1])\n\nwith open('/home/user/"]
[34.558517, "i", "reports/extension_summary.csv', 'w') as f:\n    f.write(\"extension,total_bytes\\n\")\n    for ext, total in sorted_extensions:\n        f.write(f\"{ext},{total}\\n\")\n\n# Report 3: Directory rollup\n# Find immediate subdirectories of /var/data\nsubdir_totals = defaultdict(int)\ntotal_size = 0\n\nfor size, path in entries:\n    if path == '/var/data':\n        continue\n    \n    if path.startswith('/var/data/'):\n        # Get immediate subdirectory name\n        rel_path = path[10:]  # Remove '/var/data/'\n        subdir = rel_path.split('/')[0]\n        subdir_totals[subdir] += size\n        total_size += size\n\n# Sort by total bytes descending\nsorted_subdirs = sorted(subdir_totals.items(), key=lambda x: -x[1])\n\nwith open('/home/user/reports/directory_rollup.txt', 'w') as f:\n    for dirname, total_bytes in sorted_subdirs:\n        percentage = (total_bytes / total_size * 100) if total_size > 0 else 0\n        f.write(f\"{dirname} {total_bytes} {percentage:.1f}%\\n\")\n\nEOF\n"]
