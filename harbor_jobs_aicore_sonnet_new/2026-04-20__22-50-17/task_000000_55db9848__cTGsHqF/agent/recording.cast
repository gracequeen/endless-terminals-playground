[34.570184, "o", "        total_size += size\r\n\u001b[?2004l\r"]
[34.570219, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[34.570251, "o", "\u001b[?2004h> "]
[34.570344, "o", "# Sort by total bytes descending\r\n\u001b[?2004l\r"]
[34.570376, "o", "\u001b[?2004h> "]
[34.570562, "o", "sorted_subdirs = sorted(subdir_totals.items(), key=lambda x: -x[1])\r\n\u001b[?2004l\r"]
[34.570594, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[34.570625, "o", "\u001b[?2004h> "]
[34.570803, "o", "with open('/home/user/reports/directory_rollup.txt', 'w') as f:\r\n\u001b[?2004l\r"]
[34.570834, "o", "\u001b[?2004h"]
[34.570865, "o", "> "]
[34.570984, "o", "    for dirname, total_bytes in sorted_subdirs:\r\n\u001b[?2004l\r"]
[34.571017, "o", "\u001b[?2004h"]
[34.571046, "o", "> "]
[34.571236, "o", "        percentage = (total_bytes / total_size * 100) if total_size > 0 else 0\r\n\u001b[?2004l\r"]
[34.571266, "o", "\u001b[?2004h> "]
[34.571446, "o", "        f.write(f\"{dirname} {total_bytes} {percentage:.1f}%\\n\")\r\n\u001b[?2004l\r"]
[34.571478, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[34.571516, "o", "\u001b[?2004h> "]
[34.571546, "o", "EOF\r\n\u001b[?2004l\r"]
