[?2004l[?2004h>                 # This path has children, but that doesn't mean it's a dir
[?2004l[?2004h>                 pass
[?2004l[?2004h>         
[?2004l[?2004h>         # Simple heuristic: if size is exactly 4096, it's likely a directory
[?2004l[?2004h>         if size != 4096:
[?2004l[?2004h>             mb_size = size // 1048576  # Floor division to get MB
[?2004l[?2004h>             large_files.append((mb_size, size, path))
[?2004l[?2004h> 
