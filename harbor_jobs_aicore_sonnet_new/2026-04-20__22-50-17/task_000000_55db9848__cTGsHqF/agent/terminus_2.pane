[?2004l[?2004h>     # A file is not a directory if it has an extension or if it's >= 10MB
[?2004l[?2004h>     if size >= 10485760:
[?2004l[?2004h>         # Check if it's actually a file (not a directory entry)
[?2004l[?2004h>         # Directories in du output are marked, but we need to filter them
