[32.295029, "o", "\u001b[?2004h> "]
[32.295159, "o", "    f.write('# Credential Rotation Report\\n\\n')\r\n\u001b[?2004l\r"]
[32.295186, "o", "\u001b[?2004h> "]
[32.295322, "o", "    f.write(f'**Generated:** {current_time}\\n')\r\n\u001b[?2004l\r"]
[32.295352, "o", "\u001b[?2004h> "]
[32.295544, "o", "    f.write(f'**Total Credentials Rotated:** {total_rotations}\\n\\n')\r\n\u001b[?2004l\r"]
[32.295574, "o", "\u001b[?2004h> "]
[32.295604, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[32.295633, "o", "> "]
[32.295747, "o", "    f.write('## Summary by Category\\n\\n')\r\n\u001b[?2004l\r"]
[32.295784, "o", "\u001b[?2004h"]
[32.295812, "o", "> "]
[32.295942, "o", "    f.write('| Category | Count | Success | Failed |\\n')\r\n\u001b[?2004l\r"]
[32.295974, "o", "\u001b[?2004h> "]
[32.296123, "o", "    f.write('|----------|-------|---------|--------|\\n')\r\n\u001b[?2004l\r"]
[32.296156, "o", "\u001b[?2004h> "]
[32.296358, "o", "    f.write(f'| AWS IAM | {aws_total} | {aws_success} | {aws_failed} |\\n')\r\n\u001b[?2004l\r"]
[32.296389, "o", "\u001b[?2004h> "]
[32.296587, "o", "    f.write(f'| Database | {db_total} | {db_success} | {db_failed} |\\n')\r\n\u001b[?2004l\r"]
[32.296616, "o", "\u001b[?2004h> "]
[32.296845, "o", "    f.write(f'| API Keys | {api_total} | {api_success} | {api_failed} |\\n\\n')\r\n\u001b[?2004l\r"]
[32.296877, "o", "\u001b[?2004h> "]
[32.296907, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[32.296936, "o", "> "]
[32.297041, "o", "    f.write('## Detailed Rotation Log\\n\\n')\r\n\u001b[?2004l\r"]
[32.297067, "o", "\u001b[?2004h"]
[32.297096, "o", ">     \r\n\u001b[?2004l\r"]
[32.297126, "o", "\u001b[?2004h> "]
[32.297194, "o", "    # AWS IAM Credentials\r\n\u001b[?2004l\r"]
[32.297227, "o", "\u001b[?2004h> "]
[32.297341, "o", "    f.write('### AWS IAM Credentials\\n\\n')\r\n\u001b[?2004l\r"]
[32.297373, "o", "\u001b[?2004h> "]
[32.297583, "o", "    f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\\n')\r\n\u001b[?2004l\r"]
[32.297615, "o", "\u001b[?2004h> "]
[32.297839, "o", "    f.write('|---------|------------|------------|--------|------------|\\n')\r\n\u001b[?2004l\r"]
[32.297868, "o", "\u001b[?2004h> "]
[32.297957, "o", "    for entry in aws_entries:\r\n\u001b[?2004l\r"]
[32.297984, "o", "\u001b[?2004h> "]
[32.298344, "o", "        f.write(f\"| {entry['service']} | {entry['old_key']} | {entry['new_key']} | {entry['status']} | {entry['rotated_by']} |\\n\")\r\n\u001b[?2004l\r"]
[32.298381, "o", "\u001b[?2004h> "]
[32.298428, "o", "    f.write('\\n')\r\n\u001b[?2004l\r"]
[32.298458, "o", "\u001b[?2004h> "]
[32.298485, "o", "    \r\n\u001b[?2004l\r"]
[32.298515, "o", "\u001b[?2004h> "]
[32.298585, "o", "    # Database Credentials\r\n\u001b[?2004l\r"]
[32.298614, "o", "\u001b[?2004h> "]
[32.298749, "o", "    f.write('### Database Credentials\\n\\n')\r\n\u001b[?2004l\r"]
[32.298784, "o", "\u001b[?2004h> "]
[32.299001, "o", "    f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\\n')\r\n\u001b[?2004l\r"]
[32.299036, "o", "\u001b[?2004h> "]
[32.299243, "o", "    f.write('|---------|------------|------------|--------|------------|\\n')\r\n\u001b[?2004l\r"]
[32.29927, "o", "\u001b[?2004h"]
[32.299296, "o", "> "]
[32.299358, "o", "    for entry in db_entries:\r\n\u001b[?2004l\r"]
[32.299387, "o", "\u001b[?2004h"]
[32.299419, "o", "> "]
[32.299757, "o", "        f.write(f\"| {entry['service']} | {entry['old_key']} | {entry['new_key']} | {entry['status']} | {entry['rotated_by']} |\\n\")\r\n\u001b[?2004l\r"]
[32.299793, "o", "\u001b[?2004h> "]
[32.29984, "o", "    f.write('\\n')\r\n\u001b[?2004l\r"]
[32.29987, "o", "\u001b[?2004h> "]
[32.299901, "o", "    \r\n\u001b[?2004l\r"]
[32.299934, "o", "\u001b[?2004h> "]
[32.299963, "o", "    # API Keys\r\n\u001b[?2004l\r"]
[32.299993, "o", "\u001b[?2004h> "]
[32.300083, "o", "    f.write('### API Keys\\n\\n')\r\n\u001b[?2004l\r"]
[32.300113, "o", "\u001b[?2004h> "]
[32.300325, "o", "    f.write('| Service | Old Key ID | New Key ID | Status | Rotated By |\\n')\r\n\u001b[?2004l\r"]
[32.300352, "o", "\u001b[?2004h> "]
[32.300566, "o", "    f.write('|---------|------------|------------|--------|------------|\\n')\r\n\u001b[?2004l\r"]
[32.300599, "o", "\u001b[?2004h> "]
[32.30068, "o", "    for entry in api_entries:\r\n\u001b[?2004l\r"]
[32.300711, "o", "\u001b[?2004h> "]
[32.301084, "o", "        f.write(f\"| {entry['service']} | {entry['old_key']} | {entry['new_key']} | {entry['status']} | {entry['rotated_by']} |\\n\")\r\n\u001b[?2004l\r"]
[32.301117, "o", "\u001b[?2004h> "]
[32.301167, "o", "    f.write('\\n')\r\n\u001b[?2004l\r"]
[32.301198, "o", "\u001b[?2004h> "]
[32.301225, "o", "    \r\n\u001b[?2004l\r"]
[32.301256, "o", "\u001b[?2004h> "]
[32.301311, "o", "    # Failed Rotations\r\n\u001b[?2004l\r"]
[32.301339, "o", "\u001b[?2004h> "]
[32.301451, "o", "    f.write('## Failed Rotations\\n\\n')\r\n\u001b[?2004l\r"]
[32.301487, "o", "\u001b[?2004h> "]
[32.301554, "o", "    if failed_rotations:\r\n\u001b[?2004l\r"]
[32.301589, "o", "\u001b[?2004h> "]
[32.301931, "o", "        f.write('> **Action Required:** The following credentials failed rotation and need manual intervention.\\n\\n')\r\n\u001b[?2004l\r"]
[32.30198, "o", "\u001b[?2004h> "]
[32.302097, "o", "        for service, category in failed_rotations:\r\n\u001b[?2004l\r"]
[32.302133, "o", "\u001b[?2004h> "]
[32.30229, "o", "            f.write(f'- {service} ({category}): REASON\\n')\r\n\u001b[?2004l\r"]
[32.302329, "o", "\u001b[?2004h> "]
[32.302369, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[32.302605, "o", "        f.write('> No failed rotations. All credentials rotated successfully.\\n')\r\n\u001b[?2004l\r"]
[32.302642, "o", "\u001b[?2004h> "]
[32.302677, "o", "    f.write('\\n')\r\n\u001b[?2004l\r"]
[32.30271, "o", "\u001b[?2004h> "]
[32.302763, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[32.302797, "o", "> "]
