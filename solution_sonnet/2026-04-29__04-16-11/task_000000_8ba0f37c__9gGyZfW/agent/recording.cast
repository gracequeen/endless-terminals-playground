[6.497265, "o", "total 12\r\n"]
[6.497343, "o", "drwxrwxrwx 1 user user 4096 Apr 29 04:23 .\r\ndrwxrwxrwx 1 user user 4096 Apr 29 04:24 ..\r\n-rw-r--r-- 1 user user  468 Apr 29 04:23 target_iptables.txt\r\n"]
