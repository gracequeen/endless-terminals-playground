[?2004l[?2004h>     try:
[?2004l[?2004h>         dt = datetime.strptime(date_str, '%Y-%m-%d')
[?2004l[?2004h>         return dt.strftime('%Y-%m-%d')
[?2004l[?2004h>     except ValueError:
[?2004l[?2004h>         pass
[?2004l[?2004h>     
[?2004l[?2004h>     # Try MM/DD/YYYY (US format)
[?2004l[?2004h>     try:
[?2004l[?2004h>         dt = datetime.strptime(date_str, '%m/%d/%Y')
[?2004l[?2004h>         return dt.strftime('%Y-%m-%d')
[?2004l[?2004h>     except ValueError:
[?2004l[?2004h>         pass
[?2004l[?2004h>     
[?2004l[?2004h>     # Try DD.MM.YYYY (European format)
[?2004l[?2004h>     try:
[?2004l[?2004h>         dt = datetime.strptime(date_str, '%d.%m.%Y')
[?2004l[?2004h>         return dt.strftime('%Y-%m-%d')
[?2004l[?2004h>     except ValueError:
[?2004l[?2004h>         pass
[?2004l[?2004h>     
[?2004l[?2004h>     return None
[?2004l[?2004h> 
[?2004l[?2004h> def parse_price(price_str):
[?2004l[?2004h>     """Parse price and convert to cents (positive integer)"""
[?2004l[?2004h>     try:
[?2004l[?2004h>         # Remove dollar signs, commas, and whitespace
[?2004l[?2004h>         cleaned = re.sub(r'[$,\s]', '', price_str.strip())
[?2004l[?2004h>         
[?2004l[?2004h>         # Convert to float then to cents
[?2004l[?2004h>         price_float = float(cleaned)
[?2004l[?2004h>         
[?2004l[?2004h>         # Check if positive
[?2004l[?2004h>         if price_float <= 0:
[?2004l[?2004h>             return None
[?2004l[?2004h>         
[?2004l[?2004h>         # Convert to cents (integer)
[?2004l[?2004h>         price_cents = int(round(price_float * 100))
[?2004l[?2004h>         return price_cents
[?2004l[?2004h>     except (ValueError, AttributeError):
[?2004l[?2004h>         return None
[?2004l[?2004h> 
[?2004l[?2004h> def is_serial_format(text):
[?2004l[?2004h>     """Check if text looks like a serial number (SN-XXX-XXXXX format)"""
[?2004l[?2004h>     return bool(re.match(r'^SN-[A-Z]+-\d+$', text.strip()))
[?2004l[?2004h> 
[?2004l[?2004h> def process_row(row, row_num):
[?2004l[?2004h>     """Process a single row and return (record, error) tuple"""
[?2004l[?2004h>     try:
[?2004l[?2004h>         asset_id = row['id'].strip()
[?2004l[?2004h>         name = row['name'].strip()
[?2004l[?2004h>         serial = row['serial'].strip()
[?2004l[?2004h>         purchase_date_raw = row['purchase_date'].strip()
[?2004l[?2004h>         price_raw = row['price'].strip()
[?2004l[?2004h>         location = row['location'].strip()
[?2004l[?2004h>         
[?2004l[?2004h>         # Check for swapped serial and name
[?2004l[?2004h>         if is_serial_format(name) and not is_serial_format(serial):
[?2004l[?2004h>             # Swap them
[?2004l[?2004h>             name, serial = serial, name
[?2004l[?2004h>         
[?2004l[?2004h>         # Validate and parse date
[?2004l[?2004h>         purchase_date = parse_date(purchase_date_raw)
[?2004l[?2004h>         if not purchase_date:
[?2004l[?2004h>             return None, f"Invalid date format: {purchase_date_raw}"
[?2004l[?2004h>         
[?2004l[?2004h>         # Validate and parse price
[?2004l[?2004h>         price_cents = parse_price(price_raw)
[?2004l[?2004h>         if price_cents is None:
[?2004l[?2004h>             return None, f"Invalid price: {price_raw}"
[?2004l[?2004h>         
[?2004l[?2004h>         # Basic validation
[?2004l[?2004h>         if not asset_id or not name or not serial or not location:
[?2004l[?2004h>             return None, "Missing required fields"
[?2004l[?2004h>         
[?2004l[?2004h>         record = {
[?2004l[?2004h>             'id': asset_id,
[?2004l[?2004h>             'name': name,
[?2004l[?2004h>             'serial': serial,
[?2004l[?2004h>             'purchase_date': purchase_date,
[?2004l[?2004h>             'price_cents': price_cents,
[?2004l[?2004h>             'location': location
[?2004l[?2004h>         }
[?2004l[?2004h>         
[?2004l[?2004h>         return record, None
[?2004l[?2004h>         
[?2004l[?2004h>     except Exception as e:
[?2004l[?2004h>         return None, f"Processing error: {str(e)}"
[?2004l[?2004h> 
[?2004l[?2004h> def main():
[?2004l[?2004h>     valid_records = defaultdict(list)  # id -> list of records
[?2004l[?2004h>     rejected = []
[?2004l[?2004h>     
[?2004l[?2004h>     # Read CSV
[?2004l[?2004h>     with open('/home/user/inventory/assets.csv', 'r') as f:
[?2004l[?2004h>         reader = csv.DictReader(f)
[?2004l[?2004h>         for row_num, row in enumerate(reader, start=2):  # start at 2 (after header)
[?2004l[?2004h>             record, error = process_row(row, row_num)
[?2004l[?2004h>             
[?2004l[?2004h>             if error:
[?2004l[?2004h>                 rejected.append({
[?2004l[?2004h>                     'original_row': dict(row),
[?2004l[?2004h>                     'reason': error
[?2004l[?2004h>                 })
[?2004l[?2004h>             else:
[?2004l[?2004h>                 # Group by ID for deduplication
[?2004l[?2004h>                 valid_records[record['id']].append(record)
[?2004l[?2004h>     
[?2004l[?2004h>     # Deduplicate: keep the one with the latest purchase date
[?2004l[?2004h>     final_records = []
[?2004l[?2004h>     for asset_id, records in valid_records.items():
[?2004l[?2004h>         if len(records) == 1:
