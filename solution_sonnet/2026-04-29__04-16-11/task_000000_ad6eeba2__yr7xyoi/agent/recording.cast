[40.088602, "o", "            # Swap them\r\n\u001b[?2004l\r"]
[40.088632, "o", "\u001b[?2004h> "]
[40.088745, "o", "            name, serial = serial, name\r\n\u001b[?2004l\r"]
[40.088775, "o", "\u001b[?2004h> "]
[40.0888, "o", "        \r\n"]
[40.088831, "o", "\u001b[?2004l\r\u001b[?2004h"]
[40.088861, "o", "> "]
[40.088935, "o", "        # Validate and parse date\r\n\u001b[?2004l\r"]
[40.088958, "o", "\u001b[?2004h"]
[40.088994, "o", "> "]
[40.089118, "o", "        purchase_date = parse_date(purchase_date_raw)\r\n\u001b[?2004l\r"]
[40.089146, "o", "\u001b[?2004h"]
[40.089172, "o", "> "]
[40.089232, "o", "        if not purchase_date:\r\n\u001b[?2004l\r"]
[40.089261, "o", "\u001b[?2004h> "]
[40.089467, "o", "            return None, f\"Invalid date format: {purchase_date_raw}\"\r\n\u001b[?2004l\r"]
[40.089494, "o", "\u001b[?2004h"]
[40.089521, "o", "> "]
[40.089548, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[40.089577, "o", "> "]
[40.089657, "o", "        # Validate and parse price\r\n\u001b[?2004l\r"]
[40.089686, "o", "\u001b[?2004h> "]
[40.089815, "o", "        price_cents = parse_price(price_raw)\r\n\u001b[?2004l\r"]
[40.089851, "o", "\u001b[?2004h> "]
[40.089935, "o", "        if price_cents is None:\r\n\u001b[?2004l\r"]
[40.089962, "o", "\u001b[?2004h> "]
[40.090126, "o", "            return None, f\"Invalid price: {price_raw}\"\r\n\u001b[?2004l\r"]
[40.09015, "o", "\u001b[?2004h"]
[40.090182, "o", ">         \r\n"]
[40.090213, "o", "\u001b[?2004l\r\u001b[?2004h"]
[40.090241, "o", "> "]
[40.090294, "o", "        # Basic validation\r\n\u001b[?2004l\r"]
[40.090321, "o", "\u001b[?2004h> "]
[40.090525, "o", "        if not asset_id or not name or not serial or not location:\r\n\u001b[?2004l\r"]
[40.090555, "o", "\u001b[?2004h> "]
[40.090702, "o", "            return None, \"Missing required fields\"\r\n\u001b[?2004l\r"]
[40.090731, "o", "\u001b[?2004h> "]
[40.090756, "o", "        \r\n\u001b[?2004l\r"]
[40.090781, "o", "\u001b[?2004h"]
[40.090811, "o", "> "]
[40.090842, "o", "        record = {\r\n\u001b[?2004l\r"]
[40.090865, "o", "\u001b[?2004h"]
[40.090894, "o", "> "]
[40.090952, "o", "            'id': asset_id,\r\n\u001b[?2004l\r"]
[40.090981, "o", "\u001b[?2004h> "]
[40.091058, "o", "            'name': name,\r\n\u001b[?2004l\r"]
[40.091086, "o", "\u001b[?2004h> "]
[40.091172, "o", "            'serial': serial,\r\n\u001b[?2004l\r"]
[40.091208, "o", "\u001b[?2004h> "]
[40.091325, "o", "            'purchase_date': purchase_date,\r\n\u001b[?2004l\r"]
[40.091354, "o", "\u001b[?2004h> "]
[40.091484, "o", "            'price_cents': price_cents,\r\n\u001b[?2004l\r"]
[40.091509, "o", "\u001b[?2004h"]
[40.091544, "o", "> "]
[40.091611, "o", "            'location': location\r\n\u001b[?2004l\r"]
[40.09164, "o", "\u001b[?2004h"]
[40.091672, "o", ">         }\r\n\u001b[?2004l\r"]
[40.091697, "o", "\u001b[?2004h"]
[40.091725, "o", ">         \r\n\u001b[?2004l\r"]
[40.09175, "o", "\u001b[?2004h"]
[40.091784, "o", "> "]
[40.091837, "o", "        return record, None\r\n\u001b[?2004l\r"]
[40.091865, "o", "\u001b[?2004h> "]
[40.091896, "o", "        \r\n\u001b[?2004l\r"]
[40.091924, "o", "\u001b[?2004h> "]
[40.092005, "o", "    except Exception as e:\r\n\u001b[?2004l\r"]
[40.092034, "o", "\u001b[?2004h> "]
[40.092178, "o", "        return None, f\"Processing error: {str(e)}\"\r\n\u001b[?2004l\r"]
[40.092207, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[40.092239, "o", "\u001b[?2004h> "]
[40.092276, "o", "def main():\r\n\u001b[?2004l\r"]
[40.092304, "o", "\u001b[?2004h"]
[40.092332, "o", "> "]
[40.092496, "o", "    valid_records = defaultdict(list)  # id -> list of records\r\n\u001b[?2004l\r"]
[40.092525, "o", "\u001b[?2004h> "]
[40.092579, "o", "    rejected = []\r\n\u001b[?2004l\r"]
[40.092614, "o", "\u001b[?2004h"]
[40.092641, "o", ">     \r\n\u001b[?2004l\r"]
[40.092671, "o", "\u001b[?2004h> "]
[40.092702, "o", "    # Read CSV\r\n\u001b[?2004l\r"]
[40.092732, "o", "\u001b[?2004h> "]
[40.092898, "o", "    with open('/home/user/inventory/assets.csv', 'r') as f:\r\n\u001b[?2004l\r"]
[40.092928, "o", "\u001b[?2004h> "]
[40.093026, "o", "        reader = csv.DictReader(f)\r\n\u001b[?2004l\r"]
[40.093061, "o", "\u001b[?2004h> "]
[40.093291, "o", "        for row_num, row in enumerate(reader, start=2):  # start at 2 (after header)\r\n\u001b[?2004l\r"]
[40.093319, "o", "\u001b[?2004h"]
[40.093347, "o", "> "]
[40.093487, "o", "            record, error = process_row(row, row_num)\r\n\u001b[?2004l\r"]
[40.093514, "o", "\u001b[?2004h> "]
[40.093556, "o", "            \r\n\u001b[?2004l\r"]
[40.093583, "o", "\u001b[?2004h> "]
[40.093648, "o", "            if error:\r\n\u001b[?2004l\r"]
[40.093681, "o", "\u001b[?2004h> "]
[40.093774, "o", "                rejected.append({\r\n\u001b[?2004l\r"]
[40.093802, "o", "\u001b[?2004h> "]
[40.093936, "o", "                    'original_row': dict(row),\r\n\u001b[?2004l\r"]
[40.093964, "o", "\u001b[?2004h> "]
[40.094077, "o", "                    'reason': error\r\n\u001b[?2004l\r"]
[40.094101, "o", "\u001b[?2004h"]
[40.094129, "o", "> "]
[40.094166, "o", "                })\r\n\u001b[?2004l\r"]
[40.094202, "o", "\u001b[?2004h> "]
[40.094248, "o", "            else:\r\n\u001b[?2004l\r"]
[40.094279, "o", "\u001b[?2004h> "]
[40.094411, "o", "                # Group by ID for deduplication\r\n\u001b[?2004l\r"]
[40.09444, "o", "\u001b[?2004h> "]
[40.094621, "o", "                valid_records[record['id']].append(record)\r\n\u001b[?2004l\r"]
[40.094649, "o", "\u001b[?2004h> "]
[40.094676, "o", "    \r\n\u001b[?2004l\r"]
[40.094706, "o", "\u001b[?2004h> "]
[40.094874, "o", "    # Deduplicate: keep the one with the latest purchase date\r\n\u001b[?2004l\r"]
[40.094904, "o", "\u001b[?2004h> "]
[40.094969, "o", "    final_records = []\r\n\u001b[?2004l\r"]
[40.094997, "o", "\u001b[?2004h> "]
[40.095145, "o", "    for asset_id, records in valid_records.items():\r\n\u001b[?2004l\r"]
[40.095173, "o", "\u001b[?2004h> "]
[40.095262, "o", "        if len(records) == 1:\r\n\u001b[?2004l\r"]
[40.095293, "o", "\u001b[?2004h> "]
[40.09542, "o", "            final_records.append(records[0])\r\n\u001b[?2004l\r"]
[40.095446, "o", "\u001b[?2004h"]
[40.095481, "o", "> "]
[40.095509, "o", "        else:\r\n\u001b[?2004l\r"]
[40.095536, "o", "\u001b[?2004h"]
[40.095565, "o", "> "]
[40.095677, "o", "            # Sort by date and keep the latest\r\n\u001b[?2004l\r"]
[40.095703, "o", "\u001b[?2004h> "]
[40.095964, "o", "            sorted_records = sorted(records, key=lambda x: x['purchase_date'], reverse=True)\r\n\u001b[?2004l\r"]
[40.095999, "o", "\u001b[?2004h"]
[40.096024, "o", "> "]
[40.096138, "o", "            final_records.append(sorted_records[0])\r\n\u001b[?2004l\r"]
[40.096166, "o", "\u001b[?2004h> "]
[40.096185, "o", "    \r\n\u001b[?2004l\r"]
[40.096215, "o", "\u001b[?2004h> "]
[40.096325, "o", "    # Sort by ID for consistent output\r\n\u001b[?2004l\r"]
[40.096355, "o", "\u001b[?2004h> "]
[40.096501, "o", "    final_records.sort(key=lambda x: x['id'])\r\n\u001b[?2004l\r"]
[40.096531, "o", "\u001b[?2004h> "]
[40.096562, "o", "    \r\n\u001b[?2004l\r"]
[40.096589, "o", "\u001b[?2004h> "]
[40.096642, "o", "    # Write outputs\r\n\u001b[?2004l\r"]
[40.096666, "o", "\u001b[?2004h"]
[40.096697, "o", "> "]
[40.096849, "o", "    with open('/home/user/inventory/assets.json', 'w') as f:\r\n\u001b[?2004l\r"]
[40.096878, "o", "\u001b[?2004h> "]
[40.09701, "o", "        json.dump(final_records, f, indent=2)\r\n\u001b[?2004l\r"]
[40.09704, "o", "\u001b[?2004h> "]
[40.097059, "o", "    \r\n\u001b[?2004l\r"]
[40.097093, "o", "\u001b[?2004h> "]
[40.097271, "o", "    with open('/home/user/inventory/rejected.json', 'w') as f:\r\n\u001b[?2004l\r"]
[40.097296, "o", "\u001b[?2004h"]
[40.097323, "o", "> "]
[40.097422, "o", "        json.dump(rejected, f, indent=2)\r\n\u001b[?2004l\r"]
[40.097451, "o", "\u001b[?2004h> "]
[40.097494, "o", "    \r\n\u001b[?2004l\r"]
[40.097523, "o", "\u001b[?2004h> "]
[40.097682, "o", "    print(f\"Processed {len(final_records)} valid records\")\r\n"]
[40.097708, "o", "\u001b[?2004l\r\u001b[?2004h"]
[40.097741, "o", "> "]
[40.097846, "o", "    print(f\"Rejected {len(rejected)} records\")\r\n\u001b[?2004l\r"]
[40.097874, "o", "\u001b[?2004h> "]
[40.098196, "o", "    print(f\"Deduplicated {sum(len(v) for v in valid_records.values()) - len(final_records)} duplicate records\")\r\n\u001b[?2004l\r"]
[40.098219, "o", "\u001b[?2004h"]
[40.098249, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[40.098282, "o", "> "]
[40.09834, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[40.098368, "o", "\u001b[?2004h> "]
[40.098405, "o", "    main()\r\n\u001b[?2004l\r"]
[40.098435, "o", "\u001b[?2004h> "]
[40.098471, "o", "EOF\r\n\u001b[?2004l\r"]
[40.102278, "o", "\u001b[?2004h"]
