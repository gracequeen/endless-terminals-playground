[40.079632, "i", "cat > process_assets.py << 'EOF'\nimport csv\nimport json\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\ndef parse_date(date_str):\n    \"\"\"Parse date from multiple formats to ISO 8601\"\"\"\n    date_str = date_str.strip()\n    \n    # Try YYYY-MM-DD (ISO format)\n    try:\n        dt = datetime.strptime(date_str, '%Y-%m-%d')\n        return dt.strftime('%Y-%m-%d')\n    except ValueError:\n        pass\n    \n    # Try MM/DD/YYYY (US format)\n    try:\n        dt = datetime.strptime(date_str, '%m/%d/%Y')\n        return dt.strftime('%Y-%m-%d')\n    except ValueError:\n        pass\n    \n    # Try DD.MM.YYYY (European format)\n    try:\n        dt = datetime.strptime(date_str, '%d.%m.%Y')\n        return dt.strftime('%Y-%m-%d')\n    except ValueError:\n        pass\n    \n    return None\n\ndef parse_price(price_str):\n    \"\"\"Parse price and convert to cents (positive integer)\"\"\"\n    try:\n        # Remove dollar signs, commas, and whitespace\n        cleaned = re.sub(r'[$,\\s]', '', price_str.strip())\n        \n   "]
[40.079774, "i", "     # Convert to float then to cents\n        price_float = float(cleaned)\n        \n        # Check if positive\n        if price_float <= 0:\n            return None\n        \n        # Convert to cents (integer)\n        price_cents = int(round(price_float * 100))\n        return price_cents\n    except (ValueError, AttributeError):\n        return None\n\ndef is_serial_format(text):\n    \"\"\"Check if text looks like a serial number (SN-XXX-XXXXX format)\"\"\"\n    return bool(re.match(r'^SN-[A-Z]+-\\d+$', text.strip()))\n\ndef process_row(row, row_num):\n    \"\"\"Process a single row and return (record, error) tuple\"\"\"\n    try:\n        asset_id = row['id'].strip()\n        name = row['name'].strip()\n        serial = row['serial'].strip()\n        purchase_date_raw = row['purchase_date'].strip()\n        price_raw = row['price'].strip()\n        location = row['location'].strip()\n        \n        # Check for swapped serial and name\n        if is_serial_format(name) and not is_serial_format(serial):\n            # Swap them\n         "]
[40.07981, "o", "cat > process_assets.py << 'EOF'\r\n\u001b[?2004l\r"]
[40.079854, "i", "   name, serial = serial, name\n        \n        # Validate and parse date\n        purchase_date = parse_date(purchase_date_raw)\n        if not purchase_date:\n            return None, f\"Invalid date format: {purchase_date_raw}\"\n        \n        # Validate and parse price\n        price_cents = parse_price(price_raw)\n        if price_cents is None:\n            return None, f\"Invalid price: {price_raw}\"\n        \n        # Basic validation\n        if not asset_id or not name or not serial or not location:\n            return None, \"Missing required fields\"\n        \n        record = {\n            'id': asset_id,\n            'name': name,\n            'serial': serial,\n            'purchase_date': purchase_date,\n            'price_cents': price_cents,\n            'location': location\n        }\n        \n        return record, None\n        \n    except Exception as e:\n        return None, f\"Processing error: {str(e)}\"\n\ndef main():\n    valid_records = defaultdict(list)  # id -> list of records\n    rejected = []\n    \n    #"]
[40.079877, "o", "\u001b[?2004h> "]
[40.079911, "i", " Read CSV\n    with open('/home/user/inventory/assets.csv', 'r') as f:\n        reader = csv.DictReader(f)\n        for row_num, row in enumerate(reader, start=2):  # start at 2 (after header)\n            record, error = process_row(row, row_num)\n            \n            if error:\n                rejected.append({\n                    'original_row': dict(row),\n                    'reason': error\n                })\n            else:\n                # Group by ID for deduplication\n                valid_records[record['id']].append(record)\n    \n    # Deduplicate: keep the one with the latest purchase date\n    final_records = []\n    for asset_id, records in valid_records.items():\n        if len(records) == 1:\n            final_records.append(records[0])\n        else:\n            # Sort by date and keep the latest\n            sorted_records = sorted(records, key=lambda x: x['purchase_date'], reverse=True)\n            final_records.append(sorted_records[0])\n    \n    # Sort by ID for consistent output\n    final_records"]
[40.079938, "o", "import csv\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.079969, "i", ".sort(key=lambda x: x['id'])\n    \n    # Write outputs\n    with open('/home/user/inventory/assets.json', 'w') as f:\n        json.dump(final_records, f, indent=2)\n    \n    with open('/home/user/inventory/rejected.json', 'w') as f:\n        json.dump(rejected, f, indent=2)\n    \n    print(f\"Processed {len(final_records)} valid records\")\n    print(f\"Rejected {len(rejected)} records\")\n    print(f\"Deduplicated {sum(len(v) for v in valid_records.values()) - len(final_records)} duplicate records\")\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
[40.079981, "o", "> import json\r\n\u001b[?2004l\r"]
[40.080001, "o", ".sort(key=lambda x: x['id'])\r\n    \r\n    # Write outputs\r\n \u001b[?2004h"]
