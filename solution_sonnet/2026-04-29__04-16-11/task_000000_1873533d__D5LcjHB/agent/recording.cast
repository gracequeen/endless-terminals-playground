[17.415766, "o", "\u001b[?2004huser@466d33394206:~$ "]
[17.513427, "i", "cat > /home/user/bin/env-merge.sh << 'EOF'\n#!/bin/bash\n\n# Check if two arguments are provided\nif [ $# -ne 2 ]; then\n    echo \"Usage: $0 <file1> <file2>\" >&2\n    exit 1\nfi\n\n# Check if both files exist\nif [ ! -f \"$1\" ]; then\n    echo \"Error: File '$1' not found\" >&2\n    exit 1\nfi\n\nif [ ! -f \"$2\" ]; then\n    echo \"Error: File '$2' not found\" >&2\n    exit 1\nfi\n\n# Use associative array to store key-value pairs\ndeclare -A env_vars\n\n# Function to parse and store env file\nparse_env_file() {\n    local file=\"$1\"\n    while IFS= read -r line || [ -n \"$line\" ]; do\n        # Skip empty lines and comments\n        [[ -z \"$line\" || \"$line\" =~ ^[[:space:]]*# ]] && continue\n        \n        # Extract key=value pairs\n        if [[ \"$line\" =~ ^[[:space:]]*([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]; then\n            key=\"${BASH_REMATCH[1]}\"\n            value=\"${BASH_REMATCH[2]}\"\n            env_vars[\"$key\"]=\"$value\"\n        fi\n    done < \"$file\"\n}\n\n# Parse first file, then second file (second file wins on conflicts)\nparse_env_file \"$1\"\npar"]
[17.513572, "i", "se_env_file \"$2\"\n\n# Output merged result in sorted order\nfor key in $(printf '%s\\n' \"${!env_vars[@]}\" | sort); do\n    echo \"${key}=${env_vars[$key]}\"\ndone\nEOF\n"]
