[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> # Check if two arguments are provided
[?2004l[?2004h> if [ $# -ne 2 ]; then
[?2004l[?2004h>     echo "Usage: $0 <file1> <file2>" >&2
[?2004l[?2004h>     exit 1
[?2004l[?2004h> fi
[?2004l[?2004h> 
[?2004l[?2004h> # Check if both files exist
[?2004l[?2004h> if [ ! -f "$1" ]; then
[?2004l[?2004h>     echo "Error: File '$1' not found" >&2
[?2004l[?2004h>     exit 1
[?2004l[?2004h> fi
[?2004l[?2004h> 
[?2004l[?2004h> if [ ! -f "$2" ]; then
[?2004l[?2004h>     echo "Error: File '$2' not found" >&2
[?2004l[?2004h>     exit 1
[?2004l[?2004h> fi
[?2004l[?2004h> 
[?2004l[?2004h> # Use associative array to store key-value pairs
[?2004l[?2004h> declare -A env_vars
[?2004l[?2004h> 
[?2004l[?2004h> # Function to parse and store env file
[?2004l[?2004h> parse_env_file() {
[?2004l[?2004h>     local file="$1"
[?2004l[?2004h>     while IFS= read -r line || [ -n "$line" ]; do
[?2004l[?2004h>         # Skip empty lines and comments
[?2004l[?2004h>         [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
[?2004l[?2004h>         
[?2004l[?2004h>         # Extract key=value pairs
[?2004l[?2004h>         if [[ "$line" =~ ^[[:space:]]*([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]; then
[?2004l[?2004h>             key="${BASH_REMATCH[1]}"
[?2004l[?2004h>             value="${BASH_REMATCH[2]}"
[?2004l[?2004h>             env_vars["$key"]="$value"
[?2004l[?2004h>         fi
[?2004l[?2004h>     done < "$file"
[?2004l[?2004h> }
[?2004l[?2004h> 
[?2004l[?2004h> # Parse first file, then second file (second file wins on conflicts)
[?2004l[?2004h> parse_env_file "$1"
[?2004l[?2004h> parse_env_file "$2"
[?2004l[?2004h> 
[?2004l[?2004h> # Output merged result in sorted order
[?2004l[?2004h> for key in $(printf '%s\n' "${!env_vars[@]}" | sort); do
[?2004l[?2004h>     echo "${key}=${env_vars[$key]}"
[?2004l[?2004h> done
[?2004l[?2004h> EOF
