[27.215, "i", "cat > /tmp/analyze_memory.sh << 'EOF'\n#!/bin/bash\n\n# Temporary file to store results\ntmp_file=$(mktemp)\n\n# Process each host file\nfor i in {01..08}; do\n    file=\"/home/user/memstats/host${i}.txt\"\n    hostname=\"host${i}\"\n    \n    # Extract MemTotal and MemAvailable\n    mem_total=$(grep -E '^MemTotal:' \"$file\" 2>/dev/null | awk '{print $2}')\n    mem_available=$(grep -E '^MemAvailable:' \"$file\" 2>/dev/null | awk '{print $2}')\n    \n    # Check if both values exist (handle corrupted files)\n    if [[ -n \"$mem_total\" && -n \"$mem_available\" ]]; then\n        # Calculate percentage available\n        percentage=$(awk \"BEGIN {printf \\\"%.2f\\\", ($mem_available / $mem_total) * 100}\")\n        \n        # Check if less than 20%\n        is_low=$(awk \"BEGIN {print ($percentage < 20) ? 1 : 0}\")\n        \n        if [[ $is_low -eq 1 ]]; then\n            echo -e \"${hostname}\\t${percentage}\" >> \"$tmp_file\"\n        fi\n    fi\ndone\n\n# Sort by percentage (ascending = worst first) and output to report\nsort -t$'\\t' -k2 -n \"$tmp_file\" > /ho"]
[27.215065, "i", "me/user/low_memory_report.txt\n\n# Clean up\nrm -f \"$tmp_file\"\nEOF\n"]
