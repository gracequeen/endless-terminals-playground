[?2004huser@18e6f422c9a0:~$ cat > /tmp/analyze_memory.sh << 'EOF'
[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> # Temporary file to store results
[?2004l[?2004h> tmp_file=$(mktemp)
[?2004l[?2004h> 
[?2004l[?2004h> # Process each host file
[?2004l[?2004h> for i in {01..08}; do
[?2004l[?2004h>     file="/home/user/memstats/host${i}.txt"
[?2004l[?2004h>     hostname="host${i}"
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract MemTotal and MemAvailable
[?2004l[?2004h>     mem_total=$(grep -E '^MemTotal:' "$file" 2>/dev/null | awk '{print $2}')
[?2004l[?2004h>     mem_available=$(grep -E '^MemAvailable:' "$file" 2>/dev/null | awk '{print $2}')
[?2004l[?2004h>     
[?2004l[?2004h>     # Check if both values exist (handle corrupted files)
[?2004l[?2004h>     if [[ -n "$mem_total" && -n "$mem_available" ]]; then
[?2004l[?2004h>         # Calculate percentage available
[?2004l[?2004h>         percentage=$(awk "BEGIN {printf \"%.2f\", ($mem_available / $mem_total) * 100}")
[?2004l[?2004h>         
[?2004l[?2004h>         # Check if less than 20%
[?2004l[?2004h>         is_low=$(awk "BEGIN {print ($percentage < 20) ? 1 : 0}")
[?2004l[?2004h>         
[?2004l[?2004h>         if [[ $is_low -eq 1 ]]; then
[?2004l[?2004h>             echo -e "${hostname}\t${percentage}" >> "$tmp_file"
[?2004l[?2004h>         fi
[?2004l[?2004h>     fi
[?2004l[?2004h> done
[?2004l[?2004h> 
[?2004l[?2004h> # Sort by percentage (ascending = worst first) and output to report
[?2004l[?2004h> sort -t$'\t' -k2 -n "$tmp_file" > /home/user/low_memory_report.txt
[?2004l[?2004h> 
[?2004l[?2004h> # Clean up
[?2004l[?2004h> rm -f "$tmp_file"
[?2004l[?2004h> EOF
[?2004l[?2004huser@18e6f422c9a0:~$ chmod +x /tmp/analyze_memory.sh
