[103.16485, "i", "cat > rules.txt << 'EOF'\n*filter\n:INPUT DROP [0:0]\n:FORWARD DROP [0:0]\n:OUTPUT ACCEPT [0:0]\n-A INPUT -m state --state RELATED,ESTABLISHED -j ACCEPT\n-A INPUT -p tcp -m tcp --dport 22 -j ACCEPT\n-A FORWARD -m state --state RELATED,ESTABLISHED -j ACCEPT\n-A FORWARD -s 10.200.0.0/16 -d 10.100.0.42/32 -p tcp -m tcp --dport 5000 -j ACCEPT\n-A FORWARD -i eth1 -o eth2 -j ACCEPT\nCOMMIT\n*nat\n:PREROUTING ACCEPT [0:0]\n:INPUT ACCEPT [0:0]\n:OUTPUT ACCEPT [0:0]\n:POSTROUTING ACCEPT [0:0]\n-A POSTROUTING -s 10.200.0.0/16 -o eth2 -j MASQUERADE\nCOMMIT\nEOF\n"]
