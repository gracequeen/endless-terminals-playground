[33.61265, "o", "#!/bin/bash\r\n# Flush existing rules\r\niptables -F\r\niptables -t nat -F\r\n\r\n# Default policies\r\niptables -P INPUT DROP\r\niptables -P FORWARD DROP\r\niptables -P OUTPUT ACCEPT\r\n\r\n# Allow established connections\r\niptables -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT\r\niptables -A FORWARD -m state --state ESTABLISHED,RELATED -j ACCEPT\r\n\r\n# Allow SSH to gateway\r\niptables -A INPUT -p tcp --dport 22 -j ACCEPT\r\n\r\n"]
[33.612723, "o", "# Allow inference subnet to registry on port 5000 (FIXED: moved to FORWARD chain)\r\niptables -A FORWARD -s 10.200.0.0/16 -d 10.100.0.42 -p tcp --dport 5000 -j ACCEPT\r\n\r\n# NAT for outbound\r\niptables -t nat -A POSTROUTING -s 10.200.0.0/16 -o eth2 -j MASQUERADE\r\n\r\n# General forwarding between networks\r\niptables -A FORWARD -i eth1 -o eth2 -j ACCEPT\r\n"]
