[76.201562, "o", "  OLD (buggy):  2024-04-01 14:00:00 CEST+0200\r\n  NEW (fixed):  2024-04-01 16:00:00 CEST+0200\r\n  *** CORRECTED: 2.0 hour offset fixed! ***\r\n"]
