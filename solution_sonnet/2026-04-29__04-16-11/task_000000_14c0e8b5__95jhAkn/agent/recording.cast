[50.951378, "i", "cat > check.py << 'EOF'\n#!/usr/bin/env python3\nimport json\nimport csv\nimport ipaddress\nimport sys\n\ndef parse_port_spec(port_spec):\n    \"\"\"Parse a port specification into a set of allowed ports or a range.\"\"\"\n    port_spec = str(port_spec)\n    if '-' in port_spec:\n        start, end = port_spec.split('-')\n        return ('range', int(start), int(end))\n    else:\n        return ('single', int(port_spec))\n\ndef port_matches(port, port_spec):\n    \"\"\"Check if a port matches a port specification.\"\"\"\n    spec_type, *spec_data = port_spec\n    if spec_type == 'single':\n        return port == spec_data[0]\n    elif spec_type == 'range':\n        return spec_data[0] <= port <= spec_data[1]\n    return False\n\ndef find_best_cidr_match(src_ip, rules):\n    \"\"\"Find the most specific CIDR that matches the source IP.\"\"\"\n    ip_obj = ipaddress.ip_address(src_ip)\n    matching_cidrs = []\n    \n    for rule in rules:\n        network = ipaddress.ip_network(rule['source_cidr'])\n        if ip_obj in network:\n            matching_cidrs.appe"]
