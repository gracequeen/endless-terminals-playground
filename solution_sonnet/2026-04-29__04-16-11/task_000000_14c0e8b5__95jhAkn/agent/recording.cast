[55.116478, "o", "#!/usr/bin/env python3\r\nimport json\r\nimport csv\r\nimport ipaddress\r\nimport sys\r\n\r\ndef parse_port_spec(port_spec):\r\n    \"\"\"Parse a port specification into a set of allowed ports or a range.\"\"\"\r\n    port_spec = str(port_spec)\r\n    if '-' in port_spec:\r\n        start, end = port_spec.split('-')\r\n        return ('range', int(start), int(end))\r\n    else:\r\n        return ('single', int(port_spec))\r\n\r\ndef port_matches(port, port_spec):\r\n    \"\"\"Check if a port matches a port specification.\"\"\"\r\n    spec_type, *spec_data = port_spec\r\n    if spec_type == 'single':\r\n        return port == spec_data[0]\r\n    elif spec_type == 'range':\r\n        return spec_data[0] <= port <= spec_data[1]\r\n    return False\r\n\r\ndef find_best_cidr_match(src_ip, rules):\r\n"]
[55.11657, "o", "    \"\"\"Find the most specific CIDR that matches the source IP.\"\"\"\r\n    ip_obj = ipaddress.ip_address(src_ip)\r\n    matching_cidrs = []\r\n    \r\n    for rule in rules:\r\n        network = ipaddress.ip_network(rule['source_cidr'])\r\n        if ip_obj in network:\r\n            matching_cidrs.append((rule['source_cidr'], network.prefixlen))\r\n    \r\n    if not matching_cidrs:\r\n        return None\r\n    \r\n    # Sort by prefix length (most specific first)\r\n    matching_cidrs.sort(key=lambda x: x[1], reverse=True)\r\n    return matching_cidrs[0][0]\r\n\r\ndef find_matching_rule(src_ip, dest_port, rules):\r\n    \"\"\"Find the most specific matching rule for a given source IP and destination port.\"\"\"\r\n    ip_obj = ipaddress.ip_address(src_ip)\r\n    matching_rules = []\r\n    \r\n    for rule in rules:\r\n        network = ipaddress.ip_network(rule['source_cidr'])\r\n        if ip_obj in network:\r\n            port_spec = parse_port_spec(rule['dest_port'])\r\n            if port_matches(dest_port, port_spec):\r\n                matching_rules.append(("]
[55.116639, "o", "rule, network.prefixlen))\r\n    \r\n    if not matching_rules:\r\n        return None\r\n    \r\n    # Sort by prefix length (most specific first)\r\n    matching_rules.sort(key=lambda x: x[1], reverse=True)\r\n    return matching_rules[0][0]\r\n\r\ndef main():\r\n    # Load firewall rules\r\n    with open('/home/user/audit/firewall_rules.json', 'r') as f:\r\n        config = json.load(f)\r\n    \r\n    rules = config['rules']\r\n    default_action = config.get('default_action', 'deny')\r\n    \r\n    # Load connections\r\n    with open('/home/user/audit/connections.csv', 'r') as f:\r\n        reader = csv.DictReader(f)\r\n        connections = list(reader)\r\n    \r\n    # Check each connection\r\n    for conn in connections:\r\n        src_ip = conn['src_ip']\r\n        dest_port = int(conn['dest_port'])\r\n        \r\n        matching_rule = find_matching_rule(src_ip, dest_port, rules)\r\n        \r\n        if matching_rule is None:\r\n            # No matching rule, apply default action\r\n            if default_action == 'deny':\r\n                # Find the best C"]
[55.116682, "o", "IDR match for context\r\n                best_cidr = find_best_cidr_match(src_ip, rules)\r\n                if best_cidr:\r\n                    print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from {best_cidr}\")\r\n                else:\r\n                    print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from any rule\")\r\n        elif matching_rule['action'] == 'deny':\r\n            # Explicit deny rule\r\n            print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from {matching_rule['source_cidr']}\")\r\n        # If action is 'allow', connection is permitted (no output)\r\n\r\nif __name__ == '__main__':\r\n    main()\r\n"]
