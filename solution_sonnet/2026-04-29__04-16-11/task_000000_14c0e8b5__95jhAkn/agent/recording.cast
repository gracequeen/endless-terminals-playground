[30.139228, "i", "k:\n            port_spec = parse_port_spec(rule['dest_port'])\n            if port_matches(dest_port, port_spec):\n                matching_rules.append((rule, network.prefixlen))\n    \n    if not matching_rules:\n        return None\n    \n    # Sort by prefix length (most specific first)\n    matching_rules.sort(key=lambda x: x[1], reverse=True)\n    return matching_rules[0][0]\n\ndef main():\n    # Load firewall rules\n    with open('/home/user/audit/firewall_rules.json', 'r') as f:\n        config = json.load(f)\n    \n    rules = config['rules']\n    default_action = config.get('default_action', 'deny')\n    \n    # Load connections\n    with open('/home/user/audit/connections.csv', 'r') as f:\n        reader = csv.DictReader(f)\n        connections = list(reader)\n    \n    # Check each connection\n    for conn in connections:\n        src_ip = conn['src_ip']\n        dest_port = int(conn['dest_port'])\n        \n        matching_rule = find_matching_rule(src_ip, dest_port, rules)\n        \n        if matching_rule is None:\n       "]
