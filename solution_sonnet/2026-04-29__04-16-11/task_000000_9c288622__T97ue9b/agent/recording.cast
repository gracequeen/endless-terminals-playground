[68.972022, "i", "cat > verify_fix.py << 'EOF'\n#!/usr/bin/env python3\n\"\"\"Verification that the DST bug is fixed.\"\"\"\n\nimport pytz\nfrom datetime import datetime\n\nBERLIN_TZ = pytz.timezone('Europe/Berlin')\nUTC_TZ = pytz.utc\n\ndef old_buggy_convert(utc_time_str):\n    \"\"\"The OLD buggy version that caused the issue.\"\"\"\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\n    # BUG: This treats the UTC datetime as if it's already Berlin time\n    berlin_dt = BERLIN_TZ.localize(utc_dt)\n    return berlin_dt\n\ndef new_fixed_convert(utc_time_str):\n    \"\"\"The NEW fixed version.\"\"\"\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\n    # FIX: First localize as UTC, then convert to Berlin\n    utc_dt = UTC_TZ.localize(utc_dt)\n    berlin_dt = utc_dt.astimezone(BERLIN_TZ)\n    return berlin_dt\n\nprint(\"=\" * 70)\nprint(\"DST Bug Fix Verification\")\nprint(\"=\" * 70)\nprint(\"\\nMeeting: Maintenance Window Prep\")\nprint(\"Stored UTC time: 2024-03-31T01:30:00\")\nprint(\"Expected Berlin time: 2024-03-31 03:30:00 CEST (UTC+2)\")\nprint(\"\\n"]
[68.972144, "i", "Note: March 31, 2024 is DST transition day in Europe/Berlin\")\nprint(\"At 2:00 AM CET, clocks jump forward to 3:00 AM CEST\\n\")\n\nutc_time = \"2024-03-31T01:30:00\"\n\nprint(\"-\" * 70)\nprint(\"OLD BUGGY BEHAVIOR:\")\ntry:\n    buggy_result = old_buggy_convert(utc_time)\n    print(f\"Result: {buggy_result.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\n    print(f\"✗ WRONG: Treated UTC time as Berlin time, giving {buggy_result.hour}:{buggy_result.minute:02d}\")\nexcept Exception as e:\n    print(f\"Error (may occur during DST): {e}\")\n\nprint(\"\\n\" + \"-\" * 70)\nprint(\"NEW FIXED BEHAVIOR:\")\nfixed_result = new_fixed_convert(utc_time)\nprint(f\"Result: {fixed_result.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\nif fixed_result.hour == 3 and fixed_result.minute == 30:\n    print(f\"✓ CORRECT: Properly converted UTC to Berlin time (3:30 CEST)\")\nelse:\n    print(f\"✗ Issue: Got {fixed_result.hour}:{fixed_result.minute:02d}\")\n\nprint(\"\\n\" + \"=\" * 70)\nprint(\"IMPACT: With the bug, reminders would be sent 1 hour early/late\")\nprint(\"during DST transitions, causin"]
[68.972178, "o", "cat > verify_fix.py << 'EOF'\r\n"]
[68.972215, "i", "g the exact issue reported.\")\nprint(\"=\" * 70)\nEOF\n"]
