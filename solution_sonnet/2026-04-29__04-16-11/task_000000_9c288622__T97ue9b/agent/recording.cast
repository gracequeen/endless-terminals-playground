[32.919025, "o", "cat app.py\r\n\u001b[?2004l\r"]
[32.919841, "o", "#!/usr/bin/env python3\r\n\"\"\"\r\nMeeting reminder application.\r\nSends reminders 15 minutes before each meeting.\r\nConverts UTC times to Europe/Berlin timezone.\r\n\"\"\"\r\n\r\nimport json\r\nimport pytz\r\nfrom datetime import datetime, timedelta\r\n\r\nMEETINGS_FILE = '/home/user/scheduler/meetings.json'\r\nBERLIN_TZ = pytz.timezone('Europe/Berlin')\r\nUTC_TZ = pytz.utc\r\n\r\ndef load_meetings():\r\n    \"\"\"Load meetings from JSON file.\"\"\"\r\n    with open(MEETINGS_FILE, 'r') as f:\r\n        return json.load(f)\r\n\r\ndef convert_to_berlin(utc_time_str):\r\n    \"\"\"\r\n    Convert UTC time string to Berlin timezone.\r\n    \"\"\"\r\n    # Parse the UTC time string\r\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\r\n\r\n    # First, localize as UTC (since the input is UTC)\r\n    utc_dt = UTC_TZ.localize(utc_dt)\r\n    \r\n    # Then convert to Berlin time\r\n    berlin_dt = utc_dt.astimezone(BERLIN_TZ)"]
[32.919908, "o", "\r\n\r\n    return berlin_dt\r\n\r\ndef get_current_time_berlin():\r\n    \"\"\"Get current time in Berlin timezone.\"\"\"\r\n    return datetime.now(BERLIN_TZ)\r\n\r\ndef check_reminders():\r\n    \"\"\"Check for meetings that need reminders (15-75 minutes from now).\"\"\"\r\n    meetings = load_meetings()\r\n    now = get_current_time_berlin()\r\n\r\n    reminder_start = now + timedelta(minutes=15)\r\n    reminder_end = now + timedelta(minutes=75)\r\n\r\n    reminders = []\r\n\r\n    for meeting in meetings:\r\n        berlin_time = convert_to_berlin(meeting['utc_time'])\r\n\r\n        # Check if meeting falls within reminder window\r\n        if reminder_start <= berlin_time <= reminder_end:\r\n            reminders.append({\r\n                'title': meeting['title'],\r\n                'time': berlin_time.strftime('%Y-%m-%d %H:%M:%S %Z%z')\r\n            })\r\n\r\n    return reminders\r\n\r\ndef main():\r\n    \"\"\"Main entry point.\"\"\"\r\n    reminders = check_reminders()\r\n\r\n    if reminders:\r\n        print(\"=== Meeting Reminders ===\")\r\n        for reminder in reminders:\r\n"]
[32.919961, "o", "            print(f\"REMINDER: {reminder['title']} at {reminder['time']}\")\r\n    else:\r\n        print(\"No upcoming meetings in the next 15-75 minutes.\")\r\n\r\nif __name__ == '__main__':\r\n    main()\r\n"]
[32.920034, "o", "\u001b[?2004h"]
[32.920082, "o", "user@2a422e2e1198:~/scheduler$ "]
[46.190779, "i", "cat > test_fix.py << 'EOF'\n#!/usr/bin/env python3\n\"\"\"Test the timezone conversion fix.\"\"\"\n\nimport pytz\nfrom datetime import datetime\n\n# Import the fixed function\nimport sys\nsys.path.insert(0, '/home/user/scheduler')\nfrom app import convert_to_berlin\n\ndef test_dst_transition():\n    \"\"\"Test conversion during DST transition.\"\"\"\n    print(\"Testing timezone conversion fix...\\n\")\n    \n    # Test the problematic Maintenance Window meeting\n    # 2024-03-31 is when Europe/Berlin transitions from CET to CEST\n    # At 2:00 AM CET, clocks jump to 3:00 AM CEST\n    utc_time = \"2024-03-31T01:30:00\"\n    \n    print(f\"Input UTC time: {utc_time}\")\n    \n    # Convert using the fixed function\n    berlin_time = convert_to_berlin(utc_time)\n    print(f\"Converted Berlin time: {berlin_time}\")\n    print(f\"Formatted: {berlin_time.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\n    \n    # Verify it's in CEST (UTC+2) not CET (UTC+1)\n    expected_hour = 3  # Should be 3:30 CEST, not 1:30 CET or 2:30 CET\n    if berlin_time.hour == expected_hour and b"]
[46.190815, "i", "erlin_time.minute == 30:\n        print(f\"\\n✓ PASS: Correctly converted to {expected_hour}:30 CEST (after DST transition)\")\n    else:\n        print(f\"\\n✗ FAIL: Expected {expected_hour}:30, got {berlin_time.hour}:{berlin_time.minute:02d}\")\n    \n    # Test a few more cases\n    print(\"\\n--- Additional test cases ---\")\n    test_cases = [\n        (\"2024-03-31T08:00:00\", \"Daily Standup\"),\n        (\"2024-04-01T14:00:00\", \"Weekly Review\"),\n    ]\n    \n    for utc_str, name in test_cases:\n        berlin = convert_to_berlin(utc_str)\n        print(f\"{name}: {utc_str} UTC -> {berlin.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\n\nif __name__ == '__main__':\n    test_dst_transition()\nEOF\n"]
