[40.099861, "o", "cat aggregate.py\r\n\u001b[?2004l\r"]
[40.100703, "o", "#!/usr/bin/env python3\r\nimport json\r\n\r\ndef main():\r\n    results = {\"hosts\": {}}\r\n\r\n    with open(\"results/ping.txt\") as f:\r\n        for line in f:\r\n            host, status = line.strip().split(\": \")\r\n            results[\"hosts\"][host] = {\"ping\": status}\r\n\r\n    with open(\"results/ports.txt\") as f:\r\n        for line in f:\r\n            parts = line.strip().split()\r\n            host_port = parts[0].split(\":\")\r\n            host = host_port[0]\r\n            port = host_port[1]\r\n            status = parts[1]\r\n            if host not in results[\"hosts\"]:\r\n                results[\"hosts\"][host] = {}\r\n            if \"ports\" not in results[\"hosts\"][host]:\r\n                results[\"hosts\"][host][\"ports\"] = {}\r\n            results[\"hosts\"][host][\"ports\"][port] = status\r\n\r\n    with open(\"results/status.json\", \"w\") as f:\r\n        json.dump(results, f, indent=2)\r\n\r\n    print(\"Report generated: results/status.json\")\r\n\r\nif __name__ == \"__main__\":\r\n    main()\r\n"]
[40.100882, "o", "\u001b[?2004h"]
[40.100916, "o", "root@2c38146791ee:/home/user/netmon# "]
[48.661912, "i", "cat > Makefile << 'EOF'\n.PHONY: report clean\n\n# Main target to generate the report\nreport: results/status.json\n\t@echo \"Monitoring report complete!\"\n\n# Check that hosts.conf exists before doing anything\nresults/ping.txt: hosts.conf\n\t@test -f hosts.conf || (echo \"ERROR: hosts.conf is missing!\" && exit 1)\n\t@echo \"Running ping checks...\"\n\t./scripts/check_ping.sh\n\nresults/ports.txt: hosts.conf\n\t@test -f hosts.conf || (echo \"ERROR: hosts.conf is missing!\" && exit 1)\n\t@echo \"Running port checks...\"\n\t./scripts/check_ports.sh\n\n# Aggregate results into JSON report\nresults/status.json: results/ping.txt results/ports.txt aggregate.py\n\t@echo \"Aggregating results...\"\n\tpython3 aggregate.py\n\n# Clean up generated files\nclean:\n\trm -rf results/\nEOF\n"]
