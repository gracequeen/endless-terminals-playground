[18.33269, "o", "cat scripts/check_ping.sh\r\n\u001b[?2004l\r"]
[18.333577, "o", "#!/bin/bash\r\nmkdir -p results\r\nwhile read -r host; do\r\n    if ping -c 1 -W 1 \"$host\" &>/dev/null; then\r\n        echo \"$host: up\"\r\n    else\r\n        echo \"$host: down\"\r\n    fi\r\ndone < hosts.conf > results/ping.txt\r\n"]
[18.333745, "o", "\u001b[?2004h"]
[18.333783, "o", "root@2c38146791ee:/home/user/netmon# "]
[18.438516, "i", "cat scripts/check_ports.sh\n"]
[18.438639, "o", "cat scripts/check_ports.sh\r\n"]
[18.438687, "o", "\u001b[?2004l\r"]
[18.439492, "o", "#!/bin/bash\r\nmkdir -p results\r\nwhile read -r host; do\r\n    for port in 22 80 443; do\r\n        timeout 1 bash -c \"echo >/dev/tcp/$host/$port\" 2>/dev/null && status=\"open\" || status=\"closed\"\r\n        echo \"$host:$port $status\"\r\n    done\r\ndone < hosts.conf > results/ports.txt\r\n"]
[18.439659, "o", "\u001b[?2004h"]
[18.439695, "o", "root@2c38146791ee:/home/user/netmon# "]
[18.546442, "i", "cat hosts.conf\n"]
[18.546555, "o", "cat hosts.conf\r\n\u001b[?2004l\r"]
[18.547418, "o", "192.168.1.1\r\n192.168.1.2\r\n10.0.0.1\r\n"]
[18.547567, "o", "\u001b[?2004h"]
[18.547603, "o", "root@2c38146791ee:/home/user/netmon# "]
[18.642404, "i", "cat aggregate.py\n"]
[18.642514, "o", "cat aggregate.py\r\n\u001b[?2004l\r"]
[18.643364, "o", "#!/usr/bin/env python3\r\nimport json\r\n\r\ndef main():\r\n    results = {\"hosts\": {}}\r\n\r\n    with open(\"results/ping.txt\") as f:\r\n        for line in f:\r\n            host, status = line.strip().split(\": \")\r\n            results[\"hosts\"][host] = {\"ping\": status}\r\n\r\n    with open(\"results/ports.txt\") as f:\r\n        for line in f:\r\n            parts = line.strip().split()\r\n            host_port = parts[0].split(\":\")\r\n            host = host_port[0]\r\n            port = host_port[1]\r\n            status = parts[1]\r\n            if host not in results[\"hosts\"]:\r\n                results[\"hosts\"][host] = {}\r\n            if \"ports\" not in results[\"hosts\"][host]:\r\n                results[\"hosts\"][host][\"ports\"] = {}\r\n            results[\"hosts\"][host][\"ports\"][port] = status\r\n\r\n    with open(\"results/status.json\", \"w\") as f\r\n        json.dump(results, f, indent=2)\r\n\r\n"]
[18.643418, "o", "    print(\"Report generated: results/status.json\")\r\n\r\nif __name__ == \"__main__\":\r\n    main()\r\n"]
[18.643536, "o", "\u001b[?2004h"]
[18.643585, "o", "root@2c38146791ee:/home/user/netmon# "]
