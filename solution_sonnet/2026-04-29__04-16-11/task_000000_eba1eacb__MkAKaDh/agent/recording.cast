[33.575451, "o", "#!/usr/bin/env python3\r\nimport json\r\n\r\ndef main():\r\n    results = {\"hosts\": {}}\r\n\r\n    with open(\"results/ping.txt\") as f:\r\n        for line in f:\r\n            host, status = line.strip().split(\": \")\r\n            results[\"hosts\"][host] = {\"ping\": status}\r\n\r\n    with open(\"results/ports.txt\") as f:\r\n        for line in f:\r\n            parts = line.strip().split()\r\n            host_port = parts[0].split(\":\")\r\n            host = host_port[0]\r\n            port = host_port[1]\r\n            status = parts[1]\r\n            if host not in results[\"hosts\"]:\r\n                results[\"hosts\"][host] = {}\r\n            if \"ports\" not in results[\"hosts\"][host]:\r\n                results[\"hosts\"][host][\"ports\"] = {}\r\n            results[\"hosts\"][host][\"ports\"][port] = status\r\n\r\n    with open(\"results/status.json\", \"w\") as f\r\n\r\n    print(\"Report generated: results/status.json\")\r\n\r\nif __name__ == \"__main__\":\r\n    main()\r\n"]
[33.575649, "o", "\u001b[?2004h"]
[33.575682, "o", "root@2c38146791ee:/home/user/netmon# "]
[39.994061, "i", "cat > aggregate.py << 'EOF'\n#!/usr/bin/env python3\nimport json\n\ndef main():\n    results = {\"hosts\": {}}\n\n    with open(\"results/ping.txt\") as f:\n        for line in f:\n            host, status = line.strip().split(\": \")\n            results[\"hosts\"][host] = {\"ping\": status}\n\n    with open(\"results/ports.txt\") as f:\n        for line in f:\n            parts = line.strip().split()\n            host_port = parts[0].split(\":\")\n            host = host_port[0]\n            port = host_port[1]\n            status = parts[1]\n            if host not in results[\"hosts\"]:\n                results[\"hosts\"][host] = {}\n            if \"ports\" not in results[\"hosts\"][host]:\n                results[\"hosts\"][host][\"ports\"] = {}\n            results[\"hosts\"][host][\"ports\"][port] = status\n\n    with open(\"results/status.json\", \"w\") as f:\n        json.dump(results, f, indent=2)\n\n    print(\"Report generated: results/status.json\")\n\nif __name__ == \"__main__\":\n    main()\nEOF\n"]
