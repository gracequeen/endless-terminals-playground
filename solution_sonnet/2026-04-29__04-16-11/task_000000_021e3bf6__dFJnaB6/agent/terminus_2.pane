MemAvai[?2004huser@8cbfd73c8e9a:~$ cat > /tmp/process_memory.sh << 'EOF'
[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> # Process each host file
[?2004l[?2004h> for hostfile in /home/user/memstats/host*.txt; do
[?2004l[?2004h>     hostname=$(basename "$hostfile" .txt)
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract MemTotal and MemAvailable, handle missing values
[?2004l[?2004h>     memtotal=$(grep -oP '^MemTotal:\s+\K[0-9]+' "$hostfile" 2>/dev/null)
[?2004l[?2004h>     memavail=$(grep -oP '^MemAvailable:\s+\K[0-9]+' "$hostfile" 2>/dev/null)
[?2004l[?2004h>     
[?2004l[?2004h>     # Skip if either value is missing or zero
[?2004l[?2004h>     if [[ -z "$memtotal" || -z "$memavail" || "$memtotal" -eq 0 ]]; then
[?2004l[?2004h>         continue
[?2004l[?2004h>     fi
[?2004l[?2004h>     
[?2004l[?2004h>     # Calculate percentage available
[?2004l[?2004h>     percent=$(awk "BEGIN {printf \"%.2f\", ($memavail / $memtotal) * 100}")
[?2004l[?2004h>     
[?2004l[?2004h>     # Check if less than 20%
[?2004l[?2004h>     is_low=$(awk "BEGIN {print ($percent < 20) ? 1 : 0}")
[?2004l[?2004h>     
[?2004l[?2004h>     if [[ "$is_low" -eq 1 ]]; then
[?2004l[?2004h>         echo -e "${hostname}\t${percent}"
[?2004l[?2004h>     fi
[?2004l[?2004h> done | sort -t$'\t' -k2 -n
[?2004l[?2004h> EOF
[?2004l[?2004huser@8cbfd73c8e9a:~$ chmod +x /tmp/process_memory.sh
