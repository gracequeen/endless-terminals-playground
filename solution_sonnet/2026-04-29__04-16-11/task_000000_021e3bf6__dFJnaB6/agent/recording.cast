[7.813279, "o", "\u001b[?2004h"]
[7.813312, "o", "user@8cbfd73c8e9a:~$ "]
[19.505188, "i", "cat > /tmp/process_memory.sh << 'EOF'\n#!/bin/bash\n\n# Process each host file\nfor hostfile in /home/user/memstats/host*.txt; do\n    hostname=$(basename \"$hostfile\" .txt)\n    \n    # Extract MemTotal and MemAvailable, handle missing values\n    memtotal=$(grep -oP '^MemTotal:\\s+\\K[0-9]+' \"$hostfile\" 2>/dev/null)\n    memavail=$(grep -oP '^MemAvailable:\\s+\\K[0-9]+' \"$hostfile\" 2>/dev/null)\n    \n    # Skip if either value is missing or zero\n    if [[ -z \"$memtotal\" || -z \"$memavail\" || \"$memtotal\" -eq 0 ]]; then\n        continue\n    fi\n    \n    # Calculate percentage available\n    percent=$(awk \"BEGIN {printf \\\"%.2f\\\", ($memavail / $memtotal) * 100}\")\n    \n    # Check if less than 20%\n    is_low=$(awk \"BEGIN {print ($percent < 20) ? 1 : 0}\")\n    \n    if [[ \"$is_low\" -eq 1 ]]; then\n        echo -e \"${hostname}\\t${percent}\"\n    fi\ndone | sort -t$'\\t' -k2 -n\nEOF\n"]
