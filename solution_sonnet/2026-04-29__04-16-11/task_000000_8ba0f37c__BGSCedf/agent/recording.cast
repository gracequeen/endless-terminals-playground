[6.597211, "o", "total 12\r\n"]
[6.597234, "o", "drwxrwxrwx 1 user user 4096 Apr 29 05:08 .\r\ndrwxrwxrwx 1 user user 4096 Apr 29 05:09 ..\r\n-rw-r--r-- 1 user user  468 Apr 29 05:08 target_iptables.txt\r\n"]
