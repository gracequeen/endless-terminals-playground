[55.575067, "o", "import configparser\r\nimport os\r\n\r\n# Read configuration from settings.ini\r\n_config = configparser.ConfigParser()\r\nconfig_path = os.path.join(os.path.dirname(__file__), 'settings.ini')\r\n_config.read(config_path)\r\n\r\n# Get settings with fallbacks\r\nhost = _config.get('server', 'host', fallback='127.0.0.1')\r\nport = _config.get('server', 'port', fallback='8000')\r\nworkers_count = _config.get('server', 'workers', fallback='2')\r\n\r\n# Gunicorn configuration\r\nbind = f\"{host}:{port}\"\r\nworkers = int(workers_count)\r\ndaemon = False\r\n"]
