[147.964543, "o", "\u001b[01;31m\u001b[Kdef save_checkpoint\u001b[m\u001b[K(line_num):\r\n    # FIX: Use context manager and flush to ensure write to disk\r\n    with open('.checkpoint', 'w') as f:\r\n        json.dump({'last_line': line_num}, f)\r\n        f.flush()\r\n"]
