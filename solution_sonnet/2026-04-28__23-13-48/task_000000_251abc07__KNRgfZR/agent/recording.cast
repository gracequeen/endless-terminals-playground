[27.147858, "i", "awk '\nBEGIN {\n  months[\"Jan\"]=\"01\"; months[\"Feb\"]=\"02\"; months[\"Mar\"]=\"03\"; months[\"Apr\"]=\"04\";\n  months[\"May\"]=\"05\"; months[\"Jun\"]=\"06\"; months[\"Jul\"]=\"07\"; months[\"Aug\"]=\"08\";\n  months[\"Sep\"]=\"09\"; months[\"Oct\"]=\"10\"; months[\"Nov\"]=\"11\"; months[\"Dec\"]=\"12\";\n}\n{\n  # Check if line matches internal API pattern\n  if ($0 ~ /\\/api\\/v[0-9]+\\/internal\\//) {\n    # Extract IP address (first field)\n    ip = $1;\n    # Skip if IP starts with \"10.\"\n    if (ip ~ /^10\\./) next;\n    # Skip health/ready endpoints (extra safety)\n    if ($0 ~ /\\/health/ || $0 ~ /\\/ready/) next;\n    \n    # Extract and convert timestamp\n    match($0, /\\[([0-9]{2})\\/([A-Za-z]{3})\\/([0-9]{4}):([0-9]{2}):([0-9]{2}):([0-9]{2})/, ts);\n    day = ts[1];\n    month = months[ts[2]];\n    year = ts[3];\n    hour = ts[4];\n    min = ts[5];\n    sec = ts[6];\n    \n    # Build ISO 8601 timestamp\n    iso_ts = year \"-\" month \"-\" day \"T\" hour\":\" min \":\" sec;\n    \n    # Replace timestamp in the line\n    sub(/\\[[^\\]]+\\]/, iso_ts);\n    print;\n  }\n}' /var/log/app/access."]
[27.148025, "i", "log > /home/user/internal_hits.log\n"]
