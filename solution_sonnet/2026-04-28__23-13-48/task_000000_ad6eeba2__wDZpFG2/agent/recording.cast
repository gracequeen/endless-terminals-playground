[35.211002, "o", "\u001b[?2004h> "]
[35.211072, "o", "            'name': name,\r\n\u001b[?2004l\r"]
[35.211095, "o", "\u001b[?2004h"]
[35.211121, "o", "> "]
[35.211185, "o", "            'serial': serial,\r\n\u001b[?2004l\r"]
[35.211227, "o", "\u001b[?2004h> "]
[35.211351, "o", "            'purchase_date': purchase_date,\r\n\u001b[?2004l\r"]
[35.211378, "o", "\u001b[?2004h> "]
[35.211493, "o", "            'price_cents': price_cents,\r\n\u001b[?2004l\r"]
[35.211528, "o", "\u001b[?2004h> "]
[35.211616, "o", "            'location': location\r\n\u001b[?2004l\r"]
[35.211645, "o", "\u001b[?2004h> "]
[35.211693, "o", "        }, None\r\n\u001b[?2004l\r"]
[35.211723, "o", "\u001b[?2004h> "]
[35.211753, "o", "        \r\n\u001b[?2004l\r"]
[35.21179, "o", "\u001b[?2004h> "]
[35.211858, "o", "    except KeyError as e:\r\n\u001b[?2004l\r"]
[35.211889, "o", "\u001b[?2004h> "]
[35.212013, "o", "        return None, f\"Missing column: {e}\"\r\n\u001b[?2004l\r"]
[35.212042, "o", "\u001b[?2004h> "]
[35.212119, "o", "    except Exception as e:\r\n\u001b[?2004l\r"]
[35.212149, "o", "\u001b[?2004h> "]
