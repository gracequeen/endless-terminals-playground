[35.20898, "o", "\u001b[?2004h> "]
[35.209127, "o", "        purchase_date = parse_date(purchase_date_raw)\r\n\u001b[?2004l\r"]
[35.209153, "o", "\u001b[?2004h> "]
[35.209256, "o", "        if not purchase_date:\r\n\u001b[?2004l\r"]
[35.209285, "o", "\u001b[?2004h> "]
[35.209502, "o", "            return None, f\"Invalid purchase_date format: {purchase_date_raw}\"\r\n\u001b[?2004l\r"]
[35.209527, "o", "\u001b[?2004h"]
[35.209556, "o", ">         \r\n"]
[35.209583, "o", "\u001b[?2004l\r\u001b[?2004h"]
[35.20961, "o", "> "]
[35.209701, "o", "        # Validate and normalize price\r\n\u001b[?2004l\r"]
[35.209731, "o", "\u001b[?2004h> "]
