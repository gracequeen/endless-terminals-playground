[35.209884, "o", "\u001b[?2004h> "]
[35.209976, "o", "        if price_cents is None:\r\n\u001b[?2004l\r"]
[35.210015, "o", "\u001b[?2004h> "]
[35.210158, "o", "            return None, f\"Invalid price: {price_raw}\"\r\n\u001b[?2004l\r"]
[35.21018, "o", "\u001b[?2004h"]
[35.210205, "o", "> "]
[35.210248, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
