[35.215893, "o", "                    existing_date = valid_assets[asset_id]['purchase_date']\r\n\u001b[?2004l\r"]
[35.215917, "o", "\u001b[?2004h"]
[35.215946, "o", "> "]
[35.216087, "o", "                    new_date = processed['purchase_date']\r\n\u001b[?2004l\r"]
[35.216116, "o", "\u001b[?2004h> "]
[35.21617, "o", "                    \r\n\u001b[?2004l\r"]
[35.216195, "o", "\u001b[?2004h> "]
[35.216351, "o", "                    if new_date > existing_date:\r\n\u001b[?2004l\r"]
[35.216381, "o", "\u001b[?2004h> "]
[35.216544, "o", "                        valid_assets[asset_id] = processed\r\n"]
[35.216574, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[35.216636, "o", "                else:\r\n\u001b[?2004l\r"]
[35.216663, "o", "\u001b[?2004h> "]
[35.216817, "o", "                    valid_assets[asset_id] = processed\r\n\u001b[?2004l\r"]
[35.21684, "o", "\u001b[?2004h"]
[35.216868, "o", ">     \r\n\u001b[?2004l\r"]
[35.216895, "o", "\u001b[?2004h> "]
[35.217, "o", "    # Convert to list and sort by id\r\n\u001b[?2004l\r"]
[35.217028, "o", "\u001b[?2004h> "]
[35.217243, "o", "    assets_list = sorted(valid_assets.values(), key=lambda x: x['id'])\r\n\u001b[?2004l\r"]
[35.217257, "o", "\u001b[?2004h"]
[35.217291, "o", ">     \r\n\u001b[?2004l\r"]
[35.217318, "o", "\u001b[?2004h"]
[35.217344, "o", "> "]
