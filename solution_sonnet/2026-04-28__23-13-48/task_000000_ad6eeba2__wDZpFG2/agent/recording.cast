[35.208425, "o", "> "]
[35.208591, "o", "        if is_serial_format(name) and not is_serial_format(serial):\r\n\u001b[?2004l\r"]
[35.208621, "o", "\u001b[?2004h"]
[35.208648, "o", "> "]
[35.208733, "o", "            name, serial = serial, name\r\n\u001b[?2004l\r"]
