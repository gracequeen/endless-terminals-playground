[35.21233, "o", "\u001b[?2004h"]
[35.212356, "o", "> \r\n\u001b[?2004l\r"]
[35.212383, "o", "\u001b[?2004h> "]
[35.212407, "o", "def main():\r\n\u001b[?2004l\r"]
[35.212429, "o", "\u001b[?2004h"]
[35.21246, "o", "> "]
[35.21258, "o", "    input_file = '/home/user/inventory/assets.csv'\r\n\u001b[?2004l\r"]
[35.212608, "o", "\u001b[?2004h> "]
[35.212757, "o", "    output_file = '/home/user/inventory/assets.json'\r\n\u001b[?2004l\r"]
[35.212787, "o", "\u001b[?2004h> "]
[35.212945, "o", "    rejected_file = '/home/user/inventory/rejected.json'\r\n\u001b[?2004l\r"]
[35.212976, "o", "\u001b[?2004h> "]
[35.213006, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[35.213034, "o", "> "]
[35.21308, "o", "    valid_assets = {}\r\n\u001b[?2004l\r"]
[35.213111, "o", "\u001b[?2004h> "]
[35.213175, "o", "    rejected_rows = []\r\n\u001b[?2004l\r"]
[35.213201, "o", "\u001b[?2004h> "]
[35.213243, "o", "    \r\n\u001b[?2004l\r"]
[35.213275, "o", "\u001b[?2004h> "]
[35.213418, "o", "    with open(input_file, 'r', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[35.213445, "o", "\u001b[?2004h> "]
[35.213547, "o", "        reader = csv.DictReader(f)\r\n\u001b[?2004l\r"]
[35.213574, "o", "\u001b[?2004h> "]
[35.213603, "o", "        \r\n\u001b[?2004l\r"]
[35.213632, "o", "\u001b[?2004h> "]
[35.213884, "o", "        for row_num, row in enumerate(reader, start=2):  # start=2 because row 1 is header\r\n\u001b[?2004l\r"]
[35.213913, "o", "\u001b[?2004h> "]
[35.214073, "o", "            processed, error = process_row(row, row_num)\r\n\u001b[?2004l\r"]
[35.214103, "o", "\u001b[?2004h> "]
[35.214138, "o", "            \r\n\u001b[?2004l\r"]
[35.214164, "o", "\u001b[?2004h> "]
[35.214244, "o", "            if error:\r\n\u001b[?2004l\r"]
[35.214267, "o", "\u001b[?2004h"]
[35.214297, "o", "> "]
[35.214387, "o", "                rejected_rows.append({\r\n\u001b[?2004l\r"]
[35.214414, "o", "\u001b[?2004h> "]
[35.21455, "o", "                    'original_row': dict(row),\r\n\u001b[?2004l\r"]
[35.21458, "o", "\u001b[?2004h> "]
[35.214682, "o", "                    'reason': error,\r\n\u001b[?2004l\r"]
[35.214706, "o", "\u001b[?2004h"]
[35.214735, "o", "> "]
[35.214829, "o", "                    'row_number': row_num\r\n\u001b[?2004l\r"]
[35.214856, "o", "\u001b[?2004h> "]
[35.214915, "o", "                })\r\n\u001b[?2004l\r"]
[35.214945, "o", "\u001b[?2004h> "]
[35.214997, "o", "            else:\r\n\u001b[?2004l\r"]
[35.215024, "o", "\u001b[?2004h> "]
[35.215148, "o", "                asset_id = processed['id']\r\n\u001b[?2004l\r"]
[35.215178, "o", "\u001b[?2004h> "]
[35.215246, "o", "                \r\n\u001b[?2004l\r"]
[35.215274, "o", "\u001b[?2004h> "]
[35.215489, "o", "                # Handle duplicates - keep the one with latest purchase_date\r\n\u001b[?2004l\r"]
[35.215518, "o", "\u001b[?2004h> "]
