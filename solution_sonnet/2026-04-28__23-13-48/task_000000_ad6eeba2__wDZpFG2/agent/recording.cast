[35.198736, "i", "cat > process_assets.py << 'EOF'\nimport csv\nimport json\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\ndef parse_date(date_str):\n    \"\"\"Parse date from multiple formats to ISO 8601\"\"\"\n    date_str = date_str.strip()\n    \n    # Try YYYY-MM-DD\n    try:\n        dt = datetime.strptime(date_str, '%Y-%m-%d')\n        return dt.strftime('%Y-%m-%d')\n    except ValueError:\n        pass\n    \n    # Try MM/DD/YYYY\n    try:\n        dt = datetime.strptime(date_str, '%m/%d/%Y')\n        return dt.strftime('%Y-%m-%d')\n    except ValueError:\n        pass\n    \n    # Try DD.MM.YYYY\n    try:\n        dt = datetime.strptime(date_str, '%d.%m.%Y')\n        return dt.strftime('%Y-%m-%d')\n    except ValueError:\n        pass\n    \n    return None\n\ndef parse_price(price_str):\n    \"\"\"Parse price and convert to cents (integer)\"\"\"\n    try:\n        # Remove dollar signs, commas, and whitespace\n        cleaned = price_str.strip().replace('$', '').replace(',', '')\n        \n        # Convert to float then to cents\n   "]
[35.198874, "i", "     price_float = float(cleaned)\n        \n        # Must be positive\n        if price_float <= 0:\n            return None\n        \n        # Convert to cents (round to avoid floating point issues)\n        price_cents = int(round(price_float * 100))\n        \n        return price_cents\n    except (ValueError, AttributeError):\n        return None\n\ndef is_serial_format(text):\n    \"\"\"Check if text looks like a serial number (starts with SN-)\"\"\"\n    return text.strip().startswith('SN-')\n\ndef process_row(row, row_num):\n    \"\"\"Process a single row and return normalized data or error\"\"\"\n    try:\n        asset_id = row['id'].strip()\n        name = row['name'].strip()\n        serial = row['serial'].strip()\n        purchase_date_raw = row['purchase_date'].strip()\n        price_raw = row['price'].strip()\n        location = row['location'].strip()\n        \n        # Check for swapped name and serial\n        if is_serial_format(name) and not is_serial_format(serial):\n            name, serial = serial, name\n        \n       "]
[35.198917, "o", "cat > process_assets.py << 'EOF'\r\n\u001b[?2004l\r"]
[35.198952, "i", " # Validate and normalize purchase_date\n        purchase_date = parse_date(purchase_date_raw)\n        if not purchase_date:\n            return None, f\"Invalid purchase_date format: {purchase_date_raw}\"\n        \n        # Validate and normalize price\n        price_cents = parse_price(price_raw)\n        if price_cents is None:\n            return None, f\"Invalid price: {price_raw}\"\n        \n        # Basic validation\n        if not asset_id or not name or not serial or not location:\n            return None, \"Missing required fields\"\n        \n        return {\n            'id': asset_id,\n            'name': name,\n            'serial': serial,\n            'purchase_date': purchase_date,\n            'price_cents': price_cents,\n            'location': location\n        }, None\n        \n    except KeyError as e:\n        return None, f\"Missing column: {e}\"\n    except Exception as e:\n        return None, f\"Processing error: {str(e)}\"\n\ndef main():\n    input_file = '/home/user/inventory/assets.csv'\n    output_file = '/home"]
[35.198973, "o", "\u001b[?2004h> "]
[35.199015, "i", "/user/inventory/assets.json'\n    rejected_file = '/home/user/inventory/rejected.json'\n    \n    valid_assets = {}\n    rejected_rows = []\n    \n    with open(input_file, 'r', encoding='utf-8') as f:\n        reader = csv.DictReader(f)\n        \n        for row_num, row in enumerate(reader, start=2):  # start=2 because row 1 is header\n            processed, error = process_row(row, row_num)\n            \n            if error:\n                rejected_rows.append({\n                    'original_row': dict(row),\n                    'reason': error,\n                    'row_number': row_num\n                })\n            else:\n                asset_id = processed['id']\n                \n                # Handle duplicates - keep the one with latest purchase_date\n                if asset_id in valid_assets:\n                    existing_date = valid_assets[asset_id]['purchase_date']\n                    new_date = processed['purchase_date']\n                    \n                    if new_date > existing_date:\n             "]
[35.199041, "o", "import csv\r\n\u001b[?2004l\r\u001b[?2004h> "]
[35.199072, "i", "           valid_assets[asset_id] = processed\n                else:\n                    valid_assets[asset_id] = processed\n    \n    # Convert to list and sort by id\n    assets_list = sorted(valid_assets.values(), key=lambda x: x['id'])\n    \n    # Write output files\n    with open(output_file, 'w', encoding='utf-8') as f:\n        json.dump(assets_list, f, indent=2)\n    \n    with open(rejected_file, 'w', encoding='utf-8') as f:\n        json.dump(rejected_rows, f, indent=2)\n    \n    print(f\"Processing complete:\")\n    print(f\"  Valid assets: {len(assets_list)}\")\n    print(f\"  Rejected rows: {len(rejected_rows)}\")\n    print(f\"  Output: {output_file}\")\n    print(f\"  Rejected: {rejected_file}\")\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
