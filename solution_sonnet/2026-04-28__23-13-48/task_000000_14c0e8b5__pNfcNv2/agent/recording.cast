[86.970921, "i", "cat > check.py << 'EOF'\n#!/usr/bin/env python3\nimport json\nimport csv\nimport ipaddress\nimport sys\n\ndef parse_port_spec(port_spec):\n    \"\"\"Parse port specification into a set of allowed ports.\"\"\"\n    port_spec = str(port_spec)\n    if '-' in port_spec:\n        start, end = port_spec.split('-')\n        return set(range(int(start), int(end) + 1))\n    else:\n        return {int(port_spec)}\n\ndef load_firewall_rules(json_path):\n    \"\"\"Load and parse firewall rules, sorted by CIDR specificity.\"\"\"\n    with open(json_path, 'r') as f:\n        data = json.load(f)\n    \n    rules = []\n    for rule in data['rules']:\n        network = ipaddress.ip_network(rule['source_cidr'])\n        allowed_ports = parse_port_spec(rule['dest_port'])\n        rules.append({\n            'network': network,\n            'prefix_len': network.prefixlen,\n            'action': rule['action'],\n            'allowed_ports': allowed_ports,\n            'source_cidr': rule['source_cidr']\n        })\n    \n    # Sort by prefix length (most specific first)\n  "]
[86.971067, "i", "  rules.sort(key=lambda r: r['prefix_len'], reverse=True)\n    return rules, data.get('default_action', 'deny')\n\ndef check_connection(src_ip, dest_port, rules, default_action):\n    \"\"\"Check if a connection is allowed by firewall rules.\"\"\"\n    src_ip_obj = ipaddress.ip_address(src_ip)\n    dest_port_int = int(dest_port)\n    \n    # Find the most specific matching rule\n    for rule in rules:\n        if src_ip_obj in rule['network']:\n            # Check if port is allowed\n            if dest_port_int in rule['allowed_ports']:\n                if rule['action'] == 'allow':\n                    return True, None\n                else:  # explicit deny\n                    return False, rule['source_cidr']\n            # If port doesn't match, continue to less specific rules\n    \n    # No matching rule found, apply default action\n    return False, None\n\ndef main():\n    rules, default_action = load_firewall_rules('/home/user/audit/firewall_rules.json')\n    \n    with open('/home/user/audit/connections.csv', 'r') as f:\n      "]
[86.971119, "o", "cat > check.py << 'EOF'\r\n\u001b[?2004l\r"]
[86.971171, "i", "  reader = csv.DictReader(f)\n        for row in reader:\n            src_ip = row['src_ip']\n            dest_port = row['dest_port']\n            \n            allowed, matching_cidr = check_connection(src_ip, dest_port, rules, default_action)\n            \n            if not allowed:\n                if matching_cidr:\n                    print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from {matching_cidr}\")\n                else:\n                    # Find the broadest matching CIDR for reporting\n                    src_ip_obj = ipaddress.ip_address(src_ip)\n                    matching_cidr = None\n                    for rule in reversed(rules):  # Check from least to most specific\n                        if src_ip_obj in rule['network']:\n                            matching_cidr = rule['source_cidr']\n                            break\n                    \n                    if matching_cidr:\n                        print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from {matching_cidr}\")\n                    else"]
