[50.017112, "i", "python3 << 'PYEOF'\nimport pytz\nfrom datetime import datetime\n\n# The problematic meeting time: 2024-03-31T01:30:00 UTC\n# This is during the DST transition in Europe/Berlin\nutc_time_str = \"2024-03-31T01:30:00\"\nBERLIN_TZ = pytz.timezone('Europe/Berlin')\nUTC_TZ = pytz.utc\n\n# OLD (BUGGY) METHOD\nprint(\"OLD (BUGGY) METHOD:\")\nutc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\nberlin_dt_wrong = BERLIN_TZ.localize(utc_dt)\nprint(f\"  Parsed: {utc_dt} (naive)\")\nprint(f\"  Result: {berlin_dt_wrong.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\nprint(f\"  This treats 01:30 as if it's already Berlin time!\\n\")\n\n# NEW (CORRECT) METHOD\nprint(\"NEW (CORRECT) METHOD:\")\nutc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\nutc_dt_aware = UTC_TZ.localize(utc_dt)\nberlin_dt_correct = utc_dt_aware.astimezone(BERLIN_TZ)\nprint(f\"  Parsed: {utc_dt} (naive)\")\nprint(f\"  As UTC: {utc_dt_aware.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\nprint(f\"  Result: {berlin_dt_correct.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\nprint(f\"  Correctly converts 0"]
[50.017231, "i", "1:30 UTC to Berlin time!\\n\")\n\nprint(f\"Difference: {(berlin_dt_wrong.hour - berlin_dt_correct.hour)} hour(s)\")\nPYEOF\n"]
[50.017266, "o", "python3 << 'PYEOF'\r\n\u001b[?2004l\r1:30 UTC to Berlin time!\\n\")\r\n\r\nprint(f\"Difference: {(berlin_dt_wrong.hour - berlin_dt_correct.hour)} hour(s)\")\r\nPYEOF\r\n"]
