[88.976696, "o", "grep -A 8 'def convert_to_berlin' app.py\r\n\u001b[?2004l\r"]
[88.977898, "o", "\u001b[01;31m\u001b[Kdef convert_to_berlin\u001b[m\u001b[K(utc_time_str):\r\n    \"\"\"\r\n    Convert UTC time string to Berlin timezone.\r\n    \"\"\"\r\n    # Parse the UTC time string\r\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\r\n\r\n"]
[88.977918, "o", "    # First localize as UTC, then convert to Berlin time\r\n    utc_dt_aware = UTC_TZ.localize(utc_dt)\r\n"]
[88.978113, "o", "\u001b[?2004h"]
[88.978127, "o", "user@e88682a67d3d:~/scheduler$ "]
[93.482738, "i", "grep -A 10 'def convert_to_berlin' app.py\n"]
[93.48291, "o", "grep -A 10 'def convert_to_berlin' app.py\r\n\u001b[?2004l\r"]
[93.484037, "o", "\u001b[01;31m\u001b[Kdef convert_to_berlin\u001b[m\u001b[K(utc_time_str):\r\n    \"\"\"\r\n    Convert UTC time string to Berlin timezone.\r\n    \"\"\"\r\n    # Parse the UTC time string\r\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\r\n"]
[93.484087, "o", "\r\n    # First localize as UTC, then convert to Berlin time\r\n    utc_dt_aware = UTC_TZ.localize(utc_dt)\r\n    berlin_dt = utc_dt_aware.astimezone(BERLIN_TZ)\r\n\r\n"]
