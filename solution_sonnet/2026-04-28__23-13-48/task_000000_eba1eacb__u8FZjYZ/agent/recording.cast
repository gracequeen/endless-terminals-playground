[79.106393, "i", "cat > Makefile << 'EOF'\n.PHONY: report clean check-config\n\n# Main target to generate the monitoring report\nreport: check-config results/status.json\n\t@echo \"Monitoring report complete: results/status.json\"\n\n# Check if hosts.conf exists before proceeding\ncheck-config:\n\t@if [ ! -f hosts.conf ]; then \\\n\t\techo \"ERROR: hosts.conf is missing. Cannot proceed with monitoring checks.\"; \\\n\t\texit 1; \\\n\tfi\n\n# Create results directory if needed\nresults:\n\t@mkdir -p results\n\n# Run ping checks\nresults/ping.txt: check-config results\n\t@echo \"Running ping checks...\"\n\t@bash scripts/check_ping.sh\n\n# Run port checks\nresults/ports.txt: check-config results\n\t@echo \"Running port checks...\"\n\t@bash scripts/check_ports.sh\n\n# Generate aggregated JSON report\nresults/status.json: results/ping.txt results/ports.txt\n\t@echo \"Aggregating results...\"\n\t@python3 aggregate.py\n\n# Clean up generated files\nclean:\n\t@rm -rf results\n\t@echo \"Cleaned up results directory\"\nEOF\n"]
