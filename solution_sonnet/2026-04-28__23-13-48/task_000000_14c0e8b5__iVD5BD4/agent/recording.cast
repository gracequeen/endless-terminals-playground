[49.997779, "i", "cat > test_check.py << 'EOF'\n#!/usr/bin/env python3\nimport json\nimport csv\nimport ipaddress\n\ndef parse_port_spec(port_spec):\n    if '-' in port_spec:\n        start, end = port_spec.split('-')\n        return (int(start), int(end))\n    else:\n        port = int(port_spec)\n        return (port, port)\n\ndef port_in_range(port, port_spec):\n    start, end = parse_port_spec(port_spec)\n    return start <= port <= end\n\ndef find_matching_rules(src_ip, dest_port, rules):\n    matching = []\n    ip_obj = ipaddress.ip_address(src_ip)\n    \n    for rule in rules:\n        network = ipaddress.ip_network(rule['source_cidr'])\n        if ip_obj in network and port_in_range(dest_port, rule['dest_port']):\n            matching.append((rule, network.prefixlen))\n    \n    return matching\n\ndef is_connection_allowed(src_ip, dest_port, rules):\n    matching = find_matching_rules(src_ip, dest_port, rules)\n    \n    if not matching:\n        return (False, None)\n    \n    matching.sort(key=lambda x: x[1], reverse=True)\n    most_specific_rule = mat"]
[49.997912, "i", "ching[0][0]\n    \n    if most_specific_rule['action'] == 'allow':\n        return (True, most_specific_rule)\n    else:\n        return (False, most_specific_rule)\n\nwith open('/home/user/audit/firewall_rules.json', 'r') as f:\n    config = json.load(f)\n    rules = config['rules']\n\nwith open('/home/user/audit/connections.csv', 'r') as f:\n    reader = csv.DictReader(f)\n    connections = list(reader)\n\nfor conn in connections:\n    src_ip = conn['src_ip']\n    dest_port = int(conn['dest_port'])\n    \n    allowed, matching_rule = is_connection_allowed(src_ip, dest_port, rules)\n    \n    if allowed:\n        print(f\"ALLOWED: {src_ip}:{dest_port} by rule {matching_rule['id']} ({matching_rule['source_cidr']})\")\n    else:\n        if matching_rule:\n            print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from {matching_rule['source_cidr']}\")\n        else:\n            print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from any rule\")\nEOF\n"]
