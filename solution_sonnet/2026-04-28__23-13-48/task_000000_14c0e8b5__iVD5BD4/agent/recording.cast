[26.249989, "i", "cat > check.py << 'EOF'\n#!/usr/bin/env python3\nimport json\nimport csv\nimport ipaddress\nimport sys\n\ndef parse_port_spec(port_spec):\n    \"\"\"Parse port specification - either single port or range.\"\"\"\n    if '-' in port_spec:\n        start, end = port_spec.split('-')\n        return (int(start), int(end))\n    else:\n        port = int(port_spec)\n        return (port, port)\n\ndef port_in_range(port, port_spec):\n    \"\"\"Check if port falls within the port specification.\"\"\"\n    start, end = parse_port_spec(port_spec)\n    return start <= port <= end\n\ndef find_matching_rules(src_ip, dest_port, rules):\n    \"\"\"Find all rules that match the source IP and destination port.\n    Returns list of (rule, prefix_length) tuples.\"\"\"\n    matching = []\n    ip_obj = ipaddress.ip_address(src_ip)\n    \n    for rule in rules:\n        network = ipaddress.ip_network(rule['source_cidr'])\n        if ip_obj in network and port_in_range(dest_port, rule['dest_port']):\n            matching.append((rule, network.prefixlen))\n    \n    return matching\n"]
[26.250044, "i", "\ndef is_connection_allowed(src_ip, dest_port, rules):\n    \"\"\"Check if a connection is allowed based on firewall rules.\n    Returns (allowed, matching_rule) tuple.\"\"\"\n    matching = find_matching_rules(src_ip, dest_port, rules)\n    \n    if not matching:\n        # No matching rule - default deny\n        return (False, None)\n    \n    # Sort by prefix length (most specific first)\n    matching.sort(key=lambda x: x[1], reverse=True)\n    \n    # Use the most specific rule\n    most_specific_rule = matching[0][0]\n    \n    if most_specific_rule['action'] == 'allow':\n        return (True, most_specific_rule)\n    else:\n        return (False, most_specific_rule)\n\ndef main():\n    # Load firewall rules\n    with open('/home/user/audit/firewall_rules.json', 'r') as f:\n        config = json.load(f)\n        rules = config['rules']\n    \n    # Load connections\n    with open('/home/user/audit/connections.csv', 'r') as f:\n        reader = csv.DictReader(f)\n        connections = list(reader)\n    \n    # Check each connection\n    for c"]
[26.250143, "i", "onn in connections:\n        src_ip = conn['src_ip']\n        dest_port = int(conn['dest_port'])\n        \n        allowed, matching_rule = is_connection_allowed(src_ip, dest_port, rules)\n        \n        if not allowed:\n            if matching_rule:\n                # Explicitly denied\n                print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from {matching_rule['source_cidr']}\")\n            else:\n                # No matching rule - find the least specific CIDR that could have matched\n                # For reporting purposes, we'll say \"no matching rule\"\n                print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from any rule\")\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
