[25.024404, "i", "cat scripts/check_ping.sh\n"]
[25.024542, "o", "cat scripts/check_ping.sh\r\n"]
[25.024606, "o", "\u001b[?2004l\r"]
[25.02542, "o", "#!/bin/bash\r\nmkdir -p results\r\nwhile read -r host; do\r\n    if ping -c 1 -W 1 \"$host\" &>/dev/null; then\r\n        echo \"$host: up\"\r\n    else\r\n        echo \"$host: down\"\r\n    fi\r\ndone < hosts.conf > results/ping.txt\r\n"]
[25.025592, "o", "\u001b[?2004h"]
[25.025628, "o", "root@bf5826512405:/home/user/netmon# "]
[25.125198, "i", "cat scripts/check_ports.sh\n"]
[25.125315, "o", "cat scripts/check_ports.sh\r\n\u001b[?2004l\r"]
[25.126187, "o", "#!/bin/bash\r\nmkdir -p results\r\nwhile read -r host; do\r\n    for port in 22 80 443; do\r\n        timeout 1 bash -c \"echo >/dev/tcp/$host/$port\" 2>/dev/null && status=\"open\" || status=\"closed\"\r\n        echo \"$host:$port $status\"\r\n    done\r\ndone < hosts.conf > results/ports.txt\r\n"]
[25.126333, "o", "\u001b[?2004h"]
[25.126367, "o", "root@bf5826512405:/home/user/netmon# "]
[34.05771, "i", "cat > Makefile << 'EOF'\n.PHONY: report clean\n\n# Main target to generate the monitoring report\nreport: results/status.json\n\t@echo \"Monitoring report complete: results/status.json\"\n\n# Check if hosts.conf exists before doing anything\nresults/ping.txt: hosts.conf\n\t@test -f hosts.conf || (echo \"ERROR: hosts.conf is missing!\" && exit 1)\n\t@echo \"Running ping checks...\"\n\t@./scripts/check_ping.sh\n\nresults/ports.txt: hosts.conf\n\t@test -f hosts.conf || (echo \"ERROR: hosts.conf is missing!\" && exit 1)\n\t@echo \"Running port checks...\"\n\t@./scripts/check_ports.sh\n\n# Aggregate results into JSON report\nresults/status.json: results/ping.txt results/ports.txt aggregate.py\n\t@echo \"Aggregating results...\"\n\t@python3 aggregate.py\n\n# Clean up generated files\nclean:\n\t@echo \"Cleaning up results...\"\n\t@rm -rf results/\nEOF\n"]
