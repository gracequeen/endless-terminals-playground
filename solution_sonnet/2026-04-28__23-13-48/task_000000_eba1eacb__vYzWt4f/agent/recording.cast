[118.135193, "o", "{\r\n  \"hosts\": {\r\n    \"192.168.1.1\": {\r\n      \"ping\": \"down\",\r\n      \"ports\": {\r\n        \"22\": \"closed\",\r\n        \"80\": \"closed\",\r\n        \"443\": \"closed\"\r\n      }\r\n    },\r\n    \"192.168.1.2\": {\r\n      \"ping\": \"down\",\r\n      \"ports\": {\r\n        \"22\": \"closed\",\r\n        \"80\": \"closed\",\r\n        \"443\": \"closed\"\r\n      }\r\n    },\r\n    \"10.0.0.1\": {\r\n      \"ping\": \"down\",\r\n      \"ports\": {\r\n        \"22\": \"closed\",\r\n        \"80\": \"closed\",\r\n        \"443\": \"closed\"\r\n      }\r\n    }\r\n  }\r\n}"]
