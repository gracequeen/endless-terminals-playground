[37.862661, "i", "cat > /home/user/inventory/process_assets.py << 'EOF'\nimport csv\nimport json\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\ndef parse_date(date_str):\n    \"\"\"Parse date from multiple formats and return ISO 8601 string.\"\"\"\n    date_str = date_str.strip()\n    \n    # Try different date formats\n    formats = [\n        '%Y-%m-%d',      # ISO format: 2021-03-22\n        '%m/%d/%Y',      # US format: 02/12/2017\n        '%d.%m.%Y',      # European format: 17.07.2016\n    ]\n    \n    for fmt in formats:\n        try:\n            dt = datetime.strptime(date_str, fmt)\n            return dt.date().isoformat()\n        except ValueError:\n            continue\n    \n    return None\n\ndef parse_price(price_str):\n    \"\"\"Parse price and convert to cents (integer).\"\"\"\n    try:\n        # Remove dollar signs, commas, and whitespace\n        cleaned = price_str.strip().replace('$', '').replace(',', '')\n        \n        # Convert to float first, then to cents\n        price_float = float(cleaned)\n        \n      "]
[37.862785, "i", "  # Check if positive\n        if price_float <= 0:\n            return None\n        \n        # Convert to cents\n        price_cents = int(round(price_float * 100))\n        return price_cents\n    except (ValueError, AttributeError):\n        return None\n\ndef is_serial_number(s):\n    \"\"\"Check if a string looks like a serial number.\"\"\"\n    return bool(re.match(r'^SN-[A-Z]+-\\d+$', s.strip()))\n\ndef process_row(row, row_num):\n    \"\"\"Process a single row and return (record, error) tuple.\"\"\"\n    try:\n        asset_id = row.get('id', '').strip()\n        name = row.get('name', '').strip()\n        serial = row.get('serial', '').strip()\n        purchase_date_raw = row.get('purchase_date', '').strip()\n        price_raw = row.get('price', '').strip()\n        location = row.get('location', '').strip()\n        \n        # Check for swapped name and serial\n        if is_serial_number(name) and not is_serial_number(serial):\n            name, serial = serial, name\n        \n        # Validate required fields\n        if not asset_id"]
[37.86282, "i", ":\n            return None, \"Missing asset ID\"\n        \n        if not name:\n            return None, \"Missing name\"\n        \n        if not serial:\n            return None, \"Missing serial number\"\n        \n        if not is_serial_number(serial):\n            return None, f\"Invalid serial number format: {serial}\"\n        \n        # Parse date\n        purchase_date = parse_date(purchase_date_raw)\n        if not purchase_date:\n            return None, f\"Invalid date format: {purchase_date_raw}\"\n        \n        # Parse price\n        price_cents = parse_price(price_raw)\n        if price_cents is None:\n            return None, f\"Invalid or non-positive price: {price_raw}\"\n        \n        if not location:\n            return None, \"Missing location\"\n        \n        record = {\n            'id': asset_id,\n            'name': name,\n            'serial': serial,\n            'purchase_date': purchase_date,\n            'price_cents': price_cents,\n            'location': location\n        }\n        \n        return record,"]
[37.862854, "i", " None\n        \n    except Exception as e:\n        return None, f\"Processing error: {str(e)}\"\n\ndef main():\n    input_file = '/home/user/inventory/assets.csv'\n    output_file = '/home/user/inventory/assets.json'\n    rejected_file = '/home/user/inventory/rejected.json'\n    \n    # Store records by ID to handle duplicates\n    records_by_id = {}\n    rejected = []\n    \n    with open(input_file, 'r', encoding='utf-8') as f:\n        reader = csv.DictReader(f)\n        \n        for row_num, row in enumerate(reader, start=2):  # Start at 2 (header is row 1)\n            record, error = process_row(row, row_num)\n            \n            if error:\n                rejected.append({\n                    'original_row': dict(row),\n                    'reason': error,\n                    'row_number': row_num\n                })\n            else:\n                asset_id = record['id']\n                \n                # Handle duplicates: keep the one with the latest purchase date\n                if asset_id in records_by_id:\n   "]
[37.862885, "i", "                 existing = records_by_id[asset_id]\n                    if record['purchase_date'] > existing['purchase_date']:\n                        records_by_id[asset_id] = record\n                else:\n                    records_by_id[asset_id] = record\n    \n    # Convert to list and sort by ID for consistency\n    valid_records = sorted(records_by_id.values(), key=lambda x: x['id'])\n    \n    # Write output files\n    with open(output_file, 'w', encoding='utf-8') as f:\n        json.dump(valid_records, f, indent=2)\n    \n    with open(rejected_file, 'w', encoding='utf-8') as f:\n        json.dump(rejected, f, indent=2)\n    \n    print(f\"Processed {len(valid_records)} valid records\")\n    print(f\"Rejected {len(rejected)} invalid records\")\n    print(f\"Output written to {output_file}\")\n    print(f\"Rejected records written to {rejected_file}\")\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
