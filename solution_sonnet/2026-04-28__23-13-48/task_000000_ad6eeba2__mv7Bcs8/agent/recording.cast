[37.869748, "o", "\u001b[?2004h> "]
[37.869929, "o", "    \"\"\"Process a single row and return (record, error) tuple.\"\"\"\r\n\u001b[?2004l\r"]
[37.869954, "o", "\u001b[?2004h"]
[37.869981, "o", "> "]
[37.870008, "o", "    try:\r\n\u001b[?2004l\r\u001b[?2004h"]
[37.870036, "o", "> "]
[37.870142, "o", "        asset_id = row.get('id', '').strip()\r\n\u001b[?2004l\r"]
[37.870171, "o", "\u001b[?2004h"]
[37.870199, "o", "> "]
[37.87029, "o", "        name = row.get('name', '').strip()\r\n\u001b[?2004l\r"]
[37.870317, "o", "\u001b[?2004h> "]
[37.870448, "o", "        serial = row.get('serial', '').strip()\r\n\u001b[?2004l\r"]
[37.870471, "o", "\u001b[?2004h"]
[37.870499, "o", "> "]
[37.870658, "o", "        purchase_date_raw = row.get('purchase_date', '').strip()\r\n\u001b[?2004l\r"]
[37.870681, "o", "\u001b[?2004h"]
[37.87071, "o", "> "]
[37.870835, "o", "        price_raw = row.get('price', '').strip()\r\n\u001b[?2004l\r"]
[37.870861, "o", "\u001b[?2004h"]
[37.870889, "o", "> "]
[37.87101, "o", "        location = row.get('location', '').strip()\r\n\u001b[?2004l\r"]
[37.871041, "o", "\u001b[?2004h> "]
[37.871069, "o", "        \r\n\u001b[?2004l\r"]
[37.871099, "o", "\u001b[?2004h> "]
[37.871209, "o", "        # Check for swapped name and serial\r\n\u001b[?2004l\r"]
[37.871234, "o", "\u001b[?2004h"]
[37.871252, "o", "> "]
[37.871425, "o", "        if is_serial_number(name) and not is_serial_number(serial):\r\n\u001b[?2004l\r"]
[37.871456, "o", "\u001b[?2004h> "]
[37.871568, "o", "            name, serial = serial, name\r\n\u001b[?2004l\r"]
[37.871596, "o", "\u001b[?2004h> "]
[37.871627, "o", "        \r\n\u001b[?2004l\r"]
[37.871658, "o", "\u001b[?2004h> "]
[37.871764, "o", "        # Validate required fields\r\n\u001b[?2004l\r"]
[37.871789, "o", "\u001b[?2004h> "]
[37.871864, "o", "        if not asset_id:\r\n\u001b[?2004l\r"]
[37.871893, "o", "\u001b[?2004h"]
[37.871921, "o", "> "]
[37.872015, "o", "            return None, \"Missing asset ID\"\r\n\u001b[?2004l\r"]
[37.872045, "o", "\u001b[?2004h> "]
[37.872073, "o", "        \r\n\u001b[?2004l\r"]
[37.872104, "o", "\u001b[?2004h> "]
[37.872161, "o", "        if not name:\r\n\u001b[?2004l\r"]
[37.872187, "o", "\u001b[?2004h> "]
[37.872311, "o", "            return None, \"Missing name\"\r\n\u001b[?2004l\r"]
[37.872334, "o", "\u001b[?2004h"]
[37.872363, "o", "> "]
[37.872392, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[37.87242, "o", "> "]
[37.872465, "o", "        if not serial:\r\n\u001b[?2004l\r"]
[37.872494, "o", "\u001b[?2004h> "]
[37.872629, "o", "            return None, \"Missing serial number\"\r\n\u001b[?2004l\r"]
[37.872664, "o", "\u001b[?2004h> "]
[37.872691, "o", "        \r\n\u001b[?2004l\r"]
[37.872716, "o", "\u001b[?2004h> "]
[37.87284, "o", "        if not is_serial_number(serial):\r\n\u001b[?2004l\r"]
[37.872861, "o", "\u001b[?2004h"]
[37.872888, "o", "> "]
[37.873054, "o", "            return None, f\"Invalid serial number format: {serial}\"\r\n\u001b[?2004l\r"]
[37.873084, "o", "\u001b[?2004h> "]
[37.873114, "o", "        \r\n\u001b[?2004l\r"]
[37.873143, "o", "\u001b[?2004h> "]
[37.8732, "o", "        # Parse date\r\n\u001b[?2004l\r"]
[37.87323, "o", "\u001b[?2004h> "]
[37.873378, "o", "        purchase_date = parse_date(purchase_date_raw)\r\n\u001b[?2004l\r"]
[37.873401, "o", "\u001b[?2004h"]
[37.87343, "o", "> "]
[37.873494, "o", "        if not purchase_date:\r\n\u001b[?2004l\r"]
[37.873522, "o", "\u001b[?2004h> "]
[37.873713, "o", "            return None, f\"Invalid date format: {purchase_date_raw}\"\r\n\u001b[?2004l\r"]
[37.873752, "o", "\u001b[?2004h> "]
[37.873781, "o", "        \r\n\u001b[?2004l\r"]
[37.87381, "o", "\u001b[?2004h> "]
[37.873874, "o", "        # Parse price\r\n\u001b[?2004l\r"]
[37.873902, "o", "\u001b[?2004h> "]
[37.874027, "o", "        price_cents = parse_price(price_raw)\r\n\u001b[?2004l\r"]
[37.874063, "o", "\u001b[?2004h"]
[37.874089, "o", "> "]
[37.874145, "o", "        if price_cents is None:\r\n\u001b[?2004l\r"]
[37.874174, "o", "\u001b[?2004h> "]
[37.874369, "o", "            return None, f\"Invalid or non-positive price: {price_raw}\"\r\n\u001b[?2004l\r"]
[37.874396, "o", "\u001b[?2004h> "]
[37.874426, "o", "        \r\n\u001b[?2004l\r"]
[37.874453, "o", "\u001b[?2004h> "]
[37.874524, "o", "        if not location:\r\n\u001b[?2004l\r"]
[37.874554, "o", "\u001b[?2004h> "]
[37.874676, "o", "            return None, \"Missing location\"\r\n\u001b[?2004l\r"]
[37.874703, "o", "\u001b[?2004h> "]
[37.874733, "o", "        \r\n\u001b[?2004l\r"]
[37.874766, "o", "\u001b[?2004h"]
[37.874795, "o", "> "]
[37.874831, "o", "        record = {\r\n\u001b[?2004l\r"]
[37.87486, "o", "\u001b[?2004h> "]
[37.87494, "o", "            'id': asset_id,\r\n\u001b[?2004l\r"]
[37.874967, "o", "\u001b[?2004h> "]
[37.875043, "o", "            'name': name,\r\n\u001b[?2004l\r"]
[37.875068, "o", "\u001b[?2004h> "]
[37.875156, "o", "            'serial': serial,\r\n\u001b[?2004l\r"]
[37.875182, "o", "\u001b[?2004h> "]
[37.875307, "o", "            'purchase_date': purchase_date,\r\n\u001b[?2004l\r"]
[37.875329, "o", "\u001b[?2004h"]
[37.875356, "o", "> "]
[37.875448, "o", "            'price_cents': price_cents,\r\n\u001b[?2004l\r"]
[37.875483, "o", "\u001b[?2004h> "]
[37.875571, "o", "            'location': location\r\n\u001b[?2004l\r"]
[37.8756, "o", "\u001b[?2004h> "]
[37.875633, "o", "        }\r\n\u001b[?2004l\r"]
[37.87566, "o", "\u001b[?2004h> "]
[37.875688, "o", "        \r\n"]
[37.875716, "o", "\u001b[?2004l\r\u001b[?2004h"]
[37.875757, "o", "> "]
[37.87581, "o", "        return record, None\r\n\u001b[?2004l\r"]
[37.875838, "o", "\u001b[?2004h> "]
[37.875869, "o", "        \r\n\u001b[?2004l\r"]
[37.875896, "o", "\u001b[?2004h> "]
[37.875975, "o", "    except Exception as e:\r\n\u001b[?2004l\r"]
[37.876001, "o", "\u001b[?2004h> "]
[37.876144, "o", "        return None, f\"Processing error: {str(e)}\"\r\n\u001b[?2004l\r"]
[37.876169, "o", "\u001b[?2004h"]
[37.876196, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[37.876225, "o", "> "]
[37.876252, "o", "def main():\r\n\u001b[?2004l\r"]
[37.876281, "o", "\u001b[?2004h> "]
[37.876419, "o", "    input_file = '/home/user/inventory/assets.csv'\r\n\u001b[?2004l\r"]
[37.876448, "o", "\u001b[?2004h> "]
[37.876596, "o", "    output_file = '/home/user/inventory/assets.json'\r\n\u001b[?2004l\r"]
[37.876625, "o", "\u001b[?2004h> "]
[37.876795, "o", "    rejected_file = '/home/user/inventory/rejected.json'\r\n\u001b[?2004l\r"]
[37.876824, "o", "\u001b[?2004h> "]
[37.876851, "o", "    \r\n\u001b[?2004l\r"]
[37.87688, "o", "\u001b[?2004h> "]
[37.876998, "o", "    # Store records by ID to handle duplicates\r\n\u001b[?2004l\r"]
[37.877025, "o", "\u001b[?2004h> "]
[37.877092, "o", "    records_by_id = {}\r\n\u001b[?2004l\r"]
[37.877119, "o", "\u001b[?2004h> "]
[37.877173, "o", "    rejected = []\r\n\u001b[?2004l\r"]
[37.877208, "o", "\u001b[?2004h> "]
[37.877238, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[37.877267, "o", "> "]
[37.877401, "o", "    with open(input_file, 'r', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[37.87743, "o", "\u001b[?2004h> "]
[37.87753, "o", "        reader = csv.DictReader(f)\r\n\u001b[?2004l\r"]
[37.877551, "o", "\u001b[?2004h"]
[37.877576, "o", "> "]
[37.877601, "o", "        \r\n\u001b[?2004l\r"]
[37.87763, "o", "\u001b[?2004h> "]
[37.877868, "o", "        for row_num, row in enumerate(reader, start=2):  # Start at 2 (header is row 1)\r\n\u001b[?2004l\r"]
[37.877894, "o", "\u001b[?2004h"]
[37.877906, "o", "> "]
[37.878046, "o", "            record, error = process_row(row, row_num)\r\n\u001b[?2004l\r"]
[37.878075, "o", "\u001b[?2004h> "]
[37.878114, "o", "            \r\n\u001b[?2004l\r"]
[37.878142, "o", "\u001b[?2004h> "]
[37.878205, "o", "            if error:\r\n\u001b[?2004l\r"]
[37.878233, "o", "\u001b[?2004h> "]
[37.878329, "o", "                rejected.append({\r\n\u001b[?2004l\r"]
[37.878354, "o", "\u001b[?2004h"]
[37.87838, "o", "> "]
[37.878494, "o", "                    'original_row': dict(row),\r\n\u001b[?2004l\r"]
[37.878521, "o", "\u001b[?2004h> "]
[37.878629, "o", "                    'reason': error,\r\n\u001b[?2004l\r"]
[37.878657, "o", "\u001b[?2004h> "]
[37.878787, "o", "                    'row_number': row_num\r\n\u001b[?2004l\r"]
[37.878815, "o", "\u001b[?2004h> "]
[37.878872, "o", "                })\r\n\u001b[?2004l\r"]
[37.878893, "o", "\u001b[?2004h"]
[37.87892, "o", "> "]
[37.878951, "o", "            else:\r\n\u001b[?2004l\r"]
[37.878976, "o", "\u001b[?2004h> "]
[37.879091, "o", "                asset_id = record['id']\r\n\u001b[?2004l\r"]
[37.879118, "o", "\u001b[?2004h> "]
[37.879169, "o", "                \r\n\u001b[?2004l\r"]
[37.879194, "o", "\u001b[?2004h> "]
[37.879416, "o", "                # Handle duplicates: keep the one with the latest purchase date\r\n\u001b[?2004l\r"]
[37.879444, "o", "\u001b[?2004h> "]
[37.879571, "o", "                if asset_id in records_by_id:\r\n\u001b[?2004l\r"]
[37.879607, "o", "\u001b[?2004h> "]
[37.879762, "o", "                    existing = records_by_id[asset_id]\r\n\u001b[?2004l\r"]
[37.879788, "o", "\u001b[?2004h"]
[37.879815, "o", "> "]
[37.880004, "o", "                    if record['purchase_date'] > existing['purchase_date']:\r\n\u001b[?2004l\r"]
[37.88003, "o", "\u001b[?2004h> "]
[37.880191, "o", "                        records_by_id[asset_id] = record\r\n\u001b[?2004l\r"]
[37.880221, "o", "\u001b[?2004h> "]
[37.880286, "o", "                else:\r\n\u001b[?2004l\r"]
[37.880313, "o", "\u001b[?2004h"]
[37.88034, "o", "> "]
[37.88047, "o", "                    records_by_id[asset_id] = record\r\n\u001b[?2004l\r"]
[37.880497, "o", "\u001b[?2004h> "]
[37.880525, "o", "    \r\n\u001b[?2004l\r"]
[37.880551, "o", "\u001b[?2004h> "]
[37.880696, "o", "    # Convert to list and sort by ID for consistency\r\n\u001b[?2004l\r"]
[37.880725, "o", "\u001b[?2004h> "]
[37.880936, "o", "    valid_records = sorted(records_by_id.values(), key=lambda x: x['id'])\r\n\u001b[?2004l\r"]
[37.880967, "o", "\u001b[?2004h> "]
[37.880996, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[37.881024, "o", "> "]
[37.881077, "o", "    # Write output files\r\n\u001b[?2004l\r"]
[37.881107, "o", "\u001b[?2004h> "]
[37.881263, "o", "    with open(output_file, 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[37.881289, "o", "\u001b[?2004h> "]
[37.881418, "o", "        json.dump(valid_records, f, indent=2)\r\n\u001b[?2004l\r"]
[37.881452, "o", "\u001b[?2004h"]
[37.881479, "o", ">     \r\n\u001b[?2004l\r"]
[37.881508, "o", "\u001b[?2004h> "]
[37.881656, "o", "    with open(rejected_file, 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[37.881684, "o", "\u001b[?2004h> "]
[37.88181, "o", "        json.dump(rejected, f, indent=2)\r\n\u001b[?2004l\r"]
[37.88184, "o", "\u001b[?2004h> "]
[37.881869, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[37.881898, "o", "> "]
[37.882044, "o", "    print(f\"Processed {len(valid_records)} valid records\")\r\n\u001b[?2004l\r"]
[37.882072, "o", "\u001b[?2004h> "]
[37.88222, "o", "    print(f\"Rejected {len(rejected)} invalid records\")\r\n\u001b[?2004l\r"]
[37.882249, "o", "\u001b[?2004h"]
[37.882277, "o", "> "]
[37.882383, "o", "    print(f\"Output written to {output_file}\")\r\n\u001b[?2004l\r"]
[37.88242, "o", "\u001b[?2004h> "]
[37.882575, "o", "    print(f\"Rejected records written to {rejected_file}\")\r\n\u001b[?2004l\r"]
[37.882604, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[37.882633, "o", "\u001b[?2004h> "]
[37.882711, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[37.882748, "o", "\u001b[?2004h> "]
[37.882786, "o", "    main()\r\n\u001b[?2004l\r"]
[37.882816, "o", "\u001b[?2004h> "]
[37.88284, "o", "EOF\r\n\u001b[?2004l\r"]
[37.886617, "o", "\u001b[?2004h"]
[37.886634, "o", "user@599ad7bbd9a1:~$ "]
