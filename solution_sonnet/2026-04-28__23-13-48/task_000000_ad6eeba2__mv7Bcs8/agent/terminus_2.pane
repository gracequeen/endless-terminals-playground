[?2004l[?2004h> import csv
[?2004l[?2004h> import json
[?2004l[?2004h> import re
[?2004l[?2004h> from datetime import datetime
[?2004l[?2004h> from collections import defaultdict
[?2004l[?2004h> 
[?2004l[?2004h> def parse_date(date_str):
[?2004l[?2004h>     """Parse date from multiple formats and return ISO 8601 string."""
[?2004l[?2004h>     date_str = date_str.strip()
[?2004l[?2004h>     
[?2004l[?2004h>     # Try different date formats
[?2004l[?2004h>     formats = [
[?2004l[?2004h>         '%Y-%m-%d',      # ISO format: 2021-03-22
[?2004l[?2004h>         '%m/%d/%Y',      # US format: 02/12/2017
[?2004l[?2004h>         '%d.%m.%Y',      # European format: 17.07.2016
[?2004l[?2004h>     ]
[?2004l[?2004h>     
[?2004l[?2004h>     for fmt in formats:
[?2004l[?2004h>         try:
[?2004l[?2004h>             dt = datetime.strptime(date_str, fmt)
[?2004l[?2004h>             return dt.date().isoformat()
[?2004l[?2004h>         except ValueError:
[?2004l[?2004h>             continue
[?2004l[?2004h>     
[?2004l[?2004h>     return None
[?2004l[?2004h> 
[?2004l[?2004h> def parse_price(price_str):
[?2004l[?2004h>     """Parse price and convert to cents (integer)."""
[?2004l[?2004h>     try:
[?2004l[?2004h>         # Remove dollar signs, commas, and whitespace
[?2004l[?2004h>         cleaned = price_str.strip().replace('$', '').replace(',', '')
[?2004l[?2004h>         
[?2004l[?2004h>         # Convert to float first, then to cents
[?2004l[?2004h>         price_float = float(cleaned)
[?2004l[?2004h>         
[?2004l[?2004h>         # Check if positive
[?2004l[?2004h>         if price_float <= 0:
[?2004l[?2004h>             return None
[?2004l[?2004h>         
[?2004l[?2004h>         # Convert to cents
[?2004l[?2004h>         price_cents = int(round(price_float * 100))
[?2004l[?2004h>         return price_cents
[?2004l[?2004h>     except (ValueError, AttributeError):
[?2004l[?2004h>         return None
[?2004l[?2004h> 
[?2004l[?2004h> def is_serial_number(s):
[?2004l[?2004h>     """Check if a string looks like a serial number."""
[?2004l[?2004h>     return bool(re.match(r'^SN-[A-Z]+-\d+$', s.strip()))
[?2004l[?2004h> 
[?2004l[?2004h> def process_row(row, row_num):
[?2004l[?2004h>     """Process a single row and return (record, error) tuple."""
[?2004l[?2004h>     try:
[?2004l[?2004h>         asset_id = row.get('id', '').strip()
[?2004l[?2004h>         name = row.get('name', '').strip()
[?2004l[?2004h>         serial = row.get('serial', '').strip()
[?2004l[?2004h>         purchase_date_raw = row.get('purchase_date', '').strip()
[?2004l[?2004h>         price_raw = row.get('price', '').strip()
[?2004l[?2004h>         location = row.get('location', '').strip()
[?2004l[?2004h>         
[?2004l[?2004h>         # Check for swapped name and serial
[?2004l[?2004h>         if is_serial_number(name) and not is_serial_number(serial):
[?2004l[?2004h>             name, serial = serial, name
[?2004l[?2004h>         
[?2004l[?2004h>         # Validate required fields
[?2004l[?2004h>         if not asset_id:
[?2004l[?2004h>             return None, "Missing asset ID"
[?2004l[?2004h>         
[?2004l[?2004h>         if not name:
[?2004l[?2004h>             return None, "Missing name"
[?2004l[?2004h>         
[?2004l[?2004h>         if not serial:
[?2004l[?2004h>             return None, "Missing serial number"
[?2004l[?2004h>         
[?2004l[?2004h>         if not is_serial_number(serial):
[?2004l[?2004h>             return None, f"Invalid serial number format: {serial}"
[?2004l[?2004h>         
[?2004l[?2004h>         # Parse date
[?2004l[?2004h>         purchase_date = parse_date(purchase_date_raw)
[?2004l[?2004h>         if not purchase_date:
[?2004l[?2004h>             return None, f"Invalid date format: {purchase_date_raw}"
[?2004l[?2004h>         
[?2004l[?2004h>         # Parse price
[?2004l[?2004h>         price_cents = parse_price(price_raw)
[?2004l[?2004h>         if price_cents is None:
[?2004l[?2004h>             return None, f"Invalid or non-positive price: {price_raw}"
[?2004l[?2004h>         
[?2004l[?2004h>         if not location:
[?2004l[?2004h>             return None, "Missing location"
[?2004l[?2004h>         
[?2004l[?2004h>         record = {
[?2004l[?2004h>             'id': asset_id,
[?2004l[?2004h>             'name': name,
[?2004l[?2004h>             'serial': serial,
[?2004l[?2004h>             'purchase_date': purchase_date,
[?2004l[?2004h>             'price_cents': price_cents,
[?2004l[?2004h>             'location': location
[?2004l[?2004h>         }
[?2004l[?2004h>         
[?2004l[?2004h>         return record, None
[?2004l[?2004h>         
[?2004l[?2004h>     except Exception as e:
[?2004l[?2004h>         return None, f"Processing error: {str(e)}"
[?2004l[?2004h> 
[?2004l[?2004h> def main():
[?2004l[?2004h>     input_file = '/home/user/inventory/assets.csv'
[?2004l[?2004h>     output_file = '/home/user/inventory/assets.json'
[?2004l[?2004h>     rejected_file = '/home/user/inventory/rejected.json'
[?2004l[?2004h>     
[?2004l[?2004h>     # Store records by ID to handle duplicates
[?2004l[?2004h>     records_by_id = {}
[?2004l[?2004h>     rejected = []
[?2004l[?2004h>     
[?2004l[?2004h>     with open(input_file, 'r', encoding='utf-8') as f:
[?2004l[?2004h>         reader = csv.DictReader(f)
[?2004l[?2004h>         
[?2004l[?2004h>         for row_num, row in enumerate(reader, start=2):  # Start at 2 (header is row 1)
[?2004l[?2004h>             record, error = process_row(row, row_num)
[?2004l[?2004h>             
[?2004l[?2004h>             if error:
[?2004l[?2004h>                 rejected.append({
[?2004l[?2004h>                     'original_row': dict(row),
[?2004l[?2004h>                     'reason': error,
[?2004l[?2004h>                     'row_number': row_num
[?2004l[?2004h>                 })
[?2004l[?2004h>             else:
[?2004l[?2004h>                 asset_id = record['id']
[?2004l[?2004h>                 
[?2004l[?2004h>                 # Handle duplicates: keep the one with the latest purchase date
[?2004l[?2004h>                 if asset_id in records_by_id:
[?2004l[?2004h>                     existing = records_by_id[asset_id]
[?2004l[?2004h>                     if record['purchase_date'] > existing['purchase_date']:
[?2004l[?2004h>                         records_by_id[asset_id] = record
[?2004l[?2004h>                 else:
[?2004l[?2004h>                     records_by_id[asset_id] = record
[?2004l[?2004h>     
[?2004l[?2004h>     # Convert to list and sort by ID for consistency
