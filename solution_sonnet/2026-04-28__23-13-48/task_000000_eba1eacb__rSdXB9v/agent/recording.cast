[16.096612, "o", "cat scripts/check_ping.sh\r\n\u001b[?2004l\r"]
[16.097474, "o", "#!/bin/bash\r\nmkdir -p results\r\nwhile read -r host; do\r\n    if ping -c 1 -W 1 \"$host\" &>/dev/null; then\r\n        echo \"$host: up\"\r\n    else\r\n        echo \"$host: down\"\r\n    fi\r\ndone < hosts.conf > results/ping.txt\r\n"]
[16.097601, "o", "\u001b[?2004h"]
[16.097641, "o", "root@112c7107e917:/home/user/netmon# "]
[16.196182, "i", "cat scripts/check_ports.sh\n"]
[16.196301, "o", "cat scripts/check_ports.sh\r\n"]
[16.196347, "o", "\u001b[?2004l\r"]
[16.197137, "o", "#!/bin/bash\r\nmkdir -p results\r\nwhile read -r host; do\r\n    for port in 22 80 443; do\r\n        timeout 1 bash -c \"echo >/dev/tcp/$host/$port\" 2>/dev/null && status=\"open\" || status=\"closed\"\r\n        echo \"$host:$port $status\"\r\n    done\r\ndone < hosts.conf > results/ports.txt\r\n"]
[16.19729, "o", "\u001b[?2004h"]
[16.197328, "o", "root@112c7107e917:/home/user/netmon# "]
[20.358169, "i", "cat aggregate.py\n"]
[20.358284, "o", "cat aggregate.py\r\n\u001b[?2004l\r"]
[20.359109, "o", "#!/usr/bin/env python3\r\nimport json\r\n\r\ndef main():\r\n    results = {\"hosts\": {}}\r\n\r\n    with open(\"results/ping.txt\") as f:\r\n        for line in f:\r\n            host, status = line.strip().split(\": \")\r\n            results[\"hosts\"][host] = {\"ping\": status}\r\n\r\n    with open(\"results/ports.txt\") as f:\r\n        for line in f:\r\n            parts = line.strip().split()\r\n            host_port = parts[0].split(\":\")\r\n            host = host_port[0]\r\n            port = host_port[1]\r\n            status = parts[1]\r\n            if host not in results[\"hosts\"]:"]
[20.359164, "o", "\r\n                results[\"hosts\"][host] = {}\r\n            if \"ports\" not in results[\"hosts\"][host]:\r\n                results[\"hosts\"][host][\"ports\"] = {}\r\n            results[\"hosts\"][host][\"ports\"][port] = status\r\n\r\n    with open(\"results/status.json\", \"w\") as f\r\n        json.dump(results, f, indent=2)\r\n\r\n    print(\"Report generated: results/status.json\")\r\n\r\nif __name__ == \"__main__\":\r\n    main()\r\n"]
[20.35927, "o", "\u001b[?2004h"]
[20.359323, "o", "root@112c7107e917:/home/user/netmon# "]
[20.461647, "i", "ls -la results/ 2>/dev/null || echo 'results directory does not exist yet'\n"]
