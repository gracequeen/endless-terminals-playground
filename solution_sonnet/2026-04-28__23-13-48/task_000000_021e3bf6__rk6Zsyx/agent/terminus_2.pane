MemAvai[?2004huser@fa326e60e0fe:~$ cat > process_memory.sh << 'EOF'
[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> # Output file
[?2004l[?2004h> OUTPUT="/home/user/low_memory_report.txt"
[?2004l[?2004h> 
[?2004l[?2004h> # Clear output file
[?2004l[?2004h> > "$OUTPUT"
[?2004l[?2004h> 
[?2004l[?2004h> # Temporary file for sorting
[?2004l[?2004h> TEMP_FILE=$(mktemp)
[?2004l[?2004h> 
[?2004l[?2004h> # Process each host file
[?2004l[?2004h> for hostfile in /home/user/memstats/host*.txt; do
[?2004l[?2004h>     hostname=$(basename "$hostfile" .txt)
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract MemTotal and MemAvailable, handle errors gracefully
[?2004l[?2004h>     memtotal=$(grep -E '^MemTotal:' "$hostfile" 2>/dev/null | awk '{print $2}')
[?2004l[?2004h>     memavail=$(grep -E '^MemAvailable:' "$hostfile" 2>/dev/null | awk '{print $2}')
[?2004l[?2004h>     
[?2004l[?2004h>     # Skip if either value is missing or empty
[?2004l[?2004h>     if [[ -z "$memtotal" || -z "$memavail" ]]; then
[?2004l[?2004h>         continue
[?2004l[?2004h>     fi
[?2004l[?2004h>     
[?2004l[?2004h>     # Calculate percentage available
[?2004l[?2004h>     percentage=$(awk "BEGIN {printf \"%.2f\", ($memavail / $memtotal) * 100}")
[?2004l[?2004h>     
[?2004l[?2004h>     # Check if less than 20%
[?2004l[?2004h>     is_low=$(awk "BEGIN {print ($percentage < 20) ? 1 : 0}")
[?2004l[?2004h>     
[?2004l[?2004h>     if [[ $is_low -eq 1 ]]; then
[?2004l[?2004h>         # Store for sorting: percentage, hostname, percentage_for_output
[?2004l[?2004h>         echo "$percentage\t$hostname\t$percentage" >> "$TEMP_FILE"
[?2004l[?2004h>     fi
[?2004l[?2004h> done
[?2004l[?2004h> 
[?2004l[?2004h> # Sort by percentage (ascending = worst first) and output hostname + percentage
[?2004l[?2004h> if [[ -s "$TEMP_FILE" ]]; then
[?2004l[?2004h>     sort -n "$TEMP_FILE" | awk -F'\t' '{print $2 "\t" $3}' > "$OUTPUT"
[?2004l[?2004h> fi
[?2004l[?2004h> 
[?2004l[?2004h> # Clean up
[?2004l[?2004h> rm -f "$TEMP_FILE"
[?2004l[?2004h> EOF
[?2004l[?2004huser@fa326e60e0fe:~$ chmod +x process_memory.sh
