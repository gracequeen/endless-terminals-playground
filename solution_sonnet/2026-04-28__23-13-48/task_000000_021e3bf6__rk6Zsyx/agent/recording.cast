[21.464091, "i", "cat > process_memory.sh << 'EOF'\n#!/bin/bash\n\n# Output file\nOUTPUT=\"/home/user/low_memory_report.txt\"\n\n# Clear output file\n> \"$OUTPUT\"\n\n# Temporary file for sorting\nTEMP_FILE=$(mktemp)\n\n# Process each host file\nfor hostfile in /home/user/memstats/host*.txt; do\n    hostname=$(basename \"$hostfile\" .txt)\n    \n    # Extract MemTotal and MemAvailable, handle errors gracefully\n    memtotal=$(grep -E '^MemTotal:' \"$hostfile\" 2>/dev/null | awk '{print $2}')\n    memavail=$(grep -E '^MemAvailable:' \"$hostfile\" 2>/dev/null | awk '{print $2}')\n    \n    # Skip if either value is missing or empty\n    if [[ -z \"$memtotal\" || -z \"$memavail\" ]]; then\n        continue\n    fi\n    \n    # Calculate percentage available\n    percentage=$(awk \"BEGIN {printf \\\"%.2f\\\", ($memavail / $memtotal) * 100}\")\n    \n    # Check if less than 20%\n    is_low=$(awk \"BEGIN {print ($percentage < 20) ? 1 : 0}\")\n    \n    if [[ $is_low -eq 1 ]]; then\n        # Store for sorting: percentage, hostname, percentage_for_output\n        echo \"$percentage\\t$hos"]
[21.46423, "i", "tname\\t$percentage\" >> \"$TEMP_FILE\"\n    fi\ndone\n\n# Sort by percentage (ascending = worst first) and output hostname + percentage\nif [[ -s \"$TEMP_FILE\" ]]; then\n    sort -n \"$TEMP_FILE\" | awk -F'\\t' '{print $2 \"\\t\" $3}' > \"$OUTPUT\"\nfi\n\n# Clean up\nrm -f \"$TEMP_FILE\"\nEOF\n"]
