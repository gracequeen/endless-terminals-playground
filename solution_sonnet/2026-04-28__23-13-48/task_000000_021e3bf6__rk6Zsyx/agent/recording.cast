[43.718495, "o", "# Sort by percentage (ascending = worst first) and output hostname + percentage\r\n\u001b[?2004l\r"]
[43.718526, "o", "\u001b[?2004h> "]
[43.718618, "o", "if [[ -s \"$TEMP_FILE\" ]]; then\r\n\u001b[?2004l\r"]
[43.718649, "o", "\u001b[?2004h> "]
[43.718848, "o", "    sort -n \"$TEMP_FILE\" | awk -F'\\t' '{print $2 \"\\t\" $3}' > \"$OUTPUT\"\r\n\u001b[?2004l\r"]
[43.718878, "o", "\u001b[?2004h> "]
[43.718909, "o", "fi\r\n\u001b[?2004l\r\u001b[?2004h"]
[43.718939, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[43.718967, "o", "> "]
[43.718994, "o", "# Clean up\r\n\u001b[?2004l\r"]
[43.719024, "o", "\u001b[?2004h> "]
[43.719087, "o", "rm -f \"$TEMP_FILE\"\r\n\u001b[?2004l\r"]
[43.71912, "o", "\u001b[?2004h> "]
[43.719147, "o", "EOF\r\n\u001b[?2004l\r"]
[43.720244, "o", "\u001b[?2004h"]
[43.72028, "o", "user@fa326e60e0fe:~$ "]
[43.812545, "i", "./process_memory.sh\n"]
[43.812655, "o", "./process_memory.sh\r\n\u001b[?2004l\r"]
