MemAvai[?2004huser@87826d385624:~$ cat > process_memory.sh << 'EOF'
[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> # Output file
[?2004l[?2004h> OUTPUT="/home/user/low_memory_report.txt"
[?2004l[?2004h> 
[?2004l[?2004h> # Temporary file for results
[?2004l[?2004h> TEMP=$(mktemp)
[?2004l[?2004h> 
[?2004l[?2004h> # Process each host file
[?2004l[?2004h> for hostfile in /home/user/memstats/host*.txt; do
[?2004l[?2004h>     hostname=$(basename "$hostfile" .txt)
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract MemTotal and MemAvailable, handling missing values gracefully
[?2004l[?2004h>     memtotal=$(grep -oP '^MemTotal:\s+\K[0-9]+' "$hostfile" 2>/dev/null)
[?2004l[?2004h>     memavail=$(grep -oP '^MemAvailable:\s+\K[0-9]+' "$hostfile" 2>/dev/null)
[?2004l[?2004h>     
[?2004l[?2004h>     # Only process if both values are present and non-zero
[?2004l[?2004h>     if [[ -n "$memtotal" && -n "$memavail" && "$memtotal" -gt 0 ]]; then
[?2004l[?2004h>         # Calculate percentage available
[?2004l[?2004h>         percentage=$(awk "BEGIN {printf \"%.2f\", ($memavail / $memtotal) * 100}")
[?2004l[?2004h>         
[?2004l[?2004h>         # Check if less than 20%
[?2004l[?2004h>         if (( $(awk "BEGIN {print ($percentage < 20)}") )); then
[?2004l[?2004h>             echo -e "${hostname}\t${percentage}" >> "$TEMP"
[?2004l[?2004h>         fi
[?2004l[?2004h>     fi
[?2004l[?2004h> done
[?2004l[?2004h> 
[?2004l[?2004h> # Sort by percentage (ascending - worst first) and write to output
[?2004l[?2004h> sort -t$'\t' -k2 -n "$TEMP" > "$OUTPUT"
[?2004l[?2004h> 
[?2004l[?2004h> # Clean up
[?2004l[?2004h> rm -f "$TEMP"
[?2004l[?2004h> EOF
[?2004l[?2004huser@87826d385624:~$ chmod +x process_memory.sh
[?2004l[?2004huser@87826d385624:~$ ./process_memory.sh
