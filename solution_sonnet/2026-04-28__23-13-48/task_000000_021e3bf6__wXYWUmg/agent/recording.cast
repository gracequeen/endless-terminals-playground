[8.324099, "o", "MemTotal:       16384000 kB\r\nMemAvai"]
[8.324248, "o", "\u001b[?2004h"]
[8.324277, "o", "user@87826d385624:~$ "]
[20.860695, "i", "cat > process_memory.sh << 'EOF'\n#!/bin/bash\n\n# Output file\nOUTPUT=\"/home/user/low_memory_report.txt\"\n\n# Temporary file for results\nTEMP=$(mktemp)\n\n# Process each host file\nfor hostfile in /home/user/memstats/host*.txt; do\n    hostname=$(basename \"$hostfile\" .txt)\n    \n    # Extract MemTotal and MemAvailable, handling missing values gracefully\n    memtotal=$(grep -oP '^MemTotal:\\s+\\K[0-9]+' \"$hostfile\" 2>/dev/null)\n    memavail=$(grep -oP '^MemAvailable:\\s+\\K[0-9]+' \"$hostfile\" 2>/dev/null)\n    \n    # Only process if both values are present and non-zero\n    if [[ -n \"$memtotal\" && -n \"$memavail\" && \"$memtotal\" -gt 0 ]]; then\n        # Calculate percentage available\n        percentage=$(awk \"BEGIN {printf \\\"%.2f\\\", ($memavail / $memtotal) * 100}\")\n        \n        # Check if less than 20%\n        if (( $(awk \"BEGIN {print ($percentage < 20)}\") )); then\n            echo -e \"${hostname}\\t${percentage}\" >> \"$TEMP\"\n        fi\n    fi\ndone\n\n# Sort by percentage (ascending - worst first) and write to output\nsort -t$'"]
[20.860828, "i", "\\t' -k2 -n \"$TEMP\" > \"$OUTPUT\"\n\n# Clean up\nrm -f \"$TEMP\"\nEOF\n"]
[20.860843, "o", "cat > process_memory.sh << 'EOF'\r\n"]
