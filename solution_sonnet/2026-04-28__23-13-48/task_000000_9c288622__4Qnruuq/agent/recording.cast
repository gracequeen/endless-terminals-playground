[62.325099, "i", "cat > demonstrate_bug.py << 'EOF'\n#!/usr/bin/env python3\n\"\"\"Demonstrate the bug that was fixed.\"\"\"\n\nimport pytz\nfrom datetime import datetime\n\nBERLIN_TZ = pytz.timezone('Europe/Berlin')\nUTC_TZ = pytz.utc\n\ndef old_buggy_convert(utc_time_str):\n    \"\"\"The OLD buggy conversion method.\"\"\"\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\n    # BUG: This treats the UTC time as if it's already Berlin time\n    berlin_dt = BERLIN_TZ.localize(utc_dt)\n    return berlin_dt\n\ndef new_correct_convert(utc_time_str):\n    \"\"\"The NEW correct conversion method.\"\"\"\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\n    # FIX: First localize as UTC, then convert to Berlin\n    utc_dt_aware = UTC_TZ.localize(utc_dt)\n    berlin_dt = utc_dt_aware.astimezone(BERLIN_TZ)\n    return berlin_dt\n\nprint(\"=\" * 70)\nprint(\"DEMONSTRATION: Bug vs Fix for DST Transition\")\nprint(\"=\" * 70)\nprint()\nprint(\"The Maintenance Window meeting is scheduled for:\")\nprint(\"  UTC: 2024-03-31T01:30:00\")\nprint(\"  (This is during the D"]
[62.3252, "i", "ST transition on March 31, 2024)\")\nprint()\n\nutc_time = '2024-03-31T01:30:00'\n\nprint(\"OLD BUGGY METHOD:\")\nbuggy_result = old_buggy_convert(utc_time)\nprint(f\"  Result: {buggy_result.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\nprint(f\"  ❌ WRONG! Shows 02:30 CET, but 2am-3am doesn't exist on DST day!\")\nprint()\n\nprint(\"NEW CORRECT METHOD:\")\ncorrect_result = new_correct_convert(utc_time)\nprint(f\"  Result: {correct_result.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\nprint(f\"  ✓ CORRECT! Shows 03:30 CEST (clocks jumped from 2am to 3am)\")\nprint()\n\nprint(\"EXPLANATION:\")\nprint(\"  On March 31, 2024, Europe/Berlin switched to DST at 2:00am.\")\nprint(\"  Clocks jumped forward: 01:59:59 CET → 03:00:00 CEST\")\nprint(\"  The hour from 2:00-2:59 doesn't exist!\")\nprint(\"  \")\nprint(\"  The bug: localize() on a naive datetime assumes it's already\")\nprint(\"           in that timezone, so 01:30 UTC became 01:30 CET.\")\nprint(\"  \")\nprint(\"  The fix: First mark as UTC, then convert to Berlin timezone,\")\nprint(\"           which properly adds the D"]
[62.325244, "i", "ST offset (+2 hours).\")\nprint()\nprint(\"=\" * 70)\nEOF\n"]
[62.325274, "o", "cat > demonstrate_bug.py << 'EOF'\r\n\u001b[?2004l\r"]
[62.325305, "o", "ST offset (+2 hours).\")\r\nprint()\r\nprint(\"=\" * 70)\r\nEOF\r\n\u001b[?2004h> "]
