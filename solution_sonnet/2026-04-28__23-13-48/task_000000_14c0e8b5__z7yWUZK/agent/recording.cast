[31.318332, "i", "cat > check.py << 'EOF'\n#!/usr/bin/env python3\nimport json\nimport csv\nimport ipaddress\nimport sys\n\ndef parse_port_spec(port_spec):\n    \"\"\"Parse a port specification into a list of allowed ports or a range.\"\"\"\n    port_str = str(port_spec)\n    if '-' in port_str:\n        start, end = port_str.split('-')\n        return ('range', int(start), int(end))\n    else:\n        return ('single', int(port_str))\n\ndef port_matches(port, port_spec):\n    \"\"\"Check if a port matches a port specification.\"\"\"\n    spec_type, *spec_data = parse_port_spec(port_spec)\n    if spec_type == 'single':\n        return port == spec_data[0]\n    elif spec_type == 'range':\n        return spec_data[0] <= port <= spec_data[1]\n    return False\n\ndef find_matching_rule(src_ip, dest_port, rules):\n    \"\"\"Find the most specific matching rule for a given source IP and destination port.\n    \n    Returns tuple: (action, source_cidr) or (None, None) if no match.\n    Rules should already be sorted by prefix length (most specific first).\n    \"\"\"\n    ip_obj ="]
[31.318469, "i", " ipaddress.ip_address(src_ip)\n    \n    # Check each rule in order (most specific CIDR first)\n    for rule in rules:\n        network = ipaddress.ip_network(rule['source_cidr'])\n        if ip_obj in network:\n            # IP matches this CIDR, now check port\n            if port_matches(dest_port, rule['dest_port']):\n                return (rule['action'], rule['source_cidr'])\n    \n    # No matching rule found\n    return (None, None)\n\ndef main():\n    # Load firewall rules\n    with open('/home/user/audit/firewall_rules.json', 'r') as f:\n        firewall_data = json.load(f)\n    \n    rules = firewall_data['rules']\n    default_action = firewall_data.get('default_action', 'deny')\n    \n    # Sort rules by CIDR prefix length (most specific first)\n    # This ensures /24 is checked before /16, /16 before /8, etc.\n    rules_sorted = sorted(rules, key=lambda r: ipaddress.ip_network(r['source_cidr']).prefixlen, reverse=True)\n    \n    # Load connections\n    with open('/home/user/audit/connections.csv', 'r') as f:\n        rea"]
[31.318508, "o", "cat > check.py << 'EOF'\r\n\u001b[?2004l\r ipaddress.ip_address(src_ip)\r\n    \r\n    # Check each rule in order"]
[31.318554, "i", "der = csv.DictReader(f)\n        connections = list(reader)\n    \n    # Check each connection\n    for conn in connections:\n        src_ip = conn['src_ip']\n        dest_port = int(conn['dest_port'])\n        \n        action, matching_cidr = find_matching_rule(src_ip, dest_port, rules_sorted)\n        \n        # If no rule matched, apply default action\n        if action is None:\n            action = default_action\n            # Find the least specific CIDR that contains this IP for reporting\n            ip_obj = ipaddress.ip_address(src_ip)\n            matching_cidr = None\n            for rule in sorted(rules_sorted, key=lambda r: ipaddress.ip_network(r['source_cidr']).prefixlen):\n                network = ipaddress.ip_network(rule['source_cidr'])\n                if ip_obj in network:\n                    matching_cidr = rule['source_cidr']\n                    break\n            if matching_cidr is None:\n                matching_cidr = '0.0.0.0/0'\n        \n        # Report if blocked\n        if action == 'deny' or ac"]
