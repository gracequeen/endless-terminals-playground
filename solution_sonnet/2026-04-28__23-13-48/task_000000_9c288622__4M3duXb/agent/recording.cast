[89.765846, "o", "\u001b[01;31m\u001b[Kdef convert_to_berlin\u001b[m\u001b[K(utc_time_str):\r\n    \"\"\"\r\n    Convert UTC time string to Berlin timezone.\r\n    \"\"\""]
