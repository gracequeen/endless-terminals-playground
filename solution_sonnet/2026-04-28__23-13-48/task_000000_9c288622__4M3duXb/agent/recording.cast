[66.772636, "i", "cat > demonstrate_fix.py << 'EOF'\n#!/usr/bin/env python3\n\"\"\"Demonstrate the bug and the fix.\"\"\"\n\nimport pytz\nfrom datetime import datetime\n\nBERLIN_TZ = pytz.timezone('Europe/Berlin')\nUTC_TZ = pytz.utc\n\ndef old_buggy_convert(utc_time_str):\n    \"\"\"The OLD buggy version - treats UTC time as Berlin time.\"\"\"\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\n    # BUG: This localizes as if utc_dt is already in Berlin time\n    berlin_dt = BERLIN_TZ.localize(utc_dt)\n    return berlin_dt\n\ndef new_fixed_convert(utc_time_str):\n    \"\"\"The NEW fixed version - properly converts UTC to Berlin.\"\"\"\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\n    # FIX: First localize as UTC, then convert to Berlin\n    utc_dt = UTC_TZ.localize(utc_dt)\n    berlin_dt = utc_dt.astimezone(BERLIN_TZ)\n    return berlin_dt\n\nprint(\"=\" * 70)\nprint(\"DEMONSTRATION: Bug vs Fix for DST Transition Times\")\nprint(\"=\" * 70)\nprint()\n\n# The critical test case: Monday 2:30am maintenance window\n# UTC 01:30 on March 31, 2024 (w"]
[66.772768, "i", "hen DST starts in Europe)\ntest_time = \"2024-03-31T01:30:00\"\n\nprint(f\"Input: {test_time} UTC\")\nprint(f\"Context: March 31, 2024 is when DST starts in Europe/Berlin\")\nprint(f\"         At 2:00am CET, clocks jump forward to 3:00am CEST\")\nprint()\n\nbuggy_result = old_buggy_convert(test_time)\nfixed_result = new_fixed_convert(test_time)\n\nprint(\"OLD BUGGY CODE:\")\nprint(f\"  Result: {buggy_result.strftime('%Y-%m-%d %H:%M:%S %Z (UTC%z)')}\")\nprint(f\"  Problem: Treats '01:30:00' as if it's already Berlin time!\")\nprint()\n\nprint(\"NEW FIXED CODE:\")\nprint(f\"  Result: {fixed_result.strftime('%Y-%m-%d %H:%M:%S %Z (UTC%z)')}\")\nprint(f\"  Correct: Properly converts UTC to Berlin (UTC+2 during CEST)\")\nprint()\n\nprint(\"DIFFERENCE:\")\ntime_diff = (fixed_result - buggy_result).total_seconds() / 3600\nprint(f\"  The buggy code is off by {abs(time_diff):.1f} hour(s)!\")\nprint()\n\nprint(\"IMPACT:\")\nprint(f\"  Meeting scheduled for: {fixed_result.strftime('%H:%M')} Berlin time\")\nprint(f\"  Buggy code would send reminder for: {buggy_result.strftime('"]
[66.772819, "o", "cat > demonstrate_fix.py << 'EOF'\r\n\u001b[?2004l\r"]
[66.772851, "i", "%H:%M')} Berlin time\")\nprint(f\"  This is why reminders were wrong for 2am-3am meetings!\")\nprint()\n\nprint(\"=\" * 70)\nprint(\"✓ FIX VERIFIED: The corrected code now properly handles DST transitions\")\nprint(\"=\" * 70)\nEOF\n"]
