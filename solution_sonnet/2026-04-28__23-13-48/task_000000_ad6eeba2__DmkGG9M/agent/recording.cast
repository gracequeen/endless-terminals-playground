[41.434056, "i", "cat > process_assets.py << 'EOF'\nimport csv\nimport json\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\ndef parse_date(date_str):\n    \"\"\"Parse date from multiple formats to ISO 8601\"\"\"\n    if not date_str or not date_str.strip():\n        return None\n    \n    date_str = date_str.strip()\n    formats = [\n        '%Y-%m-%d',      # YYYY-MM-DD\n        '%m/%d/%Y',      # MM/DD/YYYY\n        '%d.%m.%Y',      # DD.MM.YYYY\n    ]\n    \n    for fmt in formats:\n        try:\n            dt = datetime.strptime(date_str, fmt)\n            return dt.strftime('%Y-%m-%d')\n        except ValueError:\n            continue\n    \n    return None\n\ndef parse_price(price_str):\n    \"\"\"Parse price to cents (integer)\"\"\"\n    if not price_str or not isinstance(price_str, str):\n        if isinstance(price_str, (int, float)):\n            price_str = str(price_str)\n        else:\n            return None\n    \n    # Remove dollar signs, commas, and whitespace\n    price_str = price_str.strip().replace('$', '').replace(','"]
[41.434196, "i", ", '')\n    \n    try:\n        price_float = float(price_str)\n        price_cents = int(round(price_float * 100))\n        return price_cents if price_cents > 0 else None\n    except (ValueError, OverflowError):\n        return None\n\ndef is_serial_format(s):\n    \"\"\"Check if string looks like a serial number (starts with SN-)\"\"\"\n    return s and s.strip().startswith('SN-')\n\ndef process_row(row, row_num):\n    \"\"\"Process a single row and return (asset_dict, error_message)\"\"\"\n    try:\n        # Handle missing or empty ID\n        asset_id = row.get('id', '').strip()\n        if not asset_id:\n            return None, \"Missing asset ID\"\n        \n        name = row.get('name', '').strip()\n        serial = row.get('serial', '').strip()\n        \n        # Check if serial and name are swapped\n        if not is_serial_format(serial) and is_serial_format(name):\n            name, serial = serial, name\n        \n        # Validate serial format\n        if not is_serial_format(serial):\n            return None, f\"Invalid serial forma"]
[41.434229, "o", "cat > process_assets.py << 'EOF'\r\n\u001b[?2004l\r"]
[41.434261, "i", "t: {serial}\"\n        \n        # Parse date\n        date_str = row.get('purchase_date', '').strip()\n        purchase_date = parse_date(date_str)\n        if not purchase_date:\n            return None, f\"Invalid date format: {date_str}\"\n        \n        # Parse price\n        price_str = row.get('price', '').strip()\n        price_cents = parse_price(price_str)\n        if price_cents is None:\n            return None, f\"Invalid price: {price_str}\"\n        \n        location = row.get('location', '').strip()\n        if not location:\n            return None, \"Missing location\"\n        \n        asset = {\n            'id': asset_id,\n            'name': name,\n            'serial': serial,\n            'purchase_date': purchase_date,\n            'price_cents': price_cents,\n            'location': location\n        }\n        \n        return asset, None\n        \n    except Exception as e:\n        return None, f\"Processing error: {str(e)}\"\n\ndef main():\n    assets_by_id = {}\n    rejected = []\n    \n    # Read CSV\n    with open('"]
[41.434285, "o", "\u001b[?2004h"]
[41.434311, "i", "/home/user/inventory/assets.csv', 'r', encoding='utf-8') as f:\n        reader = csv.DictReader(f)\n        \n        for row_num, row in enumerate(reader, start=2):\n            asset, error = process_row(row, row_num)\n            \n            if error:\n                rejected.append({\n                    'original_row': dict(row),\n                    'reason': error,\n                    'row_number': row_num\n                })\n            else:\n                asset_id = asset['id']\n                \n                # Handle duplicates - keep the one with latest purchase date\n                if asset_id in assets_by_id:\n                    existing = assets_by_id[asset_id]\n                    if asset['purchase_date'] > existing['purchase_date']:\n                        assets_by_id[asset_id] = asset\n                else:\n                    assets_by_id[asset_id] = asset\n    \n    # Convert to list and sort by ID\n    assets_list = sorted(assets_by_id.values(), key=lambda x: x['id'])\n    \n    # Write assets.json"]
[41.434339, "o", "> import csv\r\n\u001b[?2004l\r"]
