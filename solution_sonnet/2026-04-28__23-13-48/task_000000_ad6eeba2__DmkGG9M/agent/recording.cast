[41.437806, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[41.437835, "o", "\u001b[?2004h> "]
[41.437915, "o", "def parse_price(price_str):\r\n\u001b[?2004l\r"]
[41.437948, "o", "\u001b[?2004h> "]
[41.438059, "o", "    \"\"\"Parse price to cents (integer)\"\"\"\r\n\u001b[?2004l\r"]
[41.438081, "o", "\u001b[?2004h"]
[41.438108, "o", "> "]
[41.438245, "o", "    if not price_str or not isinstance(price_str, str):\r\n\u001b[?2004l\r"]
[41.438274, "o", "\u001b[?2004h> "]
[41.438407, "o", "        if isinstance(price_str, (int, float)):\r\n\u001b[?2004l\r"]
[41.438435, "o", "\u001b[?2004h> "]
[41.438549, "o", "            price_str = str(price_str)\r\n\u001b[?2004l\r"]
[41.438577, "o", "\u001b[?2004h"]
[41.438611, "o", "> "]
[41.438657, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[41.438685, "o", "> "]
[41.438737, "o", "            return None\r\n\u001b[?2004l\r"]
[41.438769, "o", "\u001b[?2004h> "]
[41.438797, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[41.438826, "o", "> "]
[41.438946, "o", "    # Remove dollar signs, commas, and whitespace\r\n\u001b[?2004l\r"]
[41.438974, "o", "\u001b[?2004h"]
[41.439001, "o", "> "]
[41.439167, "o", "    price_str = price_str.strip().replace('$', '').replace(',', '')\r\n\u001b[?2004l\r"]
[41.439189, "o", "\u001b[?2004h"]
[41.439214, "o", ">     \r\n\u001b[?2004l\r"]
[41.439243, "o", "\u001b[?2004h> "]
[41.439273, "o", "    try:\r\n\u001b[?2004l\r"]
[41.4393, "o", "\u001b[?2004h> "]
[41.439411, "o", "        price_float = float(price_str)\r\n\u001b[?2004l\r"]
[41.439444, "o", "\u001b[?2004h> "]
[41.439585, "o", "        price_cents = int(round(price_float * 100))\r\n\u001b[?2004l\r"]
[41.439621, "o", "\u001b[?2004h> "]
[41.439781, "o", "        return price_cents if price_cents > 0 else None\r\n\u001b[?2004l\r"]
[41.439811, "o", "\u001b[?2004h> "]
[41.439924, "o", "    except (ValueError, OverflowError):\r\n\u001b[?2004l\r"]
[41.439946, "o", "\u001b[?2004h"]
[41.439979, "o", "> "]
[41.440012, "o", "        return None\r\n\u001b[?2004l\r"]
[41.440041, "o", "\u001b[?2004h> "]
[41.440071, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[41.440099, "o", "> "]
[41.440148, "o", "def is_serial_format(s):\r\n\u001b[?2004l\r"]
[41.440177, "o", "\u001b[?2004h> "]
[41.440381, "o", "    \"\"\"Check if string looks like a serial number (starts with SN-)\"\"\"\r\n\u001b[?2004l\r"]
[41.440413, "o", "\u001b[?2004h> "]
[41.440535, "o", "    return s and s.strip().startswith('SN-')\r\n\u001b[?2004l\r"]
[41.440559, "o", "\u001b[?2004h"]
[41.440583, "o", "> \r\n\u001b[?2004l\r"]
[41.440611, "o", "\u001b[?2004h> "]
[41.440698, "o", "def process_row(row, row_num):\r\n\u001b[?2004l\r"]
[41.440724, "o", "\u001b[?2004h"]
[41.440749, "o", "> "]
[41.44092, "o", "    \"\"\"Process a single row and return (asset_dict, error_message)\"\"\"\r\n\u001b[?2004l\r"]
[41.440952, "o", "\u001b[?2004h> "]
[41.440984, "o", "    try:\r\n\u001b[?2004l\r"]
[41.441011, "o", "\u001b[?2004h> "]
[41.44111, "o", "        # Handle missing or empty ID\r\n\u001b[?2004l\r"]
[41.44114, "o", "\u001b[?2004h> "]
[41.441267, "o", "        asset_id = row.get('id', '').strip()\r\n\u001b[?2004l\r"]
[41.441296, "o", "\u001b[?2004h> "]
[41.441371, "o", "        if not asset_id:\r\n\u001b[?2004l\r"]
[41.4414, "o", "\u001b[?2004h> "]
[41.441529, "o", "            return None, \"Missing asset ID\"\r\n\u001b[?2004l\r"]
[41.441558, "o", "\u001b[?2004h> "]
[41.441589, "o", "        \r\n\u001b[?2004l\r"]
[41.441617, "o", "\u001b[?2004h> "]
[41.441749, "o", "        name = row.get('name', '').strip()\r\n\u001b[?2004l\r"]
[41.441773, "o", "\u001b[?2004h"]
[41.441806, "o", "> "]
[41.441911, "o", "        serial = row.get('serial', '').strip()\r\n\u001b[?2004l\r"]
[41.441941, "o", "\u001b[?2004h> "]
[41.44197, "o", "        \r\n\u001b[?2004l\r"]
[41.441999, "o", "\u001b[?2004h> "]
[41.442129, "o", "        # Check if serial and name are swapped\r\n\u001b[?2004l\r"]
[41.442158, "o", "\u001b[?2004h> "]
[41.442354, "o", "        if not is_serial_format(serial) and is_serial_format(name):\r\n\u001b[?2004l\r"]
[41.442383, "o", "\u001b[?2004h> "]
[41.442499, "o", "            name, serial = serial, name\r\n\u001b[?2004l\r"]
[41.442526, "o", "\u001b[?2004h"]
[41.442555, "o", ">         \r\n"]
[41.442583, "o", "\u001b[?2004l\r\u001b[?2004h"]
[41.442612, "o", "> "]
[41.442693, "o", "        # Validate serial format\r\n\u001b[?2004l\r"]
[41.442728, "o", "\u001b[?2004h> "]
[41.442838, "o", "        if not is_serial_format(serial):\r\n\u001b[?2004l\r"]
[41.442867, "o", "\u001b[?2004h"]
[41.442895, "o", "> "]
[41.443036, "o", "            return None, f\"Invalid serial format: {serial}\"\r\n\u001b[?2004l\r"]
[41.443072, "o", "\u001b[?2004h"]
[41.443099, "o", ">         \r\n\u001b[?2004l\r"]
[41.443125, "o", "\u001b[?2004h> "]
[41.443184, "o", "        # Parse date\r\n\u001b[?2004l\r"]
[41.443206, "o", "\u001b[?2004h"]
[41.443231, "o", "> "]
[41.443371, "o", "        date_str = row.get('purchase_date', '').strip()\r\n\u001b[?2004l\r"]
[41.443399, "o", "\u001b[?2004h> "]
[41.443525, "o", "        purchase_date = parse_date(date_str)\r\n\u001b[?2004l\r"]
[41.443553, "o", "\u001b[?2004h> "]
[41.44365, "o", "        if not purchase_date:\r\n\u001b[?2004l\r"]
[41.443674, "o", "\u001b[?2004h"]
[41.443707, "o", "> "]
[41.443846, "o", "            return None, f\"Invalid date format: {date_str}\"\r\n\u001b[?2004l\r"]
[41.443876, "o", "\u001b[?2004h> "]
[41.443906, "o", "        \r\n\u001b[?2004l\r"]
[41.443932, "o", "\u001b[?2004h> "]
[41.443996, "o", "        # Parse price\r\n\u001b[?2004l\r"]
[41.444024, "o", "\u001b[?2004h> "]
[41.444163, "o", "        price_str = row.get('price', '').strip()\r\n\u001b[?2004l\r"]
[41.444185, "o", "\u001b[?2004h"]
[41.444218, "o", "> "]
[41.444326, "o", "        price_cents = parse_price(price_str)\r\n\u001b[?2004l\r"]
[41.444355, "o", "\u001b[?2004h"]
[41.444384, "o", "> "]
[41.444448, "o", "        if price_cents is None:\r\n\u001b[?2004l\r"]
[41.444483, "o", "\u001b[?2004h> "]
[41.44463, "o", "            return None, f\"Invalid price: {price_str}\"\r\n\u001b[?2004l\r"]
[41.444667, "o", "\u001b[?2004h> "]
[41.444698, "o", "        \r\n\u001b[?2004l\r"]
[41.444724, "o", "\u001b[?2004h"]
[41.44475, "o", "> "]
[41.444867, "o", "        location = row.get('location', '').strip()\r\n\u001b[?2004l\r"]
[41.444895, "o", "\u001b[?2004h> "]
[41.444971, "o", "        if not location:\r\n\u001b[?2004l\r"]
[41.445, "o", "\u001b[?2004h> "]
[41.445127, "o", "            return None, \"Missing location\"\r\n\u001b[?2004l\r"]
[41.445153, "o", "\u001b[?2004h> "]
[41.445184, "o", "        \r\n\u001b[?2004l\r"]
[41.445213, "o", "\u001b[?2004h> "]
[41.44527, "o", "        asset = {\r\n\u001b[?2004l\r"]
[41.445299, "o", "\u001b[?2004h> "]
[41.445383, "o", "            'id': asset_id,\r\n\u001b[?2004l\r"]
[41.445412, "o", "\u001b[?2004h> "]
[41.44549, "o", "            'name': name,\r\n\u001b[?2004l\r"]
[41.445519, "o", "\u001b[?2004h> "]
[41.445609, "o", "            'serial': serial,\r\n\u001b[?2004l\r"]
[41.445647, "o", "\u001b[?2004h> "]
[41.445771, "o", "            'purchase_date': purchase_date,\r\n\u001b[?2004l\r"]
[41.445793, "o", "\u001b[?2004h"]
[41.445817, "o", "> "]
[41.445914, "o", "            'price_cents': price_cents,\r\n\u001b[?2004l\r"]
[41.44594, "o", "\u001b[?2004h> "]
[41.446038, "o", "            'location': location\r\n\u001b[?2004l\r"]
[41.44606, "o", "\u001b[?2004h"]
[41.446084, "o", "> "]
[41.44611, "o", "        }\r\n\u001b[?2004l\r"]
[41.446138, "o", "\u001b[?2004h> "]
[41.446166, "o", "        \r\n\u001b[?2004l\r"]
[41.446193, "o", "\u001b[?2004h> "]
[41.446258, "o", "        return asset, None\r\n\u001b[?2004l\r"]
[41.446284, "o", "\u001b[?2004h"]
[41.446312, "o", ">         \r\n\u001b[?2004l\r"]
[41.446334, "o", "\u001b[?2004h"]
[41.446367, "o", "> "]
[41.44642, "o", "    except Exception as e:\r\n\u001b[?2004l\r"]
[41.446448, "o", "\u001b[?2004h> "]
[41.446593, "o", "        return None, f\"Processing error: {str(e)}\"\r\n\u001b[?2004l\r"]
[41.44662, "o", "\u001b[?2004h> "]
[41.44666, "o", "\r\n\u001b[?2004l\r"]
[41.446691, "o", "\u001b[?2004h"]
[41.446718, "o", "> "]
[41.446743, "o", "def main():\r\n\u001b[?2004l\r"]
[41.446772, "o", "\u001b[?2004h> "]
[41.446832, "o", "    assets_by_id = {}\r\n\u001b[?2004l\r"]
[41.446862, "o", "\u001b[?2004h> "]
[41.446916, "o", "    rejected = []\r\n\u001b[?2004l\r"]
[41.446945, "o", "\u001b[?2004h> "]
[41.446978, "o", "    \r\n\u001b[?2004l\r"]
[41.447006, "o", "\u001b[?2004h> "]
[41.447038, "o", "    # Read CSV\r\n\u001b[?2004l\r"]
[41.447064, "o", "\u001b[?2004h> "]
[41.447281, "o", "    with open('/home/user/inventory/assets.csv', 'r', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[41.447304, "o", "\u001b[?2004h"]
[41.447335, "o", "> "]
[41.447413, "o", "        reader = csv.DictReader(f)\r\n\u001b[?2004l\r"]
[41.447443, "o", "\u001b[?2004h> "]
[41.447475, "o", "        \r\n\u001b[?2004l\r"]
[41.447503, "o", "\u001b[?2004h> "]
[41.447671, "o", "        for row_num, row in enumerate(reader, start=2):\r\n\u001b[?2004l\r"]
[41.447698, "o", "\u001b[?2004h> "]
[41.447852, "o", "            asset, error = process_row(row, row_num)\r\n\u001b[?2004l\r"]
[41.447887, "o", "\u001b[?2004h> "]
[41.447921, "o", "            \r\n\u001b[?2004l\r"]
[41.447954, "o", "\u001b[?2004h> "]
[41.448014, "o", "            if error:\r\n\u001b[?2004l\r"]
[41.448043, "o", "\u001b[?2004h> "]
[41.448143, "o", "                rejected.append({\r\n\u001b[?2004l\r"]
[41.448177, "o", "\u001b[?2004h> "]
[41.448314, "o", "                    'original_row': dict(row),\r\n\u001b[?2004l\r"]
[41.448349, "o", "\u001b[?2004h> "]
[41.448452, "o", "                    'reason': error,\r\n\u001b[?2004l\r"]
[41.448481, "o", "\u001b[?2004h> "]
[41.448598, "o", "                    'row_number': row_num\r\n\u001b[?2004l\r"]
[41.448627, "o", "\u001b[?2004h"]
[41.448651, "o", "> "]
[41.448697, "o", "                })\r\n\u001b[?2004l\r"]
[41.448726, "o", "\u001b[?2004h> "]
[41.448781, "o", "            else:\r\n\u001b[?2004l\r"]
[41.448808, "o", "\u001b[?2004h"]
[41.448836, "o", "> "]
[41.448925, "o", "                asset_id = asset['id']\r\n\u001b[?2004l\r"]
[41.448951, "o", "\u001b[?2004h"]
[41.44898, "o", "> "]
[41.449007, "o", "                \r\n\u001b[?2004l\r"]
[41.449036, "o", "\u001b[?2004h> "]
[41.449245, "o", "                # Handle duplicates - keep the one with latest purchase date\r\n\u001b[?2004l\r"]
[41.449275, "o", "\u001b[?2004h> "]
[41.449403, "o", "                if asset_id in assets_by_id:\r\n\u001b[?2004l\r"]
[41.449426, "o", "\u001b[?2004h"]
[41.449452, "o", "> "]
[41.449587, "o", "                    existing = assets_by_id[asset_id]\r\n\u001b[?2004l\r"]
[41.449617, "o", "\u001b[?2004h> "]
[41.449836, "o", "                    if asset['purchase_date'] > existing['purchase_date']:\r\n\u001b[?2004l\r"]
[41.449865, "o", "\u001b[?2004h> "]
[41.450019, "o", "                        assets_by_id[asset_id] = asset\r\n\u001b[?2004l\r"]
[41.45005, "o", "\u001b[?2004h> "]
[41.450108, "o", "                else:\r\n\u001b[?2004l\r"]
[41.450137, "o", "\u001b[?2004h> "]
[41.450283, "o", "                    assets_by_id[asset_id] = asset\r\n\u001b[?2004l\r"]
[41.450312, "o", "\u001b[?2004h> "]
[41.450338, "o", "    \r\n\u001b[?2004l\r"]
[41.450362, "o", "\u001b[?2004h> "]
[41.450465, "o", "    # Convert to list and sort by ID\r\n\u001b[?2004l\r"]
[41.450487, "o", "\u001b[?2004h"]
[41.450512, "o", "> "]
[41.450706, "o", "    assets_list = sorted(assets_by_id.values(), key=lambda x: x['id'])\r\n\u001b[?2004l\r"]
[41.450729, "o", "\u001b[?2004h"]
[41.450755, "o", ">     \r\n\u001b[?2004l\r"]
[41.450776, "o", "\u001b[?2004h"]
[41.450805, "o", "> "]
[41.450855, "o", "    # Write assets.json\r\n\u001b[?2004l\r"]
[41.450884, "o", "\u001b[?2004h> "]
[41.451102, "o", "    with open('/home/user/inventory/assets.json', 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[41.45113, "o", "\u001b[?2004h> "]
[41.451253, "o", "        json.dump(assets_list, f, indent=2)\r\n\u001b[?2004l\r"]
[41.451282, "o", "\u001b[?2004h> "]
[41.451308, "o", "    \r\n\u001b[?2004l\r"]
[41.451336, "o", "\u001b[?2004h> "]
[41.451406, "o", "    # Write rejected.json\r\n\u001b[?2004l\r"]
[41.451437, "o", "\u001b[?2004h> "]
[41.451671, "o", "    with open('/home/user/inventory/rejected.json', 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[41.451702, "o", "\u001b[?2004h> "]
[41.451809, "o", "        json.dump(rejected, f, indent=2)\r\n\u001b[?2004l\r"]
[41.451838, "o", "\u001b[?2004h> "]
[41.451864, "o", "    \r\n\u001b[?2004l\r"]
[41.451895, "o", "\u001b[?2004h"]
[41.451922, "o", "> "]
[41.452041, "o", "    print(f\"Processed {len(assets_list)} valid assets\")\r\n\u001b[?2004l\r"]
[41.45207, "o", "\u001b[?2004h> "]
[41.452233, "o", "    print(f\"Rejected {len(rejected)} invalid records\")\r\n\u001b[?2004l\r"]
[41.452263, "o", "\u001b[?2004h> "]
[41.452443, "o", "    print(f\"Deduplicated {len(assets_by_id)} unique asset IDs\")\r\n\u001b[?2004l\r"]
[41.452471, "o", "\u001b[?2004h> "]
[41.452484, "o", "\r\n\u001b[?2004l\r"]
[41.452512, "o", "\u001b[?2004h> "]
[41.452586, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[41.452614, "o", "\u001b[?2004h> "]
[41.452662, "o", "    main()\r\n\u001b[?2004l\r"]
[41.452689, "o", "\u001b[?2004h> "]
[41.452717, "o", "EOF\r\n\u001b[?2004l\r"]
[41.45677, "o", "\u001b[?2004h"]
[41.45681, "o", "user@6a530118e4bf:~/inventory$ "]
[41.531333, "i", "python3 process_assets.py\n"]
[41.531445, "o", "python3 process_assets.py\r\n"]
[41.531482, "o", "\u001b[?2004l\r"]
[41.573371, "o", "Processed 809 valid assets\r\nRejected 16 invalid records\r\nDeduplicated 809 unique asset IDs\r\n"]
[41.577289, "o", "\u001b[?2004h"]
[41.577319, "o", "user@6a530118e4bf:~/inventory$ "]
[49.120244, "i", "ls -lh *.json\n"]
[49.120333, "o", "ls -lh *.json\r\n"]
[49.120375, "o", "\u001b[?2004l\r"]
[49.121591, "o", "-rw-r--r-- 1 user user 146K Apr 29 00:08 assets.json\r\n-rw-r--r-- 1 user user 4.5K Apr 29 00:08 rejected.json\r\n"]
[49.121764, "o", "\u001b[?2004h"]
[49.121802, "o", "user@6a530118e4bf:~/inventory$ "]
