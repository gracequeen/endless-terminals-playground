[74.016752, "i", "python3 << 'EOF'\nimport json\n\n# Validate assets.json\nwith open('/home/user/inventory/assets.json', 'r') as f:\n    assets = json.load(f)\n\nprint(f\"Total assets: {len(assets)}\")\nprint(f\"\\nFirst asset:\")\nprint(json.dumps(assets[0], indent=2))\n\n# Validate all required fields\nrequired_fields = ['id', 'name', 'serial', 'purchase_date', 'price_cents', 'location']\nissues = []\nfor i, asset in enumerate(assets):\n    for field in required_fields:\n        if field not in asset:\n            issues.append(f\"Asset {i} missing field: {field}\")\n    # Validate types\n    if not isinstance(asset.get('price_cents'), int):\n        issues.append(f\"Asset {i} ({asset.get('id')}) price_cents not int: {type(asset.get('price_cents'))}\")\n    if asset.get('price_cents', 0) <= 0:\n        issues.append(f\"Asset {i} ({asset.get('id')}) price_cents not positive: {asset.get('price_cents')}\")\n\nif issues:\n    print(f\"\\nValidation issues found: {len(issues)}\")\n    for issue in issues[:5]:\n        print(f\"  - {issue}\")\nelse:\n    print(\"\\n✓ All ass"]
[74.016874, "i", "ets have required fields and valid data types\")\n\n# Check rejected.json\nwith open('/home/user/inventory/rejected.json', 'r') as f:\n    rejected = json.load(f)\n\nprint(f\"\\nTotal rejected: {len(rejected)}\")\nprint(f\"\\nSample rejection reasons:\")\nfor r in rejected[:3]:\n    print(f\"  - Row {r['row_number']}: {r['reason']}\")\n\nprint(\"\\n✓ JSON files are valid and properly formatted\")\nEOF\n"]
