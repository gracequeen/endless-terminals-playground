[87.648583, "i", "cat > check.py << 'EOF'\n#!/usr/bin/env python3\nimport json\nimport csv\nimport ipaddress\nimport sys\n\ndef parse_port_spec(port_spec):\n    \"\"\"Parse a port specification into a set of allowed ports or a range tuple.\"\"\"\n    port_spec = str(port_spec)\n    if '-' in port_spec:\n        start, end = port_spec.split('-')\n        return ('range', int(start), int(end))\n    else:\n        return ('single', int(port_spec))\n\ndef port_matches(port, port_spec):\n    \"\"\"Check if a port matches a port specification.\"\"\"\n    port = int(port)\n    spec_type, *spec_data = port_spec\n    if spec_type == 'single':\n        return port == spec_data[0]\n    elif spec_type == 'range':\n        return spec_data[0] <= port <= spec_data[1]\n    return False\n\ndef load_firewall_rules(json_path):\n    \"\"\"Load and parse firewall rules from JSON.\"\"\"\n    with open(json_path, 'r') as f:\n        data = json.load(f)\n    \n    rules = []\n    for rule in data['rules']:\n        network = ipaddress.ip_network(rule['source_cidr'])\n        port_spec = parse_port_sp"]
[87.648737, "i", "ec(rule['dest_port'])\n        rules.append({\n            'network': network,\n            'prefix_len': network.prefixlen,\n            'port_spec': port_spec,\n            'action': rule['action'],\n            'source_cidr': rule['source_cidr']\n        })\n    \n    # Sort by prefix length (most specific first)\n    rules.sort(key=lambda r: r['prefix_len'], reverse=True)\n    \n    return rules, data.get('default_action', 'deny')\n\ndef check_connection(src_ip, dest_port, rules, default_action):\n    \"\"\"Check if a connection is allowed by firewall rules.\"\"\"\n    src_addr = ipaddress.ip_address(src_ip)\n    dest_port = int(dest_port)\n    \n    # Find the most specific matching rule\n    for rule in rules:\n        if src_addr in rule['network']:\n            if port_matches(dest_port, rule['port_spec']):\n                return rule['action'] == 'allow', rule['source_cidr']\n    \n    # No matching rule, use default action\n    return default_action == 'allow', None\n\ndef main():\n    rules, default_action = load_firewall_rules('/h"]
[87.648755, "o", "cat > check.py << 'EOF'\r\n\u001b[?2004l\r"]
[87.648822, "i", "ome/user/audit/firewall_rules.json')\n    \n    with open('/home/user/audit/connections.csv', 'r') as f:\n        reader = csv.DictReader(f)\n        for row in reader:\n            src_ip = row['src_ip']\n            dest_port = row['dest_port']\n            \n            allowed, matched_cidr = check_connection(src_ip, dest_port, rules, default_action)\n            \n            if not allowed:\n                if matched_cidr:\n                    print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from {matched_cidr}\")\n                else:\n                    print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from any rule (default deny)\")\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
