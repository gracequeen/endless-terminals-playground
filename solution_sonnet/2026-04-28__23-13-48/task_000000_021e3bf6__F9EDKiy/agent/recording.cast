[20.653616, "i", "cat > /tmp/analyze_mem.sh << 'EOF'\n#!/bin/bash\n\n# Temporary file to store results\ntmp_file=$(mktemp)\n\n# Process each host file\nfor file in /home/user/memstats/host*.txt; do\n    hostname=$(basename \"$file\" .txt)\n    \n    # Extract MemTotal and MemAvailable\n    mem_total=$(grep -E '^MemTotal:' \"$file\" 2>/dev/null | awk '{print $2}')\n    mem_available=$(grep -E '^MemAvailable:' \"$file\" 2>/dev/null | awk '{print $2}')\n    \n    # Skip if we couldn't extract both values (handles corrupted files)\n    if [[ -z \"$mem_total\" ]] || [[ -z \"$mem_available\" ]]; then\n        continue\n    fi\n    \n    # Calculate percentage available\n    percentage=$(awk \"BEGIN {printf \\\"%.2f\\\", ($mem_available / $mem_total) * 100}\")\n    \n    # Filter for less than 20%\n    is_low=$(awk \"BEGIN {print ($percentage < 20) ? 1 : 0}\")\n    \n    if [[ $is_low -eq 1 ]]; then\n        echo -e \"$hostname\\t$percentage\" >> \"$tmp_file\"\n    fi\ndone\n\n# Sort by percentage (ascending = worst first) and write to output\nsort -t$'\\t' -k2 -n \"$tmp_file\" > /home/use"]
[20.653746, "i", "r/low_memory_report.txt\n\n# Clean up\nrm -f \"$tmp_file\"\nEOF\n"]
[20.653802, "o", "cat > /tmp/analyze_mem.sh << 'EOF'"]
