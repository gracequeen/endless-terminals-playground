[129.163672, "i", "cat Makefile\n"]
[129.163793, "o", "cat Makefile\r\n\u001b[?2004l\r"]
[129.164695, "o", ".PHONY: report clean check-config\r\n\r\n# Main target to generate the report\r\nreport: check-config results/status.json\r\n\t@echo \"Monitoring report complete!\"\r\n\r\n# Check if hosts.conf exists\r\ncheck-config:\r\n\t@test -f hosts.conf || (echo \"ERROR: hosts.conf is missing!\" && exit 1)\r\n\t@echo \"Config file found: hosts.conf\"\r\n\r\n# Generate the final JSON report\r\nresults/status.json: results/ping.txt results/ports.txt aggregate.py\r\n\t"]
[129.164821, "o", "@echo \"Aggregating results...\"\r\n\tpython3 aggregate.py\r\n\r\n# Run ping checks\r\nresults/ping.txt: hosts.conf scripts/check_ping.sh\r\n\t@echo \"Running ping checks...\"\r\n\t./scripts/check_ping.sh\r\n\r\n# Run port checks\r\nresults/ports.txt: hosts.conf scripts/check_ports.sh\r\n\t@echo \"Running port checks...\"\r\n\t./scripts/check_ports.sh\r\n\r\n# Clean up results\r\nclean:\r\n\t@echo \"Cleaning up results...\"\r\n\trm -rf results\r\n"]
[129.164906, "o", "\u001b[?2004h"]
[129.164939, "o", "root@be495f476e8d:/home/user/netmon# "]
