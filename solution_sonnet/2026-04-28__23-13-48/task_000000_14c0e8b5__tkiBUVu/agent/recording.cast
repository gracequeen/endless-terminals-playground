[85.989169, "i", "cat > check.py << 'EOF'\n#!/usr/bin/env python3\nimport json\nimport csv\nimport ipaddress\nimport sys\n\ndef parse_port_spec(port_spec):\n    \"\"\"Parse a port specification into a list of allowed ports or a range.\"\"\"\n    port_spec = str(port_spec)\n    if '-' in port_spec:\n        start, end = port_spec.split('-')\n        return ('range', int(start), int(end))\n    else:\n        return ('single', int(port_spec))\n\ndef port_matches(port, port_spec):\n    \"\"\"Check if a port matches a port specification.\"\"\"\n    spec_type, *spec_data = parse_port_spec(port_spec)\n    port = int(port)\n    \n    if spec_type == 'single':\n        return port == spec_data[0]\n    elif spec_type == 'range':\n        return spec_data[0] <= port <= spec_data[1]\n    return False\n\ndef load_firewall_rules(json_path):\n    \"\"\"Load and parse firewall rules from JSON file.\"\"\"\n    with open(json_path, 'r') as f:\n        data = json.load(f)\n    \n    rules = []\n    for rule in data['rules']:\n        network = ipaddress.ip_network(rule['source_cidr'])\n        rul"]
[85.9893, "i", "es.append({\n            'id': rule['id'],\n            'action': rule['action'],\n            'network': network,\n            'prefix_len': network.prefixlen,\n            'dest_port': rule['dest_port']\n        })\n    \n    # Sort by prefix length (most specific first)\n    rules.sort(key=lambda r: r['prefix_len'], reverse=True)\n    \n    return rules, data.get('default_action', 'deny')\n\ndef check_connection(src_ip, dest_port, rules, default_action):\n    \"\"\"Check if a connection is allowed by the firewall rules.\"\"\"\n    ip = ipaddress.ip_address(src_ip)\n    \n    # Find the most specific matching rule\n    for rule in rules:\n        if ip in rule['network']:\n            if port_matches(dest_port, rule['dest_port']):\n                return rule['action'] == 'allow', rule\n    \n    # No matching rule found, apply default action\n    return default_action == 'allow', None\n\ndef main():\n    rules, default_action = load_firewall_rules('/home/user/audit/firewall_rules.json')\n    \n    with open('/home/user/audit/connections.csv"]
[85.989338, "o", "cat > check.py << 'EOF'\r\n\u001b[?2004l\r"]
[85.989377, "i", "', 'r') as f:\n        reader = csv.DictReader(f)\n        \n        for row in reader:\n            src_ip = row['src_ip']\n            dest_port = row['dest_port']\n            \n            allowed, matching_rule = check_connection(src_ip, dest_port, rules, default_action)\n            \n            if not allowed:\n                if matching_rule:\n                    print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from {matching_rule['network']}\")\n                else:\n                    print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from any rule\")\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
