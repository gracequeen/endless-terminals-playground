[?2004l[?2004h> 
[?2004l[?2004h> def parse_port_range(port_str):
[?2004l[?2004h>     """Parse port string into a set of allowed ports or a range tuple."""
[?2004l[?2004h>     port_str = str(port_str).strip()
[?2004l[?2004h>     if '-' in port_str:
[?2004l[?2004h>         start, end = port_str.split('-')
[?2004l[?2004h>         return ('range', int(start), int(end))
[?2004l[?2004h>     else:
[?2004l[?2004h>         return ('single', int(port_str))
[?2004l[?2004h> 
[?2004l[?2004h> def port_matches(dest_port, port_rule):
[?2004l[?2004h>     """Check if destination port matches the rule."""
[?2004l[?2004h>     port_type, *port_data = port_rule
[?2004l[?2004h>     if port_type == 'single':
[?2004l[?2004h>         return dest_port == port_data[0]
[?2004l[?2004h>     elif port_type == 'range':
[?2004l[?2004h>         return port_data[0] <= dest_port <= port_data[1]
[?2004l[?2004h>     return False
[?2004l[?2004h> 
[?2004l[?2004h> def find_matching_rules(src_ip, rules):
[?2004l[?2004h>     """Find all rules that match the source IP, sorted by specificity (most specific first)."""
[?2004l[?2004h>     matching = []
[?2004l[?2004h>     src_ip_obj = ipaddress.ip_address(src_ip)
[?2004l[?2004h>     
[?2004l[?2004h>     for rule in rules:
[?2004l[?2004h>         network = ipaddress.ip_network(rule['source_cidr'])
[?2004l[?2004h>         if src_ip_obj in network:
[?2004l[?2004h>             # Store rule with its network prefix length for sorting
[?2004l[?2004h>             matching.append((network.prefixlen, rule))
[?2004l[?2004h>     
[?2004l[?2004h>     # Sort by prefix length descending (more specific first)
[?2004l[?2004h>     matching.sort(key=lambda x: x[0], reverse=True)
[?2004l[?2004h>     return [rule for _, rule in matching]
[?2004l[?2004h> 
[?2004l[?2004h> def is_connection_allowed(src_ip, dest_port, rules):
[?2004l[?2004h>     """Check if a connection is allowed based on firewall rules."""
