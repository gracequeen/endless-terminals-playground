[28.441204, "i", "cat > check.py << 'EOF'\n#!/usr/bin/env python3\nimport json\nimport csv\nimport ipaddress\nimport sys\n\ndef parse_port_range(port_str):\n    \"\"\"Parse port string into a set of allowed ports or a range tuple.\"\"\"\n    port_str = str(port_str).strip()\n    if '-' in port_str:\n        start, end = port_str.split('-')\n        return ('range', int(start), int(end))\n    else:\n        return ('single', int(port_str))\n\ndef port_matches(dest_port, port_rule):\n    \"\"\"Check if destination port matches the rule.\"\"\"\n    port_type, *port_data = port_rule\n    if port_type == 'single':\n        return dest_port == port_data[0]\n    elif port_type == 'range':\n        return port_data[0] <= dest_port <= port_data[1]\n    return False\n\ndef find_matching_rules(src_ip, rules):\n    \"\"\"Find all rules that match the source IP, sorted by specificity (most specific first).\"\"\"\n    matching = []\n    src_ip_obj = ipaddress.ip_address(src_ip)\n    \n    for rule in rules:\n        network = ipaddress.ip_network(rule['source_cidr'])\n        if src_ip_obj"]
[28.441258, "i", " in network:\n            # Store rule with its network prefix length for sorting\n            matching.append((network.prefixlen, rule))\n    \n    # Sort by prefix length descending (more specific first)\n    matching.sort(key=lambda x: x[0], reverse=True)\n    return [rule for _, rule in matching]\n\ndef is_connection_allowed(src_ip, dest_port, rules):\n    \"\"\"Check if a connection is allowed based on firewall rules.\"\"\"\n    matching_rules = find_matching_rules(src_ip, rules)\n    \n    # Check rules in order of specificity\n    for rule in matching_rules:\n        port_rule = parse_port_range(rule['dest_port'])\n        if port_matches(dest_port, port_rule):\n            # Found a matching rule - check action\n            return rule['action'] == 'allow', rule\n    \n    # No matching rule found - default deny\n    return False, None\n\ndef main():\n    # Load firewall rules\n    with open('/home/user/audit/firewall_rules.json', 'r') as f:\n        config = json.load(f)\n        rules = config['rules']\n    \n    # Load connections\n"]
[28.441371, "i", "    with open('/home/user/audit/connections.csv', 'r') as f:\n        reader = csv.DictReader(f)\n        connections = list(reader)\n    \n    # Check each connection\n    for conn in connections:\n        src_ip = conn['src_ip']\n        dest_port = int(conn['dest_port'])\n        \n        allowed, matching_rule = is_connection_allowed(src_ip, dest_port, rules)\n        \n        if not allowed:\n            if matching_rule:\n                # Explicitly denied by a rule\n                print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from {matching_rule['source_cidr']}\")\n            else:\n                # No matching rule (default deny)\n                print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from any rule\")\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
[28.441413, "o", "cat > check.py << 'EOF'\r\n\u001b[?2004l\r"]
[28.441454, "o", "    with open('/home/user/audit/connections.csv', 'r') as f:\r\n        reader = csv.DictReader(f)\r\n        connections = list(reader)\r\n    \r\n    # Check each connection\r\n    for conn in connections:\r\n        src_ip = conn['src_ip']\r\n        dest_port = int(conn['dest_port'])\r\n        \r\n        allowed, matching_rule = is_connection_allowed(src_ip, dest_port, rules)\r\n        \r\n        if not allowed:\r\n            if matching_rule:\r\n                # Explicitly denied by a rule\r\n               "]
[28.441502, "o", " print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from {matching_rule['source_cidr']}\")\r\n            else:\r\n                # No matching rule (default deny)\r\n                print(f\"BLOCKED: {src_ip}:{dest_port} not allowed from any rule\")\r\n\r\nif __name__ == '__main__':\r\n    main()\r\nEOF\r\n"]
