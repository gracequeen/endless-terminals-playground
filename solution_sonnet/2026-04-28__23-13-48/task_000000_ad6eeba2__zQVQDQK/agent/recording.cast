[92.375424, "i", "python3 << 'EOF'\nimport json\n\n# Validate assets.json\nwith open('/home/user/inventory/assets.json', 'r') as f:\n    assets = json.load(f)\n\nprint(f\"✓ assets.json: Valid JSON array with {len(assets)} records\")\n\n# Check required fields and types\nrequired_fields = {'id', 'name', 'serial', 'purchase_date', 'price_cents', 'location'}\nsample = assets[0]\nprint(f\"✓ Required fields present: {set(sample.keys()) == required_fields}\")\nprint(f\"✓ Sample record fields: {list(sample.keys())}\")\n\n# Validate data types and formats\nimport re\nfrom datetime import datetime\n\nerrors = []\nfor i, asset in enumerate(assets[:10]):  # Check first 10\n    # Check ISO 8601 date\n    try:\n        datetime.strptime(asset['purchase_date'], '%Y-%m-%d')\n    except:\n        errors.append(f\"Record {i}: Invalid date format\")\n    \n    # Check price_cents is positive integer\n    if not isinstance(asset['price_cents'], int) or asset['price_cents'] <= 0:\n        errors.append(f\"Record {i}: Invalid price_cents\")\n    \n    # Check all required fields ar"]
