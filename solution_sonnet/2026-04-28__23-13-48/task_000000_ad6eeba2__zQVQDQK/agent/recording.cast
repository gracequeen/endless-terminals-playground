[35.846093, "i", "cat > /home/user/inventory/process_assets.py << 'EOF'\nimport csv\nimport json\nimport re\nfrom datetime import datetime\nfrom collections import defaultdict\n\ndef parse_date(date_str):\n    \"\"\"Parse multiple date formats and return ISO 8601 string or None.\"\"\"\n    date_str = date_str.strip()\n    \n    # Try YYYY-MM-DD\n    try:\n        dt = datetime.strptime(date_str, '%Y-%m-%d')\n        return dt.strftime('%Y-%m-%d')\n    except ValueError:\n        pass\n    \n    # Try MM/DD/YYYY\n    try:\n        dt = datetime.strptime(date_str, '%m/%d/%Y')\n        return dt.strftime('%Y-%m-%d')\n    except ValueError:\n        pass\n    \n    # Try DD.MM.YYYY\n    try:\n        dt = datetime.strptime(date_str, '%d.%m.%Y')\n        return dt.strftime('%Y-%m-%d')\n    except ValueError:\n        pass\n    \n    return None\n\ndef parse_price(price_str):\n    \"\"\"Parse price and return cents as positive integer or None.\"\"\"\n    try:\n        # Remove dollar signs, commas, and whitespace\n        cleaned = re.sub(r'[$,\\s]', '', price_str.strip())\n        #"]
[35.846214, "i", " Convert to float then to cents\n        price_float = float(cleaned)\n        price_cents = int(round(price_float * 100))\n        # Must be positive\n        if price_cents > 0:\n            return price_cents\n    except (ValueError, AttributeError):\n        pass\n    return None\n\ndef is_serial_number(text):\n    \"\"\"Check if text looks like a serial number.\"\"\"\n    return bool(re.match(r'^SN-[A-Z]+-\\d+$', text.strip()))\n\ndef process_row(row):\n    \"\"\"Process a single row and return (valid_record, error_message).\"\"\"\n    asset_id = row.get('id', '').strip()\n    name = row.get('name', '').strip()\n    serial = row.get('serial', '').strip()\n    purchase_date_raw = row.get('purchase_date', '').strip()\n    price_raw = row.get('price', '').strip()\n    location = row.get('location', '').strip()\n    \n    errors = []\n    \n    # Check if name and serial are swapped\n    if is_serial_number(name) and not is_serial_number(serial):\n        name, serial = serial, name\n    \n    # Validate and parse fields\n    if not asset_id:\n       "]
[35.846252, "i", " errors.append('missing asset id')\n    \n    if not name:\n        errors.append('missing name')\n    \n    if not serial:\n        errors.append('missing serial')\n    \n    purchase_date = parse_date(purchase_date_raw)\n    if not purchase_date:\n        errors.append(f'invalid purchase_date: {purchase_date_raw}')\n    \n    price_cents = parse_price(price_raw)\n    if price_cents is None:\n        errors.append(f'invalid price: {price_raw}')\n    \n    if not location:\n        errors.append('missing location')\n    \n    if errors:\n        return None, '; '.join(errors)\n    \n    return {\n        'id': asset_id,\n        'name': name,\n        'serial': serial,\n        'purchase_date': purchase_date,\n        'price_cents': price_cents,\n        'location': location\n    }, None\n\ndef main():\n    input_file = '/home/user/inventory/assets.csv'\n    output_file = '/home/user/inventory/assets.json'\n    rejected_file = '/home/user/inventory/rejected.json'\n    \n    # Read and process all rows\n    valid_records = defaultdict(list)  # as"]
[35.846281, "i", "set_id -> list of records\n    rejected_records = []\n    \n    with open(input_file, 'r', encoding='utf-8') as f:\n        reader = csv.DictReader(f)\n        for row_num, row in enumerate(reader, start=2):  # start=2 because line 1 is header\n            record, error = process_row(row)\n            \n            if record:\n                valid_records[record['id']].append(record)\n            else:\n                rejected_records.append({\n                    'original_row': dict(row),\n                    'reason': error,\n                    'line_number': row_num\n                })\n    \n    # Deduplicate: keep record with latest purchase_date for each id\n    final_records = []\n    for asset_id, records in valid_records.items():\n        if len(records) == 1:\n            final_records.append(records[0])\n        else:\n            # Sort by purchase_date and keep the latest\n            sorted_records = sorted(records, key=lambda x: x['purchase_date'], reverse=True)\n            final_records.append(sorted_records[0])\n"]
[35.84631, "o", "cat > /home/user/inventory/process_assets.py << 'EOF'\r\n\u001b[?2004l\r"]
[35.846339, "i", "            # Add duplicates to rejected\n            for dup in sorted_records[1:]:\n                rejected_records.append({\n                    'original_row': dup,\n                    'reason': f'duplicate asset_id {asset_id}, keeping record with latest purchase_date',\n                    'line_number': 'N/A'\n                })\n    \n    # Sort final records by id for consistency\n    final_records.sort(key=lambda x: x['id'])\n    \n    # Write output files\n    with open(output_file, 'w', encoding='utf-8') as f:\n        json.dump(final_records, f, indent=2)\n    \n    with open(rejected_file, 'w', encoding='utf-8') as f:\n        json.dump(rejected_records, f, indent=2)\n    \n    print(f'Processed {len(valid_records)} unique asset IDs')\n    print(f'Valid records written to {output_file}: {len(final_records)}')\n    print(f'Rejected records written to {rejected_file}: {len(rejected_records)}')\n\nif __name__ == '__main__':\n    main()\nEOF\n"]
