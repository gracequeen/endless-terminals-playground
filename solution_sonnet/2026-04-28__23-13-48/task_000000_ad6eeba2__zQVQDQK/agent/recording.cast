[35.854972, "o", "    # Check if name and serial are swapped\r\n\u001b[?2004l\r"]
[35.854998, "o", "\u001b[?2004h> "]
[35.85519, "o", "    if is_serial_number(name) and not is_serial_number(serial):\r\n\u001b[?2004l\r"]
[35.85522, "o", "\u001b[?2004h> "]
[35.855323, "o", "        name, serial = serial, name\r\n\u001b[?2004l\r"]
[35.855352, "o", "\u001b[?2004h> "]
[35.855381, "o", "    \r\n\u001b[?2004l\r"]
[35.855408, "o", "\u001b[?2004h> "]
[35.855493, "o", "    # Validate and parse fields\r\n\u001b[?2004l\r"]
[35.855521, "o", "\u001b[?2004h> "]
[35.855583, "o", "    if not asset_id:\r\n\u001b[?2004l\r"]
[35.855623, "o", "\u001b[?2004h> "]
[35.855739, "o", "        errors.append('missing asset id')\r\n\u001b[?2004l\r"]
[35.855762, "o", "\u001b[?2004h"]
[35.85579, "o", ">     \r\n\u001b[?2004l\r"]
[35.85582, "o", "\u001b[?2004h> "]
[35.855866, "o", "    if not name:\r\n\u001b[?2004l\r"]
[35.8559, "o", "\u001b[?2004h> "]
[35.856002, "o", "        errors.append('missing name')\r\n\u001b[?2004l\r"]
[35.856024, "o", "\u001b[?2004h"]
[35.856053, "o", ">     \r\n\u001b[?2004l\r"]
[35.856092, "o", "\u001b[?2004h"]
[35.856123, "o", "> "]
[35.856151, "o", "    if not serial:\r\n\u001b[?2004l\r"]
[35.856183, "o", "\u001b[?2004h> "]
[35.856287, "o", "        errors.append('missing serial')\r\n\u001b[?2004l\r"]
[35.856316, "o", "\u001b[?2004h> "]
[35.856343, "o", "    \r\n\u001b[?2004l\r"]
[35.856371, "o", "\u001b[?2004h> "]
[35.856504, "o", "    purchase_date = parse_date(purchase_date_raw)\r\n\u001b[?2004l\r"]
[35.856532, "o", "\u001b[?2004h> "]
[35.85661, "o", "    if not purchase_date:\r\n\u001b[?2004l\r"]
[35.856639, "o", "\u001b[?2004h> "]
[35.856833, "o", "        errors.append(f'invalid purchase_date: {purchase_date_raw}')\r\n\u001b[?2004l\r"]
[35.856857, "o", "\u001b[?2004h"]
[35.856884, "o", ">     \r\n\u001b[?2004l\r"]
[35.856913, "o", "\u001b[?2004h> "]
[35.857029, "o", "    price_cents = parse_price(price_raw)\r\n\u001b[?2004l\r"]
[35.857057, "o", "\u001b[?2004h> "]
[35.857152, "o", "    if price_cents is None:\r\n\u001b[?2004l\r"]
[35.857173, "o", "\u001b[?2004h"]
[35.8572, "o", "> "]
[35.857331, "o", "        errors.append(f'invalid price: {price_raw}')\r\n\u001b[?2004l\r"]
[35.85736, "o", "\u001b[?2004h> "]
[35.857379, "o", "    \r\n\u001b[?2004l\r"]
[35.857413, "o", "\u001b[?2004h> "]
[35.857471, "o", "    if not location:\r\n\u001b[?2004l\r"]
[35.857499, "o", "\u001b[?2004h> "]
[35.857618, "o", "        errors.append('missing location')\r\n\u001b[?2004l\r"]
[35.857646, "o", "\u001b[?2004h> "]
[35.857675, "o", "    \r\n\u001b[?2004l\r"]
[35.857701, "o", "\u001b[?2004h> "]
[35.857739, "o", "    if errors:\r\n\u001b[?2004l\r"]
[35.857768, "o", "\u001b[?2004h"]
[35.857797, "o", "> "]
[35.857881, "o", "        return None, '; '.join(errors)\r\n\u001b[?2004l\r"]
[35.857909, "o", "\u001b[?2004h> "]
[35.857938, "o", "    \r\n\u001b[?2004l\r"]
[35.857966, "o", "\u001b[?2004h> "]
[35.858, "o", "    return {\r\n\u001b[?2004l\r"]
[35.858026, "o", "\u001b[?2004h> "]
[35.858108, "o", "        'id': asset_id,\r\n\u001b[?2004l\r"]
[35.858143, "o", "\u001b[?2004h> "]
[35.858203, "o", "        'name': name,\r\n\u001b[?2004l\r"]
[35.858229, "o", "\u001b[?2004h> "]
[35.858306, "o", "        'serial': serial,\r\n\u001b[?2004l\r"]
[35.858334, "o", "\u001b[?2004h> "]
[35.858447, "o", "        'purchase_date': purchase_date,\r\n\u001b[?2004l\r"]
[35.858475, "o", "\u001b[?2004h> "]
[35.858579, "o", "        'price_cents': price_cents,\r\n\u001b[?2004l\r"]
[35.858608, "o", "\u001b[?2004h> "]
[35.858691, "o", "        'location': location\r\n\u001b[?2004l\r"]
[35.85872, "o", "\u001b[?2004h> "]
[35.858758, "o", "    }, None\r\n\u001b[?2004l\r"]
[35.858786, "o", "\u001b[?2004h> "]
[35.858814, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[35.858841, "o", "> "]
[35.858869, "o", "def main():\r\n\u001b[?2004l\r"]
[35.858894, "o", "\u001b[?2004h> "]
[35.85903, "o", "    input_file = '/home/user/inventory/assets.csv'\r\n\u001b[?2004l\r"]
[35.859059, "o", "\u001b[?2004h> "]
[35.859221, "o", "    output_file = '/home/user/inventory/assets.json'\r\n\u001b[?2004l\r"]
[35.859257, "o", "\u001b[?2004h> "]
[35.859412, "o", "    rejected_file = '/home/user/inventory/rejected.json'\r\n\u001b[?2004l\r"]
[35.859441, "o", "\u001b[?2004h> "]
[35.859468, "o", "    \r\n\u001b[?2004l\r"]
[35.859497, "o", "\u001b[?2004h> "]
[35.859582, "o", "    # Read and process all rows\r\n\u001b[?2004l\r"]
[35.859609, "o", "\u001b[?2004h> "]
[35.859809, "o", "    valid_records = defaultdict(list)  # asset_id -> list of records\r\n\u001b[?2004l\r"]
[35.859838, "o", "\u001b[?2004h> "]
[35.859916, "o", "    rejected_records = []\r\n\u001b[?2004l\r"]
[35.859946, "o", "\u001b[?2004h> "]
[35.859973, "o", "    \r\n\u001b[?2004l\r"]
[35.859999, "o", "\u001b[?2004h> "]
[35.860153, "o", "    with open(input_file, 'r', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[35.860181, "o", "\u001b[?2004h> "]
[35.860285, "o", "        reader = csv.DictReader(f)\r\n\u001b[?2004l\r"]
[35.860313, "o", "\u001b[?2004h> "]
[35.860566, "o", "        for row_num, row in enumerate(reader, start=2):  # start=2 because line 1 is header\r\n\u001b[?2004l\r"]
[35.860597, "o", "\u001b[?2004h> "]
[35.860724, "o", "            record, error = process_row(row)\r\n\u001b[?2004l\r"]
[35.860753, "o", "\u001b[?2004h> "]
[35.86079, "o", "            \r\n\u001b[?2004l\r"]
[35.860817, "o", "\u001b[?2004h> "]
[35.860886, "o", "            if record:\r\n\u001b[?2004l\r"]
[35.860915, "o", "\u001b[?2004h> "]
[35.86109, "o", "                valid_records[record['id']].append(record)\r\n\u001b[?2004l\r"]
[35.861118, "o", "\u001b[?2004h"]
[35.861147, "o", "> "]
[35.861172, "o", "            else:\r\n\u001b[?2004l\r"]
[35.8612, "o", "\u001b[?2004h> "]
[35.861318, "o", "                rejected_records.append({\r\n\u001b[?2004l\r"]
[35.861347, "o", "\u001b[?2004h> "]
[35.86148, "o", "                    'original_row': dict(row),\r\n\u001b[?2004l\r"]
[35.861508, "o", "\u001b[?2004h> "]
[35.861614, "o", "                    'reason': error,\r\n\u001b[?2004l\r"]
[35.861642, "o", "\u001b[?2004h> "]
[35.861766, "o", "                    'line_number': row_num\r\n\u001b[?2004l\r"]
[35.861796, "o", "\u001b[?2004h> "]
[35.861849, "o", "                })\r\n\u001b[?2004l\r"]
[35.861877, "o", "\u001b[?2004h> "]
[35.861908, "o", "    \r\n\u001b[?2004l\r"]
[35.86194, "o", "\u001b[?2004h> "]
[35.862131, "o", "    # Deduplicate: keep record with latest purchase_date for each id\r\n\u001b[?2004l\r"]
[35.862164, "o", "\u001b[?2004h> "]
[35.862222, "o", "    final_records = []\r\n\u001b[?2004l\r"]
[35.862251, "o", "\u001b[?2004h> "]
[35.862395, "o", "    for asset_id, records in valid_records.items():\r\n\u001b[?2004l\r"]
[35.862424, "o", "\u001b[?2004h> "]
[35.862512, "o", "        if len(records) == 1:\r\n\u001b[?2004l\r"]
[35.86254, "o", "\u001b[?2004h> "]
[35.862665, "o", "            final_records.append(records[0])\r\n\u001b[?2004l\r"]
[35.862695, "o", "\u001b[?2004h> "]
[35.862738, "o", "        else:\r\n\u001b[?2004l\r"]
[35.862766, "o", "\u001b[?2004h> "]
[35.862923, "o", "            # Sort by purchase_date and keep the latest\r\n\u001b[?2004l\r"]
[35.862947, "o", "\u001b[?2004h"]
[35.862974, "o", "> "]
[35.863222, "o", "            sorted_records = sorted(records, key=lambda x: x['purchase_date'], reverse=True)\r\n\u001b[?2004l\r"]
[35.863252, "o", "\u001b[?2004h"]
[35.863281, "o", "> "]
[35.863395, "o", "            final_records.append(sorted_records[0])\r\n\u001b[?2004l\r"]
[35.86343, "o", "\u001b[?2004h"]
[35.863457, "o", "> "]
[35.863538, "o", "            # Add duplicates to rejected\r\n\u001b[?2004l\r"]
[35.863567, "o", "\u001b[?2004h> "]
[35.863696, "o", "            for dup in sorted_records[1:]:\r\n\u001b[?2004l\r"]
[35.863727, "o", "\u001b[?2004h> "]
[35.863846, "o", "                rejected_records.append({\r\n\u001b[?2004l\r"]
[35.863873, "o", "\u001b[?2004h> "]
[35.86399, "o", "                    'original_row': dup,\r\n\u001b[?2004l\r"]
[35.864017, "o", "\u001b[?2004h> "]
[35.864323, "o", "                    'reason': f'duplicate asset_id {asset_id}, keeping record with latest purchase_date',\r\n\u001b[?2004l\r"]
[35.864351, "o", "\u001b[?2004h"]
[35.86438, "o", "> "]
[35.864468, "o", "                    'line_number': 'N/A'\r\n\u001b[?2004l\r"]
[35.864493, "o", "\u001b[?2004h"]
[35.86452, "o", "> "]
[35.864556, "o", "                })\r\n\u001b[?2004l\r"]
[35.864584, "o", "\u001b[?2004h> "]
[35.864611, "o", "    \r\n\u001b[?2004l\r"]
[35.864637, "o", "\u001b[?2004h> "]
[35.864757, "o", "    # Sort final records by id for consistency\r\n\u001b[?2004l\r"]
[35.864785, "o", "\u001b[?2004h> "]
[35.864918, "o", "    final_records.sort(key=lambda x: x['id'])\r\n\u001b[?2004l\r"]
[35.864941, "o", "\u001b[?2004h"]
[35.864968, "o", ">     \r\n\u001b[?2004l\r"]
[35.864996, "o", "\u001b[?2004h> "]
[35.865079, "o", "    # Write output files\r\n\u001b[?2004l\r"]
[35.865105, "o", "\u001b[?2004h"]
[35.865133, "o", "> "]
[35.865281, "o", "    with open(output_file, 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[35.86531, "o", "\u001b[?2004h"]
[35.865334, "o", "> "]
[35.86546, "o", "        json.dump(final_records, f, indent=2)\r\n\u001b[?2004l\r"]
[35.865492, "o", "\u001b[?2004h"]
[35.865519, "o", ">     \r\n\u001b[?2004l\r"]
[35.865547, "o", "\u001b[?2004h"]
[35.865576, "o", "> "]
[35.865724, "o", "    with open(rejected_file, 'w', encoding='utf-8') as f:\r\n"]
[35.865751, "o", "\u001b[?2004l\r\u001b[?2004h"]
[35.865779, "o", "> "]
[35.865906, "o", "        json.dump(rejected_records, f, indent=2)\r\n\u001b[?2004l\r"]
[35.865935, "o", "\u001b[?2004h"]
[35.865961, "o", ">     \r\n"]
[35.865987, "o", "\u001b[?2004l\r\u001b[?2004h"]
[35.866013, "o", "> "]
[35.866192, "o", "    print(f'Processed {len(valid_records)} unique asset IDs')\r\n\u001b[?2004l\r"]
[35.866218, "o", "\u001b[?2004h"]
[35.866248, "o", "> "]
[35.866434, "o", "    print(f'Valid records written to {output_file}: {len(final_records)}')\r\n\u001b[?2004l\r"]
[35.866462, "o", "\u001b[?2004h"]
[35.866497, "o", "> "]
[35.866712, "o", "    print(f'Rejected records written to {rejected_file}: {len(rejected_records)}')\r\n\u001b[?2004l\r"]
[35.86674, "o", "\u001b[?2004h"]
[35.866767, "o", "> \r\n\u001b[?2004l\r"]
[35.866794, "o", "\u001b[?2004h> "]
[35.866868, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[35.866891, "o", "\u001b[?2004h"]
[35.86692, "o", "> "]
[35.866948, "o", "    main()\r\n\u001b[?2004l\r"]
[35.866976, "o", "\u001b[?2004h> "]
[35.867003, "o", "EOF\r\n\u001b[?2004l\r"]
[35.869978, "o", "\u001b[?2004h"]
