[41.569504, "i", "cat > test_fix.py << 'EOF'\n#!/usr/bin/env python3\n\"\"\"Test script to verify the timezone conversion fix.\"\"\"\n\nimport pytz\nfrom datetime import datetime\n\n# Test the problematic time conversion\nBERLIN_TZ = pytz.timezone('Europe/Berlin')\nUTC_TZ = pytz.utc\n\nprint(\"Testing timezone conversions for DST transition...\")\nprint()\n\n# The problematic meeting: 2024-03-31T01:30:00 UTC\n# On March 31, 2024, Berlin switches from CET (UTC+1) to CEST (UTC+2) at 2am\n# So 01:30 UTC should be 03:30 CEST (after the spring forward)\n\nutc_time_str = '2024-03-31T01:30:00'\nprint(f\"UTC time: {utc_time_str}\")\n\n# OLD BUGGY WAY:\nutc_dt_naive = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\nbuggy_berlin = BERLIN_TZ.localize(utc_dt_naive)\nprint(f\"BUGGY conversion (localize as Berlin): {buggy_berlin} - {buggy_berlin.strftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\n\n# NEW CORRECT WAY:\nutc_dt = UTC_TZ.localize(utc_dt_naive)\ncorrect_berlin = utc_dt.astimezone(BERLIN_TZ)\nprint(f\"CORRECT conversion (UTC->Berlin):      {correct_berlin} - {correct_berlin.st"]
[41.569615, "i", "rftime('%Y-%m-%d %H:%M:%S %Z%z')}\")\n\nprint()\nprint(f\"Difference: {(correct_berlin - buggy_berlin).total_seconds() / 3600} hours\")\nprint()\nprint(\"Expected: 2024-03-31 03:30:00 CEST+0200 (after DST spring forward)\")\nEOF\n"]
[41.569702, "o", "cat > test_fix.py << 'EOF'\r\n"]
