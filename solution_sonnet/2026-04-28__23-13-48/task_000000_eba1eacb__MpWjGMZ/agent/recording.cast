[18.539404, "o", "\u001b[?2004l\r"]
[18.540216, "o", "#!/bin/bash\r\nmkdir -p results\r\nwhile read -r host; do\r\n    if ping -c 1 -W 1 \"$host\" &>/dev/null; then\r\n        echo \"$host: up\"\r\n    else\r\n        echo \"$host: down\"\r\n    fi\r\ndone < hosts.conf > results/ping.txt\r\n"]
[18.540365, "o", "\u001b[?2004h"]
[18.5404, "o", "root@a5f57d7c81ae:/home/user/netmon# "]
[18.63368, "i", "cat scripts/check_ports.sh\n"]
[18.633793, "o", "cat scripts/check_ports.sh\r\n"]
[18.633834, "o", "\u001b[?2004l\r"]
[18.634658, "o", "#!/bin/bash\r\nmkdir -p results\r\nwhile read -r host; do\r\n    for port in 22 80 443; do\r\n        timeout 1 bash -c \"echo >/dev/tcp/$host/$port\" 2>/dev/null && status=\"open\" || status=\"closed\"\r\n        echo \"$host:$port $status\"\r\n    done\r\ndone < hosts.conf > results/ports.txt\r\n"]
[18.634793, "o", "\u001b[?2004h"]
[18.634824, "o", "root@a5f57d7c81ae:/home/user/netmon# "]
[18.725779, "i", "cat aggregate.py\n"]
[18.725901, "o", "cat aggregate.py\r\n\u001b[?2004l\r"]
[18.726732, "o", "#!/usr/bin/env python3\r\nimport json\r\n\r\ndef main():\r\n    results = {\"hosts\": {}}\r\n\r\n    with open(\"results/ping.txt\") as f:\r\n        for line in f:\r\n            host, status = line.strip().split(\": \")\r\n            results[\"hosts\"][host] = {\"ping\": status}\r\n\r\n    with open(\"results/ports.txt\") as f:\r\n        for line in f:\r\n            parts = line.strip().split()\r\n            host_port = parts[0].split(\":\")\r\n            host = host_port[0]\r\n            port = host_port[1]\r\n            status = parts[1]\r\n            if host not in results[\"hosts\"]:\r\n                results[\"hosts\"][host] = {}\r\n            if \"ports\" not in results[\"hosts\"][host]:\r\n                results[\"hosts\"][host][\"ports\"] = {}\r\n            results[\"hosts\"][host][\"ports\"][port] = status\r\n\r\n    with open(\"results/status.json\", \"w\") as f\r\n        json.dump(results, f, indent=2)\r\n\r\n    print(\"Report generated: results/status.json\")\r\n\r\nif __name__ == \"__main__\":\r\n    main()\r\n"]
[18.726916, "o", "\u001b[?2004h"]
[18.726949, "o", "root@a5f57d7c81ae:/home/user/netmon# "]
[24.83158, "i", "sed -i 's/with open(\"results\\/status.json\", \"w\") as f$/with open(\"results\\/status.json\", \"w\") as f:/' aggregate.py\n"]
[24.831952, "o", "sed -i 's/with open(\"results\\/status.json\", \"w\") as f$/with open(\"results\\/status.json\", \"w\") as f:/' aggregate.py\r\n\u001b[?2004l\r"]
