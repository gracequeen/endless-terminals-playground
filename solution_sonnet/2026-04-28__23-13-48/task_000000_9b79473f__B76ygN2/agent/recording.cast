[11.900088, "o", "# Archive Validator\r\n\r\nA tool for validating tar.gz backup archives before running integrity checks against production systems.\r\n\r\n## Building\r\n\r\nRun `make build` to compile the validator binary.\r\n\r\n## Dependencies\r\n\r\nThe tool requires:\r\n- libarchive (for archive reading)\r\n- OpenSSL (for checksum verification)\r\n\r\nRun `./deps.sh` to install dependencies.\r\n\r\n## Usage\r\n\r\n```\r\n./bin/validator <archive.tar.gz>\r\n```\r\n\r\n## Notes\r\n\r\nIf system libarchive unavailable, vendor copy is in vendor/libarchive directory.\r\n"]
[11.900257, "o", "\u001b[?2004h"]
[11.900301, "o", "root@9d765d15a67d:/home/user/archive-validator# "]
[16.569271, "i", "make build\n"]
[16.569401, "o", "make build\r\n\u001b[?2004l\r"]
[16.571111, "o", "gcc -Wall -I/usr/local/include -o bin/validator src/main.c src/checksum.c -L/usr/local/lib -larchive -lcrypto\r\n"]
[16.585996, "o", "\u001b[01m\u001b[Ksrc/main.c:4:10:\u001b[m\u001b[K \u001b[01;31m\u001b[Kfatal error: \u001b[m\u001b[Karchive.h: No such file or directory\r\n    4 | #include \u001b[01;31m\u001b[K<archive.h>\u001b[m\u001b[K\r\n      |          \u001b[01;31m\u001b[K^~~~~~~~~~~\u001b[m\u001b[K\r\ncompilation terminated.\r\n"]
