[32.504499, "i", "cat > process_memory.sh << 'EOF'\n#!/bin/bash\n\n# Temporary file for collecting results\ntempfile=$(mktemp)\n\n# Process each host file\nfor file in /home/user/memstats/host*.txt; do\n    hostname=$(basename \"$file\" .txt)\n    \n    # Extract MemTotal and MemAvailable, handling missing values gracefully\n    memtotal=$(grep -oP '^MemTotal:\\s+\\K\\d+' \"$file\" 2>/dev/null)\n    memavail=$(grep -oP '^MemAvailable:\\s+\\K\\d+' \"$file\" 2>/dev/null)\n    \n    # Skip if either value is missing or invalid\n    if [[ -z \"$memtotal\" ]] || [[ -z \"$memavail\" ]] || [[ \"$memtotal\" -eq 0 ]]; then\n        continue\n    fi\n    \n    # Calculate percentage available using awk\n    percent=$(awk \"BEGIN {printf \\\"%.2f\\\", ($memavail * 100) / $memtotal}\")\n    \n    # Check if less than 20% using awk\n    is_low=$(awk \"BEGIN {print ($percent < 20) ? 1 : 0}\")\n    \n    if [[ \"$is_low\" -eq 1 ]]; then\n        echo -e \"$hostname\\t$percent\" >> \"$tempfile\"\n    fi\ndone\n\n# Sort by percentage (ascending = worst first) and write to report\nsort -t$'\\t' -k2 -n \"$temp"]
[32.504629, "i", "file\" > /home/user/low_memory_report.txt\n\n# Clean up\nrm -f \"$tempfile\"\nEOF\n"]
