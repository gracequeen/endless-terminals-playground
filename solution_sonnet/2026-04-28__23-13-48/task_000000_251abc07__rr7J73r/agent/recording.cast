[24.329044, "i", "awk '\n/\\/api\\/v[0-9]+\\/internal\\// && $1 !~ /^10\\./ {\n  # Parse timestamp [05/Dec/2024:10:07:16 +0000]\n  split($4, dt, /[:\\/\\[\\]]/);\n  day = dt[2];\n  month = dt[3];\n  year = dt[4];\n  time = dt[5] \":\" dt[6] \":\" dt[7];\n  \n  # Convert month name to number\n  months[\"Jan\"]=\"01\"; months[\"Feb\"]=\"02\"; months[\"Mar\"]=\"03\"; months[\"Apr\"]=\"04\";\n  months[\"May\"]=\"05\"; months[\"Jun\"]=\"06\"; months[\"Jul\"]=\"07\"; months[\"Aug\"]=\"08\";\n  months[\"Sep\"]=\"09\"; months[\"Oct\"]=\"10\"; months[\"Nov\"]=\"11\"; months[\"Dec\"]=\"12\";\n  \n  iso_timestamp = year \"-\" months[month] \"-\" sprintf(\"%02d\", day) \"T\" time;\n  \n  # Reconstruct line with ISO timestamp\n  printf \"%s - - %s \", $1, iso_timestamp;\n  for(i=6; i<=NF; i++) printf \"%s%s\", $i, (i<NF ? \" \" : \"\\n\");\n}\n' /var/log/app/access.log > /home/user/internal_hits.log\n"]
