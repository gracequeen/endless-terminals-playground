[18.617498, "i", "cat > /tmp/process_memstats.sh << 'EOF'\n#!/bin/bash\n\nfor file in /home/user/memstats/host*.txt; do\n    hostname=$(basename \"$file\" .txt)\n    \n    # Extract MemTotal and MemAvailable, handling missing values\n    memtotal=$(grep -E '^MemTotal:' \"$file\" 2>/dev/null | awk '{print $2}')\n    memavail=$(grep -E '^MemAvailable:' \"$file\" 2>/dev/null | awk '{print $2}')\n    \n    # Skip if either value is missing or empty\n    if [[ -z \"$memtotal\" ]] || [[ -z \"$memavail\" ]] || [[ \"$memtotal\" -eq 0 ]]; then\n        continue\n    fi\n    \n    # Calculate percentage available\n    percentage=$(awk -v avail=\"$memavail\" -v total=\"$memtotal\" 'BEGIN {printf \"%.2f\", (avail/total)*100}')\n    \n    # Check if less than 20%\n    if (( $(awk -v p=\"$percentage\" 'BEGIN {print (p < 20)}') )); then\n        echo -e \"${hostname}\\t${percentage}\"\n    fi\ndone | sort -t$'\\t' -k2 -n\nEOF\n"]
[18.617663, "o", "cat > /tmp/process_memstats.sh << 'EOF'\r\n"]
[18.617709, "o", "\u001b[?2004l\r\u001b[?2004h"]
