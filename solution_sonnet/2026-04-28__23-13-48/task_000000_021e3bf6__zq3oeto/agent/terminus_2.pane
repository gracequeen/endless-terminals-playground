MemAvai[?2004huser@4b0c3ffdd54c:~$ cat > /tmp/process_memstats.sh << 'EOF'
[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> for file in /home/user/memstats/host*.txt; do
[?2004l[?2004h>     hostname=$(basename "$file" .txt)
[?2004l[?2004h>     
[?2004l[?2004h>     # Extract MemTotal and MemAvailable, handling missing values
[?2004l[?2004h>     memtotal=$(grep -E '^MemTotal:' "$file" 2>/dev/null | awk '{print $2}')
[?2004l[?2004h>     memavail=$(grep -E '^MemAvailable:' "$file" 2>/dev/null | awk '{print $2}')
[?2004l[?2004h>     
[?2004l[?2004h>     # Skip if either value is missing or empty
[?2004l[?2004h>     if [[ -z "$memtotal" ]] || [[ -z "$memavail" ]] || [[ "$memtotal" -eq 0 ]]; then
[?2004l[?2004h>         continue
[?2004l[?2004h>     fi
[?2004l[?2004h>     
[?2004l[?2004h>     # Calculate percentage available
[?2004l[?2004h>     percentage=$(awk -v avail="$memavail" -v total="$memtotal" 'BEGIN {printf "%.2f", (avail/total)*100}')
[?2004l[?2004h>     
[?2004l[?2004h>     # Check if less than 20%
[?2004l[?2004h>     if (( $(awk -v p="$percentage" 'BEGIN {print (p < 20)}') )); then
[?2004l[?2004h>         echo -e "${hostname}\t${percentage}"
[?2004l[?2004h>     fi
[?2004l[?2004h> done | sort -t$'\t' -k2 -n
[?2004l[?2004h> EOF
