[39.90037, "o", "> "]
[39.900542, "o", "        dt = datetime.strptime(date_str, '%d.%m.%Y')\r\n\u001b[?2004l\r"]
[39.900571, "o", "\u001b[?2004h> "]
[39.900683, "o", "        return dt.strftime('%Y-%m-%d')\r\n\u001b[?2004l\r"]
[39.90071, "o", "\u001b[?2004h> "]
[39.900787, "o", "    except ValueError:\r\n\u001b[?2004l\r"]
[39.900826, "o", "\u001b[?2004h> "]
[39.900859, "o", "        pass\r\n\u001b[?2004l\r"]
[39.900887, "o", "\u001b[?2004h> "]
[39.900913, "o", "    \r\n\u001b[?2004l\r"]
[39.900938, "o", "\u001b[?2004h> "]
[39.90098, "o", "    return None\r\n\u001b[?2004l\r"]
[39.901007, "o", "\u001b[?2004h"]
[39.901033, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[39.901062, "o", "> "]
[39.901124, "o", "def parse_price(price_str):\r\n\u001b[?2004l\r"]
[39.901149, "o", "\u001b[?2004h> "]
[39.901346, "o", "    \"\"\"Parse price string and return cents as integer or None\"\"\"\r\n"]
[39.901379, "o", "\u001b[?2004l\r\u001b[?2004h"]
[39.901406, "o", "> "]
[39.901425, "o", "    try:\r\n\u001b[?2004l\r"]
[39.901461, "o", "\u001b[?2004h> "]
[39.901594, "o", "        # Remove dollar signs, commas, and whitespace\r\n\u001b[?2004l\r"]
[39.901615, "o", "\u001b[?2004h"]
[39.901644, "o", "> "]
[39.901789, "o", "        cleaned = re.sub(r'[$,\\s]', '', price_str.strip())\r\n\u001b[?2004l\r"]
[39.901816, "o", "\u001b[?2004h"]
[39.901842, "o", "> "]
[39.901936, "o", "        # Convert to float then to cents\r\n\u001b[?2004l\r"]
[39.901962, "o", "\u001b[?2004h> "]
[39.90207, "o", "        price_float = float(cleaned)\r\n\u001b[?2004l\r"]
[39.902103, "o", "\u001b[?2004h> "]
[39.902262, "o", "        price_cents = int(round(price_float * 100))\r\n\u001b[?2004l\r"]
[39.902299, "o", "\u001b[?2004h"]
[39.902333, "o", "> "]
[39.902374, "o", "        # Must be positive\r\n\u001b[?2004l\r"]
[39.902405, "o", "\u001b[?2004h"]
[39.902437, "o", "> "]
[39.902486, "o", "        if price_cents > 0:\r\n\u001b[?2004l\r"]
[39.902515, "o", "\u001b[?2004h"]
[39.902549, "o", "> "]
[39.902605, "o", "            return price_cents\r\n\u001b[?2004l\r"]
[39.902635, "o", "\u001b[?2004h> "]
[39.902751, "o", "    except (ValueError, AttributeError):\r\n\u001b[?2004l\r"]
[39.902792, "o", "\u001b[?2004h> "]
[39.902828, "o", "        pass\r\n\u001b[?2004l\r"]
[39.902859, "o", "\u001b[?2004h> "]
[39.9029, "o", "    return None\r\n\u001b[?2004l\r"]
[39.902925, "o", "\u001b[?2004h"]
[39.902936, "o", "> \r\n\u001b[?2004l\r"]
[39.902978, "o", "\u001b[?2004h> "]
[39.903028, "o", "def process_row(row):\r\n\u001b[?2004l\r"]
[39.903058, "o", "\u001b[?2004h"]
[39.90309, "o", "> "]
[39.903278, "o", "    \"\"\"Process a single row and return (processed_dict, error_message)\"\"\"\r\n\u001b[?2004l\r"]
[39.90332, "o", "\u001b[?2004h> "]
[39.903351, "o", "    try:\r\n\u001b[?2004l\r"]
[39.903381, "o", "\u001b[?2004h> "]
[39.903492, "o", "        asset_id = row.get('id', '').strip()\r\n\u001b[?2004l\r"]
[39.903528, "o", "\u001b[?2004h> "]
[39.903647, "o", "        name = row.get('name', '').strip()\r\n\u001b[?2004l\r"]
[39.903683, "o", "\u001b[?2004h> "]
[39.903807, "o", "        serial = row.get('serial', '').strip()\r\n\u001b[?2004l\r"]
[39.903851, "o", "\u001b[?2004h"]
[39.903885, "o", "> "]
[39.904018, "o", "        purchase_date_raw = row.get('purchase_date', '').strip()\r\n\u001b[?2004l\r"]
[39.904056, "o", "\u001b[?2004h> "]
[39.904201, "o", "        price_raw = row.get('price', '').strip()\r\n\u001b[?2004l\r"]
[39.904231, "o", "\u001b[?2004h> "]
[39.90437, "o", "        location = row.get('location', '').strip()\r\n\u001b[?2004l\r"]
[39.9044, "o", "\u001b[?2004h> "]
[39.904427, "o", "        \r\n\u001b[?2004l\r"]
[39.904462, "o", "\u001b[?2004h> "]
[39.904671, "o", "        # Check if serial and name are swapped (serial should start with SN-)\r\n\u001b[?2004l\r"]
[39.9047, "o", "\u001b[?2004h> "]
[39.904927, "o", "        if serial and not serial.startswith('SN-') and name.startswith('SN-'):\r\n\u001b[?2004l\r"]
[39.904959, "o", "\u001b[?2004h> "]
[39.90507, "o", "            serial, name = name, serial\r\n\u001b[?2004l\r"]
[39.905095, "o", "\u001b[?2004h> "]
[39.905128, "o", "        \r\n\u001b[?2004l\r"]
[39.905149, "o", "\u001b[?2004h"]
[39.905195, "o", "> "]
[39.905288, "o", "        # Validate required fields exist\r\n\u001b[?2004l\r"]
[39.905318, "o", "\u001b[?2004h> "]
[39.905392, "o", "        if not asset_id:\r\n\u001b[?2004l\r"]
[39.905419, "o", "\u001b[?2004h> "]
[39.905546, "o", "            return None, \"Missing asset ID\"\r\n\u001b[?2004l\r"]
[39.905571, "o", "\u001b[?2004h> "]
[39.905634, "o", "        if not name:\r\n\u001b[?2004l\r"]
[39.905661, "o", "\u001b[?2004h> "]
[39.905776, "o", "            return None, \"Missing name\"\r\n\u001b[?2004l\r"]
[39.905801, "o", "\u001b[?2004h> "]
[39.90587, "o", "        if not serial:\r\n\u001b[?2004l\r"]
[39.905898, "o", "\u001b[?2004h> "]
[39.906016, "o", "            return None, \"Missing serial\"\r\n\u001b[?2004l\r"]
[39.906045, "o", "\u001b[?2004h> "]
[39.906118, "o", "        if not location:\r\n\u001b[?2004l\r"]
[39.906145, "o", "\u001b[?2004h> "]
[39.906286, "o", "            return None, \"Missing location\"\r\n\u001b[?2004l\r"]
[39.906316, "o", "\u001b[?2004h> "]
[39.906345, "o", "        \r\n\u001b[?2004l\r"]
[39.906369, "o", "\u001b[?2004h"]
[39.906396, "o", "> "]
[39.906442, "o", "        # Parse date\r\n\u001b[?2004l\r"]
[39.906469, "o", "\u001b[?2004h> "]
[39.906623, "o", "        purchase_date = parse_date(purchase_date_raw)\r\n\u001b[?2004l\r"]
[39.906656, "o", "\u001b[?2004h"]
[39.906682, "o", "> "]
[39.906739, "o", "        if not purchase_date:\r\n\u001b[?2004l\r"]
[39.906766, "o", "\u001b[?2004h> "]
[39.90696, "o", "            return None, f\"Invalid date format: {purchase_date_raw}\"\r\n\u001b[?2004l\r"]
[39.906986, "o", "\u001b[?2004h> "]
[39.907016, "o", "        \r\n\u001b[?2004l\r"]
[39.907042, "o", "\u001b[?2004h"]
[39.907069, "o", "> "]
[39.90711, "o", "        # Parse price\r\n\u001b[?2004l\r"]
[39.907137, "o", "\u001b[?2004h> "]
[39.90728, "o", "        price_cents = parse_price(price_raw)\r\n\u001b[?2004l\r"]
[39.90731, "o", "\u001b[?2004h> "]
[39.9074, "o", "        if price_cents is None:\r\n\u001b[?2004l\r"]
[39.907428, "o", "\u001b[?2004h> "]
[39.907584, "o", "            return None, f\"Invalid price: {price_raw}\"\r\n\u001b[?2004l\r"]
[39.907612, "o", "\u001b[?2004h"]
[39.90764, "o", ">         \r\n\u001b[?2004l\r"]
[39.907669, "o", "\u001b[?2004h"]
[39.907696, "o", "> "]
[39.907768, "o", "        # Create processed record\r\n\u001b[?2004l\r"]
[39.907797, "o", "\u001b[?2004h> "]
[39.907863, "o", "        processed = {\r\n\u001b[?2004l\r"]
[39.907892, "o", "\u001b[?2004h> "]
[39.907973, "o", "            'id': asset_id,\r\n\u001b[?2004l\r"]
[39.908003, "o", "\u001b[?2004h> "]
[39.908079, "o", "            'name': name,\r\n\u001b[?2004l\r"]
[39.908107, "o", "\u001b[?2004h> "]
[39.908209, "o", "            'serial': serial,\r\n\u001b[?2004l\r"]
[39.908237, "o", "\u001b[?2004h> "]
[39.908367, "o", "            'purchase_date': purchase_date,\r\n\u001b[?2004l\r"]
[39.908399, "o", "\u001b[?2004h> "]
[39.908505, "o", "            'price_cents': price_cents,\r\n\u001b[?2004l\r"]
[39.908529, "o", "\u001b[?2004h"]
[39.908557, "o", "> "]
[39.908629, "o", "            'location': location\r\n\u001b[?2004l\r"]
[39.908653, "o", "\u001b[?2004h"]
[39.908681, "o", "> "]
[39.908711, "o", "        }\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.908743, "o", "> "]
[39.90877, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h"]
[39.908797, "o", "> "]
[39.90887, "o", "        return processed, None\r\n\u001b[?2004l\r"]
[39.908894, "o", "\u001b[?2004h"]
[39.908923, "o", ">         \r\n"]
[39.908958, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[39.909035, "o", "    except Exception as e:\r\n\u001b[?2004l\r"]
[39.909064, "o", "\u001b[?2004h> "]
[39.909222, "o", "        return None, f\"Processing error: {str(e)}\"\r\n\u001b[?2004l\r"]
[39.909247, "o", "\u001b[?2004h"]
[39.909276, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[39.909304, "o", "> "]
[39.909333, "o", "def main():\r\n\u001b[?2004l\r"]
[39.909361, "o", "\u001b[?2004h> "]
[39.909456, "o", "    assets_by_id = defaultdict(list)\r\n\u001b[?2004l\r"]
[39.909485, "o", "\u001b[?2004h> "]
[39.909541, "o", "    rejected = []\r\n\u001b[?2004l\r"]
[39.909569, "o", "\u001b[?2004h> "]
[39.909594, "o", "    \r\n\u001b[?2004l\r"]
[39.909621, "o", "\u001b[?2004h> "]
[39.909675, "o", "    # Read CSV file\r\n\u001b[?2004l\r"]
[39.909708, "o", "\u001b[?2004h> "]
[39.909919, "o", "    with open('/home/user/inventory/assets.csv', 'r', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[39.909948, "o", "\u001b[?2004h> "]
[39.910048, "o", "        reader = csv.DictReader(f)\r\n\u001b[?2004l\r"]
[39.910076, "o", "\u001b[?2004h> "]
[39.910349, "o", "        for row_num, row in enumerate(reader, start=2):  # start=2 because header is line 1\r\n\u001b[?2004l\r"]
[39.910374, "o", "\u001b[?2004h"]
[39.9104, "o", "> "]
[39.910515, "o", "            processed, error = process_row(row)\r\n\u001b[?2004l\r"]
[39.910549, "o", "\u001b[?2004h> "]
[39.910583, "o", "            \r\n\u001b[?2004l\r"]
[39.910613, "o", "\u001b[?2004h> "]
[39.910676, "o", "            if error:\r\n\u001b[?2004l\r"]
[39.910704, "o", "\u001b[?2004h> "]
[39.910802, "o", "                rejected.append({\r\n\u001b[?2004l\r"]
[39.91083, "o", "\u001b[?2004h> "]
[39.910966, "o", "                    'original_row': dict(row),\r\n\u001b[?2004l\r"]
[39.910995, "o", "\u001b[?2004h> "]
[39.911101, "o", "                    'reason': error,\r\n\u001b[?2004l\r"]
[39.911129, "o", "\u001b[?2004h> "]
[39.911266, "o", "                    'line_number': row_num\r\n\u001b[?2004l\r"]
[39.911295, "o", "\u001b[?2004h> "]
[39.911354, "o", "                })\r\n\u001b[?2004l\r"]
[39.911377, "o", "\u001b[?2004h"]
[39.911405, "o", "> "]
[39.911434, "o", "            else:\r\n\u001b[?2004l\r"]
[39.911459, "o", "\u001b[?2004h> "]
[39.911612, "o", "                # Group by asset ID for deduplication\r\n\u001b[?2004l\r"]
[39.911641, "o", "\u001b[?2004h> "]
[39.911819, "o", "                assets_by_id[processed['id']].append(processed)\r\n\u001b[?2004l\r"]
[39.911851, "o", "\u001b[?2004h"]
[39.911877, "o", ">     \r\n\u001b[?2004l\r"]
[39.911902, "o", "\u001b[?2004h> "]
[39.91207, "o", "    # Deduplicate: keep the one with the latest purchase date\r\n\u001b[?2004l\r"]
[39.912099, "o", "\u001b[?2004h"]
[39.912126, "o", "> "]
[39.912176, "o", "    final_assets = []\r\n\u001b[?2004l\r"]
[39.912209, "o", "\u001b[?2004h> "]
[39.91235, "o", "    for asset_id, records in assets_by_id.items():\r\n\u001b[?2004l\r"]
[39.912372, "o", "\u001b[?2004h"]
[39.9124, "o", "> "]
[39.912467, "o", "        if len(records) == 1:\r\n\u001b[?2004l\r"]
[39.912495, "o", "\u001b[?2004h> "]
[39.912618, "o", "            final_assets.append(records[0])\r\n\u001b[?2004l\r"]
[39.912642, "o", "\u001b[?2004h"]
[39.912671, "o", "> "]
[39.912698, "o", "        else:\r\n\u001b[?2004l\r"]
[39.912733, "o", "\u001b[?2004h> "]
[39.912934, "o", "            # Sort by purchase_date descending and take the first (latest)\r\n\u001b[?2004l\r"]
[39.912964, "o", "\u001b[?2004h> "]
[39.91318, "o", "            records.sort(key=lambda x: x['purchase_date'], reverse=True)\r\n\u001b[?2004l\r"]
[39.913217, "o", "\u001b[?2004h> "]
[39.913335, "o", "            final_assets.append(records[0])\r\n\u001b[?2004l\r"]
[39.913359, "o", "\u001b[?2004h"]
[39.913388, "o", ">     \r\n\u001b[?2004l\r"]
[39.913421, "o", "\u001b[?2004h"]
[39.91345, "o", "> "]
[39.913523, "o", "    # Sort by ID for consistent output\r\n\u001b[?2004l\r"]
[39.913552, "o", "\u001b[?2004h> "]
[39.91368, "o", "    final_assets.sort(key=lambda x: x['id'])\r\n\u001b[?2004l\r"]
[39.91371, "o", "\u001b[?2004h> "]
[39.913741, "o", "    \r\n\u001b[?2004l\r"]
[39.913769, "o", "\u001b[?2004h> "]
[39.913832, "o", "    # Write assets.json\r\n\u001b[?2004l\r"]
[39.913861, "o", "\u001b[?2004h> "]
[39.914081, "o", "    with open('/home/user/inventory/assets.json', 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[39.91411, "o", "\u001b[?2004h> "]
[39.914252, "o", "        json.dump(final_assets, f, indent=2)\r\n\u001b[?2004l\r"]
[39.914274, "o", "\u001b[?2004h"]
[39.914301, "o", ">     \r\n\u001b[?2004l\r"]
[39.914325, "o", "\u001b[?2004h"]
[39.914351, "o", "> "]
[39.914404, "o", "    # Write rejected.json\r\n\u001b[?2004l\r"]
[39.914433, "o", "\u001b[?2004h> "]
[39.914656, "o", "    with open('/home/user/inventory/rejected.json', 'w', encoding='utf-8') as f:\r\n\u001b[?2004l\r"]
[39.914685, "o", "\u001b[?2004h> "]
[39.914805, "o", "        json.dump(rejected, f, indent=2)\r\n\u001b[?2004l\r"]
[39.914834, "o", "\u001b[?2004h> "]
[39.914861, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[39.914888, "o", "> "]
[39.915035, "o", "    print(f\"Processed {len(final_assets)} valid assets\")\r\n\u001b[?2004l\r"]
[39.915058, "o", "\u001b[?2004h"]
[39.915087, "o", "> "]
[39.915225, "o", "    print(f\"Rejected {len(rejected)} invalid rows\")\r\n\u001b[?2004l\r"]
[39.915253, "o", "\u001b[?2004h> "]
[39.915606, "o", "    print(f\"Deduplicated {sum(len(records) - 1 for records in assets_by_id.values() if len(records) > 1)} duplicate records\")\r\n\u001b[?2004l\r"]
[39.915633, "o", "\u001b[?2004h"]
[39.915661, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[39.91569, "o", "> "]
[39.915749, "o", "if __name__ == '__main__':\r\n\u001b[?2004l\r"]
[39.915777, "o", "\u001b[?2004h> "]
[39.915815, "o", "    main()\r\n\u001b[?2004l\r"]
[39.915843, "o", "\u001b[?2004h> "]
[39.915878, "o", "EOF\r\n\u001b[?2004l\r"]
[39.918675, "o", "\u001b[?2004h"]
[39.918692, "o", "user@a426479a43b1:~/inventory$ "]
[39.992549, "i", "python3 process_assets.py\n"]
[39.992655, "o", "python3 process_assets.py\r\n\u001b[?2004l\r"]
[40.03513, "o", "Processed 809 valid assets\r\nRejected 16 invalid rows\r\n"]
[40.035213, "o", "Deduplicated 21 duplicate records\r\n"]
[40.039075, "o", "\u001b[?2004h"]
