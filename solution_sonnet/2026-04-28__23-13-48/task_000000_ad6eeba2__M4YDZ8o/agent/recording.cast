[90.823938, "i", "cat > validate.py << 'EOF'\nimport json\nimport re\n\nwith open('assets.json') as f:\n    data = json.load(f)\n\nprint(f'Total assets: {len(data)}')\nprint(f'Sample record: {data[0]}')\n\nrequired_fields = {'id', 'name', 'serial', 'purchase_date', 'price_cents', 'location'}\nall_valid_fields = all(set(d.keys()) == required_fields for d in data)\nprint(f'All have required fields: {all_valid_fields}')\n\nall_positive_prices = all(isinstance(d['price_cents'], int) and d['price_cents'] > 0 for d in data)\nprint(f'All price_cents are positive integers: {all_positive_prices}')\n\niso_pattern = re.compile(r'^\\d{4}-\\d{2}-\\d{2}$')\nall_iso_dates = all(iso_pattern.match(d['purchase_date']) for d in data)\nprint(f'All dates are ISO 8601: {all_iso_dates}')\n\nprint('\\n✓ Validation passed! All records meet requirements.')\nEOF\n"]
