[47.820934, "o", "[\r\n  {\r\n    \"id\": \"AST-00001\",\r\n    \"name\": \"Whiteboard Digital\",\r\n    \"serial\": \"SN-QQB-00002\",\r\n    \"purchase_date\": \"2023-10-08\",\r\n    \"price_cents\": 381700,\r\n    \"location\": \"Warehouse A\"\r\n  },\r\n  {\r\n    \"id\": \"AST-00002\",\r\n    \"name\": \"Headset Bluetooth\",\r\n    \"serial\": \"SN-DLP-00003\",\r\n    \"purchase_date\": \"2017-11-15\",\r\n    \"price_cents\": 279400,\r\n    \"location\": \"Building C\"\r\n  },\r\n  {\r\n"]
