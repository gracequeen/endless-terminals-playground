[?2004huser@9221fc7b5358:~$ cat > /home/user/backup.sh << 'EOF'
[?2004l[?2004h> #!/bin/bash
[?2004l[?2004h> 
[?2004l[?2004h> # Backup script that handles permission issues gracefully
[?2004l[?2004h> SOURCE_DIR="/home/user/projects"
[?2004l[?2004h> BACKUP_DIR="/home/user/backups"
[?2004l[?2004h> MANIFEST="$BACKUP_DIR/manifest.txt"
[?2004l[?2004h> 
[?2004l[?2004h> # Clear/create manifest
[?2004l[?2004h> > "$MANIFEST"
[?2004l[?2004h> 
[?2004l[?2004h> # Find all readable files, suppress errors
[?2004l[?2004h> find "$SOURCE_DIR" -type f 2>/dev/null | while read -r file; do
[?2004l[?2004h>     # Try to read the file (test if we actually have read access)
[?2004l[?2004h>     if cat "$file" > /dev/null 2>&1; then
[?2004l[?2004h>         # Get relative path
[?2004l[?2004h>         rel_path="${file#$SOURCE_DIR/}"
[?2004l[?2004h>         dest_file="$BACKUP_DIR/$rel_path"
[?2004l[?2004h>         dest_dir="$(dirname "$dest_file")"
[?2004l[?2004h>         
[?2004l[?2004h>         # Create destination directory structure
[?2004l[?2004h>         mkdir -p "$dest_dir" 2>/dev/null
[?2004l[?2004h>         
[?2004l[?2004h>         # Copy the file
[?2004l[?2004h>         if cp "$file" "$dest_file" 2>/dev/null; then
[?2004l[?2004h>             # Get owner:group info
[?2004l[?2004h>             owner_info=$(stat -c '%U:%G' "$file" 2>/dev/null)
[?2004l[?2004h>             if [ -n "$owner_info" ]; then
[?2004l[?2004h>                 echo "$rel_path $owner_info" >> "$MANIFEST"
[?2004l[?2004h>             fi
[?2004l[?2004h>         fi
[?2004l[?2004h>     fi
[?2004l[?2004h> done
[?2004l[?2004h> 
[?2004l[?2004h> echo "Backup complete. Manifest written to $MANIFEST"
[?2004l[?2004h> EOF
