[48.650621, "i", "cat > test_fix.py << 'EOF'\n#!/usr/bin/env python3\n\"\"\"Test to verify the timezone conversion fix.\"\"\"\n\nimport pytz\nfrom datetime import datetime\n\nBERLIN_TZ = pytz.timezone('Europe/Berlin')\nUTC_TZ = pytz.utc\n\n# Test case: UTC 01:30:00 on March 31, 2024\n# This is during the DST transition in Europe/Berlin\n# Should convert to 2024-03-31 02:30:00 CEST (UTC+2)\nutc_time_str = '2024-03-31T01:30:00'\n\nprint(\"Testing timezone conversion for DST transition...\")\nprint(f\"UTC time: {utc_time_str}\")\nprint()\n\n# OLD (BUGGY) METHOD:\nprint(\"OLD METHOD (buggy):\")\nutc_dt_old = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\nberlin_dt_old = BERLIN_TZ.localize(utc_dt_old)\nprint(f\"  Result: {berlin_dt_old.strftime('%Y-%m-%d %H:%M:%S %Z (UTC%z)')}\")\nprint(f\"  This incorrectly treats UTC time as if it were Berlin time!\")\nprint()\n\n# NEW (FIXED) METHOD:\nprint(\"NEW METHOD (fixed):\")\nutc_dt_new = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\nutc_dt_new = UTC_TZ.localize(utc_dt_new)\nberlin_dt_new = utc_dt_new.astimezone(BERLIN_TZ"]
[48.650723, "i", ")\nprint(f\"  Result: {berlin_dt_new.strftime('%Y-%m-%d %H:%M:%S %Z (UTC%z)')}\")\nprint(f\"  This correctly converts UTC to Berlin time!\")\nprint()\n\nprint(f\"Difference: {(berlin_dt_old - berlin_dt_new).total_seconds() / 3600} hours\")\nEOF\n"]
