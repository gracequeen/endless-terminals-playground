[77.285939, "i", "cat > verify_fix.py << 'EOF'\n#!/usr/bin/env python3\n\"\"\"Comprehensive verification of the timezone fix.\"\"\"\n\nimport json\nimport pytz\nfrom datetime import datetime\n\nBERLIN_TZ = pytz.timezone('Europe/Berlin')\nUTC_TZ = pytz.utc\n\nprint(\"=\" * 60)\nprint(\"VERIFICATION: Timezone Conversion Fix\")\nprint(\"=\" * 60)\nprint()\n\n# Load the actual meetings from the JSON file\nwith open('/home/user/scheduler/meetings.json', 'r') as f:\n    meetings = json.load(f)\n\nprint(\"Analyzing all meetings with FIXED conversion logic:\")\nprint()\n\nfor meeting in meetings:\n    utc_time_str = meeting['utc_time']\n    title = meeting['title']\n    \n    # FIXED conversion logic\n    utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\n    utc_dt = UTC_TZ.localize(utc_dt)\n    berlin_dt = utc_dt.astimezone(BERLIN_TZ)\n    \n    print(f\"Meeting: {title}\")\n    print(f\"  UTC:    {utc_dt.strftime('%Y-%m-%d %H:%M:%S %Z')}\")\n    print(f\"  Berlin: {berlin_dt.strftime('%Y-%m-%d %H:%M:%S %Z (UTC%z)')}\")\n    \n    # Check if this falls in the 2am-3am window\n "]
[77.285989, "i", "   if 2 <= berlin_dt.hour < 3:\n        print(f\"  *** This meeting falls in the 2am-3am window! ***\")\n    \n    print()\n\nprint(\"=\" * 60)\nprint(\"Key finding for 'Maintenance Window Prep':\")\nprint(\"  UTC time: 2024-03-31T01:30:00\")\nprint(\"  This is during DST transition (2am CET -> 3am CEST)\")\nprint(\"  Correct Berlin time: 2024-03-31 03:30:00 CEST\")\nprint(\"  (The 2am hour is skipped due to DST transition)\")\nprint(\"=\" * 60)\nEOF\n"]
