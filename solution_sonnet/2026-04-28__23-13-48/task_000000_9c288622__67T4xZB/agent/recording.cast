[60.871611, "o", "--- app.py.backup\t2026-04-29 00:15:33.464003880 +0000\r\n+++ app.py\t2026-04-29 00:15:33.570564707 +0000\r\n@@ -25,9 +25,9 @@\r\n     # Parse the UTC time string\r\n"]
[60.871626, "o", "     utc_dt = datetime.strptime(utc_time_str, '%Y-%m-%dT%H:%M:%S')\r\n \r\n"]
[60.871703, "o", "-    # Convert to Berlin time\r\n-    # BUG: This incorrectly localizes the UTC datetime as if it were already Berlin time\r\n-    berlin_dt = BERLIN_TZ.localize(utc_dt)\r\n+    # Localize as UTC first, then convert to Berlin time\r\n+    utc_dt = UTC_TZ.localize(utc_dt)\r\n+    berlin_dt = utc_dt.astimezone(BERLIN_TZ)\r\n \r\n     return berlin_dt\r\n \r\n"]
