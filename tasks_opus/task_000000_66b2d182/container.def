Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package lists
    apt-get update

    # Install Python 3, venv module, pip, and other essentials
    apt-get install -y python3 python3-venv python3-pip

    # Install pytest system-wide for testing
    pip3 install pytest

    # Create the user home directory
    mkdir -p /home/user

    # Create a non-root user 'user' with home directory /home/user
    useradd -m -d /home/user -s /bin/bash user || true

    # Ensure proper ownership and permissions for /home/user
    chown -R user:user /home/user
    chmod 755 /home/user

    # Clean up apt cache to reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export PATH=/usr/local/bin:/usr/bin:/bin:$PATH
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    exec /bin/bash "$@"