Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package lists
    apt-get update

    # Install basic utilities
    apt-get install -y \
        curl \
        wget \
        ca-certificates \
        gnupg \
        git \
        python3 \
        python3-pip \
        python3-venv

    # Install Node.js (using NodeSource repository for a recent version)
    curl -fsSL https://deb.nodesource.com/setup_18.x | bash -
    apt-get install -y nodejs

    # Install dependencies for headless browsers (Chromium/Chrome)
    apt-get install -y \
        libnss3 \
        libatk1.0-0 \
        libatk-bridge2.0-0 \
        libcups2 \
        libdrm2 \
        libxkbcommon0 \
        libxcomposite1 \
        libxdamage1 \
        libxfixes3 \
        libxrandr2 \
        libgbm1 \
        libasound2 \
        libpango-1.0-0 \
        libpangocairo-1.0-0 \
        libgtk-3-0 \
        libxshmfence1 \
        fonts-liberation \
        xdg-utils

    # Install pytest
    pip3 install pytest

    # Create the user home directory with proper permissions
    mkdir -p /home/user
    chmod 755 /home/user

    # Make /home/user writable by everyone (since we don't know the user ID)
    chmod 777 /home/user

    # Clean up apt cache to reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export PATH=/usr/local/bin:/usr/bin:/bin:/usr/local/sbin:/usr/sbin:/sbin
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    exec /bin/bash "$@"