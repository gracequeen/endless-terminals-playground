Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update and install required packages
    apt-get update
    apt-get install -y python3 python3-pip
    pip3 install pytest

    # Create user and home directory
    useradd -m -d /home/user -s /bin/bash user

    # Create the test files and directories with specific permissions
    # World-writable file (666)
    touch /home/user/public_notes.txt
    chmod 666 /home/user/public_notes.txt

    # World-writable directory (777)
    mkdir -p /home/user/shared_data
    chmod 777 /home/user/shared_data

    # Normal file with 644 permissions (NOT world-writable)
    touch /home/user/normal_file.txt
    chmod 644 /home/user/normal_file.txt

    # Private directory with 755 permissions (NOT world-writable)
    mkdir -p /home/user/private_dir
    chmod 755 /home/user/private_dir

    # Set ownership of all files to user
    chown -R user:user /home/user

    # Re-apply permissions after chown (chown can affect permissions in some cases)
    chmod 666 /home/user/public_notes.txt
    chmod 777 /home/user/shared_data
    chmod 644 /home/user/normal_file.txt
    chmod 755 /home/user/private_dir

%environment
    export PATH="/usr/bin:$PATH"
    export LC_ALL=C

%runscript
    exec /bin/bash "$@"