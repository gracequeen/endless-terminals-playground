Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package lists and install required packages
    apt-get update && apt-get install -y \
        coreutils \
        python3 \
        python3-pip \
        && rm -rf /var/lib/apt/lists/*

    # Install pytest
    pip3 install pytest

    # Create the user home directory
    mkdir -p /home/user

    # Create a user 'user' with home directory /home/user
    useradd -m -d /home/user -s /bin/bash user || true

    # Ensure proper ownership and permissions for /home/user
    chown -R user:user /home/user
    chmod 755 /home/user

%environment
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"
    export LC_ALL=C

%runscript
    exec /bin/bash "$@"