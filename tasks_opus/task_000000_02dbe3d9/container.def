Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update and install required packages
    apt-get update && apt-get install -y \
        python3 \
        python3-pip \
        && rm -rf /var/lib/apt/lists/*

    # Install pytest
    pip3 install pytest

    # Create user directory
    mkdir -p /home/user

    # Create the docs_project directory structure
    mkdir -p /home/user/docs_project
    mkdir -p /home/user/docs_project/api
    mkdir -p /home/user/docs_project/guides
    mkdir -p /home/user/docs_project/config

    # Create readme.md
    cat > /home/user/docs_project/readme.md << 'EOF'
# Project Documentation
Welcome to our project.
EOF

    # Create api/api.md
    cat > /home/user/docs_project/api/api.md << 'EOF'
# API Reference
This document covers the API.
EOF

    # Create api/endpoints.md
    cat > /home/user/docs_project/api/endpoints.md << 'EOF'
# Endpoints
List of all endpoints.
EOF

    # Create guides/installation.md
    cat > /home/user/docs_project/guides/installation.md << 'EOF'
# Installation Guide
How to install the software.
EOF

    # Create guides/quickstart.md
    cat > /home/user/docs_project/guides/quickstart.md << 'EOF'
# Quick Start
Getting started quickly.
EOF

    # Create raw_notes.txt with TODO items
    cat > /home/user/docs_project/raw_notes.txt << 'EOF'
Meeting notes from Monday
TODO: Review the API documentation
Discussion about new features
TODO: Update installation guide with new steps
Some random notes here
TODO: Add examples to quickstart guide
TODO: Fix broken links in readme
Final thoughts on the meeting
EOF

    # Create config/settings.conf with key-value pairs and comments
    cat > /home/user/docs_project/config/settings.conf << 'EOF'
# Configuration file
# Last updated: 2024

debug_mode=false
api_version=2.1
# This is a comment
timeout=30

log_level=info
max_connections=100

# End of file
EOF

    # Set proper permissions for the user directory
    chmod -R 755 /home/user
    chmod -R a+rw /home/user/docs_project

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    exec /bin/bash "$@"