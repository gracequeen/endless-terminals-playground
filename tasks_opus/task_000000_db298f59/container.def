Bootstrap: localimage
From: ./ubuntu_22.04.sif

%post
    # Update package lists
    apt-get update

    # Install openssh-server to get the sshd_config file
    apt-get install -y openssh-server

    # Install Python and pytest
    apt-get install -y python3 python3-pip
    pip3 install pytest

    # Create the user home directory
    mkdir -p /home/user

    # Create a user named 'user' with home directory /home/user
    useradd -d /home/user -s /bin/bash user || true

    # Set ownership and permissions for the home directory
    chown -R user:user /home/user
    chmod 755 /home/user

    # Ensure /etc/ssh/sshd_config exists and is readable
    # It should already exist from openssh-server installation
    # Make sure it's readable by all users
    chmod 644 /etc/ssh/sshd_config

    # Clean up apt cache to reduce image size
    apt-get clean
    rm -rf /var/lib/apt/lists/*

%environment
    export PATH=/usr/local/bin:/usr/bin:/bin
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    exec /bin/bash "$@"